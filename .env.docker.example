# LingoLinq AAC Docker Environment Variables
# Copy this file to .env and customize for your setup

# Environment
RAILS_ENV=development
NODE_ENV=development

# Database Configuration (Docker services)
POSTGRES_DB=lingolinq_development
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
DATABASE_URL=postgres://postgres:password@db:5432/lingolinq_development

# Cache Configuration (Docker services)
REDIS_URL=redis://redis:6379/0

# Required Rails Configuration
SECURE_ENCRYPTION_KEY=change_this_to_a_random_string_at_least_24_characters_long
SECURE_NONCE_KEY=change_this_to_another_random_string_at_least_24_characters
COOKIE_KEY=change_this_cookie_encryption_key_random_string
DEFAULT_HOST=localhost:3000
DEFAULT_EMAIL_FROM=noreply@lingolinq.local
SYSTEM_ERROR_EMAIL=errors@lingolinq.local
NEW_REGISTRATION_EMAIL=registrations@lingolinq.local

# Development Settings
USER_KEY=developer@lingolinq.local
PORT=3000

# Rails Configuration
RAILS_SERVE_STATIC_FILES=true
RAILS_LOG_TO_STDOUT=true

# AI Development (your existing keys)
GEMINI_API_KEY=your_gemini_api_key_here

# Production Settings (uncomment and configure for deployment)
# AWS Settings
# AWS_KEY=your_aws_access_key_id
# AWS_SECRET=your_aws_secret_access_key
# UPLOADS_S3_BUCKET=your-uploads-bucket
# STATIC_S3_BUCKET=your-static-assets-bucket
# UPLOADS_S3_CDN=https://your-cloudfront-distribution.cloudfront.net
# UPLOADS_S3_CDN_ID=your_cloudfront_distribution_id
# UPLOADS_S3_CDN_REGION=us-east-1

# Email Settings (SES)
# SES_KEY=your_ses_access_key
# SES_SECRET=your_ses_secret_key  
# SES_REGION=us-east-1

# External APIs (optional for basic functionality)
# GOOGLE_PLACES_TOKEN=your_google_places_api_token
# GOOGLE_TRANSLATE_TOKEN=your_google_translate_api_token
# MAPS_KEY=your_google_maps_api_key
# STRIPE_SECRET_KEY=your_stripe_secret_key
# STRIPE_PUBLIC_KEY=your_stripe_public_key

# Background Job Processing
# TRANSCODER_AUDIO_PIPELINE=your_elastic_transcoder_audio_pipeline
# TRANSCODER_VIDEO_PIPELINE=your_elastic_transcoder_video_pipeline
# TRANSCODER_REGION=us-east-1

# Monitoring and Analytics
# SLACK_NOTIFICATION_URL=your_slack_webhook_url
# NEWRELIC_LICENSE_KEY=your_newrelic_license_key