{
  "agent_type": "gemini_cli",
  "project": "LingoLinq AAC",
  "initialization": {
    "required_files_to_read": [
      "/docs/ai/GEMINI.md",
      "/README.md",
      "/.ai/context/AI_CONTEXT.md"
    ],
    "startup_message": "🔷 Gemini CLI initialized for LingoLinq AAC (Standalone Mode)\n📚 Context loaded from local files\n🐳 Docker environment preferred\n\nConstraints:\n• Ruby: 3.2.8 (LOCKED)\n• Node.js: 18.x (LOCKED)\n• Rails: 6.1 → 7.2 (planned)\n• Ember: 3.12 (legacy)"
  },
  
  "safe_operation_mode": {
    "container_first": true,
    "host_system_restrictions": [
      "No direct Node.js version changes",
      "No Ruby version modifications", 
      "No global package installations",
      "No system-level dependency changes"
    ],
    "recommended_workflow": [
      "1. Start Docker development environment",
      "2. Work within containers exclusively", 
      "3. Verify environment before changes",
      "4. Test in isolated environment"
    ]
  },

  "development_patterns": {
    "container_commands": {
      "backend_access": "docker exec -it lingolinq_backend bash",
      "frontend_access": "docker exec -it lingolinq_frontend bash", 
      "db_access": "docker exec -it lingolinq_postgres psql -U postgres -d lingolinq_development",
      "redis_access": "docker exec -it lingolinq_redis redis-cli"
    },
    "testing_workflow": [
      "# Backend tests (in container)",
      "docker exec lingolinq_backend bundle exec rspec",
      "",
      "# Frontend tests (in container)", 
      "docker exec lingolinq_frontend ember test"
    ],
    "safe_package_management": [
      "# Always use container for package changes",
      "docker exec lingolinq_backend bundle install",
      "docker exec lingolinq_frontend npm install"
    ]
  }
}