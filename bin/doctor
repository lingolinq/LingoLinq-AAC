#!/usr/bin/env bash

# LingoLinq AAC Development Environment Doctor
# Comprehensive validation script for team onboarding

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
NC='\033[0m' # No Color

# Icons
SUCCESS="✅"
FAILURE="❌"
WARNING="⚠️"
INFO="ℹ️"
ROCKET="🚀"

# Global counters
TOTAL_CHECKS=0
PASSED_CHECKS=0
FAILED_CHECKS=0
WARNING_CHECKS=0

echo -e "${BLUE}${ROCKET} LingoLinq AAC Environment Doctor${NC}"
echo -e "${BLUE}=================================================${NC}"
echo ""

# Utility functions
check_start() {
    echo -n "  $1... "
    ((TOTAL_CHECKS++))
}

check_pass() {
    echo -e "${GREEN}${SUCCESS}${NC} $1"
    ((PASSED_CHECKS++))
}

check_fail() {
    echo -e "${RED}${FAILURE}${NC} $1"
    echo -e "    ${RED}$2${NC}"
    ((FAILED_CHECKS++))
}

check_warn() {
    echo -e "${YELLOW}${WARNING}${NC} $1"
    echo -e "    ${YELLOW}$2${NC}"
    ((WARNING_CHECKS++))
}

section() {
    echo -e "\n${PURPLE}$1${NC}"
    echo -e "${PURPLE}$(echo $1 | sed 's/./─/g')${NC}"
}

# Basic System Requirements
section "System Requirements"

check_start "Git version"
if command -v git >/dev/null 2>&1; then
    GIT_VERSION=$(git --version)
    check_pass "$GIT_VERSION"
else
    check_fail "Git not found" "Install Git from https://git-scm.com/"
fi

check_start "Docker version"
if command -v docker >/dev/null 2>&1; then
    DOCKER_VERSION=$(docker --version)
    check_pass "$DOCKER_VERSION"
else
    check_fail "Docker not found" "Install Docker Desktop from https://www.docker.com/products/docker-desktop/"
fi

check_start "Docker Compose version"
if command -v docker-compose >/dev/null 2>&1 || docker compose version >/dev/null 2>&1; then
    if docker compose version >/dev/null 2>&1; then
        COMPOSE_VERSION=$(docker compose version)
    else
        COMPOSE_VERSION=$(docker-compose --version)
    fi
    check_pass "$COMPOSE_VERSION"
else
    check_fail "Docker Compose not found" "Update Docker Desktop or install docker-compose"
fi

# Repository Structure
section "Repository Structure"

check_start "AI development structure"
if [[ -d ".ai" && -d ".ai/agents" && -d ".ai/tools" ]]; then
    check_pass "AI directory structure exists"
else
    check_fail "Missing .ai directory structure" "Run git pull to get latest structure"
fi

check_start "Project constraints file"
if [[ -f ".ai/agents/project-constraints.json" ]]; then
    check_pass "Project constraints found"
else
    check_fail "Missing project constraints" "File should be at .ai/agents/project-constraints.json"
fi

check_start "Documentation structure"
if [[ -d "docs/branches" ]]; then
    check_pass "Branch documentation structure exists"
else
    check_warn "Missing branch docs structure" "Consider updating to latest reorganization"
fi

check_start "MCP configuration"
if [[ -f ".ai/tools/deepwiki-mcp/claude-mcp-config.json" ]]; then
    check_pass "MCP configuration found"
else
    check_warn "MCP configuration missing" "AI tools may not work optimally"
fi

# Docker Environment
section "Docker Environment"

check_start "Docker daemon running"
if docker info >/dev/null 2>&1; then
    check_pass "Docker daemon is running"
else
    check_fail "Docker daemon not running" "Start Docker Desktop"
fi

check_start "Docker Compose configuration"
if cd docker && docker-compose config >/dev/null 2>&1; then
    check_pass "Docker Compose configuration valid"
    cd ..
else
    cd ..
    check_fail "Docker Compose configuration invalid" "Check docker/docker-compose.yml syntax"
fi

check_start "Environment file"
if [[ -f ".env" ]]; then
    check_pass "Environment file exists"
elif [[ -f ".env.example" ]]; then
    check_warn "Using example environment file" "Copy .env.example to .env and customize"
else
    check_fail "No environment configuration" "Create .env file from .env.docker.example"
fi

# Version Constraints (if we can test them)
section "Version Constraints"

# Test Ruby version in Docker (if available)
check_start "Ruby version in Docker"
if docker info >/dev/null 2>&1; then
    if docker run --rm ruby:3.2.8-slim ruby -v >/dev/null 2>&1; then
        RUBY_VERSION=$(docker run --rm ruby:3.2.8-slim ruby -v)
        check_pass "$RUBY_VERSION"
    else
        check_warn "Cannot verify Ruby version" "Docker image may need to be built"
    fi
else
    check_warn "Cannot test Ruby version" "Docker not available"
fi

# Test local versions if available
if command -v ruby >/dev/null 2>&1; then
    RUBY_LOCAL=$(ruby -v)
    if [[ $RUBY_LOCAL == *"3.2.8"* ]]; then
        check_pass "Local Ruby version correct: $RUBY_LOCAL"
    else
        check_warn "Local Ruby version: $RUBY_LOCAL" "Expected 3.2.8 for legacy compatibility"
    fi
fi

if command -v node >/dev/null 2>&1; then
    NODE_LOCAL=$(node -v)
    if [[ $NODE_LOCAL == v18* ]]; then
        check_pass "Local Node.js version correct: $NODE_LOCAL"
    else
        check_warn "Local Node.js version: $NODE_LOCAL" "Expected 18.x for Ember 3.12 compatibility"
    fi
fi

# AI Development Tools
section "AI Development Tools (Optional)"

check_start "Claude CLI availability"
if command -v claude >/dev/null 2>&1; then
    CLAUDE_VERSION=$(claude --version 2>/dev/null || echo "Available but version unknown")
    check_pass "Claude CLI: $CLAUDE_VERSION"
else
    check_warn "Claude CLI not found" "Install from https://claude.ai/cli for enhanced development"
fi

check_start "Gemini CLI availability"  
if command -v gemini >/dev/null 2>&1; then
    check_pass "Gemini CLI available"
else
    check_warn "Gemini CLI not found" "Install from https://aistudio.google.com/ for AI assistance"
fi

check_start "AI environment variables"
if [[ -n "$GEMINI_API_KEY" ]] || [[ -n "$GOOGLE_AI_API_KEY" ]]; then
    check_pass "AI API keys configured"
else
    check_warn "No AI API keys found" "Set GEMINI_API_KEY in .env for AI features"
fi

# Network and Ports
section "Network Configuration"

check_start "Port availability (3000)"
if ! lsof -i :3000 >/dev/null 2>&1 && ! netstat -an 2>/dev/null | grep -q :3000; then
    check_pass "Port 3000 available for Rails"
else
    check_warn "Port 3000 in use" "Rails may conflict with existing service"
fi

check_start "Port availability (5432)"
if ! lsof -i :5432 >/dev/null 2>&1 && ! netstat -an 2>/dev/null | grep -q :5432; then
    check_pass "Port 5432 available for PostgreSQL"
else
    check_warn "Port 5432 in use" "PostgreSQL may conflict with existing service"
fi

# Final Summary
echo ""
echo -e "${BLUE}╔══════════════════════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║                        SUMMARY REPORT                       ║${NC}"
echo -e "${BLUE}╠══════════════════════════════════════════════════════════════╣${NC}"
echo -e "${BLUE}║${NC} Total Checks: ${TOTAL_CHECKS}"
echo -e "${BLUE}║${NC} ${GREEN}${SUCCESS} Passed: ${PASSED_CHECKS}${NC}"
echo -e "${BLUE}║${NC} ${RED}${FAILURE} Failed: ${FAILED_CHECKS}${NC}"
echo -e "${BLUE}║${NC} ${YELLOW}${WARNING} Warnings: ${WARNING_CHECKS}${NC}"
echo -e "${BLUE}╚══════════════════════════════════════════════════════════════╝${NC}"

# Recommendations
if [[ $FAILED_CHECKS -eq 0 && $WARNING_CHECKS -eq 0 ]]; then
    echo -e "\n${GREEN}🎉 Perfect! Your environment is fully ready for LingoLinq development!${NC}"
    echo -e "\n${GREEN}Next Steps:${NC}"
    echo -e "  1. ${GREEN}cd docker && docker-compose up${NC} - Start development environment"
    echo -e "  2. ${GREEN}Visit http://localhost:3000${NC} - Test the application"
    echo -e "  3. ${GREEN}Read TEAM_ONBOARDING.md${NC} - Learn about the development workflow"
elif [[ $FAILED_CHECKS -eq 0 ]]; then
    echo -e "\n${YELLOW}✨ Good! Your environment works with some minor recommendations.${NC}"
    echo -e "\n${YELLOW}Next Steps:${NC}"
    echo -e "  1. ${YELLOW}Address warnings above for optimal experience${NC}"
    echo -e "  2. ${GREEN}cd docker && docker-compose up${NC} - Start development environment"
    echo -e "  3. ${GREEN}Visit http://localhost:3000${NC} - Test the application"
else
    echo -e "\n${RED}🔧 Please fix the failed checks above before proceeding.${NC}"
    echo -e "\n${RED}Common Solutions:${NC}"
    echo -e "  • Install Docker Desktop and start it"
    echo -e "  • Run ${BLUE}git pull${NC} to get latest repository structure"
    echo -e "  • Copy ${BLUE}.env.docker.example${NC} to ${BLUE}.env${NC}"
    echo -e "  • Check ${BLUE}TEAM_ONBOARDING.md${NC} for detailed setup instructions"
fi

# Exit with appropriate code
if [[ $FAILED_CHECKS -eq 0 ]]; then
    exit 0
else
    exit 1
fi