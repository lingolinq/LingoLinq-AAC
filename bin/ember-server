#!/usr/bin/env sh
# Start Ember dev server with Node 18 via nvm when available.
# Invoked from Procfile (foreman/heroku local). Run from repo root.
# Uses bash when present (for nvm), otherwise falls back to sh for minimal envs (e.g. Alpine).
set -e

run_ember() {
  if [ -s "${HOME}/.nvm/nvm.sh" ]; then
    . "${HOME}/.nvm/nvm.sh"
    nvm install 18 && nvm use 18
  elif [ -s "/usr/local/share/nvm/nvm.sh" ]; then
    . "/usr/local/share/nvm/nvm.sh"
    nvm install 18 && nvm use 18
  fi
  cd ./app/frontend/ && npx ember server --port 8184 --proxy http://127.0.0.1:5000
}

if command -v bash >/dev/null 2>&1; then
  # Prefer bash so nvm.sh (often bash-heavy) works; use . for POSIX compatibility
  exec bash -c '
    if [ -s "$HOME/.nvm/nvm.sh" ]; then . "$HOME/.nvm/nvm.sh";
    elif [ -s "/usr/local/share/nvm/nvm.sh" ]; then . "/usr/local/share/nvm/nvm.sh"; fi;
    nvm install 18 && nvm use 18 && cd ./app/frontend/ && npx ember server --port 8184 --proxy http://127.0.0.1:5000
  '
else
  run_ember
fi
