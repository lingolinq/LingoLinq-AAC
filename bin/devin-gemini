#!/usr/bin/env bash

# Gemini-specific development assistant for LingoLinq AAC (No MCP)

REPO_PATH="$(git rev-parse --show-toplevel)"
GEMINI_CMD="gemini -a"  # Update if needed

# Function to get project context for Gemini
get_context() {
    local section="${1:-all}"
    echo "📖 Getting project context: $section"
    
    if [[ -f "$REPO_PATH/.ai/context/AI_CONTEXT.md" ]]; then
        cat "$REPO_PATH/.ai/context/AI_CONTEXT.md"
    elif [[ -f "$REPO_PATH/README.md" ]]; then
        echo "# LingoLinq AAC Context"
        head -50 "$REPO_PATH/README.md"
    else
        echo "⚠️ No project context found."
    fi
}

# Generate basic project overview
generate_overview() {
    echo "🏗️ Generating project overview..."
    
    echo "# LingoLinq AAC Overview" > "$REPO_PATH/.ai/context/gemini-overview.md"
    echo "" >> "$REPO_PATH/.ai/context/gemini-overview.md"
    echo "## Architecture" >> "$REPO_PATH/.ai/context/gemini-overview.md"
    echo "Rails + Ember.js AAC system" >> "$REPO_PATH/.ai/context/gemini-overview.md"
    echo "" >> "$REPO_PATH/.ai/context/gemini-overview.md"
    
    if [[ -f "$REPO_PATH/README.md" ]]; then
        echo "## Project Details" >> "$REPO_PATH/.ai/context/gemini-overview.md"
        head -30 "$REPO_PATH/README.md" >> "$REPO_PATH/.ai/context/gemini-overview.md"
    fi
    
    echo "✅ Overview generated at .ai/context/gemini-overview.md"
}

case "$1" in
  context)
    get_context "$2"
    ;;

  generate)
    generate_overview
    ;;

  ask)
    shift
    QUESTION="$*"
    echo "🤖 Asking Gemini: $QUESTION"
    CONTEXT=$(get_context all)
    $GEMINI_CMD "LingoLinq AAC Context: This is a Rails + Ember.js AAC system. $CONTEXT. Question: $QUESTION"
    ;;

  simple)
    echo "🔷 Starting simple Gemini session with basic context..."
    CONTEXT=$(get_context all)
    $GEMINI_CMD "You are working with LingoLinq AAC, a Rails + Ember.js AAC system. Context: $CONTEXT. Ready to help with development tasks."
    ;;

  *)
    echo "Usage: devin-gemini [context|generate|ask|simple] <args>"
    echo ""
    echo "Commands:"
    echo "  context [section]  - Get project context"
    echo "  generate          - Generate basic project overview" 
    echo "  ask <question>    - Ask Gemini with project context"
    echo "  simple            - Start simple Gemini session"
    echo ""
    echo "Note: This is the Gemini-specific version without MCP coordination."
    ;;
esac