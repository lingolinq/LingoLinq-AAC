#!/bin/bash

set -e  # Exit on any error

echo "=== LingoLinq Fresh Start ==="
echo ""

# Kill any existing processes
echo "1. Stopping any existing processes..."
"$(dirname "$0")/kill_all"
sleep 2

echo ""
echo "2. Checking Redis..."
if ! redis-cli ping > /dev/null 2>&1; then
    echo "Starting Redis..."
    sudo service redis-server start
    sleep 1
fi
redis-cli ping > /dev/null && echo "✓ Redis is running" || { echo "✗ Redis failed to start"; exit 1; }

echo ""
echo "3. Checking PostgreSQL..."
if ! pg_isready > /dev/null 2>&1; then
    echo "Starting PostgreSQL..."
    sudo service postgresql start
    sleep 1
fi
pg_isready > /dev/null && echo "✓ PostgreSQL is running" || { echo "✗ PostgreSQL failed to start"; exit 1; }

echo ""
echo "4. Checking environment..."
if [ ! -f .env ]; then
    echo "✗ .env file not found. Copy .env.example to .env first!"
    exit 1
fi
echo "✓ .env file exists"

# Load .env file
set -a
source .env
set +a

echo ""
echo "5. Starting all services..."
echo ""
echo "=========================================="
echo "LingoLinq is starting on:"
echo "  Backend:  http://localhost:3000"
echo "  Frontend: http://localhost:8184"
echo "=========================================="
echo ""

# Create a log directory
mkdir -p tmp/logs

# Start Puma (Rails backend)
echo "Starting Puma..."
bundle exec puma -C config/puma.rb > tmp/logs/puma.log 2>&1 &
PUMA_PID=$!
echo "  Puma started (PID: $PUMA_PID)"

# Start Resque workers
echo "Starting Resque workers..."
env QUEUES=priority,default,slow INTERVAL=0.1 TERM_CHILD=1 bundle exec rake environment resque:work > tmp/logs/resque.log 2>&1 &
RESQUE_PID=$!
echo "  Resque started (PID: $RESQUE_PID)"

# Start Ember frontend
echo "Starting Ember..."
(
  export NVM_DIR="/usr/local/share/nvm"
  [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
  cd ./app/frontend/
  nvm use 18
  export NODE_OPTIONS=--openssl-legacy-provider
  npx ember server --port 8184 > ../../tmp/logs/ember.log 2>&1 &
  echo $! > ../../tmp/ember.pid
)
EMBER_PID=$(cat tmp/ember.pid)
rm tmp/ember.pid
echo "  Ember started (PID: $EMBER_PID)"

echo ""
echo "All services started!"
echo ""
echo "Logs are in tmp/logs/"
echo "  - tmp/logs/puma.log"
echo "  - tmp/logs/resque.log"
echo "  - tmp/logs/ember.log"
echo ""
echo "To view logs: tail -f tmp/logs/*.log"
echo "To stop all: bin/kill_all"
echo ""

# Wait for any process to exit (keeps script running)
wait
