#!/usr/bin/env bash

# Lightweight development assistant for LingoLinq AAC
# Provides basic project context and commands

REPO_PATH="$(git rev-parse --show-toplevel)"

# Function to ensure MCP context is up-to-date
update_context() {
    echo "🔄 Updating project context..."
    cd "$REPO_PATH"
    mkdir -p .ai/context
    git log --since="7 days ago" --oneline --stat > .ai/context/recent-changes.txt 2>/dev/null || echo "⚠️ Could not update git context"
    echo "✅ Context updated successfully"
}

# Function to get project context for AI agents
get_context() {
    local section="${1:-all}"
    echo "📖 Getting project context: $section"
    
    if [[ -f "$REPO_PATH/.ai/context/PROJECT_MAP.md" ]]; then
        cat "$REPO_PATH/.ai/context/PROJECT_MAP.md"
    elif [[ -f "$REPO_PATH/.ai/context/AI_CONTEXT.md" ]]; then
        cat "$REPO_PATH/.ai/context/AI_CONTEXT.md"
    else
        echo "⚠️ No project context found. Run 'devin generate' first."
    fi
}

case "$1" in
  context)
    get_context "$2"
    ;;

  update)
    update_context
    ;;

  generate)
    echo "🏗️ Generating fresh architecture map..."
    update_context
    cd "$REPO_PATH"
    
    # Generate basic project map without Node.js dependency
    cat > .ai/context/PROJECT_MAP.md << EOF
# LingoLinq AAC Project Architecture

## Overview
Rails + Ember.js AAC system with multi-platform support

## Recent Activity
EOF
    
    if [[ -f .ai/context/recent-changes.txt ]]; then
        head -10 .ai/context/recent-changes.txt >> .ai/context/PROJECT_MAP.md
    else
        echo "No recent changes found" >> .ai/context/PROJECT_MAP.md
    fi
    
    cat >> .ai/context/PROJECT_MAP.md << EOF

## Key Directories
- app/models/ - Rails models
- app/controllers/ - Rails controllers
- app/frontend/ - Ember.js frontend
- lib/ - Shared utilities
- .ai/context/ - AI context files
EOF
    
    echo "✅ Architecture map generated"
    ;;

  review)
    echo "🔥 Basic commit review suggestions..."
    echo "📝 Use Claude Code for review:"
    echo "claude \"Review this commit: $2\""
    ;;

  analyze)
    case "$2" in
      repo)
        echo "🔍 Basic repo analysis suggestions..."
        echo "📊 Use Claude Code:"
        echo "claude \"Analyze this repository architecture and identify major modules, hotspots, and legacy code risks\""
        ;;
      changes)
        echo "📊 Recent changes suggestions..."
        echo "📈 Use Claude Code:"
        echo "claude \"Analyze recent changes in this repository\""
        ;;
      *)
        echo "Usage: devin analyze [repo|changes]"
        ;;
    esac
    ;;

  ask)
    shift
    QUESTION="$*"
    echo "🤖 Use Claude Code directly:"
    echo "claude \"$QUESTION\""
    ;;

  tokens)
    echo "🤖 Checking AI token status..."
    if [[ -x "$REPO_PATH/bin/token-status" ]]; then
      "$REPO_PATH/bin/token-status" "$2"
    else
      echo "❌ Token status script not found. Please ensure bin/token-status exists and is executable."
    fi
    ;;

  *)
    echo "Usage: devin [context|update|generate|review|analyze|ask|tokens] <args>"
    echo ""
    echo "Commands:"
    echo "  context [section]     - Get project context (architecture, dependencies, etc.)"
    echo "  update               - Update project context from recent changes"
    echo "  generate             - Generate fresh architecture map"
    echo "  review <commit>      - Basic code review suggestions"
    echo "  analyze <target>     - Basic analysis suggestions (repo, changes)"
    echo "  ask <question>       - Get Claude Code command suggestions"
    echo "  tokens [cmd]         - Check AI token usage status (gemini, claude, trends, tips)"
    ;;
esac