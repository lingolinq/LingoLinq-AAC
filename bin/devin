#!/usr/bin/env bash

# DeepWiki MCP-powered development assistant for LingoLinq AAC

REPO_PATH="$(git rev-parse --show-toplevel)"
MCP_SERVER_PATH="$REPO_PATH/.ai/tools/deepwiki-mcp"
CLAUDE_CMD="claude" # Update if using a different alias
GEMINI_CMD="$(which gemini 2>/dev/null || echo 'gemini-cli')"  # Update if needed

# Function to ensure MCP context is up-to-date
update_context() {
    echo "🔄 Updating DeepWiki context..."
    cd "$MCP_SERVER_PATH"
    node -e "
    const { execSync } = require('child_process');
    try {
        execSync('git log --since=\"7 days ago\" --oneline --stat > .ai/context/recent-changes.txt', { cwd: '$REPO_PATH' });
        console.log('✅ Context updated successfully');
    } catch (error) {
        console.log('⚠️ Failed to update context:', error.message);
    }
    "
}

# Token usage monitoring and logging
log_token_usage() {
    local command="$1"
    local estimated_tokens="$2" 
    local additional_info="$3"
    
    mkdir -p "$REPO_PATH/.ai/logs"
    local log_file="$REPO_PATH/.ai/logs/gemini-token-usage.log"
    local timestamp=$(date '+%a, %b %d, %Y %l:%M:%S %p')
    
    echo "$timestamp: $command | Estimated tokens: $estimated_tokens${additional_info:+ | $additional_info}" >> "$log_file"
    
    # Check for potential overuse (more than 10 calls in last hour)
    local recent_count=$(tail -50 "$log_file" 2>/dev/null | grep "$(date '+%a, %b %d, %Y %l')" | wc -l)
    if [[ $recent_count -gt 10 ]]; then
        echo "⚠️  WARNING: High token usage detected ($recent_count calls in last hour)"
        echo "   Consider using lighter commands like 'gemini-safe' or taking a break"
    fi
}

# Function to get project context for AI agents
get_context() {
    local section="${1:-all}"
    echo "📖 Getting project context: $section"
    
    if [[ -f "$REPO_PATH/.ai/context/PROJECT_MAP.md" ]]; then
        cat "$REPO_PATH/.ai/context/PROJECT_MAP.md"
    elif [[ -f "$REPO_PATH/.ai/context/AI_CONTEXT.md" ]]; then
        cat "$REPO_PATH/.ai/context/AI_CONTEXT.md"
    else
        echo "⚠️ No project context found. Run 'devin generate' first."
    fi
}

# Safe git operations to prevent interactive editor loops
safe_git_commit() {
    local message="$1"
    if [[ -z "$message" ]]; then
        message="Auto-commit: $(date '+%Y-%m-%d %H:%M:%S')"
    fi
    echo "🔒 Safe git commit with message: $message"
    git commit -m "$message" || {
        echo "❌ Git commit failed. Check for conflicts or staging issues."
        return 1
    }
}

safe_git_merge() {
    local branch="$1"
    if [[ -z "$branch" ]]; then
        echo "❌ Branch name required for safe merge"
        return 1
    fi
    
    echo "🔒 Safe git merge of $branch (non-interactive)"
    # Check for uncommitted changes first
    if ! git diff-index --quiet HEAD --; then
        echo "⚠️ Uncommitted changes detected. Stashing first..."
        git stash push -m "Auto-stash before merge $(date '+%Y-%m-%d %H:%M:%S')"
    fi
    
    # Perform merge with automatic commit message
    timeout 60s git merge "$branch" --no-edit -m "Merge branch '$branch' into $(git branch --show-current)" || {
        echo "❌ Git merge failed or timed out. Aborting merge..."
        git merge --abort 2>/dev/null || true
        return 1
    }
}

safe_git_checkout() {
    local branch="$1"
    if [[ -z "$branch" ]]; then
        echo "❌ Branch name required for safe checkout"
        return 1
    fi
    
    echo "🔒 Safe git checkout to $branch"
    # Check for uncommitted changes first
    if ! git diff-index --quiet HEAD --; then
        echo "⚠️ Uncommitted changes detected. Stashing first..."
        git stash push -m "Auto-stash before checkout $(date '+%Y-%m-%d %H:%M:%S')"
    fi
    
    git checkout "$branch" || {
        echo "❌ Git checkout failed. Branch may not exist or have conflicts."
        return 1
    }
}

case "$1" in
  context)
    get_context "$2"
    ;;

  update)
    update_context
    ;;

  generate)
    echo "🏗️ Generating fresh architecture map..."
    update_context
    cd "$MCP_SERVER_PATH"
    timeout 30s node -e "
    const fs = require('fs');
    const path = require('path');
    
    // Generate basic project map
    const projectRoot = '$REPO_PATH';
    let map = '# LingoLinq AAC Project Architecture\\n\\n';
    map += '## Overview\\n';
    map += 'Rails + Ember.js AAC system with multi-platform support\\n\\n';
    map += '## Recent Activity\\n';
    
    try {
        const recentChanges = fs.readFileSync(path.join(projectRoot, '.ai/context/recent-changes.txt'), 'utf8');
        const lines = recentChanges.split('\\n').slice(0, 10);
        map += lines.join('\\n') + '\\n\\n';
    } catch (e) {
        map += 'No recent changes found\\n\\n';
    }
    
    map += '## Key Directories\\n';
    map += '- app/models/ - Rails models\\n';
    map += '- app/controllers/ - Rails controllers\\n';
    map += '- app/frontend/ - Ember.js frontend\\n';
    map += '- lib/ - Shared utilities\\n';
    map += '- .ai/context/ - AI context files\\n';
    
    fs.writeFileSync(path.join(projectRoot, '.ai/context/PROJECT_MAP.md'), map);
    console.log('✅ Architecture map generated');
    " 2>/dev/null || echo "⚠️ Generation timed out, but basic context should be available"
    ;;

  review)
    echo "🔥 AI-powered commit review with context..."
    update_context
    CONTEXT=$(get_context architecture)
    git log "$2" --oneline | while read -r line; do
      COMMIT_HASH=$(echo "$line" | awk '{print $1}')
      MESSAGE=$(echo "$line" | cut -d' ' -f2-)
      echo "🧠 Reviewing $COMMIT_HASH: $MESSAGE"
      $CLAUDE_CMD "Context: This is a Rails + Ember.js AAC system. Recent changes: $(head -5 $REPO_PATH/.ai/context/recent-changes.txt | tr '\n' ' '). Give a roast-style code review of commit: $MESSAGE"
    done
    ;;

  analyze)
    case "$2" in
      repo)
        echo "🔍 Deep repo analysis with MCP context..."
        update_context
        CONTEXT=$(get_context all)
        $CLAUDE_CMD "Here's the current project context: $CONTEXT. Give me an architecture summary including major modules, hotspots, and legacy code risks."
        ;;
      changes)
        echo "📊 Analyzing recent changes..."
        update_context
        if [[ -f "$REPO_PATH/.ai/context/recent-changes.txt" ]]; then
            RECENT=$(cat "$REPO_PATH/.ai/context/recent-changes.txt")
            $CLAUDE_CMD "Analyze these recent changes in the LingoLinq AAC codebase and identify patterns, risks, and recommendations: $RECENT"
        else
            echo "❌ No recent changes found."
        fi
        ;;
      *)
        echo "Usage: devin analyze [repo|changes]"
        ;;
    esac
    ;;

  ask)
    shift
    QUESTION="$*"
    echo "🤖 Asking AI with full project context: $QUESTION"
    update_context
    CONTEXT=$(get_context all)
    $CLAUDE_CMD "LingoLinq AAC Project Context: $CONTEXT. Question: $QUESTION"
    ;;

  gemini-full)
    shift
    QUESTION="$*"
    if [[ -z "$QUESTION" ]]; then
        echo "Usage: devin gemini-full 'your question here'"
        exit 1
    fi
    echo "🛡️  Safe Gemini mode (prevents token loops and uses lightweight context)"
    
    # Log the command usage
    log_token_usage "gemini-full command" "~250" "Question: ${QUESTION:0:50}..."
    
    if [[ -z "$GEMINI_CMD" ]]; then
        echo "❌ Gemini CLI not found. Run './bin/devin validate' for setup help."
        exit 1
    fi
    if [[ -z "$GOOGLE_AI_API_KEY" ]]; then
        echo "❌ GOOGLE_AI_API_KEY environment variable is not set."
        echo "   Set it with: export GOOGLE_AI_API_KEY='your-key-here'"
        exit 1
    fi
    # Ensure lightweight context exists
    if [[ ! -f "$REPO_PATH/.ai/context/LIGHTWEIGHT_CONTEXT.md" ]]; then
        echo "📝 Creating lightweight context..."
        mkdir -p "$REPO_PATH/.ai/context"
        cat > "$REPO_PATH/.ai/context/LIGHTWEIGHT_CONTEXT.md" << 'EOF'
# LingoLinq AAC - Quick Context

## What This Is
Web-based AAC (Augmentative and Alternative Communication) app for people who need help communicating through speech synthesis and communication boards.

## Architecture
- **Backend**: Rails API, **Frontend**: Ember.js app, **Database**: PostgreSQL + Redis

## Key Features
- Cloud-synced communication boards, Multi-device support, Team coordination, Real-time collaboration, Offline capability

## Development Stack
Ruby 3.2.8+, Node.js 18+, Rails + Ember + PostgreSQL + Redis, Docker support available

Use `ask-full` for detailed context.
EOF
    fi
    CONTEXT=$(cat "$REPO_PATH/.ai/context/LIGHTWEIGHT_CONTEXT.md")
    cd "$REPO_PATH"
    echo "🔄 Calling Gemini API (safe mode with timeout)..."
    timeout 30s $GEMINI_CMD -p "LingoLinq AAC Context: $CONTEXT. Please answer concisely: $QUESTION" || {
        log_token_usage "gemini-full ERROR" "N/A" "Timeout or API failure"
        echo "❌ Gemini CLI timed out or failed. This may be due to:"
        echo "   - Google AI API server issues (500 errors)"
        echo "   - Network connectivity issues"
        echo "   - Invalid API key"
        echo "   Try again in a few minutes or check Google AI API status."
        exit 1
    }
    log_token_usage "gemini-full SUCCESS" "~250" "Completed successfully"
    ;;

  gemini-safe)
    shift
    QUESTION="$*"
    if [[ -z "$QUESTION" ]]; then
        echo "Usage: devin gemini-safe 'your question here'"
        exit 1
    fi
    echo "🔷 Ultra-safe Gemini mode (minimal context, 15s timeout)"
    
    # Log the command usage
    log_token_usage "gemini-safe command" "~100" "Question: ${QUESTION:0:50}..."
    
    if [[ -z "$GEMINI_CMD" ]]; then
        echo "❌ Gemini CLI not found."
        exit 1
    fi
    cd "$REPO_PATH"
    echo "🔄 Calling Gemini API (ultra-safe mode)..."
    timeout 15s $GEMINI_CMD -p "This is LingoLinq AAC, a Rails+Ember.js communication app. Question: $QUESTION" || {
        log_token_usage "gemini-safe ERROR" "N/A" "Timeout or API failure"
        echo "❌ Gemini CLI failed. Try checking your API key and connection."
        exit 1
    }
    log_token_usage "gemini-safe SUCCESS" "~100" "Completed successfully"
    ;;

  deepwiki)
    DEEPWIKI_URL="${2:-https://deepwiki.com/swahlquist/LingoLinq-AAC}"
    shift $(( $# > 1 ? 1 : 0 ))
    echo "🗂️ Aggregating DeepWiki for $DEEPWIKI_URL ..."
    npx --yes mcp-deepwiki "$DEEPWIKI_URL" --mode aggregate ${@:2}
    ;;

  export)
    if [[ "$2" == "wiki" ]]; then
      echo "📦 Exporting project context as markdown..."
      update_context
      CONTEXT=$(get_context all)
      $GEMINI_CMD "Convert this LingoLinq AAC project context to well-formatted markdown for documentation: $CONTEXT"
    else
      echo "❌ Unsupported export target."
    fi
    ;;

  git-safe)
    case "$2" in
      commit)
        shift 2
        MESSAGE="$*"
        if [[ -z "$MESSAGE" ]]; then
          MESSAGE="Auto-commit from AI assistant: $(date '+%Y-%m-%d %H:%M:%S')"
        fi
        safe_git_commit "$MESSAGE"
        ;;
      merge)
        if [[ -z "$3" ]]; then
          echo "Usage: devin git-safe merge <branch-name>"
          exit 1
        fi
        safe_git_merge "$3"
        ;;
      checkout)
        if [[ -z "$3" ]]; then
          echo "Usage: devin git-safe checkout <branch-name>"
          exit 1
        fi
        safe_git_checkout "$3"
        ;;
      status)
        echo "📊 Safe git status check..."
        git status --porcelain
        ;;
      stash-clean)
        echo "🧹 Stashing all changes and cleaning working directory..."
        git add .
        git stash push -m "AI cleanup stash: $(date '+%Y-%m-%d %H:%M:%S')"
        echo "✅ Working directory is now clean"
        ;;
      *)
        echo "Usage: devin git-safe [commit|merge|checkout|status|stash-clean]"
        echo ""
        echo "Safe Git Commands:"
        echo "  commit [message]     - Safe commit with automatic message"
        echo "  merge <branch>       - Safe merge with conflict handling"
        echo "  checkout <branch>    - Safe checkout with stash protection"
        echo "  status               - Clean status check"
        echo "  stash-clean          - Stash all changes and clean working dir"
        ;;
    esac
    ;;

  monitor)
    case "$2" in
      tokens)
        echo "📊 Token Usage Monitor"
        echo "======================"
        
        log_file="$REPO_PATH/.ai/logs/gemini-token-usage.log"
        if [[ ! -f "$log_file" ]]; then
          echo "No token usage data found yet."
          echo "Start using 'gemini-full' or 'gemini-safe' commands to begin tracking."
          exit 0
        fi
        
        echo ""
        echo "📈 Recent Activity (last 10 entries):"
        tail -10 "$log_file"
        echo ""
        
        echo "📊 Usage Statistics:"
        today=$(date '+%a, %b %d, %Y')
        today_count=$(grep "$today" "$log_file" 2>/dev/null | wc -l)
        echo "  • Calls today: $today_count"
        
        success_count=$(grep "SUCCESS" "$log_file" 2>/dev/null | wc -l)
        error_count=$(grep "ERROR" "$log_file" 2>/dev/null | wc -l)
        echo "  • Successful calls: $success_count"
        echo "  • Failed calls: $error_count"
        
        # Check for high usage patterns
        recent_hour=$(date '+%a, %b %d, %Y %l')
        recent_count=$(grep "$recent_hour" "$log_file" 2>/dev/null | wc -l)
        if [[ $recent_count -gt 5 ]]; then
          echo ""
          echo "⚠️  HIGH USAGE WARNING: $recent_count calls in the last hour"
          echo "   Consider taking a break or using lighter 'gemini-safe' mode"
        fi
        ;;
      reset)
        log_file="$REPO_PATH/.ai/logs/gemini-token-usage.log"
        if [[ -f "$log_file" ]]; then
          mv "$log_file" "${log_file}.backup.$(date +%Y%m%d_%H%M%S)"
          echo "✅ Token usage log reset. Previous log backed up."
        else
          echo "No token usage log found to reset."
        fi
        ;;
      *)
        echo "Usage: devin monitor [tokens|reset]"
        echo ""
        echo "Monitor Commands:"
        echo "  tokens  - Show current token usage statistics and warnings"
        echo "  reset   - Reset token usage logs (backs up existing log)"
        echo ""
        echo "💡 Use this to track Gemini API usage and prevent token exhaustion loops"
        ;;
    esac
    ;;

  *)
    echo "Usage: devin [context|update|generate|review|analyze|ask|gemini-full|gemini-safe|git-safe|monitor|deepwiki|export] <args>"
    echo ""
    echo "Commands:"
    echo "  context [section]  - Get project context (architecture, dependencies, etc.)"
    echo "  update            - Update project context from recent changes"
    echo "  generate          - Generate fresh architecture map"
    echo "  review <commit>   - AI code review with project context"
    echo "  analyze <target>  - Deep analysis (repo, changes)"
    echo "  ask <question>    - Ask AI with full project context"
    echo "  gemini-full <q>   - 🛡️  Safe Gemini mode with lightweight context & timeout"
    echo "  gemini-safe <q>   - 🔷 Ultra-safe Gemini mode (minimal context, 15s timeout)"
    echo "  git-safe <cmd>    - 🔒 Safe git operations (commit|merge|checkout|status|stash-clean)"
    echo "  monitor <cmd>     - 📊 Token usage monitoring (tokens|reset)"
    echo "  deepwiki <url>    - Aggregate DeepWiki content"
    echo "  export wiki       - Export context as markdown"
    ;;
esac
