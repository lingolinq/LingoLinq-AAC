#!/usr/bin/env bash

# DeepWiki MCP-powered development assistant for LingoLinq AAC

REPO_PATH="$(git rev-parse --show-toplevel)"

# Load environment variables from .env file if it exists
if [[ -f "$REPO_PATH/.env" ]]; then
    # Export variables from .env file, handling comments and empty lines
    set -a  # Automatically export all variables
    source <(grep -E '^[A-Z_].*=' "$REPO_PATH/.env" | sed 's/^/export /')
    set +a  # Turn off auto-export
fi
# Cross-platform CLI detection
detect_cli() {
    local cli_name="$1"
    local cmd_path
    
    # Try common global npm paths
    local npm_paths=(
        "/c/Users/$USER/AppData/Roaming/npm/$cli_name"      # Windows npm global
        "$HOME/AppData/Roaming/npm/$cli_name.cmd"           # Windows alternative
        "/usr/local/bin/$cli_name"                           # macOS/Linux standard
        "/opt/homebrew/bin/$cli_name"                        # macOS Apple Silicon
        "$HOME/.local/bin/$cli_name"                         # Linux user local
        "$HOME/.npm-global/bin/$cli_name"                    # Custom npm prefix
    )
    
    # First try which/where command
    if command -v "$cli_name" >/dev/null 2>&1; then
        echo "$cli_name"
        return 0
    fi
    
    # Try each potential path
    for path in "${npm_paths[@]}"; do
        if [[ -x "$path" ]] || [[ -f "$path" ]]; then
            echo "$path"
            return 0
        fi
    done
    
    return 1
}

CLAUDE_CMD=$(detect_cli "claude")
GEMINI_CMD=$(detect_cli "gemini")

# Function to ensure MCP context is up-to-date
update_context() {
    echo "🔄 Updating DeepWiki context..."
    cd "$REPO_PATH"
    mkdir -p .ai/context
    git log --since="7 days ago" --oneline --stat > .ai/context/recent-changes.txt 2>/dev/null || echo "⚠️ Could not update git context"
    echo "✅ Context updated successfully"
}

# Function to get project context for AI agents
get_context() {
    local section="${1:-all}"
    echo "📖 Getting project context: $section"
    
    if [[ -f "$REPO_PATH/.ai/context/PROJECT_MAP.md" ]]; then
        cat "$REPO_PATH/.ai/context/PROJECT_MAP.md"
    elif [[ -f "$REPO_PATH/.ai/context/AI_CONTEXT.md" ]]; then
        cat "$REPO_PATH/.ai/context/AI_CONTEXT.md"
    else
        echo "⚠️ No project context found. Run 'devin generate' first."
    fi
}

case "$1" in
  validate)
    echo "🔍 Validating AI CLI setup..."
    echo ""
    
    # Check Claude CLI
    if [[ -n "$CLAUDE_CMD" ]]; then
        echo "✅ Claude CLI found: $CLAUDE_CMD"
        if command -v "$CLAUDE_CMD" >/dev/null 2>&1; then
            echo "   Version: $($CLAUDE_CMD --version 2>/dev/null || echo 'Unable to get version')"
        fi
    else
        echo "❌ Claude CLI not found. Install with: npm install -g @anthropic-ai/claude-cli"
    fi
    
    # Check Gemini CLI
    if [[ -n "$GEMINI_CMD" ]]; then
        echo "✅ Gemini CLI found: $GEMINI_CMD"
        if command -v "$GEMINI_CMD" >/dev/null 2>&1; then
            echo "   Version: $($GEMINI_CMD --version 2>/dev/null || echo 'Unable to get version')"
        fi
    else
        echo "⚠️  Gemini CLI not found. Install with: npm install -g @google/generative-ai-cli"
    fi
    
    # Check environment variables
    echo ""
    echo "🔑 Environment variables:"
    if [[ -n "$ANTHROPIC_API_KEY" ]]; then
        echo "✅ ANTHROPIC_API_KEY is set"
    else
        echo "❌ ANTHROPIC_API_KEY not set"
    fi
    
    if [[ -n "$GOOGLE_AI_API_KEY" ]]; then
        echo "✅ GOOGLE_AI_API_KEY is set"
    else
        echo "⚠️  GOOGLE_AI_API_KEY not set (optional for Gemini)"
    fi
    
    # Check npm global path
    echo ""
    echo "📦 npm global configuration:"
    if command -v npm >/dev/null 2>&1; then
        npm_prefix=$(npm config get prefix 2>/dev/null || echo "unknown")
        echo "   npm prefix: $npm_prefix"
        
        # Check PATH based on platform - Windows npm global is in prefix directly, Unix uses prefix/bin
        if [[ "$OSTYPE" == "msys" ]] || [[ "$OSTYPE" == "win32" ]] || [[ -n "$WINDIR" ]]; then
            # Windows - npm global commands are in the prefix directory directly
            # Convert Windows path to Unix format for Git Bash compatibility
            npm_prefix_unix=$(echo "$npm_prefix" | sed 's|C:|/c|g' | sed 's|\\|/|g')
            if echo "$PATH" | grep -q "$npm_prefix" || echo "$PATH" | grep -q "$npm_prefix_unix"; then
                echo "   PATH includes npm directory: Yes ✅"
            else
                echo "   PATH includes npm directory: No ❌"
                echo "   Add to PATH: export PATH=\"$npm_prefix:\$PATH\""
            fi
        else
            # Unix-like systems use prefix/bin
            npm_bin="$npm_prefix/bin"
            if echo "$PATH" | grep -q "$npm_bin"; then
                echo "   PATH includes npm bin: Yes ✅"
            else
                echo "   PATH includes npm bin: No ❌"
                echo "   Add to PATH: export PATH=\"$npm_bin:\$PATH\""
            fi
        fi
    else
        echo "❌ npm not found in PATH"
    fi
    ;;

  ask)
    shift
    QUESTION="$*"
    if [[ -z "$QUESTION" ]]; then
        echo "❌ Please provide a question"
        echo "Usage: ./bin/devin ask 'your question here'"
        exit 1
    fi
    echo "🤖 Asking Claude (lightweight context ~200 tokens): $QUESTION"
    if [[ -z "$CLAUDE_CMD" ]]; then
        echo "❌ Claude CLI not found. Run './bin/devin validate' for setup help."
        exit 1
    fi
    # Ensure lightweight context exists
    if [[ ! -f "$REPO_PATH/.ai/context/LIGHTWEIGHT_CONTEXT.md" ]]; then
        echo "📝 Creating lightweight context..."
        mkdir -p "$REPO_PATH/.ai/context"
        cat > "$REPO_PATH/.ai/context/LIGHTWEIGHT_CONTEXT.md" << 'EOF'
# LingoLinq AAC - Quick Context

## What This Is
Web-based AAC (Augmentative and Alternative Communication) app for people who need help communicating through speech synthesis and communication boards.

## Architecture
- **Backend**: Rails API, **Frontend**: Ember.js app, **Database**: PostgreSQL + Redis

## Key Features
- Cloud-synced communication boards, Multi-device support, Team coordination, Real-time collaboration, Offline capability

## Development Stack
Ruby 3.2.8+, Node.js 18+, Rails + Ember + PostgreSQL + Redis, Docker support available

Use `ask-full` for detailed context.
EOF
    fi
    CONTEXT=$(cat "$REPO_PATH/.ai/context/LIGHTWEIGHT_CONTEXT.md")
    $CLAUDE_CMD "LingoLinq AAC Context: $CONTEXT. Question: $QUESTION"
    ;;

  ask-full)
    shift
    QUESTION="$*"
    if [[ -z "$QUESTION" ]]; then
        echo "❌ Please provide a question"
        echo "Usage: ./bin/devin ask-full 'your question here'"
        exit 1
    fi
    echo "⚠️  Using full context (~4K tokens - higher cost)"
    echo "🤖 Asking Claude with full project context: $QUESTION"
    if [[ -z "$CLAUDE_CMD" ]]; then
        echo "❌ Claude CLI not found. Run './bin/devin validate' for setup help."
        exit 1
    fi
    update_context
    CONTEXT=$(get_context all)
    $CLAUDE_CMD "LingoLinq AAC Project Context: $CONTEXT. Question: $QUESTION"
    ;;

  context)
    get_context "$2"
    ;;

  update)
    update_context
    ;;

  generate)
    echo "🏗️ Generating fresh architecture map..."
    update_context
    cd "$REPO_PATH"
    
    # Generate basic project map without Node.js dependency
    cat > .ai/context/PROJECT_MAP.md << EOF
# LingoLinq AAC Project Architecture

## Overview
Rails + Ember.js AAC system with multi-platform support

## Recent Activity
EOF
    
    if [[ -f .ai/context/recent-changes.txt ]]; then
        head -10 .ai/context/recent-changes.txt >> .ai/context/PROJECT_MAP.md
    else
        echo "No recent changes found" >> .ai/context/PROJECT_MAP.md
    fi
    
    cat >> .ai/context/PROJECT_MAP.md << EOF

## Key Directories
- app/models/ - Rails models
- app/controllers/ - Rails controllers
- app/frontend/ - Ember.js frontend
- lib/ - Shared utilities
- .ai/context/ - AI context files
EOF
    
    echo "✅ Architecture map generated"
    ;;

  review)
    echo "🔥 AI-powered commit review with context..."
    update_context
    CONTEXT=$(get_context architecture)
    git log "$2" --oneline | while read -r line; do
      COMMIT_HASH=$(echo "$line" | awk '{print $1}')
      MESSAGE=$(echo "$line" | cut -d' ' -f2-)
      echo "🧠 Reviewing $COMMIT_HASH: $MESSAGE"
      $CLAUDE_CMD "Context: This is a Rails + Ember.js AAC system. Recent changes: $(head -5 $REPO_PATH/.ai/context/recent-changes.txt | tr '\n' ' '). Give a roast-style code review of commit: $MESSAGE"
    done
    ;;

  analyze)
    case "$2" in
      repo)
        echo "🔍 Deep repo analysis with MCP context..."
        update_context
        CONTEXT=$(get_context all)
        $CLAUDE_CMD "Here's the current project context: $CONTEXT. Give me an architecture summary including major modules, hotspots, and legacy code risks."
        ;;
      changes)
        echo "📊 Analyzing recent changes..."
        update_context
        if [[ -f "$REPO_PATH/.ai/context/recent-changes.txt" ]]; then
            RECENT=$(cat "$REPO_PATH/.ai/context/recent-changes.txt")
            $CLAUDE_CMD "Analyze these recent changes in the LingoLinq AAC codebase and identify patterns, risks, and recommendations: $RECENT"
        else
            echo "❌ No recent changes found."
        fi
        ;;
      *)
        echo "Usage: devin analyze [repo|changes]"
        ;;
    esac
    ;;

  claude)
    shift
    QUESTION="$*"
    echo "🤖 Direct Claude access: $QUESTION"
    if [[ -z "$CLAUDE_CMD" ]]; then
        echo "❌ Claude CLI not found. Run './bin/devin validate' for setup help."
        exit 1
    fi
    $CLAUDE_CMD "$QUESTION"
    ;;

  gemini)
    shift
    QUESTION="$*"
    echo "🧠 Direct Gemini access: $QUESTION"
    if [[ -z "$GEMINI_CMD" ]]; then
        echo "❌ Gemini CLI not found. Run './bin/devin validate' for setup help."
        exit 1
    fi
    if [[ -z "$GOOGLE_AI_API_KEY" ]]; then
        echo "❌ GOOGLE_AI_API_KEY not set. Gemini CLI requires this environment variable."
        echo "   Set it with: export GOOGLE_AI_API_KEY='your-key-here'"
        exit 1
    fi
    cd "$REPO_PATH"
    echo "🔄 Calling Gemini API (this may take a moment)..."
    timeout 30s $GEMINI_CMD -p "$QUESTION" || {
        echo "❌ Gemini CLI timed out or failed. This may be due to:"
        echo "   - Google AI API server issues (500 errors)"
        echo "   - Invalid API key"
        echo "   - Network connectivity issues"
        echo "   Try again in a few minutes or check Google AI API status."
        exit 1
    }
    ;;

  gemini-full)
    shift
    QUESTION="$*"
    if [[ -z "$QUESTION" ]]; then
        echo "❌ Please provide a question"
        echo "Usage: ./bin/devin gemini-full 'your question here'"
        exit 1
    fi
    echo "🛡️  Safe Gemini mode (prevents token loops and uses lightweight context)"
    if [[ -z "$GEMINI_CMD" ]]; then
        echo "❌ Gemini CLI not found. Run './bin/devin validate' for setup help."
        exit 1
    fi
    if [[ -z "$GOOGLE_AI_API_KEY" ]]; then
        echo "❌ GOOGLE_AI_API_KEY not set. Gemini CLI requires this environment variable."
        echo "   Set it with: export GOOGLE_AI_API_KEY='your-key-here'"
        exit 1
    fi
    # Ensure lightweight context exists
    if [[ ! -f "$REPO_PATH/.ai/context/LIGHTWEIGHT_CONTEXT.md" ]]; then
        echo "📝 Creating lightweight context..."
        mkdir -p "$REPO_PATH/.ai/context"
        cat > "$REPO_PATH/.ai/context/LIGHTWEIGHT_CONTEXT.md" << 'EOF'
# LingoLinq AAC - Quick Context

## What This Is
Web-based AAC (Augmentative and Alternative Communication) app for people who need help communicating through speech synthesis and communication boards.

## Architecture
- **Backend**: Rails API, **Frontend**: Ember.js app, **Database**: PostgreSQL + Redis

## Key Features
- Cloud-synced communication boards, Multi-device support, Team coordination, Real-time collaboration, Offline capability

## Development Stack
Ruby 3.2.8+, Node.js 18+, Rails + Ember + PostgreSQL + Redis, Docker support available

Use `ask-full` for detailed context.
EOF
    fi
    CONTEXT=$(cat "$REPO_PATH/.ai/context/LIGHTWEIGHT_CONTEXT.md")
    cd "$REPO_PATH"
    echo "🔄 Calling Gemini API (safe mode with timeout)..."
    timeout 30s $GEMINI_CMD -p "LingoLinq AAC Context: $CONTEXT. Please answer concisely: $QUESTION" || {
        echo "❌ Gemini CLI timed out or failed. This may be due to:"
        echo "   - Google AI API server issues (500 errors)"
        echo "   - Network connectivity issues"
        echo "   - Invalid API key"
        echo "   Try again in a few minutes or check Google AI API status."
        exit 1
    }
    ;;

  gemini-safe)
    shift
    QUESTION="$*"
    if [[ -z "$QUESTION" ]]; then
        echo "❌ Please provide a question"
        echo "Usage: ./bin/devin gemini-safe 'your question here'"
        exit 1
    fi
    echo "🛡️  Safe Gemini mode (prevents token loops and uses lightweight context)"
    if [[ -z "$GEMINI_CMD" ]]; then
        echo "❌ Gemini CLI not found. Run './bin/devin validate' for setup help."
        exit 1
    fi
    if [[ -z "$GOOGLE_AI_API_KEY" ]]; then
        echo "❌ GOOGLE_AI_API_KEY not set. Gemini CLI requires this environment variable."
        echo "   Set it with: export GOOGLE_AI_API_KEY='your-key-here'"
        exit 1
    fi
    # Ensure lightweight context exists
    if [[ ! -f "$REPO_PATH/.ai/context/LIGHTWEIGHT_CONTEXT.md" ]]; then
        echo "📝 Creating lightweight context..."
        mkdir -p "$REPO_PATH/.ai/context"
        cat > "$REPO_PATH/.ai/context/LIGHTWEIGHT_CONTEXT.md" << 'EOF'
# LingoLinq AAC - Quick Context

## What This Is
Web-based AAC (Augmentative and Alternative Communication) app for people who need help communicating through speech synthesis and communication boards.

## Architecture
- **Backend**: Rails API, **Frontend**: Ember.js app, **Database**: PostgreSQL + Redis

## Key Features
- Cloud-synced communication boards, Multi-device support, Team coordination, Real-time collaboration, Offline capability

## Development Stack
Ruby 3.2.8+, Node.js 18+, Rails + Ember + PostgreSQL + Redis, Docker support available

Use `ask-full` for detailed context.
EOF
    fi
    CONTEXT=$(cat "$REPO_PATH/.ai/context/LIGHTWEIGHT_CONTEXT.md")
    cd "$REPO_PATH"
    echo "🔄 Calling Gemini API (safe mode with timeout)..."
    timeout 30s $GEMINI_CMD -p "LingoLinq AAC Context: $CONTEXT. Please answer concisely: $QUESTION" || {
        echo "❌ Gemini CLI timed out or failed. This may be due to:"
        echo "   - Google AI API server issues (500 errors)"
        echo "   - Network connectivity issues"
        echo "   - Invalid API key"
        echo "   Try again in a few minutes or check Google AI API status."
        exit 1
    }
    ;;

  review-gemini)
    echo "🔥 Gemini-powered commit review with context..."
    update_context
    CONTEXT=$(get_context architecture)
    git log "$2" --oneline | while read -r line; do
      COMMIT_HASH=$(echo "$line" | awk '{print $1}')
      MESSAGE=$(echo "$line" | cut -d' ' -f2-)
      echo "🧠 Gemini reviewing $COMMIT_HASH: $MESSAGE"
      if [[ -z "$GOOGLE_AI_API_KEY" ]]; then
        echo "❌ GOOGLE_AI_API_KEY not set. Skipping Gemini review."
        continue
      fi
      timeout 30s $GEMINI_CMD -p "Context: This is a Rails + Ember.js AAC system. Recent changes: $(head -5 $REPO_PATH/.ai/context/recent-changes.txt | tr '\n' ' '). Give a detailed code review of commit: $MESSAGE" || echo "⚠️ Gemini review failed for $COMMIT_HASH"
    done
    ;;

  analyze-gemini)
    case "$2" in
      repo)
        echo "🔍 Deep repo analysis with Gemini + MCP context..."
        update_context
        CONTEXT=$(get_context all)
        if [[ -z "$GOOGLE_AI_API_KEY" ]]; then
          echo "❌ GOOGLE_AI_API_KEY not set. Cannot run Gemini analysis."
          exit 1
        fi
        timeout 60s $GEMINI_CMD -p "Here's the current project context: $CONTEXT. Give me a comprehensive architecture analysis including major modules, technical debt hotspots, performance bottlenecks, and legacy code risks with specific recommendations." || {
          echo "❌ Gemini analysis failed or timed out."
          exit 1
        }
        ;;
      changes)
        echo "📊 Gemini analyzing recent changes..."
        update_context
        if [[ -f "$REPO_PATH/.ai/context/recent-changes.txt" ]]; then
            RECENT=$(cat "$REPO_PATH/.ai/context/recent-changes.txt")
            if [[ -z "$GOOGLE_AI_API_KEY" ]]; then
              echo "❌ GOOGLE_AI_API_KEY not set. Cannot run Gemini analysis."
              exit 1
            fi
            timeout 45s $GEMINI_CMD -p "Analyze these recent changes in the LingoLinq AAC codebase and provide detailed insights on patterns, risks, refactoring opportunities, and actionable recommendations: $RECENT" || {
              echo "❌ Gemini analysis failed or timed out."
              exit 1
            }
        else
            echo "❌ No recent changes found."
        fi
        ;;
      *)
        echo "Usage: devin analyze-gemini [repo|changes]"
        ;;
    esac
    ;;

  deepwiki)
    DEEPWIKI_URL="${2:-https://deepwiki.com/swahlquist/LingoLinq-AAC}"
    shift $(( $# > 1 ? 1 : 0 ))
    echo "🗂️ Aggregating DeepWiki for $DEEPWIKI_URL ..."
    npx --yes mcp-deepwiki "$DEEPWIKI_URL" --mode aggregate ${@:2}
    ;;

  export)
    if [[ "$2" == "wiki" ]]; then
      echo "📦 Exporting project context as markdown..."
      update_context
      CONTEXT=$(get_context all)
      if [[ -z "$GOOGLE_AI_API_KEY" ]]; then
        echo "❌ GOOGLE_AI_API_KEY not set. Cannot export with Gemini."
        exit 1
      fi
      timeout 30s $GEMINI_CMD -p "Convert this LingoLinq AAC project context to well-formatted markdown for documentation: $CONTEXT" || {
        echo "❌ Gemini export failed or timed out."
        exit 1
      }
    else
      echo "❌ Unsupported export target."
    fi
    ;;

  *)
    echo "Usage: devin [validate|ask|ask-full|claude|gemini|gemini-safe|gemini-full|context|update|generate|review|analyze|deepwiki|export] <args>"
    echo ""
    echo "🚀 Quick Commands (Cross-Platform):"
    echo "  validate              - Check AI CLI installation and setup"
    echo "  ask <question>        - Ask Claude (lightweight, ~200 tokens)"
    echo "  ask-full <question>   - Ask Claude with full project context (~4K tokens)"
    echo "  claude <question>     - Direct Claude CLI access"
    echo "  gemini <question>     - Direct Gemini CLI access (can loop on errors)"
    echo "  gemini-safe <question> - Safe Gemini with lightweight context (prevents loops)"
    echo "  gemini-full <question> - Ask Gemini with full project context"
    echo ""
    echo "📋 Context Management:"
    echo "  context [section]     - Get project context (architecture, dependencies, etc.)"
    echo "  update               - Update project context from recent changes"
    echo "  generate             - Generate fresh architecture map"
    echo ""
    echo "🔍 Analysis Commands:"
    echo "  review <commit>      - Claude code review with project context"
    echo "  review-gemini <commit> - Gemini code review with project context"
    echo "  analyze <target>     - Claude deep analysis (repo, changes)"
    echo "  analyze-gemini <target> - Gemini deep analysis (repo, changes)"
    echo ""
    echo "🛠️  Advanced:"
    echo "  deepwiki <url>       - Aggregate DeepWiki content"
    echo "  export wiki          - Export context as markdown"
    echo ""
    echo "💡 Token Optimization:"
    echo "  Use 'ask' for quick questions (fast, cost-effective)"
    echo "  Use 'ask-full' for complex analysis requiring full context"
    echo "  Use 'gemini-safe' instead of 'gemini' to prevent infinite loops"
    echo "  Use 'claude'/'gemini' for direct CLI access without context"
    ;;
esac
