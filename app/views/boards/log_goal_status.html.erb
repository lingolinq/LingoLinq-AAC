<%= render 'shared/static_header' %>
<div id="content">
  <% if @error || !@log %>
    <div style="display: flex; align-items: flex-start; justify-content: center; padding: 20px 24px; min-height: 60vh;">
      <div style="background: rgba(255,255,255,0.76); border: 1px solid rgba(17,26,46,0.10); border-radius: 28px; box-shadow: 0 18px 50px rgba(17,26,46,0.12); padding: 48px; max-width: 600px; width: 100%; text-align: center;">
        <div style="display: flex; align-items: center; justify-content: center; gap: 20px; margin-bottom: 24px;">
          <img src="/images/not-found.png" alt="" style="width: 180px; height: auto; flex-shrink: 0;">
          <div style="display: inline-block; background: rgba(240,106,91,0.16); color: #f06a5b; font-size: 18px; font-weight: 700; padding: 4px 14px; border-radius: 20px;">Error</div>
        </div>
        <h1 style="font-size: 32px; font-weight: 800; color: #1B365D; margin-bottom: 12px; letter-spacing: -0.5px; font-family: 'Lexend','Nunito Sans',system-ui,sans-serif;">Goal Not Available</h1>
        <p style="font-size: 17px; line-height: 1.6; color: #46505F; margin-bottom: 16px;">
          Oops! It looks like there was a problem finding the goal you were trying to
          update. It may have been deleted. Please find the correct user and update
          their status from the "goals" page in their profile.
        </p>
        <p style="font-size: 15px; line-height: 1.6; color: #7389A3; margin-bottom: 28px;">
          If you reached this page unexpectedly, we'd appreciate it if you let us know so we can look into it.
        </p>
        <a href="/beta-feedback" style="display: inline-block; background: #316f70; color: #fff; font-size: 16px; font-weight: 700; padding: 12px 32px; border-radius: 50px; text-decoration: none; box-shadow: 0 4px 12px rgba(49,111,112,0.3);">Send Beta Feedback</a>
      </div>
    </div>
  <% else %>
    <div style="width: 700px; height: 300px; margin: 100px auto;">
      <h1 style='padding-top: 20px; margin-bottom: 20px; font-weight: 200; font-size: 2em; margin-left: 0;'>Goal Status Saved!</h1>
      <% status = 'face happy'; status = 'face neutral' if params['result_status'] == '2'; status = 'face sad' if params['result_status'] == '1'; status = 'face laugh' if params['result_status'] == '4' %>
      <span class='big_face' style="float: left; padding-right: 10px;">
        <span class='<%= status %>'></span>
      </span>
      <p>
        Thank you for updating the status of the goal 
        <strong><a href="/<%= @log.user.user_name %>/goals/<%= @log.goal.global_id %>"><%= @log.goal.settings['summary'] %></a></strong>.
        Keeping goals up-to-date helps show what progress is or isn't being made, and
        helps everyone stay informed.
      </p>
      <p>
        You can review all of <a href="/<%= @log.user.user_name %>/goals"><%= @log.user.user_name %>'s goals</a> through their profile.
      </p>
    </p>
    </div>
  <% end %>
</div>
<%= render 'shared/footer' %>
  