}
.ll-bento-dock__supervisor .ll-bento-dock__label,
.ll-bento-dock__logging .ll-bento-dock__label {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ll-bento-dock__logging {
  flex: 1.35 1 0;
  border: none;
  background: transparent;
  padding: 0;
  cursor: default;
  gap: 8px;
}

.ll-bento-dock__logging-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  border: none;
  background: transparent;
  padding: 0 8px 0 16px;
  height: 42px;
  border-radius: 999px;
