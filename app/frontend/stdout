  flex-shrink: 0;
  margin-left: -8px;
}

.ll-bento-dock__logging-last {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  font-weight: 600;
  color: rgba(30, 36, 48, 0.98);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
