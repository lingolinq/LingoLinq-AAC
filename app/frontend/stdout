/* ========================================
   Scot's Design marketing page
   Style guide: LingoLinq Brand Kit & Accessibility Guide
   - Navy (#1B365D) for all body text, headings, captions (WCAG AAA)
   - Coral/Teal accents only; Dark Teal (#2A9D8F) for readable teal text
   - Line height 1.5+ min, line length 50-75 chars
   ======================================== */
.landing-page {
  --fs-navy: #1B365D;
  --fs-coral: #FF6B47;
  --fs-teal: #4ECDC4;
  --fs-dark-teal: #2A9D8F;
  --fs-white: #FFFFFF;
  --fs-light-gray: #F0F0F0;
  --fs-medium-gray: rgb(146.8808510638, 152.7936170213, 164.6191489362);
  --fs-text: #1B365D;
  --fs-shadow-sm: 0 1px 3px rgba(27, 54, 93, 0.08);
  --fs-shadow-md: 0 4px 16px rgba(27, 54, 93, 0.10);
  --fs-shadow-lg: 0 8px 32px rgba(27, 54, 93, 0.12);
  --fs-radius: 12px;
  --fs-radius-lg: 20px;
  --fs-content-width: min(80vw, 1400px);
  overflow-x: hidden;
  max-width: 100%;
  box-sizing: border-box;
  padding-left: 0;
  font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
  color: var(--fs-text);
  background: var(--fs-white);
  line-height: 1.6;
  font-size: 26px;
  -webkit-font-smoothing: antialiased;
}
.landing-page h1, .landing-page h2, .landing-page h3, .landing-page h4, .landing-page h5, .landing-page h6 {
  font-family: inherit;
  line-height: 1.3;
}
.landing-page {
  /* Links on light backgrounds: Dark Teal passes WCAG AA (4.6:1) */
}
.landing-page .landing-hero a:not(.landing-btn),
.landing-page .landing-features a:not(.landing-btn),
.landing-page .landing-a11y-note a {
  color: var(--fs-dark-teal);
  text-decoration: underline;
}
.landing-page .landing-hero a:not(.landing-btn):hover,
.landing-page .landing-features a:not(.landing-btn):hover,
.landing-page .landing-a11y-note a:hover {
  color: var(--fs-navy);
}

/* Scot's palette (Navy, Royal Blue, Sky Blue, Gold, Emerald) */
.landing-page--scot-palette {
  --fs-navy: #1B2A4A;
  --fs-coral: #3A6BC7;
  --fs-teal: #7EB8E0;
  --fs-dark-teal: #3D8C6E;
  --fs-gold: #f5c23b;
  --fs-text: #1B2A4A;
  --fs-shadow-sm: 0 1px 3px rgba(27, 42, 74, 0.08);
  --fs-shadow-md: 0 4px 16px rgba(27, 42, 74, 0.10);
  --fs-shadow-lg: 0 8px 32px rgba(27, 42, 74, 0.12);
}

.landing-page--scot-palette .landing-hero-highlight {
  color: var(--fs-gold);
}

@media (min-width: 901px) {
  .landing-page--scot-palette .landing-hero-highlight {
    background: linear-gradient(120deg, var(--fs-gold) 0%, #f7d04d 100%);
    -webkit-background-clip: text;
