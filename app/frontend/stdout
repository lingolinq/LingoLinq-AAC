  .landing-footer-brand p {
    font-size: 1.2rem;
  }
  .landing-footer-logo {
    font-size: 1.6rem;
  }
  .landing-footer-bottom {
    font-size: 1.1rem;
  }
  .landing-btn {
    font-size: 1.25rem;
    padding: 14px 28px;
  }
  .landing-mockup {
    max-width: 100%;
  }
  .landing-feature-header-row h3 {
    font-size: 1.75rem;
  }
  .landing-feature-card p {
    font-size: 1.35rem;
  }
}
/* Very small screens (360px and below): minimal typography */
@media (max-width: 360px) {
  .landing-hero-title {
    font-size: 2rem;
  }
  .landing-section-title {
    font-size: 2rem;
  }
  .landing-cta-inner h2 {
    font-size: 2rem;
  }
  .landing-hero-subtitle {
    font-size: 1.2rem;
  }
  .landing-btn {
    font-size: 1.15rem;
    padding: 12px 24px;
  }
