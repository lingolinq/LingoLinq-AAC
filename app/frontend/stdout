/* Hero – clip horizontal overflow from ::before/::after so no page-level scrollbar */
.landing-hero {
  padding: calc(0.7 * (20px + 10rem)) calc(0.9 * (20px + 25rem)) calc(0.7 * (20px + 10rem)) 22.5rem;
  background: linear-gradient(165deg, var(--fs-white) 0%, #F7FAFE 40%, #EDF6FF 100%);
  position: relative;
  overflow-x: clip;
  overflow-y: visible;
}

.landing-hero::before {
  content: "";
  position: absolute;
  top: -200px;
  right: -200px;
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(78, 205, 196, 0.08) 0%, transparent 70%);
  border-radius: 50%;
}

.landing-hero::after {
  content: "";
  position: absolute;
  bottom: -100px;
  left: -100px;
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, rgba(255, 107, 71, 0.06) 0%, transparent 70%);
  border-radius: 50%;
}

.landing-hero-inner {
  width: 100%;
  max-width: 1400px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 80px;
  align-items: center;
  position: relative;
  z-index: 1;
  box-sizing: border-box;
}

.landing-hero-content {
  margin-bottom: 1.5rem;
}

.landing-hero-header {
  margin-bottom: 5rem;
}

.landing-hero-title {
  font-size: 5.03rem; /* +25% from 4.025rem */
  font-weight: 700;
  color: var(--fs-navy);
  margin-bottom: 2rem;
  letter-spacing: 0.01em;
  line-height: 1.25;
  /* Override global h1 { height: 60px; display: inline-block } which constrains
     the title to a tiny box and causes text to overflow into the subtitle */
  height: auto;
  display: block;
  margin-top: 0;
  margin-left: 0;
}

.landing-hero-highlight {
  display: inline;
  margin-left: 0.25em;
  font-size: 0.978em;
  font-weight: 700;
  color: var(--fs-coral);
  filter: brightness(0.95);
}

@media (min-width: 901px) {
  .landing-hero-highlight {
    background: linear-gradient(120deg, var(--fs-coral) 0%, #FF8A6B 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }
}
.landing-hero-subtitle {
  font-size: 1.76rem;
