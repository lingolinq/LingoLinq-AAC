<div class='col-sm-12'>
  <h4>{{t "Usage Logging and Reports" key="usage_logging_and_reports"}}</h4>
</div>
<div class='col-sm-6'>
  <img src={{path "images/reports.png"}} alt="" style='width: 100%;' >
</div>
<div class='col-sm-6'>
  <p class='prompt'>{{t "Logging tracks word usage, session activity, and goal progress — giving you and your team clear insight into how communication is growing." key="logging_reports_1"}}</p>
  {{#if setup_user}}
    <p style='margin-top: 20px;'><button class='btn btn-default btn-lg' {{action "set_preference" "logging" true}}>
      {{#if setup_user.preferences.logging}}
        {{t "Logging is Enabled" key="logging_is_enabled"}}
      {{else}}
        {{t "Enable Logging" key="enable_logging"}}
      {{/if}}
    </button></p>
  {{/if}}
</div>
<div class='col-sm-12'>
  <h4>{{t "Reporting Notifications" key="reporting_notifications"}}</h4>
</div>
<div class='col-sm-6'>
  {{#if setup_user.supporter_role}}
    <p class='prompt'>{{t "As a supervisor, you can receive progress updates for your communicators — including email summaries and messages from those who've added you." key="notifications_settings"}}</p>
  {{else}}
    <p class='prompt'>{{t "Stay informed with regular updates on word usage and goal progress — great for keeping your whole support team in the loop." key="communicator_notifications"}}</p>
  {{/if}}
  <p class='prompt'>{{t "You can update these settings anytime from your Profile." key="available_under_profile"}}</p>
</div>
<div class='col-sm-6'>
  <div class='setup_setting' style='margin-top: 0;'>
    <label>{{t "How often do you want summary emails?" key="summary_emails"}}</label>
    <div class="btn-group-vertical" style="width: 100%;">
      <a href="#" class={{if notification.1_week "btn btn-lg btn-primary" "btn btn-lg btn-default"}} {{action "set_preference" "notification_frequency" "1_week"}}>{{t "Every Week" key="every_week"}}</a>
      <a href="#" class={{if notification.2_weeks "btn btn-lg btn-primary" "btn btn-lg btn-default"}} {{action "set_preference" "notification_frequency" "2_weeks"}}>{{t "Every Other Week" key="every_other_week"}}</a>
      <a href="#" class={{if notification.1_month "btn btn-lg btn-primary" "btn btn-lg btn-default"}} {{action "set_preference" "notification_frequency" "1_month"}}>{{t "Every Month" key="every_month"}}</a>
      <a href="#" class={{if notification.none "btn btn-lg btn-primary" "btn btn-lg btn-default"}} {{action "set_preference" "notification_frequency" ""}}>{{t "Never" key="never"}}</a>
    </div>
  </div>
  {{#if setup_user.supporter_role}}
    <div class='setup_setting'>
      <label>{{t "How would you like communicators to message you?" key="comm_preference"}}</label>
      <div class="btn-group-vertical" style="width: 100%;">
        <span class={{if notification.text "btn btn-lg btn-primary" "btn btn-lg btn-default"}} {{action "set_preference" "share_notifications" "text"}}>
          {{t "As Text Messages" key="via_text"}}
          <br>
          <span style='display: inline-block; width: 300px;'><Input type="text" class="form-control input-lg" @value={{cell}} placeholder="cell #" /></span>
        </span>
        <a href="#" class={{if notification.email "btn btn-lg btn-primary" "btn btn-lg btn-default"}} {{action "set_preference" "share_notifications" "email"}}>{{t "As Email Messages" key="via_email"}}</a>
        <a href="#" class={{if notification.app "btn btn-lg btn-primary" "btn btn-lg btn-default"}} {{action "set_preference" "share_notifications" "app"}}>{{t "As Dashboard Notifications" key="via_dashboard"}}</a>
      </div>
    </div>
  {{/if}}
</div>
