<div class='col-sm-10 col-sm-offset-1'>
  <h4>{{t "Using %app_name%" key="using_lingolinq"}}</h4>
</div>
<div class='col-sm-10 col-sm-offset-1'>
  <img src={{path "images/board.png"}} style='width: 100%; border-radius: 12px;' alt="LingoLinq board">
</div>
<div class='col-sm-10 col-sm-offset-1' style="margin-top: 16px;">
  <h5 class="usage-checklist__title">{{t "Key things to know" key="usage_checklist_heading"}}</h5>
  <ul class="usage-checklist" role="list">
    <li class="usage-checklist__item">{{t "Tap buttons to speak words, sentences, or spell—%app_name% turns your choices into speech." key="usage_1"}}</li>
    <li class="usage-checklist__item">{{t "%app_name% isn't only for people who don't speak. Many use it while learning or when they need a little support." key="usage_2"}}</li>
    <li class="usage-checklist__item">{{t "Use %app_name% on any device: free in app stores, as a Windows app, or in your browser." key="usage_3"}}</li>
    <li class="usage-checklist__item">{{t "LingoLinq supports speech development—it doesn't hold it back. Many users grow more comfortable and build spoken language skills faster." key="usage_4"}}</li>
  </ul>
</div>
{{#unless this.app_state.no_linky}}
  <div class='col-sm-10 col-sm-offset-1' style="margin-top: 12px; display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
    {{#if this.app_state.domain_settings.ios_store_url}}
      <a href={{this.app_state.domain_settings.ios_store_url}} target="_blank" rel="noopener">
        <img src={{path "images/ios_app_store.svg"}} alt="iOS App Store" style="height: 36px;">
      </a>
    {{/if}}
    {{#if this.app_state.domain_settings.play_store_url}}
      <a href={{this.app_state.domain_settings.play_store_url}} target="_blank" rel="noopener">
        <img src={{path "images/google_play.png"}} alt="Google Play" style="height: 36px;">
      </a>
    {{/if}}
    {{#if this.app_state.domain_settings.kindle_store_url}}
      <a href={{this.app_state.domain_settings.kindle_store_url}} target="_blank" rel="noopener">
        <img src={{path "images/amazon.png"}} alt="Amazon" style="height: 36px;">
      </a>
    {{/if}}
    <a href="https://app.mylingolinq.com/download" target="_blank" rel="noopener">
      <img src={{path "images/windows.svg"}} alt="Windows" style="height: 36px;">
    </a>
  </div>
{{/unless}}
