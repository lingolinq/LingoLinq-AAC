<div class='col-sm-6 col-sm-offset-3'>
  <p class='prompt'>{{t "Choose the voice that will speak when the communicator taps buttons." key="select_voice"}}
  {{#if this.setup_user.grace_period}}
    {{#if this.setup_user.supporter_role}}
      {{t "Keep in mind, supporter accounts can use the device's built-in voices, and can download any premium voices used by the people they supervise." key="supporter_voices_limited"}}
    {{else}}
      {{t "You can always select from the device's built-in voices, or during the free trial you can preview one of the 90 available premium voices." key="premium_voices_available"}}
    {{/if}}
  {{else if this.setup_user.subscription.premium_supporter}}
    {{t "You are using a limited %app_name% account, so currently you only have access to the device's built-in voices, and premium voices activated by people you supervise. Paid communicator accounts can download from over 90 premium voices for use in Speak Mode." key="supporter_limited_voices"}}
  {{else if this.setup_user.subscription.modeling_only}}
    {{t "You are using a modeling-only %app_name% account, so currently you only have access to the device's built-in voices. Consider purchasing a paid communicator account if you need access to premium voices." key="supporter_modeling_only"}}
  {{else}}
    {{t "Paid accounts can browse and download premium voices for mobile and Windows." key="paid_voices"}}
  {{/if}}
  {{t "This voice is used for buttons without a recording and for words spelled on the keyboard." key="voice_as_fallback"}}
  </p>

  <div class='setup_setting'>
    <label>{{t "Select a Voice" key="select_a_voice"}}</label>
    <div style='max-height: 300px; overflow: auto;'>
      <div class="btn-group-vertical" style="width: 100%;">
        {{#each this.user_voice_list as |voice|}}
          <a href="#" class={{if voice.selected "btn btn-lg btn-primary" "btn btn-lg btn-default"}} {{action "set_preference" "device.voice.voice_uri" voice.id}}>{{voice.name}}</a>
        {{/each}}
      </div>
    </div>
    <div style='margin-top: 15px;'>
      <button class='btn btn-lg btn-default' {{action "test_voice"}}>{{t "Listen to This Voice" key="listen_to_this_voice"}}</button>
      <button class='btn btn-lg btn-default' {{action "premium_voices"}}>{{t "Browse Premium Voices" key="browse_premium_voices"}}</button>
    </div>
  </div>
</div>