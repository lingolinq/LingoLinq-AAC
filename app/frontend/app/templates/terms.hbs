              <li><strong>{{t "Commercial Misuse" key="terms_indemnification_commercial_label"}}</strong> — {{t "Any violation of our open-source or non-commercial licensing terms, including unauthorized repackaging or selling of the LingoLinq codebase." key="terms_indemnification_commercial"}}</li>
              <li><strong>{{t "Violation of Law" key="terms_indemnification_law_label"}}</strong> — {{t "Your use of the Product to violate applicable laws, including HIPAA, FERPA, or COPPA." key="terms_indemnification_law"}}</li>
