{{#if this.model.permissions.edit}}
  {{#if this.available_reports}}
    <form class="form-horizontal">
      <div class="form-group">
        <label for="report_type" class="col-sm-1 control-label">{{t "Report:" key="report_colon"}}</label>
        <div class="col-sm-6">
          {{bound-select select_class="form-control" select_id="report_type" content=this.available_reports selection=this.current_report action=(action (mut this.current_report)) }}
          {{#if this.custom_report}}
            <em>{{this.custom_report}}</em>
          {{/if}}
        </div>
      </div>
    </form>
    {{#if this.results.loading}}
      <h2>
        <span class="glyphicon glyphicon-refresh spinning"></span>&nbsp;&nbsp;
        {{t "Loading..." key="loading"}}
      </h2>
    {{else if this.results}}
      {{#if this.results.error}}
        <p class='text-danger'>{{this.results.error}}</p>
      {{/if}}
      <div class="row">
        <div class="col-sm-8">
          {{#if this.show_list_controls}}
            <form class="form-inline" style="margin-bottom: 15px;">
              <div class="form-group">
                <label for="report_per_page">{{t "Per page:" key="per_page_colon"}}</label>
                {{bound-select select_class="form-control" select_id="report_per_page" content=this.per_page_options selection=this.per_page action=(action (mut this.per_page)) }}
              </div>
              <div class="form-group" style="margin-left: 15px;">
                <label for="report_sort">{{t "Sort:" key="sort_colon"}}</label>
                {{#if this.show_sort_by}}
                  {{bound-select select_class="form-control" select_id="report_sort_by" content=this.sort_by_options selection=this.sort_by action=(action (mut this.sort_by)) }}
                {{/if}}
                {{bound-select select_class="form-control" select_id="report_sort_order" content=this.sort_order_options selection=this.sort_order action=(action (mut this.sort_order)) }}
              </div>
              {{#if this.show_filter}}
                <div class="form-group" style="margin-left: 15px;">
                  <label for="report_filter">{{t "Filter:" key="filter_colon"}}</label>
                  <Input id="report_filter" @type="text" @value={{this.filter}} class="form-control" placeholder={{t "Search..." key="search_ellipsis"}} style="width: 150px; display: inline-block; margin-left: 5px;" />
                </div>
              {{/if}}
            </form>
          {{/if}}
          <h2>
            <span class="glyphicon glyphicon-th-list"></span>&nbsp;
            {{t "result" key="x_results" count=this.results.count}}
          </h2>
          <div class='list-group'>
            {{#each this.results.list as |item|}}
              {{#if item.started_at}}
                <span class='list-group-item'>
                  <span title={{date item.started_at}}>
                    {{date_ago item.started_at}}
                  </span>
                  <LinkTo @route="user.log" @models={{array item.user.user_name item.id}}>
                    {{t "button" count=item.button_count key="button_count"}}
                  </LinkTo>
                  <span> -
                    <LinkTo @route="user" @model={{item.user.user_name}}>
                      {{item.user.user_name}}
                    </LinkTo>
                  </span>
                  <br>
                  <span style="color: #888; font-size: 10px; white-space: nowrap; overflow: hidden; display: block;">{{item.summary}}</span>
                </span>
              {{else}}
                {{#if this.removable_report}}
                  <a href="#" {{action "remove_report_user" item}} style="position: absolute; z-index: 2; right: 20px; padding: 10px;">
                    <span class="glyphicon glyphicon-remove"></span>
                  </a>
                {{/if}}
                {{#if this.model.premium}}
                  {{#if item.org_status_class}}
                    <button {{action "set_status" item}} class='btn btn-default' style="position: absolute; z-index: 2; right: 60px; margin-top: 5px;">
                      <span class={{item.org_status_class}} style='font-size: 20px;'></span>
                    </button>
                  {{/if}}
                {{/if}}
                <LinkTo @route="user" @model={{item.user_name}} class="list-group-item">
                  <img src={{item.avatar_url}} style='height: 40px; width: 40px; object-fit: contain; margin-right: 5px; margin-top: -5px; float: left;'>
                  <span style="font-size: 16px;">
                    {{item.user_name}}
                  </span>
                  {{#if item.email}}
                    ({{item.email}})
                  {{/if}}
                  <span style='font-size: 10px; display: block; margin-top: -3px;' class="comma_item_list">
                    {{#if this.custom_report_all}}
                      {{#if item.vocab_name}}
                        <span class="comma_item">{{item.vocab_name}}</span>
                      {{/if}}
                    {{/if}}
                    {{#if item.org_pending}}
                      <span class="comma_item">{{t "pending" key="pending"}}</span>
                    {{/if}}
                    {{#if item.org_supervision_pending}}
                      <span class="comma_item">{{t "pending" key="pending"}}</span>
                    {{/if}}
                    {{#if item.org_sponsored}}
                      <span class="comma_item">{{t "sponsored" key="sponsored_lower"}}</span>
                    {{/if}}
                    {{#if item.goal}}
                      <span class="comma_item">goal set</span>
                    {{/if}}
                    {{#if item.goal.recently_tracked}}
                      <span class="comma_item">goal recently tracked</span>
                    {{/if}}
                    &nbsp;
                  </span>
                  <span style='clear: both;'></span>
                </LinkTo>
              {{/if}}
            {{/each}}
            {{#each this.results.stats as |stat|}}
              <a href="#" class='list-group-item' style='font-size: 18px;'>
                <span style='display: inline-block; width: 90%;'>{{stat.key}}</span> <span class={{stat.label_class}}>{{stat.value}}</span>
              </a>
            {{/each}}
          </div>
          {{#if this.has_more}}
            <div style="margin-top: 10px;">
              {{#if this.results.loading_more}}
                <span class="glyphicon glyphicon-refresh spinning"></span>&nbsp;{{t "Loading..." key="loading"}}
              {{else}}
                <button type="button" class="btn btn-default" {{action "load_more"}}>{{t "Load more" key="load_more"}}</button>
              {{/if}}
            </div>
          {{/if}}
          {{#if this.user_report}}
            <a href="#" {{action "download_list"}}>{{t "Download list as a csv" key="download_as_csv"}}</a>
          {{/if}}
        </div>
      </div>
    {{else}}
    {{/if}}
  {{else}}
    <p>{{t "No reports available yet" key="no_reports_available"}}</p>
  {{/if}}
{{else}}
  <p>{{t "Not authorized" key="not_authorized"}}</p>
{{/if}}
