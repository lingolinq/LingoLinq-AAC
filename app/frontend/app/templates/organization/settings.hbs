<h3 class="md-org-section-title" style="text-align: center; margin-bottom: 24px;">{{t "Edit Organization Details" key="edit_org_details"}}</h3>
<form class="md-org-settings-form" {{action "save" on="submit"}}>

  {{!-- ═══════════ General Settings ═══════════ --}}
  <section class="md-org-settings-card">
    <h4 class="md-org-settings-card__title">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      {{t "General" key="general"}}
    </h4>

    <div class="md-org-settings-field">
      <label for="org-settings-name" class="md-org-settings-field__label">{{t "Name" key="name"}}</label>
      {{#if this.model.permissions.update_licenses}}
        <Input @value={{this.model.name}} class="md-org-settings-input" id="org-settings-name" name="organization-name" autocomplete="organization" placeholder="Organization Name" />
      {{else}}
        <span class="md-org-settings-field__static">{{this.model.name}}</span>
      {{/if}}
    </div>

    <div class="md-org-settings-field">
      <label for="preferred_symbols" class="md-org-settings-field__label">{{t "Preferred Symbols" key="preferred_symbols"}}</label>
      {{bound-select select_class="md-org-report-select" select_id="preferred_symbols" content=this.symbols_list selection=this.model.preferred_symbols action=(action (mut this.model.preferred_symbols)) }}
      {{#if this.premium_symbol_library}}
        <span class="md-org-settings-field__hint md-org-settings-field__hint--warn">
          {{t "(will not apply for users without premium symbols enabled)" key="wont_work_without_premium_symbols"}}
        </span>
      {{/if}}
    </div>

    <div class="md-org-settings-field">
      <label for="default_locale" class="md-org-settings-field__label">{{t "Default Language" key="default_language"}}</label>
      {{bound-select select_class="md-org-report-select" select_id="default_locale" content=this.locale_list selection=this.model.default_locale action=(action (mut this.model.default_locale)) }}
    </div>

    <div class="md-org-settings-field">
      <label for="board" class="md-org-settings-field__label">{{t "Home Boards" key="home_boards"}}</label>
      <Textarea @value={{this.home_board_key_lines}} class="md-org-settings-textarea" id="board" placeholder={{this.board_keys_placeholder}} />
      <span class="md-org-settings-field__hint">
        {{t "any users you add that don't have a home board set will be set with the first board unless specified" key="default_home_board_explainer"}}
      </span>
    </div>

    {{#if this.model.premium}}
      <div class="md-org-settings-field">
        <label for="logo_url" class="md-org-settings-field__label">{{t "Logo URL" key="logo_url"}}</label>
        <Input @value={{this.model.image_url}} class="md-org-settings-input" id="logo_url" placeholder="URL to (circular) image, ~50px" />
      </div>
    {{/if}}
  </section>

  {{!-- ═══════════ Admin Settings ═══════════ --}}
  {{#if this.model.permissions.delete}}
    <section class="md-org-settings-card">
      <h4 class="md-org-settings-card__title">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        {{t "Administration" key="administration"}}
      </h4>

      <div class="md-org-settings-field">
        <label for="inactivity_timeout" class="md-org-settings-field__label">{{t "Login Timeout" key="inactivity_timeout"}}</label>
        <div class="md-org-settings-field__row">
          <Input id="inactivity_timeout" @value={{this.model.inactivity_timeout}} class="md-org-settings-input md-org-settings-input--sm" type="text" />
          <span class="md-org-settings-field__suffix">{{t "minutes" key="minutes"}}</span>
        </div>
      </div>

      <div class="md-org-settings-field">
        <label class="md-org-settings-field__label">{{t "Org Access" key="org_access"}}</label>
        <label class="md-org-settings-toggle">
          <Input @checked={{this.model.org_access}} @type="checkbox" class="md-org-settings-toggle__input" />
          <span class="md-org-settings-toggle__label">{{t "Allow manager access to the org management tool" key="allow_org_access"}}</span>
        </label>
      </div>

      <div class="md-org-settings-field">
        <label class="md-org-settings-field__label">{{t "Premium" key="premium"}}</label>
        <label class="md-org-settings-toggle">
          <Input @checked={{this.model.premium}} @type="checkbox" class="md-org-settings-toggle__input" />
          <span class="md-org-settings-toggle__label">{{t "This org has an active annual subscription" key="allow_premium"}}</span>
        </label>
      </div>

      <div class="md-org-settings-field">
        <label for="parent_org_id" class="md-org-settings-field__label">{{t "Parent Org ID" key="parent_org_id"}}</label>
        <div class="md-org-settings-field__row">
          <Input @value={{this.model.parent_org_id}} class="md-org-settings-input md-org-settings-input--sm" id="parent_org_id" placeholder="ID of Parent Org" />
          {{#if this.model.parent_org.name}}
            <span class="md-org-settings-field__suffix {{if this.model.parent_org.pending 'md-org-settings-field__suffix--pending'}}">
              {{this.model.parent_org.name}}
            </span>
          {{/if}}
        </div>
      </div>

      <div class="md-org-settings-field">
        <label class="md-org-settings-field__label">{{t "Authentication" key="authentication"}}</label>
        <label class="md-org-settings-toggle">
          <Input @checked={{this.external_auth}} @type="checkbox" class="md-org-settings-toggle__input" />
          <span class="md-org-settings-toggle__label">{{t "Enable external authentication (beta)" key="enable_external_auth"}}</span>
        </label>
        {{#if this.external_auth}}
          <div class="md-org-settings-field__nested">
            <Input @value={{this.model.saml_metadata_url}} class="md-org-settings-input" id="metadata_url" placeholder="SAML Metadata URL" />
            <Input @value={{this.model.saml_sso_url}} class="md-org-settings-input" id="sso_url" placeholder="SSO URL Override (optional)" />
            <label class="md-org-settings-toggle">
              <Input @checked={{this.model.saml_enforced}} @type="checkbox" class="md-org-settings-toggle__input" />
              <span class="md-org-settings-toggle__label">{{t "Require all org users to log in using external authentication" key="require_external_auth"}}</span>
            </label>
          </div>
        {{/if}}
      </div>
    </section>
  {{/if}}

  {{!-- ═══════════ Premium Features ═══════════ --}}
  {{#if this.model.premium}}
    <section class="md-org-settings-card">
      <h4 class="md-org-settings-card__title">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        {{t "Premium Features" key="premium_features"}}
      </h4>

      <div class="md-org-settings-field">
        <label class="md-org-settings-field__label">{{t "Support Emails" key="support_emails"}}</label>
        <label class="md-org-settings-toggle">
          <Input @checked={{this.allow_support_target}} @type="checkbox" class="md-org-settings-toggle__input" />
          <span class="md-org-settings-toggle__label">{{t "Email a copy of all support tickets from within this organization" key="allow_support_target"}}</span>
        </label>
        {{#if this.allow_support_target}}
          <div class="md-org-settings-field__nested">
            <Input @value={{this.support_email}} class="md-org-settings-input" placeholder="email address" />
          </div>
        {{/if}}
      </div>
    </section>
  {{/if}}

  {{!-- ═══════════ Customization ═══════════ --}}
  <section class="md-org-settings-card">
    <h4 class="md-org-settings-card__title">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      {{t "Customization" key="customization"}}
    </h4>

    <div class="md-org-settings-field">
      <label class="md-org-settings-field__label">{{t "Editing Colors" key="editing_colors"}}</label>
      {{extra-colors colors=this.model.extra_colors}}
    </div>

    <div class="md-org-settings-field">
      <label class="md-org-settings-field__label">{{t "Start Codes" key="start_codes"}}</label>
      <div class="md-org-settings-field__row">
        <span class="md-org-settings-field__static">
          {{#if this.model.start_codes.length}}
            {{t "Start Code" count=this.model.start_codes.length key="n_start_codes"}}
          {{else}}
            {{t "None Defined" key="none_defined"}}
          {{/if}}
        </span>
        <button type="button" class="md-org-btn md-org-btn--outline md-org-btn--sm" {{action "manage_start_codes"}}>{{t "Manage Start Codes" key="manage_start_codes"}}</button>
      </div>
    </div>

    <div class="md-org-settings-field">
      <label class="md-org-settings-field__label">{{t "Note Templates" key="note_templates"}}</label>
      <div class="md-org-settings-field__row">
        <span class="md-org-settings-field__static">
          {{#if this.model.note_templates.length}}
            {{t "Template" count=this.model.note_templates.length key="n_templates"}}
          {{else}}
            {{t "None Defined" key="none_defined"}}
          {{/if}}
        </span>
        <button type="button" class="md-org-btn md-org-btn--outline md-org-btn--sm" {{action "modify_templates"}}>{{t "Modify Templates" key="modify_templates"}}</button>
      </div>
    </div>
  </section>

  {{!-- ═══════════ Profiles ═══════════ --}}
  {{#if this.app_state.feature_flags.profiles}}
    <section class="md-org-settings-card">
      <h4 class="md-org-settings-card__title">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        {{t "Profiles" key="profiling"}}
      </h4>

      <div class="md-org-settings-field">
        <label for="comm_prof_id" class="md-org-settings-field__label">{{t "for communicators" key="for_communicators"}}</label>
        <div class="md-org-settings-field__row">
          <Input @value={{this.model.communicator_profile_id}} class="md-org-settings-input md-org-settings-input--sm" id="comm_prof_id" placeholder="Profile ID" />
        </div>
        {{#unless this.no_communicator_profile}}
          <div class="md-org-settings-field__row" style="margin-top: 8px;">
            <Input @value={{this.model.communicator_profile_frequency}} class="md-org-settings-input md-org-settings-input--xs" id="comm_prof_freq" placeholder="##" />
            <span class="md-org-settings-field__suffix">{{t "months until next profile due" key="days_until_next_profile_due"}}</span>
          </div>
        {{/unless}}
      </div>

      <div class="md-org-settings-field">
        <label for="comm_sup_id" class="md-org-settings-field__label">{{t "for supervisors" key="for_supervisors"}}</label>
        <div class="md-org-settings-field__row">
          <Input @value={{this.model.supervisor_profile_id}} class="md-org-settings-input md-org-settings-input--sm" id="comm_sup_id" placeholder="Profile ID" />
        </div>
        {{#unless this.no_supervisor_profile}}
          <div class="md-org-settings-field__row" style="margin-top: 8px;">
            <Input @value={{this.model.supervisor_profile_frequency}} class="md-org-settings-input md-org-settings-input--xs" id="comm_sup_freq" placeholder="##" />
            <span class="md-org-settings-field__suffix">{{t "months until next profile due" key="days_until_next_profile_due"}}</span>
          </div>
        {{/unless}}
      </div>
    </section>
  {{/if}}

  {{!-- ═══════════ Custom Domain Settings ═══════════ --}}
  {{#if this.model.custom_domain}}
    <section class="md-org-settings-card">
      <h4 class="md-org-settings-card__title">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        {{t "Customization Settings For" key="customization_settings_for"}}
        {{#if this.model.hosts}}
          {{#each this.model.hosts as |host|}}
            <span class="md-org-settings-card__host-chip">{{host}}</span>
          {{/each}}
        {{else}}
          {{t "custom domains" key="custom_domains"}}
        {{/if}}
      </h4>

      <div class="md-org-settings-field">
        <label for="app_name" class="md-org-settings-field__label">{{t "App Name" key="app_name_prompt"}}</label>
        <Input @value={{this.model.host_settings.app_name}} class="md-org-settings-input" id="app_name" placeholder="name for the application" />
      </div>
      <div class="md-org-settings-field">
        <label for="company_name" class="md-org-settings-field__label">{{t "Organization Name" key="company_name"}}</label>
        <Input @value={{this.model.host_settings.company_name}} class="md-org-settings-input" id="company_name" placeholder="shown in the app" />
      </div>
      <div class="md-org-settings-field">
        <label for="admin_email" class="md-org-settings-field__label">{{t "Admin Email" key="admin_email"}}</label>
        <Input @value={{this.model.host_settings.admin_email}} class="md-org-settings-input" id="admin_email" placeholder="for alerts and messages" />
      </div>
      <div class="md-org-settings-field">
        <label for="logo_url" class="md-org-settings-field__label">{{t "Logo Image URL" key="logo_image_url"}}</label>
        <Input @value={{this.model.host_settings.logo_url}} class="md-org-settings-input" id="logo_url" placeholder="100px x 100px" />
      </div>
      <div class="md-org-settings-field">
        <label for="css_url" class="md-org-settings-field__label">{{t "CSS Override URL" key="css_url"}}</label>
        <Input @value={{this.model.host_settings.css_url}} class="md-org-settings-input" id="css_url" placeholder="https://" />
      </div>
      <div class="md-org-settings-field">
        <label for="support_url" class="md-org-settings-field__label">{{t "Customer Support URL" key="support_url"}}</label>
        <Input @value={{this.model.host_settings.support_url}} class="md-org-settings-input" id="support_url" placeholder="https://" />
      </div>
      <div class="md-org-settings-field">
        <label for="board_user_name" class="md-org-settings-field__label">{{t "Suggest Boards User Name" key="board_user_name"}}</label>
        <Input @value={{this.model.host_settings.board_user_name}} class="md-org-settings-input" id="board_user_name" placeholder="user_name" />
      </div>

      <hr class="md-org-report-divider">

      <div class="md-org-settings-field">
        <label for="ios_store_url" class="md-org-settings-field__label">{{t "iOS App Store URL" key="ios_store_url"}}</label>
        <Input @value={{this.model.host_settings.ios_store_url}} class="md-org-settings-input" id="ios_store_url" placeholder="https://" />
      </div>
      <div class="md-org-settings-field">
        <label for="play_store_url" class="md-org-settings-field__label">{{t "Google Play Store URL" key="play_store_url"}}</label>
        <Input @value={{this.model.host_settings.play_store_url}} class="md-org-settings-input" id="play_store_url" placeholder="https://" />
      </div>
      <div class="md-org-settings-field">
        <label for="kindle_store_url" class="md-org-settings-field__label">{{t "Amazon Kindle Store URL" key="kindle_store_url"}}</label>
        <Input @value={{this.model.host_settings.kindle_store_url}} class="md-org-settings-input" id="kindle_store_url" placeholder="https://" />
      </div>
      <div class="md-org-settings-field">
        <label for="windows_64_bit_url" class="md-org-settings-field__label">{{t "Windows 64-bit URL" key="windows_64_bit_url"}}</label>
        <Input @value={{this.model.host_settings.windows_64_bit_url}} class="md-org-settings-input" id="windows_64_bit_url" placeholder="https://" />
      </div>
      <div class="md-org-settings-field">
        <label for="windows_32_bit_url" class="md-org-settings-field__label">{{t "Windows 32-bit Download URL" key="windows_32_bit_url"}}</label>
        <Input @value={{this.model.host_settings.windows_32_bit_url}} class="md-org-settings-input" id="windows_32_bit_url" placeholder="https://" />
      </div>

      <hr class="md-org-report-divider">

      <div class="md-org-settings-field">
        <label for="blog_url" class="md-org-settings-field__label">{{t "Blog URL" key="blog_url"}}</label>
        <Input @value={{this.model.host_settings.blog_url}} class="md-org-settings-input" id="blog_url" placeholder="https://" />
      </div>
      <div class="md-org-settings-field">
        <label for="twitter_url" class="md-org-settings-field__label">{{t "Twitter URL" key="twitter_url"}}</label>
        <Input @value={{this.model.host_settings.twitter_url}} class="md-org-settings-input" id="twitter_url" placeholder="https://" />
      </div>
      <div class="md-org-settings-field">
        <label for="twitter_handle" class="md-org-settings-field__label">{{t "Twitter Handle" key="twitter_handle"}}</label>
        <Input @value={{this.model.host_settings.twitter_handle}} class="md-org-settings-input" id="twitter_handle" placeholder="@whoever" />
      </div>
      <div class="md-org-settings-field">
        <label for="facebook_url" class="md-org-settings-field__label">{{t "Facebook URL" key="facebook_url"}}</label>
        <Input @value={{this.model.host_settings.facebook_url}} class="md-org-settings-input" id="facebook_url" placeholder="https://" />
      </div>
      <div class="md-org-settings-field">
        <label for="youtube_url" class="md-org-settings-field__label">{{t "YouTube URL" key="youtube_url"}}</label>
        <Input @value={{this.model.host_settings.youtube_url}} class="md-org-settings-input" id="youtube_url" placeholder="https://" />
      </div>
    </section>
  {{/if}}

  {{!-- ═══════════ Save / Cancel ═══════════ --}}
  <div class="md-org-settings-actions">
    <button class="md-org-btn md-org-btn--primary" type="submit" disabled={{this.status.saving}}>
      {{#if this.status.saving}}
        {{t "Updating Organization..." key="updating_org"}}
      {{else if this.status.error}}
        {{t "Error Updating Organization" key="error_updating_organization"}}
      {{else}}
        {{t "Update Organization" key="update_org"}}
      {{/if}}
    </button>
    <button type="button" class="md-org-btn md-org-btn--outline" {{action "cancel"}}>{{t "Cancel" key="cancel"}}</button>
    {{#if this.error}}
      <p class="md-org-error" style="margin-top: 8px;">{{t "There was an unexpected error while updating the organization" key="error_updating_org"}}</p>
    {{/if}}
  </div>
</form>
