            <span class="md-board-detail-edit-toolbar__section-label">{{t "Layout" key="board_detail_layout_label"}}</span>
            <div class="md-board-detail-edit-toolbar__section-buttons">
              <div class="md-board-detail-edit-toolbar__stepper">
                <button type="button"
                  class="md-board-detail-edit-toolbar__stepper-btn"
                  data-tooltip={{t "Remove Row" key="board_detail_remove_row"}}
                  {{action "modify_size" "row" "remove"}}>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12" stroke="#46505F"/></svg>
                </button>
                <span class="md-board-detail-edit-toolbar__stepper-label">{{t "Rows" key="board_detail_rows"}}</span>
                <button type="button"
                  class="md-board-detail-edit-toolbar__stepper-btn"
                  data-tooltip={{t "Add Row" key="board_detail_add_row"}}
                  {{action "modify_size" "row" "add"}}>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19" stroke="#2A9D8F"/><line x1="5" y1="12" x2="19" y2="12" stroke="#2A9D8F"/></svg>
                </button>
              </div>
              <div class="md-board-detail-edit-toolbar__stepper">
                <button type="button"
                  class="md-board-detail-edit-toolbar__stepper-btn"
                  data-tooltip={{t "Remove Column" key="board_detail_remove_col"}}
                  {{action "modify_size" "column" "remove"}}>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12" stroke="#46505F"/></svg>
                </button>
                <span class="md-board-detail-edit-toolbar__stepper-label">{{t "Cols" key="board_detail_cols"}}</span>
                <button type="button"
                  class="md-board-detail-edit-toolbar__stepper-btn"
                  data-tooltip={{t "Add Column" key="board_detail_add_col"}}
                  {{action "modify_size" "column" "add"}}>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19" stroke="#2A9D8F"/><line x1="5" y1="12" x2="19" y2="12" stroke="#2A9D8F"/></svg>
                </button>
              </div>
            </div>
          </div>

          <div class="md-board-detail-edit-toolbar__divider"></div>

          {{!-- ── Content ── --}}
          <div class="md-board-detail-edit-toolbar__section">
            <span class="md-board-detail-edit-toolbar__section-label">{{t "Boards" key="board_detail_boards_label"}}</span>
            <div class="md-board-detail-edit-toolbar__section-buttons">
              <button type="button"
                class="md-board-detail-edit-toolbar__btn"
                data-tooltip={{t "Button Stash" key="board_detail_button_stash"}}
                {{action "open_button_stash"}}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2" stroke="#2A9D8F"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" stroke="#46505F"/></svg>
                <span class="md-board-detail-edit-toolbar__label">{{t "Stash" key="board_detail_stash"}}</span>
              </button>
              <button type="button"
                class="md-board-detail-edit-toolbar__btn"
                data-tooltip={{t "Button Suggestions" key="board_detail_suggestions"}}
                {{action "suggestions"}}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" stroke="#4C86D8"/><line x1="12" y1="16" x2="12" y2="12" stroke="#46505F"/><line x1="12" y1="8" x2="12.01" y2="8" stroke="#46505F"/></svg>
                <span class="md-board-detail-edit-toolbar__label">{{t "Ideas" key="board_detail_ideas"}}</span>
              </button>
            </div>
          </div>

          {{#if this.has_levels}}
            <div class="md-board-detail-edit-toolbar__divider"></div>

            {{!-- ── Levels ── --}}
            <div class="md-board-detail-edit-toolbar__section">
              <span class="md-board-detail-edit-toolbar__section-label">{{t "Levels" key="board_detail_levels_label"}}</span>
              <div class="md-board-detail-edit-toolbar__section-buttons">
                <button type="button"
                  class="md-board-detail-edit-toolbar__btn {{if this.preview_levels 'md-board-detail-edit-toolbar__btn--active'}}"
                  data-tooltip={{t "Preview Levels" key="board_detail_preview_levels"}}
                  {{action "toggle_preview_levels"}}>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12" stroke="#2A9D8F"/></svg>
                </button>
                {{#if this.preview_levels}}
                  <button type="button"
                    class="md-board-detail-edit-toolbar__btn"
                    data-tooltip={{t "Level Down" key="board_detail_level_down"}}
                    {{action "shift_level" "down"}}>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" stroke="#46505F"/></svg>
                  </button>
                  {{#if this.preview_level}}
                    <span class="md-board-detail-edit-toolbar__level-badge">{{this.preview_level}}</span>
                  {{/if}}
                  <button type="button"
                    class="md-board-detail-edit-toolbar__btn"
                    data-tooltip={{t "Level Up" key="board_detail_level_up"}}
                    {{action "shift_level" "up"}}>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15" stroke="#46505F"/></svg>
                  </button>
                  <button type="button"
                    class="md-board-detail-edit-toolbar__btn"
                    data-tooltip={{t "Exit Level Preview" key="board_detail_exit_level"}}
                    {{action "shift_level" "done"}}>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" stroke="#2A9D8F"/></svg>
                  </button>
                {{/if}}
              </div>
            </div>
          {{/if}}

          <div class="md-board-detail-edit-toolbar__divider"></div>

          {{!-- ── Filter ── --}}
          <div class="md-board-detail-edit-toolbar__section">
            <span class="md-board-detail-edit-toolbar__section-label">{{t "Filter" key="board_detail_filter_label"}}</span>
            <div class="md-board-detail-edit-toolbar__section-buttons">
              <button type="button"
                class="md-board-detail-edit-toolbar__btn {{if this.show_categories 'md-board-detail-edit-toolbar__btn--active'}}"
                data-tooltip={{t "Categories" key="board_detail_categories_label"}}
                {{action "toggle_categories"}}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="7" height="7" stroke="#4C86D8"/><rect x="14" y="3" width="7" height="7" stroke="#46505F"/><rect x="14" y="14" width="7" height="7" stroke="#4C86D8"/><rect x="3" y="14" width="7" height="7" stroke="#46505F"/>
                </svg>
                <span class="md-board-detail-edit-toolbar__label">{{t "Categories" key="board_detail_categories_label"}}</span>
              </button>
              <div class="md-board-detail-edit-toolbar__search">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3" fill="none" stroke="#2A9D8F"/>
                </svg>
                <input
                  id="board-detail-search"
                  type="text"
                  class="md-board-detail-edit-toolbar__search-input"
                  placeholder={{t "Search buttons..." key="search_buttons"}}
                  value={{this.board_search_string}}
                  {{on "input" (action "update_board_search")}}
                />
                {{#if this.board_search_string}}
                  <button type="button" class="md-board-detail-edit-toolbar__search-clear" {{action "clear_board_search"}} aria-label={{t "Clear filter" key="clear_filter"}}>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#46505F" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </button>
                {{/if}}
              </div>
            </div>
          </div>

          <div class="md-board-detail-edit-toolbar__spacer"></div>

          {{!-- ── Save / Cancel ── --}}
          <div class="md-board-detail-edit-toolbar__section md-board-detail-edit-toolbar__section--actions">
            <div class="md-board-detail-edit-toolbar__section-buttons">
              <button type="button"
                class="md-board-detail-edit-toolbar__btn md-board-detail-edit-toolbar__btn--save"
                data-tooltip={{t "Save Board" key="board_detail_save_board"}}
                {{action "save_board"}}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" stroke="currentColor"/><polyline points="17 21 17 13 7 13 7 21" stroke="currentColor"/><polyline points="7 3 7 8 15 8" stroke="currentColor"/></svg>
                <span class="md-board-detail-edit-toolbar__label">{{t "Save" key="board_detail_save"}}</span>
              </button>
              <button type="button"
                class="md-board-detail-edit-toolbar__btn md-board-detail-edit-toolbar__btn--cancel"
                data-tooltip={{t "Cancel Changes" key="board_detail_cancel_changes"}}
                {{action "cancel_edit"}}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor"/></svg>
                <span class="md-board-detail-edit-toolbar__label">{{t "Cancel" key="board_detail_cancel"}}</span>
              </button>
            </div>
          </div>
        </div>
      {{/if}}

      {{!-- Toolbar row: Quick Phrases + Category Filter --}}
      <div class="md-board-detail-toolbar">
        <div class="md-board-detail-quick-wrap">
          {{#unless this.edit_mode}}
            <button type="button"
              class="md-board-detail-quick-toggle {{if this.show_quick_phrases 'md-board-detail-quick-toggle--active'}}"
              {{action "toggle_quick_phrases"}}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
              <span>{{t "Quick Phrases" key="board_detail_quick_phrases_label"}}</span>
              <svg class="md-board-detail-quick-toggle__chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </button>
          {{/unless}}
          {{#unless this.edit_mode}}
            <button type="button"
              class="md-board-detail-quick-toggle md-board-detail-quick-toggle--categories {{if this.show_categories 'md-board-detail-quick-toggle--active'}}"
              {{action "toggle_categories"}}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
              </svg>
              <span>{{t "Categories" key="board_detail_categories_label"}}</span>
              <svg class="md-board-detail-quick-toggle__chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </button>
          {{/unless}}

          {{#if this.active_filter_label}}
            <span class="md-board-detail-filter-chip">
              {{#if this.active_filter_css}}
                <span class="md-board-detail-filter-chip__swatch md-board-detail-symbol-card--{{this.active_filter_css}}"></span>
              {{/if}}
              <span class="md-board-detail-filter-chip__label">{{this.active_filter_label}}</span>
              <button type="button" class="md-board-detail-filter-chip__clear" {{action "set_category" "all"}} title={{t "Clear filter" key="board_detail_clear_filter"}}>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </button>
            </span>
          {{/if}}

          {{#if this.show_categories}}
            <div class="md-board-detail-cat-panel" role="toolbar" aria-label={{t "Symbol categories" key="board_detail_symbol_categories"}}>
              <div class="md-board-detail-cat-panel__left">
                <button type="button"
                  class="md-board-detail-quick-reveal__btn {{if (is-equal 'all' this.active_category) 'md-board-detail-quick-reveal__btn--active'}}"
                  {{action "set_category" "all"}}>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                  <span class="md-board-detail-quick-reveal__btn-label">{{t "All" key="category_all"}}</span>
                </button>
                <button type="button"
                  class="md-board-detail-quick-reveal__btn {{if (is-equal 'folder' this.active_category) 'md-board-detail-quick-reveal__btn--active'}}"
                  {{action "set_category" "folder"}}>
                  <span class="md-board-detail-quick-reveal__swatch md-board-detail-symbol-card--folder"></span>
                  <span class="md-board-detail-quick-reveal__btn-label">{{t "Folders" key="category_folders"}}</span>
                </button>
              </div>
              <div class="md-board-detail-cat-panel__divider"></div>
              <div class="md-board-detail-cat-panel__right">
                {{#each this.pos_type_categories as |cat|}}
                  <button type="button"
                    class="md-board-detail-quick-reveal__btn {{if (is-equal cat.id this.active_category) 'md-board-detail-quick-reveal__btn--active'}}"
                    {{action "set_category" cat.id}}>
                    <span class="md-board-detail-quick-reveal__swatch md-board-detail-symbol-card--{{cat.css_class}}"></span>
                    <span class="md-board-detail-quick-reveal__btn-label">{{cat.label}}</span>
                  </button>
                {{/each}}
              </div>
            </div>
          {{/if}}

          {{!-- Quick Phrases content (non-edit mode, full width) --}}
          {{#unless this.edit_mode}}
            {{#if this.show_quick_phrases}}
              <div class="md-board-detail-quick-reveal" role="toolbar" aria-label={{t "Quick phrases" key="board_detail_quick_phrases"}}>
                {{#each this.quick_buttons as |qb|}}
                  <button type="button" class="md-board-detail-quick-reveal__btn" {{action "select_quick" qb}}>
                    <span class="md-board-detail-quick-reveal__btn-icon" aria-hidden="true">{{qb.icon}}</span>
                    <span class="md-board-detail-quick-reveal__btn-label">{{qb.label}}</span>
                  </button>
                {{/each}}
              </div>
            {{/if}}
          {{/unless}}
        </div>

      </div>

      <div class="md-board-detail-divider"></div>

      {{!-- Loading indicator --}}
      {{#if this.board_saving}}
        <div class="md-board-detail-loading">
          <div class="md-board-detail-loading__spinner"></div>
          <span class="md-board-detail-loading__text">{{t "Saving..." key="board_detail_saving"}}</span>
        </div>
      {{/if}}

      {{!-- Grid + Sidebar wrapper --}}
      <div class="md-board-detail-grid-sidebar-wrap">

      {{!-- Symbol Grid (wrapped in button-listener for scanning/gaze/dwell support) --}}
      {{#button-listener buttonEvent=(action "button_event")}}
      {{!-- Do NOT add advanced_selection here: raw_events delegates click on .advanced_selection and preventDefault/stopPropagation, which blocks Ember {{action}} on symbol cards. Classic board uses raw_events-only selection; board-detail relies on {{action "select_button"}} for taps. Long-press inflections use .board / .button and board-detail route checks in raw_events + edit_manager. --}}
      <div class="md-board-detail-grid board {{if this.app_state.speak_mode 'speak'}} {{if this.board_saving 'md-board-detail-grid--hidden'}} {{if this.folder_labels_on_tab 'md-board-detail-grid--folder-tab-labels'}} {{if this.folder_colored_corner 'md-board-detail-grid--folder-colored-corner'}} {{this.button_text_size_class}} {{this.button_text_position_class}} {{this.symbol_background_class}} {{this.high_contrast_class}}" role="grid" aria-label={{t "Symbol board" key="board_detail_symbol_board"}}
        data-id={{this.model.id}}
        data-filter={{this.active_category}}
        style={{safe-style (concat this.grid_style ";--bd-button-text-size:" this.button_text_size_px "px" (if this.button_font_style.family (concat ";--bd-button-font:" this.button_font_style.family)) (if this.button_font_style.transform (concat ";--bd-button-text-transform:" this.button_font_style.transform)))}}>
        {{#each this.ordered_buttons as |row|}}
          {{#each row as |btn|}}
          <div class="md-board-detail-grid__cell {{if btn.load_board 'md-board-detail-grid__cell--folder'}} {{if btn._filtered_out 'md-board-detail-grid__cell--filtered-out'}}"
            data-id={{btn.id}}
            draggable={{if this.edit_mode "true" "false"}}>
            {{#if btn.load_board}}
              <div class="md-folder-back">
                <div class="md-folder-tab" {{action "select_button" btn}}>
                  {{#if this.edit_mode}}
                    {{label-field value=btn.label class="md-folder-tab__label-input" placeholder="enter label" aria-label=(concat (t "Folder label" key="board_detail_folder_label_aria") " " btn.id)}}
                  {{else}}
                    <span class="md-folder-tab__label" aria-label={{btn.label}}>{{btn.label}}</span>
                  {{/if}}
                </div>
              </div>
            {{/if}}
            <div
              class="button md-board-detail-symbol-card md-board-detail-symbol-card--{{or btn.part_of_speech btn.painted_part_of_speech btn.suggested_part_of_speech 'default'}} {{if btn.empty 'md-board-detail-symbol-card--empty'}} {{if btn.hidden 'md-board-detail-symbol-card--hidden'}} {{if btn.for_swap 'md-board-detail-symbol-card--swapping'}} {{if btn.load_board 'md-board-detail-symbol-card--folder'}} {{unless btn.background_color 'md-board-detail-symbol-card--no-color'}}"
              role="gridcell"
              data-id={{btn.id}}
              style={{safe-style (concat (if btn.background_color (concat "background-color:" btn.background_color ";--btn-bg:" btn.background_color ";")) (if btn.border_color (concat "outline-color:" btn.border_color ";")))}}
              {{action "select_button" btn}}>
              {{#if this.edit_mode}}
                {{!-- Inline edit actions (shown when card is tall enough) --}}
                <div class="md-board-detail-symbol-card__edit-actions md-board-detail-symbol-card__edit-actions--inline">
                  <button type="button"
                    class="md-board-detail-symbol-card__edit-btn"
                    title={{t "Edit button settings" key="board_detail_edit_button"}}
                    {{action "edit_button_settings" btn bubbles=false}}>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                  </button>
                  <button type="button"
                    class="md-board-detail-symbol-card__edit-btn"
                    title={{t "Change button color" key="board_detail_change_color"}}
                    {{action "open_color_picker" btn bubbles=false}}>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
                  </button>
                  <button type="button"
                    class="md-board-detail-symbol-card__edit-btn"
                    title={{t "Copy to Button Stash" key="copy_to_button_stash"}}
                    {{action "stash_button" btn bubbles=false}}>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                  </button>
                  <button type="button"
                    class="md-board-detail-symbol-card__edit-btn"
                    title={{t "Word Data" key="view_word_data"}}
                    {{action "word_data" btn bubbles=false}}>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                  </button>
                  <button type="button"
                    class="md-board-detail-symbol-card__edit-btn md-board-detail-symbol-card__edit-btn--danger"
                    title={{t "Clear button" key="board_detail_clear_button"}}
                    {{action "clear_button" btn bubbles=false}}>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                  </button>
                </div>
                {{!-- Dropdown menu trigger (shown when card is too short for inline actions) --}}
                <div class="md-board-detail-symbol-card__edit-actions md-board-detail-symbol-card__edit-actions--dropdown">
                  <button type="button"
                    class="md-board-detail-symbol-card__edit-btn md-board-detail-symbol-card__edit-menu-trigger"
                    title={{t "Button options" key="board_detail_button_options"}}
                    {{action "toggle_button_menu" btn bubbles=false}}>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg>
                  </button>
                  {{#if (is-equal this.button_menu_id btn.id)}}
                    <div class="md-board-detail-symbol-card__edit-dropdown">
                      <button type="button" class="md-board-detail-symbol-card__edit-dropdown-item" {{action "edit_button_settings" btn bubbles=false}}>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        <span>{{t "Edit" key="edit"}}</span>
                      </button>
                      <button type="button" class="md-board-detail-symbol-card__edit-dropdown-item" {{action "open_color_picker" btn bubbles=false}}>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
                        <span>{{t "Color" key="color"}}</span>
                      </button>
                      <button type="button" class="md-board-detail-symbol-card__edit-dropdown-item" {{action "stash_button" btn bubbles=false}}>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                        <span>{{t "Stash" key="stash"}}</span>
                      </button>
                      <button type="button" class="md-board-detail-symbol-card__edit-dropdown-item" {{action "word_data" btn bubbles=false}}>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                        <span>{{t "Word Data" key="view_word_data"}}</span>
                      </button>
                      <button type="button" class="md-board-detail-symbol-card__edit-dropdown-item md-board-detail-symbol-card__edit-dropdown-item--danger" {{action "clear_button" btn bubbles=false}}>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                        <span>{{t "Clear" key="clear"}}</span>
                      </button>
                    </div>
                  {{/if}}
                </div>
              {{/if}}
              {{#if btn.image_url}}
                <div class="md-board-detail-symbol-card__image">
                  <img class="symbol" src={{btn.image_url}} alt={{btn.label}} loading="lazy" onerror="this.style.display='none';this.nextElementSibling&&(this.nextElementSibling.style.display='flex');">
                  <img class="md-board-detail-symbol-card__fallback-img" src="/images/square.svg" alt="" draggable="false" style="display:none; max-width: 70%; max-height: 70%;">
                </div>
              {{else}}
                <div class="md-board-detail-symbol-card__image md-board-detail-symbol-card__image--placeholder">
                  {{#if btn.load_board}}
                    <img class="symbol" src="/images/folder_home.png" alt="" draggable="false" style="opacity: 0.35; max-width: 60%; max-height: 60%;">
                  {{else if btn.label}}
                    <img class="symbol" src="/images/square.svg" alt="" draggable="false" style="max-width: 70%; max-height: 70%;">
                  {{/if}}
                </div>
              {{/if}}
              {{#if this.edit_mode}}
                {{label-field value=btn.label class="md-board-detail-symbol-card__label-input" placeholder="enter label" aria-label=(concat (t "Button label" key="board_detail_button_label_aria") " " btn.id)}}
              {{else}}
                <span class="md-board-detail-symbol-card__label" style={{if btn.text_color (safe-style (concat "color:" btn.text_color))}}>{{btn.label}}</span>
              {{/if}}
              {{#if btn.load_board}}
                <span class="md-board-detail-symbol-card__folder-badge" aria-label={{t "Folder" key="folder"}}>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                    <path d="M10 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-8l-2-2z"/>
                  </svg>
                </span>
              {{/if}}
            </div>

            {{#if this.edit_mode}}
              {{!-- Color Picker Popover --}}
              {{#if (is-equal this.color_picker_button btn)}}
                <div class="md-board-detail-color-picker">
                  <div class="md-board-detail-color-picker__header">
                    <span class="md-board-detail-color-picker__title">{{t "Choose Color" key="board_detail_choose_color"}}</span>
                    <button type="button" class="md-board-detail-color-picker__close" {{action "close_color_picker"}}>&times;</button>
                  </div>

                  <div class="md-board-detail-color-picker__swatches">
                    {{#each this.color_picker_swatches as |swatch|}}
                      <button type="button"
                        class="md-board-detail-color-picker__swatch"
                        {{action "apply_swatch_color" swatch}}>
                        <span class="md-board-detail-color-picker__swatch-color" style={{safe-style (concat "background-color:" swatch.bg ";border-color:" swatch.border)}}></span>
                        <span class="md-board-detail-color-picker__swatch-label">{{swatch.label}}</span>
                      </button>
                    {{/each}}
                  </div>

                  <div class="md-board-detail-color-picker__custom">
                    <div class="md-board-detail-color-picker__custom-header">
                      <label class="md-board-detail-color-picker__custom-label" for="bd-btn-custom-color">{{t "Custom Color" key="board_detail_custom_color"}}</label>
                    </div>
                    <div class="md-board-detail-color-picker__custom-row">
                      <span class="md-board-detail-color-picker__preview"
                        {{action "toggle_minicolors"}}
                        style={{if this.custom_color_value (safe-style (concat "background-color:" this.custom_color_value))}}></span>
                      <input type="text" id="bd-btn-custom-color" class="md-board-detail-color-picker__input" placeholder="#hex" autocomplete="off" />
                      <button type="button" class="md-board-detail-color-picker__apply" {{action "apply_custom_color"}}>{{t "Apply" key="board_detail_apply"}}</button>
                    </div>
                  </div>
                </div>
              {{/if}}
            {{/if}}
          </div>
          {{/each}}
        {{/each}}
        {{#unless this.ordered_buttons.length}}
          <div class="md-board-detail-grid__empty">
            <p>{{t "No symbols found for this category" key="board_detail_no_symbols"}}</p>
          </div>
        {{/unless}}
      </div>
      {{/button-listener}}

      {{!-- Inline Sidebar Boards (speak mode navigation) --}}
      {{#unless this.edit_mode}}
        {{#if this.inlineSidebarOpen}}
          <div class="md-board-detail-inline-sidebar">
            {{#each this.app_state.sidebar_boards as |board|}}
              {{#if board.alert}}
                <a href="#" {{action "sidebar_alert"}} class="md-board-detail-inline-sidebar__item">
                  <img src={{board.image}} class="md-board-detail-inline-sidebar__img" alt="" onerror="button_broken_image(this);">
                  <span class="md-board-detail-inline-sidebar__name">{{board.name}}</span>
                </a>
              {{else}}
                <a href="#" class="md-board-detail-inline-sidebar__item" {{action "sidebar_jump" board.key board}}>
                  <img src={{board.image}} class="md-board-detail-inline-sidebar__img" alt="" onerror="button_broken_image(this);">
                  <span class="md-board-detail-inline-sidebar__name">{{board.name}}</span>
                </a>
              {{/if}}
            {{/each}}
          </div>
        {{/if}}
      {{/unless}}

      </div>{{!-- /.md-board-detail-grid-sidebar-wrap --}}

    </main>

    {{!-- Right Sidebar --}}
    <aside class="md-board-detail-right-panel {{if this.panels_collapsed 'md-board-detail-right-panel--collapsed'}}" aria-label={{t "Activity panel" key="board_detail_activity_panel"}}>
      {{!-- Recent Phrases --}}
      <section class="md-board-detail-right-panel__section">
        <h3 class="md-board-detail-right-panel__heading">{{t "Recent Phrases" key="board_detail_recent_phrases"}}</h3>
        {{#if this.recent_phrases.length}}
          <ul class="md-board-detail-phrase-list">
            {{#each this.recent_phrases as |phrase|}}
              <li class="md-board-detail-phrase-list__item" {{action "speak_phrase" phrase}}>
                <span class="md-board-detail-phrase-list__dot" aria-hidden="true"></span>
                {{phrase.text}}
              </li>
            {{/each}}
          </ul>
        {{else}}
          <p class="md-board-detail-right-panel__empty">{{t "Phrases appear here" key="board_detail_phrases_empty"}}</p>
        {{/if}}
      </section>

      {{!-- Weekly Goals --}}
      <section class="md-board-detail-right-panel__section">
        <h3 class="md-board-detail-right-panel__heading">{{t "Weekly Goals" key="board_detail_weekly_goals"}}</h3>
        {{#if this.weekly_goals.length}}
          <ul class="md-board-detail-goals-list">
            {{#each this.weekly_goals as |goal|}}
              <li class="md-board-detail-goals-list__item">
                <div class="md-board-detail-goals-list__header">
                  <span class="md-board-detail-goals-list__label">{{goal.label}}</span>
                  <span class="md-board-detail-goals-list__count">{{goal.current}} / {{goal.target}}</span>
                </div>
                <div class="md-board-detail-goals-list__bar">
                  <div class="md-board-detail-goals-list__fill md-board-detail-goals-list__fill--{{goal.color}}" style={{safe-style (concat "width:" goal.percent "%")}}></div>
                </div>
              </li>
            {{/each}}
          </ul>
        {{else}}
          <p class="md-board-detail-right-panel__empty">{{t "No goals set yet" key="board_detail_no_goals"}}</p>
        {{/if}}
      </section>

      {{!-- Today's Schedule --}}
      <section class="md-board-detail-right-panel__section">
        <h3 class="md-board-detail-right-panel__heading">{{t "Today's Schedule" key="board_detail_todays_schedule"}}</h3>
        {{#if this.todays_schedule.length}}
          <ul class="md-board-detail-schedule-list">
            {{#each this.todays_schedule as |event|}}
              <li class="md-board-detail-schedule-list__item">
                <span class="md-board-detail-schedule-list__time">{{event.time}}</span>
                <div class="md-board-detail-schedule-list__info">
                  <span class="md-board-detail-schedule-list__name">{{event.name}}</span>
                  <span class="md-board-detail-schedule-list__type md-board-detail-schedule-list__type--{{event.type_class}}">{{event.type}}</span>
                </div>
              </li>
            {{/each}}
          </ul>
        {{else}}
          <p class="md-board-detail-right-panel__empty">{{t "No events scheduled" key="board_detail_no_events"}}</p>
        {{/if}}
      </section>
    </aside>
  </div>
</div>
