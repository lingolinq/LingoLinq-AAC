<div class="md-shell md-shell--board-detail {{if this.edit_mode 'md-shell--board-detail-edit'}} {{if this.board_collapsed 'md-shell--board-collapsed'}} {{if this.paint_mode 'md-shell--board-paint'}}">
  {{outlet}}
  <div class="md-board-detail-layout {{if this.panels_collapsed 'md-board-detail-layout--collapsed'}}">
    {{!-- Overlay backdrop for mobile panels --}}
    {{#unless this.panels_collapsed}}
      <div class="md-board-detail-overlay-backdrop" {{action "toggle_panels"}}></div>
      <button type="button" class="md-board-detail-panels-close-btn" {{action "toggle_panels"}} aria-label={{t "Collapse panels" key="board_detail_collapse_panels"}}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    {{/unless}}
    {{!-- Left Sidebar Navigation --}}
    <aside class="md-board-detail-sidebar {{if this.panels_collapsed 'md-board-detail-sidebar--collapsed'}}" aria-label={{t "Board navigation" key="board_navigation"}}>
      <section class="md-board-detail-sidebar__section">
        <h3 class="md-board-detail-sidebar__heading">{{t "Communicate" key="board_detail_communicate"}}</h3>
        {{#each this.sidebar_nav.communicate as |item|}}
          <button type="button"
            class="md-board-detail-sidebar__item {{if item.active 'md-board-detail-sidebar__item--active'}}"
            {{action "nav_select" item.id}}>
            <span class="md-board-detail-sidebar__icon md-board-detail-sidebar__icon--{{item.icon}}" aria-hidden="true"></span>
            <span class="md-board-detail-sidebar__label">{{item.label}}</span>
          </button>
        {{/each}}
      </section>

      <section class="md-board-detail-sidebar__section">
        <h3 class="md-board-detail-sidebar__heading">{{t "Clinical" key="board_detail_clinical"}}</h3>
        {{#each this.sidebar_nav.clinical as |item|}}
          <button type="button"
            class="md-board-detail-sidebar__item {{if item.active 'md-board-detail-sidebar__item--active'}}"
            {{action "nav_select" item.id}}>
            <span class="md-board-detail-sidebar__icon md-board-detail-sidebar__icon--{{item.icon}}" aria-hidden="true"></span>
            <span class="md-board-detail-sidebar__label">{{item.label}}</span>
          </button>
        {{/each}}
      </section>

      <section class="md-board-detail-sidebar__section">
        <h3 class="md-board-detail-sidebar__heading">{{t "Settings" key="board_detail_settings"}}</h3>
        {{#each this.sidebar_nav.settings as |item|}}
          <button type="button"
            class="md-board-detail-sidebar__item {{if item.active 'md-board-detail-sidebar__item--active'}}"
            {{action "nav_select" item.id}}>
            <span class="md-board-detail-sidebar__icon md-board-detail-sidebar__icon--{{item.icon}}" aria-hidden="true"></span>
            <span class="md-board-detail-sidebar__label">{{item.label}}</span>
          </button>
        {{/each}}
      </section>
    </aside>

    {{!-- Main Content Area --}}
    <main class="md-board-detail-main">
      {{!-- Sentence Bar --}}
      <div class="md-board-detail-sentence-row">
      {{#unless this.edit_mode}}
      <div class="md-board-detail-sentence-nav">
        <button type="button"
          class="md-board-detail-sentence-nav__btn"
          title={{t "Home Board" key="board_detail_home_board"}}
          {{action "go_home"}}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
        </button>
        <div class="md-board-detail-sentence-nav__divider"></div>
        <button type="button"
          class="md-board-detail-sentence-nav__btn"
          title={{t "Go back" key="board_detail_go_back"}}
          disabled={{unless this.has_board_history true}}
          {{action "go_back"}}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
        </button>
      </div>
      {{/unless}}
      <div class="md-board-detail-sentence-bar" role="region" aria-label={{t "Message composition" key="board_detail_message_composition"}}>
        <div class="md-board-detail-sentence-bar__text" aria-live="polite">
          {{#if this.has_sentence}}
            {{this.sentence_text}}
          {{else}}
            <span class="md-board-detail-sentence-bar__placeholder">{{t "Tap symbols to build your message" key="board_detail_tap_symbols"}}</span>
          {{/if}}
        </div>
        <div class="md-board-detail-sentence-bar__actions">
          <button type="button" class="md-board-detail-sentence-bar__btn md-board-detail-sentence-bar__btn--speak" {{action "speak_sentence"}}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
              <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
              <line x1="12" y1="19" x2="12" y2="23"/>
              <line x1="8" y1="23" x2="16" y2="23"/>
            </svg>
            <span class="md-board-detail-sentence-bar__btn-label">{{t "Speak" key="board_detail_speak"}}</span>
          </button>
          <div class="md-board-detail-sentence-bar__tools">
            <button type="button" class="md-board-detail-sentence-bar__tool-btn" title={{t "Backspace" key="backspace_lower"}} {{action "backspace_sentence"}}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 4H8l-7 8 7 8h13a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2z"/>
                <line x1="18" y1="9" x2="12" y2="15"/>
                <line x1="12" y1="9" x2="18" y2="15"/>
              </svg>
            </button>
            <button type="button" class="md-board-detail-sentence-bar__tool-btn" title={{t "Clear" key="board_detail_clear"}} {{action "clear_sentence"}}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
              </svg>
            </button>
            <button type="button" class="md-board-detail-sentence-bar__tool-btn" title={{t "Speak options" key="speak_options"}} {{action "open_speak_menu"}}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
            </svg>
            </button>
          </div>
        </div>
      </div>
      <div class="md-board-detail-sentence-bar__divider"></div>
      <div class="md-board-detail-sentence-bar__actions-wrap">
        <button type="button"
          class="md-board-detail-actions-toggle"
          title={{t "Options" key="board_detail_options"}}
          {{action "toggle_options_menu"}}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true">
            <circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/>
          </svg>
        </button>
        {{#if this.show_options_menu}}
          <div class="md-board-detail-actions-backdrop" {{action "toggle_options_menu"}}></div>
          <div class="md-board-detail-actions-menu">
            <button type="button" class="md-board-detail-actions-menu__item" {{action "go_home"}}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true">
                <path d="M12 3L2 12h3v8h6v-6h2v6h6v-8h3L12 3z"/>
              </svg>
              <span>{{t "Home Board" key="board_detail_home_board"}}</span>
            </button>
            <button type="button" class="md-board-detail-actions-menu__item" {{action "open_board_picker"}}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true">
                <path fill-rule="evenodd" d="M3 3h8v8H3V3zm10 0h8v8h-8V3zM3 13h8v8H3v-8zm10 0h8v8h-8v-8z" clip-rule="evenodd"/>
              </svg>
              <span>{{t "My Boards" key="my_boards"}}</span>
            </button>
            {{#unless this.edit_mode}}
              <button type="button" class="md-board-detail-actions-menu__item" {{action "enter_edit_mode"}}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
                <span>{{t "Edit Board" key="board_detail_edit_board"}}</span>
              </button>
            {{/unless}}
            {{#unless this.edit_mode}}
              <button type="button" class="md-board-detail-actions-menu__item" {{action "toggle_panels"}}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  {{#if this.panels_collapsed}}
                    <polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/>
                  {{else}}
                    <polyline points="4 14 4 20 10 20"/><polyline points="20 10 20 4 14 4"/><line x1="14" y1="10" x2="21" y2="3"/><line x1="3" y1="21" x2="10" y2="14"/>
                  {{/if}}
                </svg>
                <span>{{if this.panels_collapsed (t "Expand Panels" key="board_detail_expand_panels") (t "Collapse Panels" key="board_detail_collapse_panels")}}</span>
              </button>
            {{/unless}}
            <button type="button" class="md-board-detail-actions-menu__item" {{action "revert_to_old_style"}}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
              </svg>
              <span>{{t "Revert to Old Style" key="board_detail_revert_old_style"}}</span>
            </button>
            <div class="md-board-detail-actions-menu__divider"></div>
            <button type="button" class="md-board-detail-actions-menu__item md-board-detail-actions-menu__item--exit" {{action "exit_to_home"}}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
              <span>{{t "Exit Board" key="board_detail_exit_board"}}</span>
            </button>
          </div>
        {{/if}}
      </div>
      </div>

      {{!-- Word Suggestions --}}
      {{#if this.show_word_suggestions}}
        <div class="md-board-detail-suggestions" role="region" aria-label={{t "Word suggestions" key="board_detail_word_suggestions"}}>
          {{#if this.suggestions.ready}}
            {{#each this.suggestions.list as |suggestion|}}
              <button type="button" class="md-board-detail-suggestion" {{action "complete_word" suggestion}}>
                {{#if suggestion.image}}
                  <img src={{suggestion.image}} class="md-board-detail-suggestion__img" alt="">
                {{/if}}
                <span class="md-board-detail-suggestion__text">{{suggestion.word}}</span>
              </button>
            {{/each}}
          {{else}}
            <span class="md-board-detail-suggestion__loading">{{t "Loading suggestions..." key="loading_word_suggestions"}}</span>
          {{/if}}
        </div>
      {{/if}}

      {{!-- Board Title --}}
      <header class="md-board-detail-header">
        <div class="md-board-detail-header__row">
          <div class="md-board-detail-header__title-group">
            {{#unless this.edit_mode}}
              <div class="md-board-detail-nav-btns">
                {{#if this.has_board_history}}
                  <button type="button"
                    class="md-board-detail-nav-btn"
                    title={{t "Go back" key="board_detail_go_back"}}
                    {{action "go_back"}}>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="15 18 9 12 15 6"/>
                    </svg>
                  </button>
                {{/if}}
              </div>
            {{/unless}}
            {{#if this.board_image_url}}
              <img src={{this.board_image_url}} alt="" class="md-board-detail-header__board-icon">
            {{/if}}
            <div>
              <div class="md-board-detail-header__title-row">
                <h1 class="md-board-detail-header__title">{{this.title}}</h1>
                <button type="button"
                  class="md-board-detail-info-btn"
                  title={{t "Board information" key="board_detail_board_info"}}
                  {{action "board_details"}}>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
                  </svg>
                </button>
              </div>
              <p class="md-board-detail-header__sub {{unless this.description_expanded 'md-board-detail-header__sub--collapsed'}}">{{this.subtitle}}</p>
              {{#if this.subtitle_is_long}}
                <button type="button" class="md-board-detail-header__expand-link" {{action "toggle_description"}}>
                  {{#if this.description_expanded}}
                    {{t "Show less" key="show_less"}}
                  {{else}}
                    {{t "Show more" key="show_more"}}
                  {{/if}}
                </button>
              {{/if}}
            </div>
          </div>
          <div class="md-board-detail-header__actions">
            <button type="button"
              class="md-board-detail-color-legend-toggle {{if this.show_color_legend 'md-board-detail-color-legend-toggle--active'}}"
              {{action "toggle_color_legend"}}
              title={{t "Color key — see what each button color means" key="board_detail_color_key_tooltip"}}>
              <span class="md-board-detail-color-legend-toggle__icon" aria-hidden="true">&#x1F3A8;</span>
              <span class="md-board-detail-color-legend-toggle__label">{{t "Color Key" key="board_detail_color_key"}}</span>
            </button>
            {{#if this.edit_mode}}
              <LinkTo @route="user.board-detail.index" class="md-board-detail-edit-btn md-board-detail-edit-btn--active">
                <svg class="md-board-detail-edit-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                <span class="md-board-detail-edit-btn__label">{{t "Done Editing" key="board_detail_done_editing"}}</span>
              </LinkTo>
            {{else}}
              <LinkTo @route="user.board-detail.edit" class="md-board-detail-edit-btn">
                <svg class="md-board-detail-edit-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
                <span class="md-board-detail-edit-btn__label">{{t "Edit Board" key="board_detail_edit_board"}}</span>
              </LinkTo>
            {{/if}}
          </div>
        </div>

        {{#if this.show_color_legend}}
          <div class="md-board-detail-color-legend" role="region" aria-label={{t "Button color legend" key="board_detail_color_legend"}}>
            <div class="md-board-detail-color-legend__grid">
              {{#each this.color_legend_items as |item|}}
                <div class="md-board-detail-color-legend__item">
                  <span class="md-board-detail-color-legend__swatch md-board-detail-symbol-card--{{item.css_class}}"></span>
                  <div class="md-board-detail-color-legend__info">
                    <span class="md-board-detail-color-legend__type">{{item.type}}</span>
                    <span class="md-board-detail-color-legend__parts">{{item.parts}}</span>
                  </div>
                </div>
              {{/each}}
            </div>
          </div>
        {{/if}}
      </header>

      {{!-- Edit Mode Toolbar --}}
      {{#if this.edit_mode}}
        <div class="md-board-detail-edit-toolbar" role="toolbar" aria-label={{t "Edit tools" key="board_detail_edit_tools"}}>
          <div class="md-board-detail-edit-toolbar__group">
            {{!-- Undo --}}
            <button type="button"
              class="md-board-detail-edit-toolbar__btn"
              disabled={{this.noUndo}}
              title={{t "Undo" key="board_detail_undo"}}
              {{action "undo_edit"}}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
              <span class="md-board-detail-edit-toolbar__label">{{t "Undo" key="board_detail_undo"}}</span>
            </button>
            {{!-- Redo --}}
            <button type="button"
              class="md-board-detail-edit-toolbar__btn"
              disabled={{this.noRedo}}
              title={{t "Redo" key="board_detail_redo"}}
              {{action "redo_edit"}}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.13-9.36L23 10"/></svg>
              <span class="md-board-detail-edit-toolbar__label">{{t "Redo" key="board_detail_redo"}}</span>
            </button>
          </div>

          <div class="md-board-detail-edit-toolbar__divider"></div>

          <div class="md-board-detail-edit-toolbar__group">
            {{!-- Paint mode toggle --}}
            <button type="button"
              class="md-board-detail-edit-toolbar__btn {{if this.paint_mode 'md-board-detail-edit-toolbar__btn--active'}}"
              title={{if this.paint_mode (t "Exit paint mode" key="board_detail_exit_paint") (t "Paint mode" key="board_detail_paint_mode")}}
              {{action "clear_paint_mode"}}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
              <span class="md-board-detail-edit-toolbar__label">{{t "Paint" key="board_detail_paint"}}</span>
            </button>
            {{!-- Paint swatches (shown when paint mode is active or for quick access) --}}
            {{#each this.color_picker_swatches as |swatch|}}
              <button type="button"
                class="md-board-detail-edit-toolbar__paint-swatch"
                title={{swatch.label}}
                {{action "set_paint_mode" swatch.bg swatch.border swatch.pos_class}}>
                <span class="md-board-detail-edit-toolbar__paint-dot" style={{safe-style (concat "background-color:" swatch.bg ";border-color:" swatch.border)}}></span>
              </button>
            {{/each}}
            {{!-- Custom color picker for paint mode --}}
            <div class="md-board-detail-paint-custom-wrap">
              <button type="button"
                class="md-board-detail-edit-toolbar__paint-swatch md-board-detail-edit-toolbar__paint-custom"
                title={{t "Custom Color" key="board_detail_custom_paint_color"}}
                {{action "toggle_paint_color_picker"}}>
                <span class="md-board-detail-edit-toolbar__paint-dot md-board-detail-edit-toolbar__paint-dot--custom"></span>
              </button>
              {{#if this.show_paint_color_picker}}
                <div class="md-board-detail-paint-picker">
                  <div class="md-board-detail-paint-picker__header">
                    <span class="md-board-detail-paint-picker__title">{{t "Custom Paint Color" key="board_detail_custom_paint_color_title"}}</span>
                    <button type="button" class="md-board-detail-paint-picker__close" {{action "toggle_paint_color_picker"}}>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                  </div>
                  <div class="md-board-detail-paint-picker__row">
                    <input type="color" value={{this.custom_paint_color}} class="md-board-detail-paint-picker__input"
                      oninput={{action "update_custom_paint_color" value="target.value"}}
                      onchange={{action "update_custom_paint_color" value="target.value"}}>
                    <Input @value={{this.custom_paint_color}} placeholder="#hex" class="md-board-detail-paint-picker__hex" />
                    <button type="button" class="md-board-detail-paint-picker__apply" {{action "apply_custom_paint_color"}}>
                      {{t "Apply" key="board_detail_apply"}}
                    </button>
                  </div>
                </div>
              {{/if}}
            </div>
          </div>

          <div class="md-board-detail-edit-toolbar__divider"></div>

          <div class="md-board-detail-edit-toolbar__group">
            {{!-- Edit Board Details --}}
            <button type="button"
              class="md-board-detail-edit-toolbar__btn"
              title={{t "Edit Name & Details" key="board_detail_edit_details"}}
              {{action "edit_board_details"}}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              <span class="md-board-detail-edit-toolbar__label">{{t "Details" key="board_detail_details"}}</span>
            </button>
            {{!-- Button Stash --}}
            <button type="button"
              class="md-board-detail-edit-toolbar__btn"
              title={{t "Button Stash" key="board_detail_button_stash"}}
              {{action "open_button_stash"}}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <span class="md-board-detail-edit-toolbar__label">{{t "Stash" key="board_detail_stash"}}</span>
            </button>
            {{!-- Suggestions --}}
            <button type="button"
              class="md-board-detail-edit-toolbar__btn"
              title={{t "Button Suggestions" key="board_detail_suggestions"}}
              {{action "suggestions"}}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
              <span class="md-board-detail-edit-toolbar__label">{{t "Ideas" key="board_detail_ideas"}}</span>
            </button>
          </div>

          <div class="md-board-detail-edit-toolbar__divider"></div>

          {{!-- Grid Configuration --}}
          <div class="md-board-detail-edit-toolbar__group">
            <button type="button"
              class="md-board-detail-edit-toolbar__btn"
              title={{t "Add Row" key="board_detail_add_row"}}
              {{action "modify_size" "row" "add"}}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              <span class="md-board-detail-edit-toolbar__label">{{t "Row" key="board_detail_row"}}</span>
            </button>
            <button type="button"
              class="md-board-detail-edit-toolbar__btn"
              title={{t "Remove Row" key="board_detail_remove_row"}}
              {{action "modify_size" "row" "remove"}}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
              <span class="md-board-detail-edit-toolbar__label">{{t "Row" key="board_detail_row"}}</span>
            </button>
            <button type="button"
              class="md-board-detail-edit-toolbar__btn"
              title={{t "Add Column" key="board_detail_add_col"}}
              {{action "modify_size" "column" "add"}}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              <span class="md-board-detail-edit-toolbar__label">{{t "Col" key="board_detail_col"}}</span>
            </button>
            <button type="button"
              class="md-board-detail-edit-toolbar__btn"
              title={{t "Remove Column" key="board_detail_remove_col"}}
              {{action "modify_size" "column" "remove"}}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
              <span class="md-board-detail-edit-toolbar__label">{{t "Col" key="board_detail_col"}}</span>
            </button>
          </div>

          {{#if this.has_levels}}
            <div class="md-board-detail-edit-toolbar__divider"></div>

            {{!-- Level Preview --}}
            <div class="md-board-detail-edit-toolbar__group">
              <button type="button"
                class="md-board-detail-edit-toolbar__btn {{if this.preview_levels 'md-board-detail-edit-toolbar__btn--active'}}"
                title={{t "Preview Levels" key="board_detail_preview_levels"}}
                {{action "toggle_preview_levels"}}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                <span class="md-board-detail-edit-toolbar__label">{{t "Levels" key="board_detail_levels"}}</span>
              </button>
              {{#if this.preview_levels}}
                <button type="button"
                  class="md-board-detail-edit-toolbar__btn"
                  title={{t "Level Down" key="board_detail_level_down"}}
                  {{action "shift_level" "down"}}>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                </button>
                {{#if this.preview_level}}
                  <span class="md-board-detail-edit-toolbar__level-badge">{{this.preview_level}}</span>
                {{/if}}
                <button type="button"
                  class="md-board-detail-edit-toolbar__btn"
                  title={{t "Level Up" key="board_detail_level_up"}}
                  {{action "shift_level" "up"}}>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
                </button>
                <button type="button"
                  class="md-board-detail-edit-toolbar__btn"
                  title={{t "Exit Level Preview" key="board_detail_exit_level"}}
                  {{action "shift_level" "done"}}>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </button>
              {{/if}}
            </div>
          {{/if}}

          <div class="md-board-detail-edit-toolbar__spacer"></div>

          <div class="md-board-detail-edit-toolbar__group">
            {{!-- Save --}}
            <button type="button"
              class="md-board-detail-edit-toolbar__btn md-board-detail-edit-toolbar__btn--save"
              title={{t "Save Board" key="board_detail_save_board"}}
              {{action "save_board"}}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
              <span class="md-board-detail-edit-toolbar__label">{{t "Save" key="board_detail_save"}}</span>
            </button>
            {{!-- Cancel --}}
            <button type="button"
              class="md-board-detail-edit-toolbar__btn md-board-detail-edit-toolbar__btn--cancel"
              title={{t "Cancel Changes" key="board_detail_cancel_changes"}}
              {{action "cancel_edit"}}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              <span class="md-board-detail-edit-toolbar__label">{{t "Cancel" key="board_detail_cancel"}}</span>
            </button>
          </div>
        </div>
      {{/if}}

      {{!-- Toolbar row: Quick Phrases + Category Filter --}}
      <div class="md-board-detail-toolbar">
        {{#unless this.edit_mode}}
        <div class="md-board-detail-quick-wrap">
          <button type="button"
            class="md-board-detail-quick-toggle {{if this.show_quick_phrases 'md-board-detail-quick-toggle--active'}}"
            {{action "toggle_quick_phrases"}}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
            <span>{{t "Quick Phrases" key="board_detail_quick_phrases_label"}}</span>
            <svg class="md-board-detail-quick-toggle__chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </button>

          {{#if this.show_quick_phrases}}
            <div class="md-board-detail-quick-reveal" role="toolbar" aria-label={{t "Quick phrases" key="board_detail_quick_phrases"}}>
              {{#each this.quick_buttons as |qb|}}
                <button type="button" class="md-board-detail-quick-reveal__btn" {{action "select_quick" qb}}>
                  <span class="md-board-detail-quick-reveal__btn-icon" aria-hidden="true">{{qb.icon}}</span>
                  <span class="md-board-detail-quick-reveal__btn-label">{{qb.label}}</span>
                </button>
              {{/each}}
            </div>
          {{/if}}
        </div>
        {{/unless}}

        <div class="md-board-detail-quick-wrap">
          <button type="button"
            class="md-board-detail-quick-toggle {{if this.show_categories 'md-board-detail-quick-toggle--active'}}"
            {{action "toggle_categories"}}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
            </svg>
            <span>{{t "Categories" key="board_detail_categories_label"}}</span>
            <svg class="md-board-detail-quick-toggle__chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </button>

          {{#if this.active_filter_label}}
            <span class="md-board-detail-filter-chip">
              {{#if this.active_filter_css}}
                <span class="md-board-detail-filter-chip__swatch md-board-detail-symbol-card--{{this.active_filter_css}}"></span>
              {{/if}}
              <span class="md-board-detail-filter-chip__label">{{this.active_filter_label}}</span>
              <button type="button" class="md-board-detail-filter-chip__clear" {{action "set_category" "all"}} title={{t "Clear filter" key="board_detail_clear_filter"}}>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </button>
            </span>
          {{/if}}

          {{#if this.show_categories}}
            <div class="md-board-detail-cat-panel" role="toolbar" aria-label={{t "Symbol categories" key="board_detail_symbol_categories"}}>
              <div class="md-board-detail-cat-panel__left">
                <button type="button"
                  class="md-board-detail-quick-reveal__btn {{if (is-equal 'all' this.active_category) 'md-board-detail-quick-reveal__btn--active'}}"
                  {{action "set_category" "all"}}>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                  <span class="md-board-detail-quick-reveal__btn-label">{{t "All" key="category_all"}}</span>
                </button>
                <button type="button"
                  class="md-board-detail-quick-reveal__btn {{if (is-equal 'folder' this.active_category) 'md-board-detail-quick-reveal__btn--active'}}"
                  {{action "set_category" "folder"}}>
                  <span class="md-board-detail-quick-reveal__swatch md-board-detail-symbol-card--folder"></span>
                  <span class="md-board-detail-quick-reveal__btn-label">{{t "Folders" key="category_folders"}}</span>
                </button>
              </div>
              <div class="md-board-detail-cat-panel__divider"></div>
              <div class="md-board-detail-cat-panel__right">
                {{#each this.pos_type_categories as |cat|}}
                  <button type="button"
                    class="md-board-detail-quick-reveal__btn {{if (is-equal cat.id this.active_category) 'md-board-detail-quick-reveal__btn--active'}}"
                    {{action "set_category" cat.id}}>
                    <span class="md-board-detail-quick-reveal__swatch md-board-detail-symbol-card--{{cat.css_class}}"></span>
                    <span class="md-board-detail-quick-reveal__btn-label">{{cat.label}}</span>
                  </button>
                {{/each}}
              </div>
            </div>
          {{/if}}
        </div>
      </div>

      <div class="md-board-detail-divider">
        {{#unless this.edit_mode}}
          <button type="button"
            class="md-board-detail-collapse-btn"
            title={{if this.board_collapsed (t "Show header" key="board_detail_show_header") (t "Hide header" key="board_detail_hide_header")}}
            {{action "toggle_board_collapsed"}}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              {{#if this.board_collapsed}}
                <polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/>
              {{else}}
                <polyline points="4 14 4 20 10 20"/><polyline points="20 10 20 4 14 4"/><line x1="14" y1="10" x2="21" y2="3"/><line x1="3" y1="21" x2="10" y2="14"/>
              {{/if}}
            </svg>
          </button>
        {{/unless}}
      </div>

      {{!-- Loading indicator --}}
      {{#if this.board_saving}}
        <div class="md-board-detail-loading">
          <div class="md-board-detail-loading__spinner"></div>
          <span class="md-board-detail-loading__text">{{t "Saving..." key="board_detail_saving"}}</span>
        </div>
      {{/if}}

      {{!-- Symbol Grid (wrapped in button-listener for scanning/gaze/dwell support) --}}
      {{#button-listener buttonEvent=(action "button_event")}}
      <div class="md-board-detail-grid {{if this.board_saving 'md-board-detail-grid--hidden'}}" role="grid" aria-label={{t "Symbol board" key="board_detail_symbol_board"}}
        style={{safe-style this.grid_style}}>
        {{#each this.ordered_buttons as |row|}}
          {{#each row as |btn|}}
          <div class="md-board-detail-grid__cell {{if btn.load_board 'md-board-detail-grid__cell--folder'}}"
            data-id={{btn.id}}
            draggable={{if this.edit_mode "true" "false"}}>
            {{#if btn.load_board}}
              <div class="md-folder-back" aria-hidden="true">
                <div class="md-folder-tab"></div>
              </div>
            {{/if}}
            <div
              class="md-board-detail-symbol-card md-board-detail-symbol-card--{{or btn.part_of_speech btn.painted_part_of_speech btn.suggested_part_of_speech 'default'}} {{if btn.empty 'md-board-detail-symbol-card--empty'}} {{if btn.hidden 'md-board-detail-symbol-card--hidden'}} {{if btn.for_swap 'md-board-detail-symbol-card--swapping'}} {{if btn.load_board 'md-board-detail-symbol-card--folder'}}"
              role="gridcell"
              data-id={{btn.id}}
              style={{if btn.background_color (safe-style (concat "background-color:" btn.background_color ";border-color:" btn.border_color))}}
              {{action "select_button" btn}}>
              {{#if this.edit_mode}}
                <div class="md-board-detail-symbol-card__edit-actions">
                  <button type="button"
                    class="md-board-detail-symbol-card__edit-btn"
                    title={{t "Change button color" key="board_detail_change_color"}}
                    {{action "open_color_picker" btn bubbles=false}}>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
                  </button>
                  <button type="button"
                    class="md-board-detail-symbol-card__edit-btn"
                    title={{t "Copy to Button Stash" key="copy_to_button_stash"}}
                    {{action "stash_button" btn bubbles=false}}>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                  </button>
                  <button type="button"
                    class="md-board-detail-symbol-card__edit-btn"
                    title={{t "Word Data" key="view_word_data"}}
                    {{action "word_data" btn bubbles=false}}>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                  </button>
                  <button type="button"
                    class="md-board-detail-symbol-card__edit-btn md-board-detail-symbol-card__edit-btn--danger"
                    title={{t "Clear button" key="board_detail_clear_button"}}
                    {{action "clear_button" btn bubbles=false}}>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                  </button>
                </div>
              {{/if}}
              {{#if btn.image_url}}
                <div class="md-board-detail-symbol-card__image">
                  <img src={{btn.image_url}} alt={{btn.label}} loading="lazy" onerror="this.style.display='none';this.nextElementSibling&&(this.nextElementSibling.style.display='flex');">
                  <span class="md-board-detail-symbol-card__alt-text" style="display:none;">{{btn.label}}</span>
                </div>
              {{else}}
                <div class="md-board-detail-symbol-card__image md-board-detail-symbol-card__image--placeholder">
                  {{#if btn.load_board}}
                    <span class="md-board-detail-symbol-card__placeholder-icon" aria-hidden="true">&#x1F4C1;</span>
                  {{else if btn.label}}
                    <span class="md-board-detail-symbol-card__alt-text">{{btn.label}}</span>
                  {{else}}
                    <span class="md-board-detail-symbol-card__placeholder-icon" aria-hidden="true">&#x1F4AC;</span>
                  {{/if}}
                </div>
              {{/if}}
              {{#if this.edit_mode}}
                {{label-field value=btn.label class="md-board-detail-symbol-card__label-input" placeholder="enter label"}}
              {{else}}
                <span class="md-board-detail-symbol-card__label">{{btn.label}}</span>
              {{/if}}
              {{#if btn.load_board}}
                <span class="md-board-detail-symbol-card__folder-badge" aria-label={{t "Folder" key="folder"}}>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                    <path d="M10 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-8l-2-2z"/>
                  </svg>
                </span>
              {{/if}}
            </div>

            {{#if this.edit_mode}}
              {{!-- Color Picker Popover --}}
              {{#if (is-equal this.color_picker_button btn)}}
                <div class="md-board-detail-color-picker">
                  <div class="md-board-detail-color-picker__header">
                    <span class="md-board-detail-color-picker__title">{{t "Choose Color" key="board_detail_choose_color"}}</span>
                    <button type="button" class="md-board-detail-color-picker__close" {{action "close_color_picker"}}>&times;</button>
                  </div>

                  <div class="md-board-detail-color-picker__swatches">
                    {{#each this.color_picker_swatches as |swatch|}}
                      <button type="button"
                        class="md-board-detail-color-picker__swatch"
                        {{action "apply_swatch_color" swatch}}>
                        <span class="md-board-detail-color-picker__swatch-color" style={{safe-style (concat "background-color:" swatch.bg ";border-color:" swatch.border)}}></span>
                        <span class="md-board-detail-color-picker__swatch-label">{{swatch.label}}</span>
                      </button>
                    {{/each}}
                  </div>

                  <div class="md-board-detail-color-picker__custom">
                    <div class="md-board-detail-color-picker__custom-header">
                      <label class="md-board-detail-color-picker__custom-label">{{t "Custom Color" key="board_detail_custom_color"}}</label>
                    </div>
                    <div class="md-board-detail-color-picker__custom-row">
                      <span class="md-board-detail-color-picker__preview"
                        {{action "toggle_minicolors"}}
                        style={{if this.custom_color_value (safe-style (concat "background-color:" this.custom_color_value))}}></span>
                      <input type="text" id="board-detail-custom-color" class="md-board-detail-color-picker__input" placeholder="#hex" />
                      <button type="button" class="md-board-detail-color-picker__apply" {{action "apply_custom_color"}}>{{t "Apply" key="board_detail_apply"}}</button>
                    </div>
                  </div>
                </div>
              {{/if}}
            {{/if}}
          </div>
          {{/each}}
        {{/each}}
        {{#unless this.ordered_buttons.length}}
          <div class="md-board-detail-grid__empty">
            <p>{{t "No symbols found for this category" key="board_detail_no_symbols"}}</p>
          </div>
        {{/unless}}
      </div>
      {{/button-listener}}
    </main>

    {{!-- Right Sidebar --}}
    <aside class="md-board-detail-right-panel {{if this.panels_collapsed 'md-board-detail-right-panel--collapsed'}}" aria-label={{t "Activity panel" key="board_detail_activity_panel"}}>
      {{!-- Recent Phrases --}}
      <section class="md-board-detail-right-panel__section">
        <h3 class="md-board-detail-right-panel__heading">{{t "Recent Phrases" key="board_detail_recent_phrases"}}</h3>
        {{#if this.recent_phrases.length}}
          <ul class="md-board-detail-phrase-list">
            {{#each this.recent_phrases as |phrase|}}
              <li class="md-board-detail-phrase-list__item" {{action "speak_phrase" phrase}}>
                <span class="md-board-detail-phrase-list__dot" aria-hidden="true"></span>
                {{phrase.text}}
              </li>
            {{/each}}
          </ul>
        {{else}}
          <p class="md-board-detail-right-panel__empty">{{t "Phrases appear here" key="board_detail_phrases_empty"}}</p>
        {{/if}}
      </section>

      {{!-- Weekly Goals --}}
      <section class="md-board-detail-right-panel__section">
        <h3 class="md-board-detail-right-panel__heading">{{t "Weekly Goals" key="board_detail_weekly_goals"}}</h3>
        {{#if this.weekly_goals.length}}
          <ul class="md-board-detail-goals-list">
            {{#each this.weekly_goals as |goal|}}
              <li class="md-board-detail-goals-list__item">
                <div class="md-board-detail-goals-list__header">
                  <span class="md-board-detail-goals-list__label">{{goal.label}}</span>
                  <span class="md-board-detail-goals-list__count">{{goal.current}} / {{goal.target}}</span>
                </div>
                <div class="md-board-detail-goals-list__bar">
                  <div class="md-board-detail-goals-list__fill md-board-detail-goals-list__fill--{{goal.color}}" style={{safe-style (concat "width:" goal.percent "%")}}></div>
                </div>
              </li>
            {{/each}}
          </ul>
        {{else}}
          <p class="md-board-detail-right-panel__empty">{{t "No goals set yet" key="board_detail_no_goals"}}</p>
        {{/if}}
      </section>

      {{!-- Today's Schedule --}}
      <section class="md-board-detail-right-panel__section">
        <h3 class="md-board-detail-right-panel__heading">{{t "Today's Schedule" key="board_detail_todays_schedule"}}</h3>
        {{#if this.todays_schedule.length}}
          <ul class="md-board-detail-schedule-list">
            {{#each this.todays_schedule as |event|}}
              <li class="md-board-detail-schedule-list__item">
                <span class="md-board-detail-schedule-list__time">{{event.time}}</span>
                <div class="md-board-detail-schedule-list__info">
                  <span class="md-board-detail-schedule-list__name">{{event.name}}</span>
                  <span class="md-board-detail-schedule-list__type md-board-detail-schedule-list__type--{{event.type_class}}">{{event.type}}</span>
                </div>
              </li>
            {{/each}}
          </ul>
        {{else}}
          <p class="md-board-detail-right-panel__empty">{{t "No events scheduled" key="board_detail_no_events"}}</p>
        {{/if}}
      </section>
    </aside>
  </div>
</div>
