                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1" stroke="#2A9D8F"/><rect x="14" y="3" width="7" height="7" rx="1" stroke="#46505F"/><rect x="3" y="14" width="7" height="7" rx="1" stroke="#46505F"/><rect x="14" y="14" width="7" height="7" rx="1" stroke="#2A9D8F"/></svg>
              </button>
            </div>
          </div>

          <div class="md-board-detail-edit-toolbar__divider"></div>

          {{!-- ── Layout ── --}}
