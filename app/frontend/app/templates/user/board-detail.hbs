              <div class="md-board-detail-edit-toolbar__dropdown-wrap" style="position: relative;">
                <button type="button"
                  class="md-board-detail-edit-toolbar__btn {{unless (is-equal this.folder_display_style 'default') 'md-board-detail-edit-toolbar__btn--active'}}"
                  data-tooltip={{t "Folder display style" key="board_detail_folder_style"}}
                  {{action "toggle_folder_dropdown"}}>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-8l-2-2z" stroke="#46505F"/><line x1="9" y1="14" x2="15" y2="14" stroke="#2A9D8F"/></svg>
                </button>
                {{#if this.folder_dropdown_open}}
                  <div class="md-board-detail-folder-dropdown">
                    <button type="button"
                      class="md-board-detail-folder-dropdown__item {{if (is-equal this.folder_display_style 'default') 'md-board-detail-folder-dropdown__item--active'}}"
                      {{action "set_folder_style" "default"}}>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-8l-2-2z"/></svg>
                      <span>{{t "Default" key="board_detail_folder_default"}}</span>
                    </button>
                    <button type="button"
                      class="md-board-detail-folder-dropdown__item {{if (is-equal this.folder_display_style 'tab_labels') 'md-board-detail-folder-dropdown__item--active'}}"
                      {{action "set_folder_style" "tab_labels"}}>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-8l-2-2z"/><line x1="9" y1="14" x2="15" y2="14"/></svg>
                      <span>{{t "Show Labels on Tab" key="board_detail_folder_tab_labels"}}</span>
                    </button>
                    <button type="button"
                      class="md-board-detail-folder-dropdown__item {{if (is-equal this.folder_display_style 'colored_corner') 'md-board-detail-folder-dropdown__item--active'}}"
                      {{action "set_folder_style" "colored_corner"}}>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M21 3l-6 6" stroke-width="3"/></svg>
                      <span>{{t "Colored Corner Tab" key="board_detail_folder_colored_corner"}}</span>
                    </button>
                  </div>
                {{/if}}
              </div>
              {{!-- Board Layout --}}
              <button type="button"
                class="md-board-detail-edit-toolbar__btn"
                data-tooltip={{t "Change button appearance, symbols, skin tones, and display preferences" key="board_layout_explainer"}}
