                  <button type="button" class="md-board-detail-header__expand-link" {{action "toggle_description"}}>
                    {{#if this.description_expanded}}
                      {{t "Show less" key="show_less"}}
                    {{else}}
                      {{t "Show more" key="show_more"}}
                    {{/if}}
                  </button>
                {{/if}}
              {{/if}}
            </div>
          </div>
          {{#if this.edit_mode}}
            <div class="md-board-detail-board-actions-wrap">
            <span class="md-board-detail-edit-pill md-board-detail-edit-pill--mobile" role="status">{{t "Edit Mode" key="board_detail_edit_mode"}}</span>
            <div class="md-board-detail-board-actions">
              <div class="md-board-detail-details-dropdown-wrap" style="position: relative;">
                <button type="button" class="md-board-detail-board-actions__btn {{if this.details_dropdown_open 'md-board-detail-board-actions__btn--active'}}" title={{t "Details & Actions" key="details_and_actions"}} {{action "toggle_details_dropdown"}}>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
                  </svg>
                  <span>{{t "Details & Actions" key="details_and_actions"}}</span>
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin-left: 2px;"><polyline points="6 9 12 15 18 9"/></svg>
                </button>
                {{#if this.details_dropdown_open}}
                  <div class="md-board-detail-share-dropdown">
                    <button type="button" class="md-board-detail-share-dropdown__item" {{action "board_details"}}>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
                      </svg>
                      <span>{{t "Details" key="board_details"}}</span>
                    </button>
                    <button type="button" class="md-board-detail-share-dropdown__item" {{action "set_as_home"}}>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                        <path d="M12 3L2 12h3v8h6v-6h2v6h6v-8h3L12 3z"/>
                      </svg>
                      <span>{{t "Home" key="set_as_home_board"}}</span>
                    </button>
                    <button type="button" class="md-board-detail-share-dropdown__item" {{action "add_to_sidebar"}}>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="3" x2="9" y2="21"/>
                      </svg>
                      <span>{{t "Sidebar" key="add_to_sidebar"}}</span>
                    </button>
                    <button type="button" class="md-board-detail-share-dropdown__item" {{action "toggle_favorite"}}>
                      {{#if this.model.starred}}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                        </svg>
                      {{else}}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                        </svg>
                      {{/if}}
                      <span>{{t "Favorite" key="star"}}</span>
                    </button>
                    <button type="button" class="md-board-detail-share-dropdown__item" {{action "other_board_actions"}}>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="1"/><circle cx="12" cy="5" r="1"/><circle cx="12" cy="19" r="1"/>
                      </svg>
                      <span>{{t "Other Actions" key="other_actions"}}</span>
                    </button>
                    <div class="md-board-detail-share-dropdown__divider"></div>
                    <button type="button" class="md-board-detail-share-dropdown__item" {{action "share_board"}}>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
                      </svg>
                      <span>{{t "Share" key="share"}}</span>
                    </button>
                    <button type="button" class="md-board-detail-share-dropdown__item" {{action "make_a_copy"}}>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                      </svg>
                      <span>{{t "Copy" key="make_copy"}}</span>
                    </button>
                    <button type="button" class="md-board-detail-share-dropdown__item" {{action "print_board"}}>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/>
                      </svg>
                      <span>{{t "Print" key="print_board"}}</span>
                    </button>
                    <button type="button" class="md-board-detail-share-dropdown__item" {{action "download_board"}}>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
                      </svg>
                      <span>{{t "Download" key="download_board"}}</span>
                    </button>
                  </div>
                {{/if}}
              </div>
            </div>
            </div>
          {{/if}}
          <div class="md-board-detail-header__actions">
            {{#unless this.edit_mode}}
              <button type="button"
                class="md-board-detail-color-legend-toggle {{if this.show_color_legend 'md-board-detail-color-legend-toggle--active'}}"
                {{action "toggle_color_legend"}}
                title={{t "Color key — see what each button color means" key="board_detail_color_key_tooltip"}}>
                <span class="md-board-detail-color-legend-toggle__icon" aria-hidden="true">&#x1F3A8;</span>
                <span class="md-board-detail-color-legend-toggle__label">{{t "Color Key" key="board_detail_color_key"}}</span>
              </button>
            {{/unless}}
            {{#if this.edit_mode}}
              <LinkTo @route="user.board-detail.index" class="md-board-detail-edit-btn md-board-detail-edit-btn--active">
                <svg class="md-board-detail-edit-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                <span class="md-board-detail-edit-btn__label">{{t "Done Editing" key="board_detail_done_editing"}}</span>
              </LinkTo>
            {{else}}
              <LinkTo @route="user.board-detail.edit" class="md-board-detail-edit-btn">
                <svg class="md-board-detail-edit-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
                <span class="md-board-detail-edit-btn__label">{{t "Edit Board" key="board_detail_edit_board"}}</span>
              </LinkTo>
            {{/if}}
          </div>
        </div>

        {{#if this.show_color_legend}}
          <div class="md-board-detail-color-legend" role="region" aria-label={{t "Button color legend" key="board_detail_color_legend"}}>
            <div class="md-board-detail-color-legend__grid">
              {{#each this.color_legend_items as |item|}}
                <div class="md-board-detail-color-legend__item">
                  {{#if (is-equal item.css_class "folder")}}
                    <span class="md-board-detail-color-legend__folder-wrap">
                      <span class="md-folder-back"><span class="md-folder-tab"></span></span>
                      <span class="md-board-detail-color-legend__swatch md-board-detail-symbol-card--folder"></span>
                    </span>
                  {{else}}
                    <span class="md-board-detail-color-legend__swatch md-board-detail-symbol-card--{{item.css_class}}"></span>
                  {{/if}}
                  <div class="md-board-detail-color-legend__info">
                    <span class="md-board-detail-color-legend__type">{{item.type}}</span>
                    <span class="md-board-detail-color-legend__parts">{{item.parts}}</span>
                  </div>
                </div>
              {{/each}}
            </div>
          </div>
        {{/if}}
      </header>

      {{!-- Edit Mode Toolbar --}}
      {{#if this.edit_mode}}
        <div class="md-board-detail-edit-toolbar" role="toolbar" aria-label={{t "Edit tools" key="board_detail_edit_tools"}}>
          {{!-- ── History ── --}}
          <div class="md-board-detail-edit-toolbar__section">
            <span class="md-board-detail-edit-toolbar__section-label">{{t "History" key="board_detail_history_label"}}</span>
            <div class="md-board-detail-edit-toolbar__section-buttons">
              <button type="button"
                class="md-board-detail-edit-toolbar__btn"
                disabled={{this.undo_redo_disabled}}
                data-tooltip={{t "Undo" key="board_detail_undo"}}
                {{action "undo_edit"}}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10" stroke="#2A9D8F"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10" stroke="#46505F"/></svg>
              </button>
              <button type="button"
                class="md-board-detail-edit-toolbar__btn"
                disabled={{this.undo_redo_disabled}}
                data-tooltip={{t "Redo" key="board_detail_redo"}}
                {{action "redo_edit"}}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10" stroke="#2A9D8F"/><path d="M20.49 15a9 9 0 1 1-2.13-9.36L23 10" stroke="#46505F"/></svg>
              </button>
            </div>
          </div>

          <div class="md-board-detail-edit-toolbar__divider"></div>

          {{!-- ── Paint ── --}}
          <div class="md-board-detail-edit-toolbar__section">
            <span class="md-board-detail-edit-toolbar__section-label">{{t "Paint" key="board_detail_paint_label"}}</span>
            <div class="md-board-detail-edit-toolbar__section-buttons">
              {{!-- Paint mode toggle --}}
              <button type="button"
                class="md-board-detail-edit-toolbar__btn {{if this.paint_mode 'md-board-detail-edit-toolbar__btn--active'}}"
                data-tooltip={{if this.paint_mode (t "Exit paint mode" key="board_detail_exit_paint") (t "Paint mode" key="board_detail_paint_mode")}}
                {{action "clear_paint_mode"}}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z" stroke="#2A9D8F"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z" stroke="#46505F"/><path d="M2 2l7.586 7.586" stroke="#46505F"/><circle cx="11" cy="11" r="2" stroke="#2A9D8F"/></svg>
              </button>
              {{!-- Color palette dropdown --}}
              <div class="md-board-detail-edit-toolbar__dropdown-wrap" style="position: relative;">
                <button type="button"
                  class="md-board-detail-edit-toolbar__btn md-board-detail-edit-toolbar__btn--palette"
                  data-tooltip={{t "Choose paint color" key="board_detail_choose_paint"}}
                  {{action "toggle_paint_dropdown"}}>
                  <span class="md-board-detail-edit-toolbar__palette-preview" style={{safe-style (concat "background-color:" (if this.paint_mode.fill this.paint_mode.fill "#fff"))}}></span>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" stroke="#46505F"/></svg>
                </button>
                {{#if this.show_paint_dropdown}}
                  <div class="md-board-detail-edit-toolbar__paint-dropdown">
                    <div class="md-board-detail-edit-toolbar__paint-dropdown-grid">
                      {{#each this.color_picker_swatches as |swatch|}}
                        <button type="button"
                          class="md-board-detail-edit-toolbar__paint-dropdown-item"
                          {{action "set_paint_mode" swatch.bg swatch.border swatch.pos_class}}>
                          <span class="md-board-detail-edit-toolbar__paint-dot" style={{safe-style (concat "background-color:" swatch.bg ";border-color:" swatch.border)}}></span>
                          <span>{{swatch.label}}</span>
                        </button>
                      {{/each}}
                    </div>
                    <div class="md-board-detail-edit-toolbar__paint-dropdown-footer">
                      <div class="md-board-detail-paint-custom-wrap">
                        <button type="button"
                          class="md-board-detail-edit-toolbar__paint-dropdown-item md-board-detail-edit-toolbar__paint-dropdown-item--custom"
                          {{action "toggle_paint_color_picker"}}>
                          <span class="md-board-detail-edit-toolbar__paint-dot md-board-detail-edit-toolbar__paint-dot--custom"></span>
                          <span>{{t "Custom Color" key="board_detail_custom_paint_color"}}</span>
                        </button>
                        {{#if this.show_paint_color_picker}}
                          <div class="md-board-detail-paint-picker md-board-detail-paint-picker--in-dropdown">
                            <div class="md-board-detail-paint-picker__row">
                              <input type="color" id="bd-paint-color-picker" value={{this.custom_paint_color}} class="md-board-detail-paint-picker__input"
                                aria-label={{t "Pick paint color" key="board_detail_pick_paint_color"}}
                                autocomplete="off"
                                oninput={{action "update_custom_paint_color" value="target.value"}}
                                onchange={{action "update_custom_paint_color" value="target.value"}}>
                              <label for="bd-paint-hex-input" class="sr-only">{{t "Paint color hex value" key="board_detail_paint_hex"}}</label>
                              <Input @id="bd-paint-hex-input" @value={{this.custom_paint_color}} placeholder="#hex" class="md-board-detail-paint-picker__hex" autocomplete="off" />
                              <button type="button" class="md-board-detail-paint-picker__apply" {{action "apply_custom_paint_color"}}>
                                {{t "Apply" key="board_detail_apply"}}
                              </button>
                            </div>
                          </div>
                        {{/if}}
                      </div>
                    </div>
                  </div>
                {{/if}}
              </div>
            </div>
          </div>

          <div class="md-board-detail-edit-toolbar__divider"></div>

          {{!-- ── Styling ── --}}
          <div class="md-board-detail-edit-toolbar__section">
            <span class="md-board-detail-edit-toolbar__section-label">{{t "Styling" key="board_detail_styling_label"}}</span>
            <div class="md-board-detail-edit-toolbar__section-buttons">
              {{!-- Recolor Board --}}
              <button type="button"
                class="md-board-detail-edit-toolbar__btn {{if this.board_recolored 'md-board-detail-edit-toolbar__btn--active'}}"
                data-tooltip={{if this.board_recolored (t "Revert to previous colors" key="board_detail_revert_recolor") (t "Reassign all button colors by word type" key="board_detail_recolor_board")}}
                {{action "recolor_board"}}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="14" width="7" height="7" rx="1.5" stroke="#2A9D8F"/><rect x="15" y="3" width="7" height="7" rx="1.5" stroke="#2A9D8F"/><path d="M13 6.5H9.5a2 2 0 0 0-2 2V13" stroke="#46505F"/><polyline points="10 11 7.5 13.5 5 11" stroke="#46505F"/><path d="M11 17.5h3.5a2 2 0 0 0 2-2V11" stroke="#46505F"/><polyline points="14 13 16.5 10.5 19 13" stroke="#46505F"/></svg>
              </button>
