<div class="md-shell md-shell--board-detail {{if this.edit_mode 'md-shell--board-detail-edit'}} {{if this.board_collapsed 'md-shell--board-collapsed'}} {{if this.paint_mode 'md-shell--board-paint'}} {{if this.dark_mode 'md-board-detail--dark'}}">
  {{outlet}}
  <div class="md-board-detail-layout {{if this.panels_collapsed 'md-board-detail-layout--collapsed'}}">
    {{!-- Overlay backdrop for mobile panels --}}
    {{#unless this.panels_collapsed}}
      <div class="md-board-detail-overlay-backdrop" {{action "toggle_panels"}}></div>
      <button type="button" class="md-board-detail-panels-close-btn" {{action "toggle_panels"}} aria-label={{t "Collapse panels" key="board_detail_collapse_panels"}}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    {{/unless}}
    {{!-- Left Sidebar Navigation --}}
    <aside class="md-board-detail-sidebar {{if this.panels_collapsed 'md-board-detail-sidebar--collapsed'}}" aria-label={{t "Board navigation" key="board_navigation"}}>
      <section class="md-board-detail-sidebar__section">
        <h3 class="md-board-detail-sidebar__heading">{{t "Communicate" key="board_detail_communicate"}}</h3>
        {{#each this.sidebar_nav.communicate as |item|}}
          <button type="button"
            class="md-board-detail-sidebar__item {{if item.active 'md-board-detail-sidebar__item--active'}}"
            {{action "nav_select" item.id}}>
            <span class="md-board-detail-sidebar__icon md-board-detail-sidebar__icon--{{item.icon}}" aria-hidden="true"></span>
            <span class="md-board-detail-sidebar__label">{{item.label}}</span>
          </button>
        {{/each}}
      </section>

      <section class="md-board-detail-sidebar__section">
        <h3 class="md-board-detail-sidebar__heading">{{t "Clinical" key="board_detail_clinical"}}</h3>
        {{#each this.sidebar_nav.clinical as |item|}}
          <button type="button"
            class="md-board-detail-sidebar__item {{if item.active 'md-board-detail-sidebar__item--active'}}"
            {{action "nav_select" item.id}}>
            <span class="md-board-detail-sidebar__icon md-board-detail-sidebar__icon--{{item.icon}}" aria-hidden="true"></span>
            <span class="md-board-detail-sidebar__label">{{item.label}}</span>
          </button>
        {{/each}}
      </section>

      <section class="md-board-detail-sidebar__section">
        <h3 class="md-board-detail-sidebar__heading">{{t "Settings" key="board_detail_settings"}}</h3>
        {{#each this.sidebar_nav.settings as |item|}}
          <button type="button"
            class="md-board-detail-sidebar__item {{if item.active 'md-board-detail-sidebar__item--active'}}"
            {{action "nav_select" item.id}}>
            <span class="md-board-detail-sidebar__icon md-board-detail-sidebar__icon--{{item.icon}}" aria-hidden="true"></span>
            <span class="md-board-detail-sidebar__label">{{item.label}}</span>
          </button>
        {{/each}}
      </section>
    </aside>

    {{!-- Main Content Area --}}
    <main class="md-board-detail-main">
      {{!-- Sentence Bar --}}
      <div class="md-board-detail-sentence-row">
      {{#unless this.edit_mode}}
      <button type="button"
        class="md-board-detail-collapse-btn md-board-detail-collapse-btn--sentence-row"
        title={{if this.board_collapsed (t "Show header" key="board_detail_show_header") (t "Hide header" key="board_detail_hide_header")}}
        {{action "toggle_board_collapsed"}}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          {{#if this.board_collapsed}}
            <polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/>
          {{else}}
            <polyline points="4 14 4 20 10 20"/><polyline points="20 10 20 4 14 4"/><line x1="14" y1="10" x2="21" y2="3"/><line x1="3" y1="21" x2="10" y2="14"/>
          {{/if}}
        </svg>
      </button>
      <div class="md-board-detail-sentence-nav">
        <button type="button"
          class="md-board-detail-sentence-nav__btn"
          title={{t "Home Board" key="board_detail_home_board"}}
          {{action "go_home"}}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true">
            <path d="M12 3L2 12h3v8h6v-6h2v6h6v-8h3L12 3z"/>
          </svg>
        </button>
        <div class="md-board-detail-sentence-nav__divider"></div>
        <button type="button"
          class="md-board-detail-sentence-nav__btn"
          title={{t "My Boards" key="my_boards"}}
          {{action "open_board_picker"}}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 3h8v8H3V3zm10 0h8v8h-8V3zM3 13h8v8H3v-8zm10 0h8v8h-8v-8z" clip-rule="evenodd"/>
          </svg>
        </button>
      </div>
      {{/unless}}
      <div class="md-board-detail-sentence-bar" role="region" aria-label={{t "Message composition" key="board_detail_message_composition"}}>
        <div class="md-board-detail-sentence-bar__text {{if this.utterance_show_symbols "md-board-detail-sentence-bar__text--with-symbols"}}" aria-live="polite">
          {{#if this.has_sentence}}
            {{#if this.utterance_show_symbols}}
              {{#each this.sentence_parts as |part|}}
                <span class="md-board-detail-sentence-bar__chip {{if this.utterance_text_on_top "md-board-detail-sentence-bar__chip--text-top"}}">
                  {{#if this.utterance_text_on_top}}
                    <span class="md-board-detail-sentence-bar__chip-label">{{part.label}}</span>
                  {{/if}}
                  {{#if part.image_url}}
                    <img src={{part.image_url}} alt="" class="md-board-detail-sentence-bar__chip-img">
                  {{/if}}
                  {{#unless this.utterance_text_on_top}}
                    <span class="md-board-detail-sentence-bar__chip-label">{{part.label}}</span>
                  {{/unless}}
                </span>
              {{/each}}
            {{else}}
              {{this.sentence_text}}
            {{/if}}
          {{else}}
            <span class="md-board-detail-sentence-bar__placeholder">{{t "Tap symbols to build your message" key="board_detail_tap_symbols"}}</span>
          {{/if}}
        </div>
        <div class="md-board-detail-sentence-bar__actions">
          <button type="button" class="md-board-detail-sentence-bar__btn md-board-detail-sentence-bar__btn--speak" aria-label={{t "Speak sentence" key="board_detail_speak_sentence"}} {{action "speak_sentence"}}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
              <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
              <line x1="12" y1="19" x2="12" y2="23"/>
              <line x1="8" y1="23" x2="16" y2="23"/>
            </svg>
          </button>
          <div class="md-board-detail-sentence-bar__tools">
            <button type="button" class="md-board-detail-sentence-bar__tool-btn" title={{t "Backspace" key="backspace_lower"}} {{action "backspace_sentence"}}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 4H8l-7 8 7 8h13a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2z"/>
                <line x1="18" y1="9" x2="12" y2="15"/>
                <line x1="12" y1="9" x2="18" y2="15"/>
              </svg>
            </button>
            <button type="button" class="md-board-detail-sentence-bar__tool-btn" title={{t "Clear" key="board_detail_clear"}} {{action "clear_sentence"}}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
              </svg>
            </button>
            <button type="button" class="md-board-detail-sentence-bar__tool-btn" title={{t "Speak options" key="speak_options"}} {{action "open_speak_menu"}}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
            </svg>
            </button>
          </div>
        </div>
      </div>
      <div class="md-board-detail-sentence-bar__divider"></div>
      <div class="md-board-detail-sentence-bar__actions-wrap md-board-detail-sentence-bar__actions-wrap--stacked">
        <button type="button"
          class="md-board-detail-actions-toggle"
          title={{t "Options" key="board_detail_options"}}
          {{action "toggle_options_menu"}}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true">
            <circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/>
          </svg>
        </button>
        {{#unless this.edit_mode}}
          <button type="button" class="md-board-detail-sidebar-toggle md-board-detail-sidebar-toggle--stacked {{if this.inlineSidebarOpen 'md-board-detail-sidebar-toggle--open'}}" title={{t "Toggle sidebar" key="toggle_sidebar"}} {{action "toggleInlineSidebar"}}>
            {{#if this.inlineSidebarOpen}}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="18 14 12 8 6 14" stroke="#46505F"/>
                <polyline points="18 22 12 16 6 22" stroke="#7693B9"/>
              </svg>
            {{else}}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 14 12 20 18 14" stroke="#46505F"/>
                <polyline points="6 6 12 12 18 6" stroke="#7693B9"/>
              </svg>
            {{/if}}
          </button>
        {{/unless}}
        {{#if this.show_options_menu}}
          <div class="md-board-detail-actions-backdrop" {{action "toggle_options_menu"}}></div>
          <div class="md-board-detail-actions-menu">
            {{#unless this.edit_mode}}
              <button type="button" class="md-board-detail-actions-menu__item" {{action "enter_edit_mode"}}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
                <span>{{t "Edit Board" key="board_detail_edit_board"}}</span>
              </button>
            {{/unless}}
            {{#unless this.edit_mode}}
              <button type="button" class="md-board-detail-actions-menu__item" {{action "toggle_panels"}}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  {{#if this.panels_collapsed}}
                    <polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/>
                  {{else}}
                    <polyline points="4 14 4 20 10 20"/><polyline points="20 10 20 4 14 4"/><line x1="14" y1="10" x2="21" y2="3"/><line x1="3" y1="21" x2="10" y2="14"/>
                  {{/if}}
                </svg>
                <span>{{if this.panels_collapsed (t "Expand Panels" key="board_detail_expand_panels") (t "Collapse Panels" key="board_detail_collapse_panels")}}</span>
              </button>
            {{/unless}}
            {{!-- Speak Mode options (board-detail browse mode is equivalent to speak mode) --}}
            {{#unless this.edit_mode}}
              <div class="md-board-detail-actions-menu__divider"></div>
              {{#if this.app_state.feature_flags.enable_all_buttons}}
                {{#unless this.app_state.currentUser.preferences.prevent_hide_buttons}}
                  {{#unless this.app_state.eval_mode}}
                    <button type="button" class="md-board-detail-actions-menu__item" {{action "toggle_all_buttons"}}>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        {{#if this.stashes.all_buttons_enabled}}
                          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                        {{else}}
                          <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>
                        {{/if}}
                      </svg>
                      <span>
                        {{#if this.stashes.all_buttons_enabled}}
                          {{t "Hide Hidden Buttons" key="hide_disabled_buttons"}}
                        {{else}}
                          {{t "Show Hidden Buttons" key="show_all_buttons"}}
                        {{/if}}
                      </span>
                    </button>
                  {{/unless}}
                {{/unless}}
              {{/if}}
              {{#if this.app_state.feature_flags.focus_word_highlighting}}
                {{#unless this.app_state.eval_mode}}
                  <button type="button" class="md-board-detail-actions-menu__item" {{action "toggle_focus"}}>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>
                    </svg>
                    <span>
                      {{#if this.app_state.focus_words}}
                        {{t "Clear Focus Words" key="clear_focus_words"}}
                      {{else}}
                        {{t "Focus Words" key="focus_words"}}
                      {{/if}}
                    </span>
                  </button>
                {{/unless}}
              {{/if}}
              {{#unless this.app_state.eval_mode}}
                {{#if this.app_state.sessionUser.supervisees}}
                  {{#if this.app_state.currentUser.permissions.delete}}
                    <button type="button" class="md-board-detail-actions-menu__item" {{action "switch_communicators"}}>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                      </svg>
                      <span>{{t "Switch Communicators" key="switch_communicators"}}</span>
                    </button>
                  {{/if}}
                {{/if}}
                {{#if this.app_state.currentBoardState}}
                  <button type="button" class="md-board-detail-actions-menu__item" {{action "find_button"}}>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                    <span>{{t "Find a Button" key="find_a_button"}}</span>
                  </button>
                {{/if}}
              {{/unless}}
              {{#unless this.app_state.superProtectedSpeakMode}}
                {{#if this.stashes.sticky_board}}
                  <button type="button" class="md-board-detail-actions-menu__item" {{action "toggle_sticky_board"}}>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    <span>{{t "Release Board Lock" key="release_board_lock"}}</span>
                  </button>
                {{else}}
                  <button type="button" class="md-board-detail-actions-menu__item" {{action "toggle_sticky_board"}}>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 5-5 5 5 0 0 1 5 5v4"/>
                    </svg>
                    <span>{{t "Stay on this Board" key="stay_on_board"}}</span>
                  </button>
                {{/if}}
                {{#if this.app_state.currentUser.preferences.logging}}
                  <button type="button" class="md-board-detail-actions-menu__item" {{action "toggle_pause_logging"}}>
                    {{#if this.app_state.logging_paused}}
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polygon points="5 3 19 12 5 21 5 3"/>
                      </svg>
                      <span>{{t "Resume Logging" key="resume_logging"}}</span>
                    {{else}}
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>
                      </svg>
                      <span>{{t "Pause Logging" key="pause_logging"}}</span>
                    {{/if}}
                  </button>
                {{/if}}
              {{/unless}}
            {{/unless}}
            <button type="button" class="md-board-detail-actions-menu__item" {{action "toggle_dark_mode"}}>
              {{#if this.dark_mode}}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true">
                  <path d="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58a.996.996 0 0 0-1.41 0 .996.996 0 0 0 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41L5.99 4.58zm12.37 12.37a.996.996 0 0 0-1.41 0 .996.996 0 0 0 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0a.996.996 0 0 0 0-1.41l-1.06-1.06zm1.06-10.96a.996.996 0 0 0 0-1.41.996.996 0 0 0-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06zM7.05 18.36a.996.996 0 0 0 0-1.41.996.996 0 0 0-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06z"/>
                </svg>
                <span>{{t "Light Mode" key="board_detail_light_mode"}}</span>
              {{else}}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true">
                  <path d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.389 5.389 0 0 1-4.4 2.26 5.403 5.403 0 0 1-3.14-9.8c-.44-.06-.9-.1-1.36-.1z"/>
                </svg>
                <span>{{t "Dark Mode" key="board_detail_dark_mode"}}</span>
              {{/if}}
            </button>
            <button type="button" class="md-board-detail-actions-menu__item" {{action "revert_to_old_style"}}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
              </svg>
              <span>{{t "Revert to Old Style" key="board_detail_revert_old_style"}}</span>
            </button>
            <div class="md-board-detail-actions-menu__divider"></div>
            <button type="button" class="md-board-detail-actions-menu__item md-board-detail-actions-menu__item--exit" {{action "exit_to_home"}}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>
              </svg>
              <div>
                <span>{{t "Exit Speak Mode" key="exit_speak_mode"}}</span>
                <span class="md-board-detail-actions-menu__hint">{{t "Settings, Menu, etc." key="settings_etc"}}</span>
              </div>
            </button>
          </div>
        {{/if}}
      </div>
      </div>
      {{!-- tease-row removed: collapse btn moved to sentence row, sidebar toggle moved to actions-wrap --}}

      {{!-- Word Suggestions --}}
      {{#if this.show_word_suggestions}}
        <div class="md-board-detail-suggestions" role="region" aria-label={{t "Word suggestions" key="board_detail_word_suggestions"}}>
          {{#if this.suggestions.ready}}
            {{#each this.suggestions.list as |suggestion|}}
              <button type="button" class="md-board-detail-suggestion" {{action "complete_word" suggestion}}>
                {{#if suggestion.image}}
                  <img src={{suggestion.image}} class="md-board-detail-suggestion__img" alt={{suggestion.word}}>
                {{/if}}
                <span class="md-board-detail-suggestion__text">{{suggestion.word}}</span>
              </button>
            {{/each}}
          {{else}}
            <span class="md-board-detail-suggestion__loading">{{t "Loading suggestions..." key="loading_word_suggestions"}}</span>
          {{/if}}
        </div>
      {{/if}}

      {{!-- Board Search Filter moved to edit toolbar Filter section --}}

      {{!-- Board Title --}}
      <header class="md-board-detail-header">
        <div class="md-board-detail-header__row">
          <div class="md-board-detail-header__title-group">
            {{#unless this.edit_mode}}
              <div class="md-board-detail-nav-btns">
                {{#if this.has_board_history}}
                  <button type="button"
                    class="md-board-detail-nav-btn"
                    title={{t "Go back" key="board_detail_go_back"}}
                    {{action "go_back"}}>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="15 18 9 12 15 6"/>
                    </svg>
                  </button>
                {{/if}}
              </div>
            {{/unless}}
