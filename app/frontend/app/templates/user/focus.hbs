<h2>
  {{#if this.focus.title}}
    {{this.focus.title}}
  {{else}}
    {{t "Focus Words" key="focus_words"}}
  {{/if}}
  {{#if this.focus.user}}
    - 
    <img src={{this.focus.user.avatar_url_with_fallback}} style='width: 50px;'>
    {{this.focus.user.user_name}}
  {{/if}}
</h2>
{{#if this.focus.words}}
  <div class='text-muted' style='white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-style: italic;'>{{this.focus.words}}</div>
{{/if}}

{{#if this.focus.analysis}}
  <div class='col-sm-12'>
    <h4>{{t "Found Words (%{cnt})" cnt=this.focus.analysis.found.length key="found_words"}}</h4>
    {{#if this.focus.analysis.found}}
      <table><tbody>
      {{#each this.analysis_subset as |btn|}}
        {{#unless btn.collapsed}}
          <tr>
            <td style='min-width: 70px;'>
              <strong style='font-size: 16px;'>{{btn.label}}:</strong><br>
              <button class='btn btn-default btn-sm hidden-print' {{action "toggle" btn}}>{{t "hide" key="hide"}}</button>
            </td>
            <td style='width: 80%;'>
              <div style='white-space: nowrap; overflow: hidden; margin-bottom: 10px;'>
                {{#if btn.sequence.buttons}}
                  {{#each btn.sequence.buttons as |sub|}}
                    <span style={{sub.big_style}}>
                      <div style={{sub.print_style}}></div>
                      <div style='position: absolute; top: 0; right: 0; left: 0; bottom: 0;'>
                        {{sub.label}}<br>
                        <img src={{sub.focus_image}} style='width: 70px; height: 70px;' class='fit_image'>
                      </div>
                    </span>
                    <span class='glyphicon glyphicon-arrow-right' style='vertical-align: middle; margin-left: 5px;'></span>
                  {{/each}}
                  <span style={{btn.big_style}}>
                    <div style={{btn.print_style}}></div>
                    <div style='position: absolute; top: 0; right: 0; left: 0; bottom: 0;'>
                      {{btn.label}}<br>
                      <img src={{btn.focus_image}} style='width: 70px; height: 70px;' class='fit_image'>
                    </div>
                  </span>
                {{else}}
                  <span style={{btn.big_style}}>
                    <div style={{btn.print_style}}></div>
                    <div style='position: absolute; top: 0; right: 0; left: 0; bottom: 0;'>
                      {{btn.label}}<br>
                      <img src={{btn.focus_image}} style='width: 70px; height: 70px;' class='fit_image'>
                    </div>
                  </span>
                {{/if}}
              </div>
            </td>
          </tr>
        {{/unless}}
      {{/each}}
      </tbody></table>
      {{#if this.analysis_extras}}
        <p>
          <em>{{t "Plus %{n} more:" n=this.analysis_extras.length key="plus_n_more"}}</em>
          {{#each this.analysis_extras as |btn|}}
            <span class='analysis_extra' style={{btn.mini_style}} {{action "toggle" btn}}>
              <div style={{btn.print_style}}></div>
              <div style='position: absolute; top: 0; right: 0; left: 0; bottom: 0;'>
                {{btn.label}}
              </div>
              <span style='visibility: hidden;'>
                {{btn.label}}
              </span>
            </span>
          {{/each}}
        </p>
      {{/if}}
    {{else}}
      <p>{{t "No words found" key="no_words_found"}}</p>
    {{/if}}
    {{#if this.focus.analysis.missing}}
      <h4 style='margin-top: 30px;'>{{t "Missing Words (%{cnt})" cnt=this.focus.analysis.missing.length key="missing_words"}}</h4>
      {{#each this.focus.analysis.missing as |word|}}
        {{word}}
      {{/each}}
    {{/if}}
    <div style='margin-top: 20px;' class='hidden-print'>
      <button class='btn btn-lg btn-default' {{action "print"}}>{{t "Print This Report" key="print_this_report"}}</button>
    </div>
  </div>
{{else}}
  <p>{{t "Analysis lost" key="analysis_lost"}}</p>
{{/if}}