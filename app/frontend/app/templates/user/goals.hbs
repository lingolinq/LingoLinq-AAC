{{#if this.app_state.currentUser.modeling_only}}
  {{modeling-only-notice}}
{{else if this.model.currently_premium}}
<div class="md-goals">
  <div class="md-goals__header">
    <svg class="md-extras-card__svg-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18" stroke="#46505F"/><path d="M18 9l-5 5-2-2-4 4" stroke="#2A9D8F"/></svg>
    <h2 class="md-goals__title">{{t "Communication Goals" key="communication_goals"}}</h2>
  </div>
  <div class="md-goals__card">
  {{#if this.goals.loading}}
    <p class="md-goals__loading">{{t "Loading goals..." key="loading_goals"}}</p>
  {{else if this.goals.error}}
    <p class="md-goals__loading">{{t "Goals failed to load" key="goals_failed_to_load"}}</p>
  {{else}}
    {{#if this.primary_goal}}
      {{#let this.primary_goal as |goal|}}
        <div class='well goal sparkle_list_item'>
          {{#if this.badges_loaded}}
            <div style='float: left; width: 50px; height: 65px; overflow: hidden; margin-right: 10px; font-size: 40px; text-align: center; line-height: 20px;'>
              {{#if goal.current_badge}}
                {{# if goal.current_badge.earned}}
                  <span style='display: inline-block; position: relative;'>
                    <img src={{goal.current_badge.image_url}} style='width: 50px; max-height: 50px;'>
                    <div class='sparkle' style='font-size: 14px;'>&#10022;</div>
                  </span>
                {{else}}
                  <img src={{goal.current_badge.image_url}} style='width: 50px; max-height: 50px;'>
                  <div class="progress" style="border: 1px solid #aaa;margin: 0 auto 5px; height: 10px;">
                    <div class="progress-bar" role="progressbar" aria-value={{goal.current_badge.progress_out_of_100}} aria-valuemin="0" aria-valuemax="100" style={{goal.current_badge.progress_style}}>
                      <span class="sr-only">
                        {{t "%{pct}% Complete" key="percent_complete" pct=goal.current_badge.progress_out_of_100}}
                      </span>
                    </div>
                  </div>
                {{/if}}
              {{else if goal.badge_image_url}}
                <img src={{goal.badge_image_url}} style='width: 50px; max-height: 50px; opacity: 0.8;' >
              {{else}}
                <span class='glyphicon glyphicon-flag' style='margin-top: 10px;'></span>
              {{/if}}
            </div>
          {{/if}}
          <LinkTo @route="user.goal" @models={{array this.model.user_name goal.id}} class="summary">
            {{goal.summary}}
          </LinkTo>
          {{#if goal.template}}
            {{t "(template)" key="template_paren"}}
          {{/if}}
          {{#if this.model.permissions.edit}}
            <div style='float: right;'>
              {{#if goal.active}}
                <span style='margin-right: 15px;'>
                  <button {{action "new_note" goal}} class='btn btn-lg btn-default' title={{t "new note" key="new_note_lower"}}><span class='glyphicon glyphicon-file'></span><span class='sr-only'>{{t "new note" key="new_note_lower"}}</span></button>
                  <button {{action "quick_assessment" goal}} class='btn btn-lg btn-default' title={{t "quick assessment" key="quick_assessment_lower"}}><span class='glyphicon glyphicon-list-alt'></span><span class='sr-only'>{{t "quick assessment" key="quick_assessment_lower"}}</span></button>
                </span>
                {{#if goal.primary}}
                  <button {{action "update" goal "primary" "off"}} class='btn btn-lg btn-default' title={{t "make secondary goal" key="make_secondary_goal"}}><span class='glyphicon glyphicon-hand-down'></span><span class='sr-only'>{{t "make secondary goal" key="make_secondary_goal"}}</span></button>
                {{else}}
                  <button {{action "update" goal "primary" "on"}} class='btn btn-lg btn-default' title={{t "make primary goal" key="make_primary_goal"}}><span class='glyphicon glyphicon-hand-up'></span><span class='sr-only'>{{t "make primary goal" key="make_primary_goal"}}</span></button>
                {{/if}}
                <button {{action "delete" goal}} class='btn btn-lg btn-default' title={{t "retire goal" key="retire_goal_lower"}}><span class='glyphicon glyphicon-ok'></span><span class='sr-only'>{{t "retire goal" key="retire_goal_lower"}}</span></button>
              {{else}}
                <button {{action "update" goal "active" "on"}} class='btn btn-lg btn-default' title={{t "restore goal" key="restore_goal"}}><span class='glyphicon glyphicon-arrow-up'></span><span class='sr-only'>{{t "restore goal" key="restore_goal"}}</span></button>
                <button {{action "delete" goal}} class='btn btn-lg btn-default' title={{t "delete goal" key="delete_goal_lower"}}><span class='glyphicon glyphicon-trash'></span><span class='sr-only'>{{t "delete goal" key="delete_goal_lower"}}</span></button>
              {{/if}}
            </div>
          {{/if}}
          <div class='details'>
            {{#if goal.active}}
              {{date_ago goal.started}}
            {{else}}
              {{date_ago goal.ended}}
            {{/if}}
            <span style='margin-left: 10px;'>
              {{#if goal.advance}}
                {{t "advances" key="advances_in"}}
                {{date_ago goal.advance "day"}}
              {{else if goal.expires}}
                {{t "concludes" key="concludes_in"}}
                {{date_ago goal.expires "day"}}
              {{/if}}
            </span>
          </div>
          <div class='description text-muted'>
            {{goal.description}}
          </div>
        </div>
      {{/let}}
    {{else if this.any_goal}}
      <p>{{t "No primary goal set" key="no_primary_goal_set"}}</p>
    {{else}}
      <div style='max-width: 600px;'>
        <p>{{t "Goals keep strategies top of mind for communicators and their support teams — whether it's a communicator goal like \"Answer questions with yes or no\" or a team goal like \"Use a prompting hierarchy.\"" key="goals_explainer1"}}</p>
        <p>{{t "Track progress through notes and assessments, and view how each goal develops over time. Users can have multiple goals, but only one primary goal at a time." key="goals_explainer2"}}</p>
        <p>{{t "For tips on choosing effective goals, explore these <a href='https://praacticalaac.org/praactical/how-i-do-it-writing-iep-goals-for-students-who-use-aac-with-lauren-enders/' target='_blank' rel='noopener'>helpful resources</a> from <a href='https://praacticalaac.org/praactical/praactical-goals-that-matter/' target='_blank' rel='noopener'>PrAACtical AAC</a>." key="goals_explainer_4"}}</p>
      </div>
      <!--
      things we could programmatically track:
        - average number of sessions
        - average session length
        - average number of buttons
        - requesting
        - longer phrases
        - get it out more often
        - use describing words
        - use pronouns
        - words of the week/month
        - https://praacticalaac.org/praactical/praactically-may-resources-for-a-year-of-core-vocabulary-words/
        - use in different locations
      - notification when goal is changed/added
      - link to report on goals within reports summary email
      -->
    {{/if}}
    {{#if this.model.permissions.edit}}
      <button {{action "add_goal"}} class='btn btn-default'>{{t "Set a New Goal" key="set_a_new_goal"}}</button>
      <button {{action "find_goal"}} class='btn btn-default'>{{t "Browse Community Goals" key="browse_community_goals"}}</button>
    {{/if}}
    <LinkTo @route="user.badges" @model={{this.model.user_name}} class="btn btn-default">{{t "See User Badges" key="see_user_badges"}}</LinkTo>

    {{#if this.any_goal}}
      <h3>{{t "Secondary Goals" key="secondary_goals"}}</h3>
      {{#if this.secondary_goals}}
        {{#each this.secondary_goals as |goal|}}
          <div class='well goal sparkle_list_item'>
