{{#if this.model.permissions.edit}}
<div class="md-edit-profile">
  <div class="md-edit-profile__header">
    <svg class="md-extras-card__svg-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke="#4C86D8"/><circle cx="12" cy="7" r="4" stroke="#46505F"/></svg>
    <h2 class="md-edit-profile__title">{{t "User Profile for %{term}" key="profile_for" term=this.model.user_name}}</h2>
  </div>
  <form class="form-horizontal md-edit-profile__form md-preferences__form" {{action "saveProfile" on="submit"}}>

  {{!-- Section: Personal Information --}}
  {{#preference-box title="Personal Information" glyph='glyphicon glyphicon-user' title_key='profile_section_personal' open=true}}
    <div class="form-group">
      <label for="name" class="col-sm-3 control-label">{{t "Name" key="name"}}</label>
      <div class="col-sm-5">
        <Input @value={{this.model.name}} class="form-control" id="name" placeholder="Full Name" />
      </div>
    </div>
    <div class="form-group">
      <label for="email" class="col-sm-3 control-label">{{t "Email" key="email"}}</label>
      <div class="col-sm-5">
        <Input @value={{this.model.email}} class="form-control" id="email" placeholder="" />
      </div>
    </div>
    <div class="form-group">
      <label for="cell_phone" class="col-sm-3 control-label">{{t "Cell Phone" key="cell_phone"}}</label>
      <div class="col-sm-5">
        <Input @value={{this.model.cell_phone}} class="form-control" id="cell_phone" placeholder="optional, for alerts" />
      </div>
    </div>
  {{/preference-box}}

  {{!-- Section: Account & Security --}}
  {{#preference-box title="Account & Security" glyph='glyphicon glyphicon-lock' title_key='profile_section_security' open=true}}
    <div class="form-group">
      <span class="col-sm-3 control-label">{{t "Username" key="username"}}</span>
      <div class="col-sm-5">
        <span class="form-control-static">
          {{ this.model.user_name }}
        </span>
      </div>
    </div>
    <div class="form-group">
      <span class="col-sm-3 control-label">{{t "Login Role" key="login_is_for"}}</span>
      <div class="col-sm-5">
        {{modern-select selectId="registration_type" content=this.registration_types selection=this.model.preferences.registration_type action=(action (mut this.model.preferences.registration_type)) }}
      </div>
    </div>
    {{#unless this.change_password}}
      <div class="form-group">
        <label class="col-sm-3 control-label">{{t "Password" key="password"}}</label>
        <div class="col-sm-5">
          <p class="form-control-static">
            <a href="#" {{action "enable_change_password"}}>change password</a>
          </p>
        </div>
      </div>
    {{else}}
      <div class="form-group">
        <label class="col-sm-3 control-label">{{t "Password" key="password"}}</label>
        <div class="col-sm-5">
          <Input @type="password" @value={{this.model.old_password}} class="form-control" id="old_password" placeholder="current password" />
        </div>
      </div>
      <div class="form-group">
        <span class="col-sm-3 control-label"></span>
        <div class="col-sm-5">
          <Input @type="password" @value={{this.model.password}} class="form-control" id="password" placeholder="new password" />
        </div>
      </div>
    {{/unless}}
    {{#if this.model.state_2fa.required}}
      <div class='form-group'>
        <label for='2fa' class='col-sm-3 control-label'>{{t "2-Factor Authentication" key="2fa"}}</label>
        <div class='col-sm-8'>
          {{#if this.status_2fa.loading}}
            <p>{{t "updating..." key="updating_ellipsis"}}</p>
          {{else if this.status_2fa.uri}}
            <p style='max-width: 300px;'>{{t "To complete two-factor authentication setup, scan the code into your authentication app and enter the generated code to confirm:" key="confirm_2fa_code"}}</p>
            <div style='width: 300px'>
            {{qr-code text=this.status_2fa.uri size=300}}
            </div>
            <span style='display: inline-block; width: 200px;'>
              <Input type="number" class="form-control" @value={{this.code_2fa}} placeholder="# # # # # #" />
            </span>
            {{#if this.status_2fa.error}}
              <p class='text-danger'>{{t "Invalid code, please check again" key="invalid_code_please_try_again"}}</p>
            {{/if}}
            <button class='btn btn-default' {{action "update_2fa" "confirm"}}>{{t "Confirm" key="confirm"}}</button>
          {{else}}
            {{#if this.model.permissions.edit}}
              {{#if this.model.state_2fa.required}}
                {{#if this.model.state_2fa.mandatory}}
                  {{t "Required for This Account" key="required_for_this_account"}}
                {{else}}
                  {{t "Currently Enabled" key="currently_enabled"}}
                {{/if}}
                {{#unless this.model.state_2fa.mandatory}}
                  <button class='btn btn-default' {{action "update_2fa" "disable"}}>{{t "Disable" key="disable_2fa"}}</button>
                {{/unless}}
                <button class='btn btn-default' {{action "update_2fa" "reset"}}>{{t "Reset" key="reset_2fa"}}</button>
              {{else}}
                {{t "Ensure you have the latest app versions before enabling!" key="ensure_latest_app_versions"}}
                <button class='btn btn-default' {{action "update_2fa" "enable"}}>{{t "Enable Two-Factor Authentication" key="enable_2fa"}}</button>
              {{/if}}
            {{/if}}
            {{#if this.status_2fa.error}}
              <p class='text-danger'>{{t "Error updating two-factor authentication" key="error_updating_2fa"}}</p>
            {{else if this.status_2fa.success}}
              <p class='text-success'>{{t "Two-factor authentcation successfully updated!" key="success_2fa"}}</p>
            {{/if}}
          {{/if}}
        </div>
      </div>
    {{/if}}
  {{/preference-box}}

  {{!-- Section: Profile & Visibility --}}
  {{#preference-box title="Profile & Visibility" glyph='glyphicon glyphicon-edit' title_key='profile_section_visibility' open=true}}
    <div class="form-group">
      <label for="description" class="col-sm-3 control-label">{{t "Short Bio" key="one_liner"}}</label>
      <div class="col-sm-5">
        <Input @value={{this.model.description}} class="form-control" id="description" placeholder="a short bio" />
      </div>
    </div>
    <div class="form-group">
      <label for="url" class="col-sm-3 control-label">{{t "URL" key="url"}}</label>
      <div class="col-sm-5">
        <Input @value={{this.model.details_url}} class="form-control" id="url" placeholder="https://" />
      </div>
    </div>
    <div class="form-group">
      <label for="location" class="col-sm-3 control-label">{{t "Location" key="location"}}</label>
      <div class="col-sm-5">
        <Input @value={{this.model.location}} class="form-control" id="location" placeholder="City, State, Whatever" />
      </div>
    </div>
    <div class="form-group">
      <span class="col-sm-3 control-label">{{t "Avatar" key="avatar"}}</span>
      <div class="col-sm-5">
        <img src={{this.model.avatar_url_with_fallback}} style="max-height: 30px;">
        <a href="#" {{action "pick_avatar"}}>{{t "Choose a different profile pic" key="choose_a_different_profile_pic"}}</a>
        <a href="https://www.gravatar.com" target="_blank" style="display: none;" rel="noopener">{{t "Change your avatar at Gravatar.com" key="change_at_gravatar"}}</a>
      </div>
    </div>
    <div class="form-group">
      <label for="public" class="col-sm-3 control-label">{{t "Public" key="public"}}</label>
      <div class="col-sm-5">
        <div class="checkbox big_checkbox">
          <label>
            <Input @type="checkbox" @checked={{this.model.public}} id="public" />
            {{t "Anyone can see my profile" key="anyone_can_see_profile"}}
            <br><em>{{t "(your email and cell will stay private)" key="email_stays_private"}}</em>
          </label>
        </div>
      </div>
    </div>
    <div class="form-group">
      <span class="col-sm-3 control-label">{{t "Home Board" key="home_board"}}</span>
      <div class="col-sm-5">
        <p class="form-control-static">
          {{#if this.model.preferences.home_board.key}}
            <LinkTo @route="board" @model={{this.model.preferences.home_board.key}}>{{this.model.preferences.home_board.key}}</LinkTo>
          {{else}}
            {{t "None selected. Find the home board you would like and pick it!" key="none_selected_find_one"}}
          {{/if}}
        </p>
      </div>
    </div>
  {{/preference-box}}

  {{#if this.app_state.feature_flags.new_speak_menu}}
    <div class='form-group'>
      <span class='col-sm-3 control-label'>{{t "Contacts" key="contacts"}}</span>
      <div class='col-sm-5'>
        <p class='form-control-static'><em>{{t "You can add email addresses or cell numbers of people the communicator can message through the share tool, or through a messaging link you can send them." key="add_contacts"}}</em></p>
        {{#if this.model.contacts}}
          <ul class='list-group'>
            {{#each this.model.contacts as |contact|}}          
              <li class='list-group-item'>
                <div style='float: right;'>
                  {{#unless contact.temporary}}
                    <button class='btn btn-default' {{action "message_link" contact}} title={{t "Send message link to contact" key="send_message_link_to_contact"}} style='position: relative;'>
                      <span class='glyphicon glyphicon-envelope' style='position: absolute;top: 3px;left: 3px;'></span>
                      <span class='glyphicon glyphicon-link' style='margin-right: -7px;margin-left: 7px;'></span>
                      <span class='sr-only'>{{t "Send message link to contact" key="send_message_link_to_contact"}}</span>
                    </button>
                  {{/unless}}
                  <button class='btn btn-default' {{action "remove_contact" contact}}>
                    <span class='glyphicon glyphicon-trash'></span>
                    <span class='sr-only'>{{t "Remove contact" key="remove_contact"}}</span>
                  </button>
                </div>
                <img class='fit_image' style='height: 50px; width: 50px; float: left; margin-top: -5px; padding-right: 5px;' src={{contact.image_url}} >
                {{contact.name}}<br>
                <span class='text-muted'><em>
                  {{#if contact.email}}{{contact.email}}{{/if}}
                  {{#if contact.cell_phone}}{{contact.cell_phone}}{{/if}}
                </em></span>
              </li>
            {{/each}}
          </ul>
        {{/if}}

        {{#if this.app_state.supporter_role}}
          <p class='text-danger'>{{t "NOTE: contacts will only show up in Speak Mode for communicators with a currently-active premium account" key="premium_account_required_for_contacts"}}</p>
        {{else if this.app_state.sessionUser.any_limited_supervisor}}
          <p class='text-danger'>{{t "NOTE: contacts will not show up in Speak Mode for supervised users who do not have a currently-active premium account" key="premium_communicator_required_for_contacts"}}</p>
        {{else if this.model.currently_premium}}
        {{else}}
          <p class='text-danger'>{{t "NOTE: contacts will not show up in Speak Mode for users who do not have a currently-active premium account" key="premium_required_for_contacts"}}</p>
        {{/if}}
      </div>
      {{#if this.model.permissions.edit}}
        <div class='col-sm-3 col-sm-offset-3'>
          <Input type="text" class="form-control" @value={{this.contact_name}} placeholder="Contact Name" />
        </div>
        <div class='col-sm-2'>
          <Input type="text" class="form-control" @value={{this.contact_contact}} placeholder="email or cell #" />
          <span style="font-size: 14px; color: #888;">+country prefix for non-US</span>
        </div>
        <div class='col-sm-3'>
          <button class='btn btn-default' {{action "set_picture"}} style='width: 100%;'>
            <span class='glyphicon glyphicon-camera'></span>
            {{t "Set Picture & Add" key="set_picture"}}
          </button>
        </div>
      {{/if}}
    </div>
  {{/if}}
  {{#if this.model.single_org}}
    <div class="form-group">
      <label for="third_party" class="col-sm-3 control-label">{{t "Third-Party App" key="third_party_app"}}</label>
      <div class="col-sm-5">
        <div class="checkbox big_checkbox">
          <label>
            <Input @type="checkbox" @checked={{this.allow_external_device}} id="third_party" />
            {{t "This user uses a third-party app instead of %app_name% to communicate" key="user_third_party_app"}}
          </label>
        </div>
      </div>
    </div>
    {{#if this.allow_external_device}}
      <div class="form-group">
        <label for="device_type" class="col-sm-3 control-label">{{t "App/Device" key="app_device"}}</label>
        <div class="col-sm-4">
          <Input @value={{this.external_device}} class="form-control" id="device_type" placeholder="third-party app or device name" />
        </div>
        <div class="col-sm-1" style='margin-left: -35px;'>
          <div class='btn-group dropdown'>
            <button class='btn btn-default dropdown-toggle' style='border-top-left-radius: 0; border-bottom-left-radius: 0;' data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
              {{t "Device" key="device"}} <span class="caret"></span>
            </button>
            <ul class='dropdown-menu' style="right: 0; left: inherit; text-align: left; max-height: 183px; overflow: auto;">
              {{#each this.device_options as |option|}}
                <li><a href='#' {{action "set_device" option}}>{{option.name}}</a></li>
              {{/each}}
            </ul>
          </div>
        </div>
      </div>
      {{#if this.external_device}}
        <div class="form-group">
          <label for="vocabulary_type" class="col-sm-3 control-label">{{t "Vocabulary" key="vocabulary"}}</label>
          <div class="col-sm-4">
            <Input @value={{this.external_vocab}} class="form-control" id="vocabulary_type" placeholder="vocabulary used" />
          </div>
          <div class="col-sm-1" style='margin-left: -35px;'>
            <div class='btn-group dropdown' style='max-height: 183px;'>
              <button class='btn btn-default dropdown-toggle' style='border-top-left-radius: 0; border-bottom-left-radius: 0;' data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                {{t "Vocab" key="vocab"}} <span class="caret"></span>
              </button>
              <ul class='dropdown-menu' style="right: 0; left: inherit; text-align: left; max-height: 183px; overflow: auto;">
                {{#each this.vocab_options as |option|}}
                  <li><a href='#' {{action "set_vocab" option}}>{{option.name}}</a></li>
                {{/each}}
              </ul>
            </div>
          </div>
        </div>
        <div class="form-group">
          <label for="vocab_size" class="col-sm-3 control-label">{{t "Vocab Size" key="vocab_size"}}</label>
          <div class="col-sm-2">
            <Input type="number" @value={{this.external_vocab_size}} class="form-control" id="vocab_size" placeholder="###" />
          </div>
          <div class='col-sm-3'>
            <p class='form-control-static'>{{t "average buttons per board" key="average_buttons_per_view"}}</p>
          </div>
        </div>
      {{/if}}
      <div class="form-group">
        <span class="col-sm-4 control-label">{{t "Access Method" key="access_method"}}</span>
        <div class="col-sm-6">
          {{modern-select selectId="external_access_method" content=this.access_methods selection=this.external_access_method action=(action (mut this.external_access_method)) }}
        </div>
      </div>
    {{/if}}
  {{/if}}
  {{#if this.model.supporter_role}}
    {{#if this.model.permissions.delete}}
      {{#preference-box title="Shared Access" glyph='glyphicon glyphicon-share' title_key='profile_section_shared_access' open=true}}
      <div class="form-group">
        <label for="valet_login" class="col-sm-3 control-label">{{t "Classroom Login" key="classroom_login"}}</label>
        <div class="col-sm-5">
          <div class="checkbox big_checkbox">
            <label>
              <Input @type="checkbox" @checked={{this.model.valet_login}} id="valet_login" />
              <p>{{t "Classroom login can be used in a classroom setting to allow speak-mode-only access on multiple devices at the same time in the same classroom" key="valet_as_classroom2"}}</p>
            </label>
          </div>
        </div>
      </div>
      {{#if this.model.valet_login}}
        <div class='form-group'>
          <div class='col-sm-6 col-sm-offset-3'>
            <p class='form-control-static'><em>
              {{t "Classroom login allows you to share an alternative username and password that allows speak-mode-only access to the account across multiple devices, such as in a classroom. When someone uses your classroom login, that device will have access to boards and user settings only, similar to a modeling-only account." key="classroom_login_explainer"}}
            </em></p>
          </div>
        </div>
        <div class="form-group">
          <span class="col-sm-3 control-label">{{t "Classroom User Name" key="classroom_user_name"}}</span>
          <div class="col-sm-5">
            <p class="form-control-static">
              {{this.valet_user_name}}
            </p>
          </div>
        </div>
        <div class="form-group">
          <label class="col-sm-3 control-label" for='valet_password'>{{t "Classroom Password" key="classroom_password"}}</label>
          <div class="col-sm-3">
            {{#if this.model.valet_password_set}}
              <Input @type="password" @value={{this.model.valet_password}} class="form-control" id="valet_password" placeholder="enter to change" />
            {{else}}
              <Input @type="password" @value={{this.model.valet_password}} class="form-control" id="valet_password" placeholder="required" />
            {{/if}}
          </div>
          <div class="col-sm-2">
            <button type='button' class='btn btn-default' {{action "generate_qr"}}>{{t "Generate QR Code" key="generate_qr_code"}}</button>
          </div>
        </div>
      {{/if}}
      {{/preference-box}}
    {{/if}}
  {{else}}
    {{#if this.model.permissions.delete}}
      {{#preference-box title="Shared Access" glyph='glyphicon glyphicon-share' title_key='profile_section_shared_access' open=true}}
      <div class="form-group">
        <label for="valet_login" class="col-sm-3 control-label">{{t "Valet/Classroom Login" key="valet_login"}}</label>
        <div class="col-sm-5">
          <div class="checkbox big_checkbox">
            <label>
              <Input @type="checkbox" @checked={{this.model.valet_login}} id="valet_login" />
              {{t "Enable Valet/Classroom Login" key="enable_valet_login_label"}}
              <ul class="md-edit-profile__feature-list">
                <li>{{t "Modeling-only access for shared devices" key="valet_feature_modeling"}}</li>
                <li>{{t "Speak-mode access across multiple devices simultaneously" key="valet_feature_speak"}}</li>
                <li>{{t "Ideal for classroom or therapy settings" key="valet_feature_classroom"}}</li>
              </ul>
              {{#if this.model.valet_disabled}}
                <br><em class='text-danger'>{{t "(valet login was automatically disabled after being used)" key="valet_login_disabled"}}</em>
              {{/if}}
            </label>
          </div>
        </div>
      </div>
      {{#if this.model.valet_login}}
        <div class='form-group'>
          <div class='col-sm-6 col-sm-offset-3'>
            <p class='form-control-static'><em>
              {{t "Provides temporary, limited access to boards and settings only — no full account access. Credentials expire after 24 hours or upon your next login." key="valet_login_explainer"}}
            </em></p>
          </div>
        </div>
        <div class="form-group">
          <span class="col-sm-3 control-label">{{t "Valet User Name" key="valet_user_name"}}</span>
          <div class="col-sm-5">
            <p class="form-control-static">
              {{this.valet_user_name}}
            </p>
          </div>
        </div>
        <div class="form-group">
          <label class="col-sm-3 control-label" for='valet_password'>{{t "Valet Password" key="valet_password"}}</label>
          <div class="col-sm-3">
            {{#if this.model.valet_password_set}}
              <Input @type="password" @value={{this.model.valet_password}} class="form-control" id="valet_password" placeholder="enter to change" />
            {{else}}
              <Input @type="password" @value={{this.model.valet_password}} class="form-control" id="valet_password" placeholder="required" />
            {{/if}}
          </div>
          <div class="col-sm-2">
            <button type='button' class='btn btn-default' {{action "generate_qr"}}>{{t "Generate QR Code" key="generate_qr_code"}}</button>
          </div>
        </div>

        <div class="form-group">
          <label for="valet_long_term" class="col-sm-3 control-label">{{t "Valet Long-Term" key="valet_long_term"}}</label>
          <div class="col-sm-5">
            <div class="checkbox big_checkbox">
              <label>
                <Input @type="checkbox" @checked={{this.model.valet_long_term}} id="valet_long_term" />
                {{t "Allow valet logins to last longer than 24 hours" key="allow_valet_long_term"}}
              </label>
            </div>
          </div>
        </div>
        <div class="form-group">
          <label for="valet_prevent_disable" class="col-sm-3 control-label">{{t "Valet Disabling" key="valet_disabling"}}</label>
          <div class="col-sm-5">
            <div class="checkbox big_checkbox">
              <label>
                <Input @type="checkbox" @checked={{this.model.valet_prevent_disable}} id="valet_prevent_disable" />
                {{t "Don't require re-authorization after a valet login is used" key="valet_prevent_disable"}}
              </label>
            </div>
          </div>
        </div>

      {{/if}}
      {{/preference-box}}
    {{/if}}
  {{/if}}
  {{#if this.tools}}
    {{#preference-box title="Installed Tools" glyph='glyphicon glyphicon-wrench' title_key='installed_tools' open=true}}
      <div class="form-group">
        <div class="col-sm-8">
          {{#each this.tools as |tool|}}
            <div style='float: left; cursor: pointer;' {{action "integration_details" tool}}>
              <img src={{tool.icon_url}} alt={{tool.name}} title={{tool.name}} style='height: 50px; width: 50px; object-fit: contain; border: 1px solid #ccc; border-radius: 3px; padding: 5px; margin-right: 5px;'>
            </div>
          {{/each}}
          <div style='clear: left;'></div>
          {{#unless this.model.currently_premium_or_premium_supporter}}
            <p class='text-danger'>{{t "Installed tools will only work correctly for currently-active premium accounts" key="premium_required_for_tools"}}</p>
          {{/unless}}
        </div>
      </div>
    {{/preference-box}}
  {{/if}}
  <div class="md-edit-profile__actions">
    <button type="submit" class="btn btn-primary">{{t "Save Profile" key="save_profile"}}</button>
    <button type="button" class="btn btn-default" {{action "cancelSave"}}>{{t "Cancel" key="cancel"}}</button>
  </div>
  </form>

  <hr class="md-edit-profile__divider" aria-hidden="true">
  {{#preference-box title="Integrations" glyph='glyphicon glyphicon-link' title_key='integrations_heading'}}
    <div class="md-edit-profile__integrations-row">
      <button class='md-edit-profile__integration-btn' {{action "browse_tools" "lessonpix"}}>
        <img src='https://s3.amazonaws.com/lingolinq/icons/lessonpix.png' class="md-edit-profile__integration-icon">
        {{t "Connect To LessonPix" key="connect_lessonpix"}}
      </button>
      <button class='md-edit-profile__integration-btn' {{action "browse_tools" "ifttt"}}>
        <img src='https://s3.amazonaws.com/lingolinq/icons/ifttt.png' class="md-edit-profile__integration-icon">
        {{t "Connect to IFTTT" key="connect_ifttt"}}
      </button>
    </div>
    {{#if this.managing_connections}}
      <div class="md-edit-profile__conn-panel">
        <h3 class="md-edit-profile__conn-panel-title">{{t "Connections" key="connections"}}</h3>

        <div class="md-edit-profile__conn-section">
          <h4 class="md-edit-profile__conn-section-label">{{t "Connected Tools" key="connected_tools"}}</h4>
          {{#if this.model.integrations.loading}}
            <p class="md-edit-profile__conn-empty">{{t "Loading connected tools..." key="loading_connected_tools"}}</p>
          {{else if this.model.integrations.error}}
            <p class="md-edit-profile__conn-empty">{{t "There was an error loading connected tools" key="error_loading_connected_tools"}}</p>
          {{else if this.model.integrations}}
            <ul class="md-edit-profile__conn-list">
              {{#each this.model.integrations as |integration|}}
                <li class="md-edit-profile__conn-item" {{action "integration_details" integration}}>
                  <div class="md-edit-profile__conn-item-info">
                    {{#if integration.icon_url}}
                      <img src={{integration.icon_url}} class="md-edit-profile__conn-item-icon">
                    {{else}}
                      <div class="md-edit-profile__conn-item-icon-placeholder">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#46505F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                      </div>
                    {{/if}}
                    <div>
                      <div class="md-edit-profile__conn-item-name">{{integration.name}}</div>
                      <div class="md-edit-profile__conn-item-meta">
                        {{#if integration.custom_integration}}
                          {{#if integration.truncated_access_token}}
                            {{t "API: %{token}" token=integration.truncated_access_token key="displayable_access_token"}}
                          {{/if}}
                        {{else}}
                          {{t "recognized tool" key="known_tool"}}
                        {{/if}}
                        {{#if integration.webhook}}
                          <span class="md-edit-profile__conn-badge">{{t "button" key="for_buttons"}}</span>
                        {{/if}}
                        {{#if integration.render}}
                          <span class="md-edit-profile__conn-badge">{{t "launch" key="launch"}}</span>
                        {{/if}}
                      </div>
                    </div>
                  </div>
                  {{#if this.model.permissions.edit}}
                    <button class="md-edit-profile__conn-remove" {{action "delete_integration" integration}}>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#374151" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                      <span class='sr-only'>{{t "delete connected tool" key="delete_connected_tool"}}</span>
                    </button>
                  {{/if}}
                </li>
              {{/each}}
            </ul>
          {{else}}
            <p class="md-edit-profile__conn-empty">{{t "No tools connected" key="no_tools_connected"}}</p>
          {{/if}}
          {{#if this.model.permissions.edit}}
            <div class="md-edit-profile__conn-actions">
              <a href="#" class='md-edit-profile__integration-btn' {{action "browse_tools"}}>{{t "browse tools" key="browse_tools_lower"}}</a>
              <a href="#" class='md-edit-profile__integration-btn' {{action "add_integration"}}>{{t "add custom tool" key="add_custom_tool"}}</a>
            </div>
          {{/if}}
        </div>

        <div class="md-edit-profile__conn-section">
          <h4 class="md-edit-profile__conn-section-label">{{t "Event Handlers" key="event_handlers"}}</h4>
          {{#if this.webhooks.loading}}
            <p class="md-edit-profile__conn-empty">{{t "Loading event handlers..." key="loading_event_handlers"}}</p>
          {{else if this.webhooks.error}}
            <p class="md-edit-profile__conn-empty">{{t "There was an error loading event handlers" key="error_loading_webhooks"}}</p>
          {{else if this.webhooks}}
            <ul class="md-edit-profile__conn-list">
              {{#each this.webhooks as |webhook|}}
                <li class="md-edit-profile__conn-item">
                  <div class="md-edit-profile__conn-item-info">
                    <div class="md-edit-profile__conn-item-icon-placeholder">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2A9D8F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    </div>
                    <div>
                      <div class="md-edit-profile__conn-item-name">
                        {{webhook.name}}
                        {{#if webhook.include_content}}
                          <span class="md-edit-profile__conn-badge">{{t "sends content" key="sends_content"}}</span>
                        {{/if}}
                      </div>
                      {{#if webhook.webhooks}}
                        <div class="md-edit-profile__conn-item-meta"><em>{{webhook.webhooks_list}}</em></div>
                      {{/if}}
                    </div>
                  </div>
                  <div class="md-edit-profile__conn-item-actions">
                    {{#if webhook.custom_configuration}}
                      <a href="#" class="md-edit-profile__conn-test" {{action "test_webhook" webhook}}>{{t "test" key="test"}}</a>
                    {{/if}}
                    {{#if this.model.permissions.edit}}
                      <button class="md-edit-profile__conn-remove" {{action "delete_webhook" webhook}}>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#374151" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                        <span class='sr-only'>{{t "delete event handler" key="delete_event_handler_lower"}}</span>
                      </button>
                    {{/if}}
                  </div>
                </li>
              {{/each}}
            </ul>
          {{else}}
            <p class="md-edit-profile__conn-empty">{{t "None enabled" key="none_enabled"}}</p>
          {{/if}}
          {{#if this.model.permissions.edit}}
            <div class="md-edit-profile__conn-actions">
              <a href="#" class='md-edit-profile__integration-btn' {{action "add_webhook"}}>{{t "add custom handler" key="add_handler"}}</a>
            </div>
          {{/if}}
        </div>
      </div>
    {{else}}
      <div style="padding: 0 20px 12px;"><a href="#" class='md-edit-profile__integration-btn' {{action "manage_connections"}}>{{t "Manage Tools and Connections" key="manage_connections"}}</a></div>
    {{/if}}
  {{/preference-box}}
  {{#if this.model.permissions.delete}}
    <div class="md-edit-profile__delete-row">
      <a href="#" class="md-edit-profile__delete-btn" {{action "delete_user"}}>{{t "Delete My Account" key="delete_my_account"}}</a>
    </div>
  {{/if}}
</div>
{{else if this.session.isAuthenticated}}
  <p>{{t "It appears you don't have permission to access this user's information" key="not_allowed_user_long"}}</p>
{{else}}
  {{login-form left=true prompt=true return=true}}
{{/if}}
