<div class="ub-boards-page">

  <div class="la-section-header ub-boards-page__page-header" style="display: block; text-align: center;">
    <span class="la-section-eyebrow-badge">{{t "My Boards" key="my_boards"}}</span>
    <div class="la-hero-title-wrap">
      <h1 class="la-hero-title">{{t "Let's " key="lets_prefix"}}<span class="ub-communicate" aria-label={{t "Communicate" key="communicate_word"}}><span class="ub-letter" style="animation-delay:0.25s" aria-hidden="true">C</span><span class="ub-letter" style="animation-delay:0.31s" aria-hidden="true">o</span><span class="ub-letter" style="animation-delay:0.37s" aria-hidden="true">m</span><span class="ub-letter" style="animation-delay:0.43s" aria-hidden="true">m</span><span class="ub-letter" style="animation-delay:0.49s" aria-hidden="true">u</span><span class="ub-letter" style="animation-delay:0.55s" aria-hidden="true">n</span><span class="ub-letter" style="animation-delay:0.61s" aria-hidden="true">i</span><span class="ub-letter" style="animation-delay:0.67s" aria-hidden="true">c</span><span class="ub-letter" style="animation-delay:0.73s" aria-hidden="true">a</span><span class="ub-letter" style="animation-delay:0.79s" aria-hidden="true">t</span><span class="ub-letter" style="animation-delay:0.85s" aria-hidden="true">e</span></span></h1>
    </div>
    <hr class="la-about-hero-separator" aria-hidden="true">
    <p class="la-pricing-hero-subtitle">{{t "Browse, manage, and open your boards — or create" key="ub_boards_subtitle_pre"}} <em><a href="#" class="ub-boards-page__subtitle-link" {{action "newBoard"}}>{{t "something new." key="ub_boards_subtitle_em"}}</a></em></p>
  </div>

  <div class="ub-boards-page__content">


  {{!-- Pending alerts --}}
  {{#if this.model.permissions.delete}}
    {{#if this.model.pending_org}}
      <div class='alert alert-info' style="margin-bottom: 16px;">
        {{t "%{org} wants to support this user as part of their organization. This addition must be approved before it is complete." key="confirm_pending_org2" org=this.model.pending_org.name}}
        <br><br>
        <button class="btn btn-default" {{action "approve_or_reject_org" "user_approve"}}>{{t "Approve %{org}" org=this.model.pending_org.name}}</button>
        <button class="btn btn-default" {{action "approve_or_reject_org" "user_reject"}}>{{t "Deny Access"}}</button>
      </div>
    {{else if this.model.pending}}
      <div class='alert alert-success' style="margin-bottom: 16px;">
        {{t "Welcome to %app_name%! Watch for an email from us in your inbox." key="welcome_remember_confirm"}}
      </div>
    {{else if this.model.expired}}
      {{#if this.app_state.feature_flags.subscriptions}}
        <div class='alert alert-warning' style="margin-bottom: 16px;">
          <LinkTo @route="user.subscription" @model={{this.model.user_name}}>
            {{t "This user's free preview has ended. Please purchase a premium account." key="this_user_needs_to_subscribe"}}
          </LinkTo>
        </div>
      {{/if}}
    {{/if}}
  {{/if}}

  {{!-- Getting Started (no home board yet) --}}
  {{#unless this.model.preferences.home_board.key}}
    <section class="ub-boards-page__getting-started md-card md-card--getting-started" aria-label={{t "Getting Started" key="getting_started"}}>
      <img src={{path "images/getting-started-journey-wave.svg"}} class="md-card__getting-started-wave" alt="" aria-hidden="true">
      <div class="md-card__head md-card__head--getting-started">
        <div class="md-card__head-left">
          <div class="md-card__icon md-card__icon--getting-started" aria-hidden="true">
            <img src={{path "images/pastel-getting-started.svg"}} class="md-card__icon-img" alt="" aria-hidden="true">
          </div>
          <div class="md-card__titles">
            <div class="md-card__title">{{t "Getting Started" key="getting_started"}}</div>
            <div class="md-card__sub">{{t "You haven't selected a home board yet." key="no_home_board_yet"}}</div>
          </div>
        </div>
      </div>

      <div class="ub-boards-page__getting-started-actions">
        <a href="#" class="ub-boards-page__gs-secondary-btn" {{action "newBoard"}}>{{t "Create a New Board" key="create_a_new_board"}}</a>
        <LinkTo @route="home-boards" class="md-btn md-card__getting-started-btn">{{t "Help me Choose" key="help_me_choose"}}</LinkTo>
      </div>
    </section>
  {{/unless}}

  {{!-- Stats + Actions grid --}}
  {{#if this.model.permissions.view_detailed}}
    <div class="ub-boards-page__stats-row">
      <div class="ub-boards-page__stat-card">
        <div class="ub-boards-page__stat-label">{{t "Home Board" key="home_board"}}</div>
        <div class="ub-boards-page__stat-value">
          {{#if this.model.preferences.home_board.key}}
            <LinkTo @route="board" @model={{this.model.preferences.home_board.key}} class="ub-boards-page__stat-link">{{this.model.preferences.home_board.key}}</LinkTo>
          {{else}}
            <span class="ub-boards-page__stat-none">{{t "None" key="none_upper"}}</span>
          {{/if}}
        </div>
      </div>
      <div class="ub-boards-page__stat-card">
        <div class="ub-boards-page__stat-label">{{t "My Boards" key="my_boards"}}</div>
        <div class="ub-boards-page__stat-value">
          {{#if this.model.my_boards.done}}
            {{t "board" key="n_boards" count=this.model.my_boards.length}}
          {{else}}
            <span class="ub-boards-page__stat-loading">—</span>
          {{/if}}
        </div>
      </div>
      <div class="ub-boards-page__stat-card">
        <div class="ub-boards-page__stat-label">{{t "Liked Boards" key="starred_boards"}}</div>
        <div class="ub-boards-page__stat-value">{{t "board" key="n_boards" count=this.model.stats.starred_boards}}</div>
      </div>
      <div class="ub-boards-page__stat-card">
        <div class="ub-boards-page__stat-label">{{t "Status" key="status"}}</div>
        <div class="ub-boards-page__stat-value">
          {{#if this.model.public}}
            <span class="ub-boards-page__badge ub-boards-page__badge--public">{{t "public" key="public_lower"}}</span>
          {{else}}
            <span class="ub-boards-page__badge ub-boards-page__badge--private">{{t "private" key="private_lower"}}</span>
          {{/if}}
        </div>
      </div>
    </div>

    {{!-- Action buttons --}}
    {{#if this.app_state.currentUser.preferences.new_index}}
      <div class="ub-boards-page__actions-row">
        {{#if this.model.preferences.home_board.key}}
          {{board-icon board=home_board_pref localized=true}}
        {{else}}
          <LinkTo @route="home-boards" class="ub-boards-page__action-btn">
            <span class="glyphicon glyphicon-home ub-boards-page__action-icon" aria-hidden="true"></span>
            <span class="ub-boards-page__action-label">{{t "Set Home Board" key="no_home_board_set"}}</span>
          </LinkTo>
        {{/if}}
        <button class="ub-boards-page__action-btn" {{action "stats"}}>
          <img src={{path "images/bar_chart.svg"}} class="ub-boards-page__action-icon" aria-hidden="true">
          <span class="ub-boards-page__action-label">{{t "Reports" key="reports"}}</span>
        </button>
        <LinkTo @route="user.goals" @model={{this.model.user_name}} class="ub-boards-page__action-btn">
          <span class="glyphicon glyphicon-flag ub-boards-page__action-icon" aria-hidden="true"></span>
          <span class="ub-boards-page__action-label">{{t "Goals" key="goals"}}</span>
        </LinkTo>
        <button class="ub-boards-page__action-btn" {{action "supervision_settings"}}>
          <span class="glyphicon glyphicon-user ub-boards-page__action-icon" aria-hidden="true"></span>
          <span class="ub-boards-page__action-label">
            {{#if this.model.supporter_role}}
              {{t "Supervision" key="supervision"}}
            {{else}}
              {{t "Supervisors" key="supervisors"}}
            {{/if}}
          </span>
        </button>
        {{#unless this.app_state.currentUser.modeling_only}}
          <div class="ub-boards-page__action-btn ub-boards-page__action-btn--extras dropdown">
            <button type="button" class="dropdown-toggle ub-boards-page__extras-trigger" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
              <img src="https://d18vdu4p71yql0.cloudfront.net/libraries/noun-project/extra_455_g.svg" class="ub-boards-page__action-icon" aria-hidden="true">
              <span class="ub-boards-page__action-label">{{t "Extras" key="extras"}} <span class="caret"></span></span>
            </button>
            <ul class="dropdown-menu">
              <li><a href="#" {{action "recordNote" "text"}}>{{t "New Note" key="text_note"}}</a></li>
              <li><a href="#" {{action "quick_assessment"}}>{{t "Quick Assessment" key="quick_assessment"}}</a></li>
              <li><a href="#" {{action "run_eval"}}>{{t "Run Evaluation" key="run_evaluation"}}</a></li>
              {{#if this.model.permissions.edit}}
                <li><a href="#" {{action "setup"}}>{{t "Getting Started Wizard" key="getting_started_wizard"}}</a></li>
              {{/if}}
              {{#if this.model.permissions.support_actions}}
                <li><a href="#" {{action "masquerade"}}>{{t "Masquerade as User" key="masquerade_as_user"}}</a></li>
              {{/if}}
            </ul>
          </div>
        {{/unless}}
      </div>
    {{/if}}
  {{/if}}

  {{!-- Available Boards --}}
  <section class="ub-boards-page__boards-section" aria-labelledby="ub-boards-heading">
    <div class="ub-boards-page__boards-header">
      <h2 id="ub-boards-heading" class="ub-boards-page__boards-title">
        {{#if this.model.external_device}}
          {{t "%app_name% Boards in this Account:" key="boards_in_this_account"}}
        {{else}}
          {{t "Available Boards" key="available_boards_colon"}}
        {{/if}}
      </h2>
      <button class="md-btn md-btn--primary ub-boards-page__new-board-btn" {{action "newBoard"}}>
        + {{t "New Board" key="create_a_new_board"}}
      </button>
    </div>

    {{!-- Tab strip --}}
    <ul class="ub-boards-page__tabs" role="tablist">
      {{#if this.model.permissions.edit}}
        <li role="presentation" class={{if this.mine_selected "is-active"}}><a href="#" {{action "set_selected" "mine"}}>{{t "Mine" key="mine"}}</a></li>
      {{else if this.model.permissions.model}}
        <li role="presentation" class={{if this.mine_selected "is-active"}}><a href="#" {{action "set_selected" "mine"}}>{{t "Mine" key="mine"}}</a></li>
      {{/if}}
      {{#unless this.app_state.currentUser.modeling_only}}
        <li role="presentation" class={{if this.public_selected "is-active"}}><a href="#" {{action "set_selected" "public"}}>{{t "Public" key="public"}}</a></li>
      {{/unless}}
      {{#if this.model.permissions.model}}
        <li role="presentation" class={{if this.root_selected "is-active"}}><a href="#" {{action "set_selected" "root"}}>{{t "Root" key="root"}}</a></li>
      {{/if}}
      {{#unless this.app_state.currentUser.modeling_only}}
        <li role="presentation" class={{if this.starred_selected "is-active"}}><a href="#" {{action "set_selected" "starred"}}>{{t "Liked" key="starred"}}</a></li>
      {{/unless}}
      {{#unless this.app_state.currentUser.modeling_only}}
        {{#if this.model.permissions.model}}
          <li role="presentation" class="dropdown {{if this.other_selected "is-active"}}">
            <a class="dropdown-toggle" data-toggle="dropdown" href="#" role="button" aria-haspopup="true" aria-expanded="false">
              {{this.more_label}} <span class="caret"></span>
            </a>
            <ul class="dropdown-menu">
              {{#if this.model.permissions.edit}}
                <li><a href="#" {{action "set_selected" "shared"}}>{{t "Shared with Me" key="shared_with_me"}}</a></li>
              {{/if}}
              {{#if this.model.prior_home_boards}}
                <li><a href="#" {{action "set_selected" "prior_home"}}>{{t "Prior Home Boards" key="prior_home"}}</a></li>
              {{/if}}
              {{#if this.model.permissions.edit}}
                <li><a href="#" {{action "set_selected" "private"}}>{{t "Private" key="private"}}</a></li>
              {{/if}}
              {{#each this.model.board_tags as |tag|}}
                <li><a href="#" {{action "set_tag" tag}}>{{tag}}</a></li>
              {{/each}}
            </ul>
          </li>
        {{/if}}
      {{/unless}}
    </ul>

    {{!-- Board grid --}}
    <div class="ub-boards-page__boards-body">
      {{#if this.board_list}}
        {{#if this.board_list.loading}}
          <p class="ub-boards-page__loading">{{t "Loading..." key="loading"}}</p>
        {{else if this.board_list.error}}
          <p class="ub-boards-page__loading">{{t "Failed to load" key="failed_to_load"}}</p>
        {{else if this.board_list.results}}
          {{#if this.prior_home_selected}}
            <ul class="list-group" style="max-width: 350px;">
              {{#each this.board_list.filtered_results as |board|}}
                <li class="list-group-item">
                  <LinkTo @route="board" @model={{board.board.key}}>{{board.board.key}}</LinkTo>
                </li>
              {{/each}}
            </ul>
            {{#unless this.show_all_boards}}
              <a href="#" {{action "show_more_boards"}}>{{t "show more" key="show_more"}}</a>
            {{/unless}}
          {{else}}
            {{#if this.board_list.sub_result}}
              <p><em>{{t "Showing boards copied with %{k}" key="showing_boards_copied_with" k=this.parent_object.board.key}}</em></p>
              <a href="#" class="md-btn" {{action "load_children"}}>← {{t "Back to Full List" key="back_to_full_list"}}</a>
            {{/if}}
            <form class="ub-boards-page__filter-form" {{action "nothing" on="submit"}}>
              <Input @type="text" @value={{this.filterString}} class="ub-boards-page__filter-input" placeholder={{t "Filter Results" key="filter_results"}} />
            </form>
            <div class="ub-boards-page__board-grid">
              {{#each this.board_list.filtered_results as |board|}}
                {{#if board.board.key}}
                  {{#unless board.board.removed}}
                    <div class="ub-boards-page__board-item board_with_action simple_board_holder" rel={{board.hidden}} style={{safe-style (if board.hidden "position: absolute; left: -1000px; visibility: hidden;" "")}}>
                      {{#if board.children}}
                        {{board-icon board=board noinfo=true onAction=(action "load_children")}}
                      {{else}}
                        {{board-icon board=board.board}}
                      {{/if}}
                      {{#if this.model.permissions.edit}}
                        {{#if board.board.id}}
                          <button class="board_action" {{action "remove_board" this.board_list.remove_type board.board}}>
                            <span title={{this.board_list.remove_label}}><span class={{this.board_list.remove_icon}}></span></span>
                          </button>
                        {{/if}}
                      {{/if}}
                    </div>
                  {{/unless}}
                {{else if board.orphan}}
                  {{#if board.children}}
                    <div class="ub-boards-page__board-item board_with_action simple_board_holder" rel={{board.hidden}} style={{safe-style (if board.hidden "position: absolute; left: -1000px; visibility: hidden;" "")}}>
                      {{board-icon board=board noinfo=true onAction=(action "load_children")}}
                      {{#if this.model.permissions.edit}}
                        <button class="board_action" {{action "remove_board" "delete_orphans" board}}>
                          <span title={{t "delete" key="delete"}}><span class="glyphicon glyphicon-trash"></span></span>
                        </button>
                      {{/if}}
                    </div>
                  {{/if}}
                {{/if}}
              {{/each}}
              {{#unless this.show_all_boards}}
                {{#unless this.filterString}}
                  <div class="ub-boards-page__show-more">
                    <a href="#" class="ub-boards-page__show-more-btn" {{action "show_more_boards"}}>
                      {{t "More" key="more"}}
                      <span class="ub-boards-page__show-more-chevrons" aria-hidden="true">
                        <span class="glyphicon glyphicon-chevron-down"></span><span class="glyphicon glyphicon-chevron-down"></span>
                      </span>
                    </a>
                  </div>
                {{/unless}}
              {{/unless}}
            </div>
          {{/if}}
        {{else}}
          <p class="ub-boards-page__loading">{{t "None found" key="none_found"}}</p>
        {{/if}}
      {{/if}}
    </div>
  </section>

  </div>{{!-- /.ub-boards-page__content --}}

</div>
