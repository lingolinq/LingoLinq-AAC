                  <div style='width: 60px;'>
                    {{key-code-text-field id='scanning_next_keycode' class='form-control' value=this.pending_preferences.device.scanning_next_keycode placeholder='press a key'}}
                  </div>
                  <span class='form-control-static' style='color: var(--md-muted);'>{{next_keycode_string}}</span>
                </div>
              </div>
            </div>
            <div class="form-group">
              <label for="scanning_prev_keycode" class="col-sm-3 control-label">{{t "Scanning \"Previous\" Key" key='scanning_prev_keycode'}}</label>
              <div class="col-sm-5">
                <div style='display: flex; align-items: center; gap: 10px;'>
                  <div style='width: 60px;'>
                    {{key-code-text-field id='scanning_prev_keycode' class='form-control' value=this.pending_preferences.device.scanning_prev_keycode placeholder='press a key'}}
                  </div>
                  <span class='form-control-static' style='color: var(--md-muted);'>{{prev_keycode_string}}</span>
                </div>
              </div>
            </div>
          {{/unless}}
          <div class="form-group">
            <label for="scanning_cancel_keycode" class="col-sm-3 control-label">{{t "Scanning \"Cancel\" Key" key='scanning_cancel_keycode'}}</label>
            <div class="col-sm-5">
              <div style='display: flex; align-items: center; gap: 10px;'>
                <div style='width: 60px;'>
                  {{key-code-text-field id='scanning_cancel_keycode' class='form-control' value=this.pending_preferences.device.scanning_cancel_keycode placeholder='press a key'}}
                </div>
                <span class='form-control-static' style='color: var(--md-muted);'>{{cancel_keycode_string}}</span>
              </div>
