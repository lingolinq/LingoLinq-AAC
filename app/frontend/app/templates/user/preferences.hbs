                {{#each this.requested_phrases as |phrase|}}
                  <div style='padding-left: 10px; margin-bottom: 4px;'>
                    {{#if phrase.used}}<span class='glyphicon glyphicon-ok'></span>{{/if}}
                    {{phrase.text}}
                    <a href="#" {{action 'remove_phrase' phrase.text}} style='padding-left: 8px; font-size: 13px;'>{{t "remove" key='remove_lower'}}</a>
                  </div>
                {{/each}}
              {{else}}
