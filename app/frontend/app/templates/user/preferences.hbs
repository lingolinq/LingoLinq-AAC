{{#if this.model.permissions.edit}}
<div class="md-preferences">
  <div class="md-preferences__header">
    <svg class="md-extras-card__svg-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3" stroke="#2A9D8F"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z" stroke="#46505F"/></svg>
    <h2 class="md-preferences__title">{{t "General Preferences" key='general_preferences'}}</h2>
  </div>
  <form class="form-horizontal md-preferences__form" {{action "savePreferences" on="submit"}}>
  {{#preference-box title="Basics" glyph='glyphicon glyphicon-cog' title_key='basics' open=true}}
    <span style='display: none;'>{{t "Basics" key='basics'}}</span>
    <div class="form-group">
      <label for="role" class="col-sm-3 control-label">{{t "Account Type" key='role'}}</label>
      <div class="col-sm-5">
        {{bound-select select_class="form-control" select_id="role" content=this.dashboardViewList selection=this.pending_preferences.role action=(action (mut this.pending_preferences.role)) }}
      </div>
    </div>
    {{#unless this.non_communicator}}
      <div class="form-group">
        <label for="device_role" class="col-sm-3 control-label">{{t "Device Purpose" key='device_purpose'}}</label>
        <div class="col-sm-5">
          {{bound-select select_class="form-control" select_id="device_role" content=this.device_type_list selection=this.pending_preferences.device.role action=(action (mut this.pending_preferences.device.role)) }}
        </div>
      </div>
      <div class="form-group">
        <label for="auto_open_speak_mode" class="col-sm-3 control-label">{{t "On Launch" key='on_launch'}}</label>
        <div class="col-sm-5">
          <div class="checkbox big_checkbox">
            <label>
              <Input @type="checkbox" id='auto_open_speak_mode' @checked={{this.pending_preferences.auto_open_speak_mode}} />
              {{t "Start app in Speak Mode on launch" key='start_in_speak_mode_on_launch'}}
            </label>
          </div>
        </div>
      </div>
    {{/unless}}
    {{#if this.advanced}}
      <div class="form-group">
        <label for="long_token" class="col-sm-3 control-label">{{t "Session Timeout" key='long_token'}}</label>
        <div class="col-sm-5">
          <div class="checkbox big_checkbox">
            <label>
              <Input @type="checkbox" @checked={{this.pending_preferences.device.long_token}} id="long_token" />
              {{t "Keep me logged in on this private device" key='enable_long_token'}}
            </label>
          </div>
        </div>
      </div>
    {{/if}}
    <div class="form-group">
      <label for="require_speak_mode_pin" class="col-sm-3 control-label">{{t "Exiting" key='editing'}}</label>
      <div class="col-sm-5">
        <div class="checkbox big_checkbox">
          <label>
            <Input @type="checkbox" @checked={{this.pending_preferences.require_speak_mode_pin}} id="require_speak_mode_pin" />
            {{t "Require a PIN when exiting Speak Mode" key='require_speak_mode_pin'}}
          </label>
        </div>
      </div>
    </div>
    {{#if this.pending_preferences.require_speak_mode_pin}}
      <div class="form-group">
        <label for="speak_mode_pin" class="col-sm-3 control-label">{{t "Speak Mode PIN" key='speak_mode_pin'}}</label>
        <div class="col-sm-5">
          <label>
            <Input @value={{this.pending_preferences.speak_mode_pin}} class="form-control" id="speak_mode_pin" placeholder="4-digit numerical PIN" />
          </label>
        </div>
      </div>
      <div class="form-group">
        <label for="hide_pin_hint" class="col-sm-3 control-label">{{t "Hide PIN" key='hide_pin'}}</label>
        <div class="col-sm-5">
          <div class="checkbox big_checkbox">
            <label>
              <Input @type="checkbox" @checked={{this.pending_preferences.hide_pin_hint}} id="hide_pin_hint" />
              {{t "Don't show hint for discovering forgotten PIN" key='hide_pin_hint'}}
            </label>
          </div>
          {{#if this.pending_preferences.hide_pin_hint}}
            <p class='text-danger' style='margin-top: 10px;'>{{t "NOTE: If the PIN hint is hidden, you won't be able to exit Speak Mode unless you remember the PIN, or can look it up on a different device." key='hidden_pin_warning'}}</p>
          {{/if}}
        </div>
      </div>
    {{/if}}

    <div class="form-group">
      <label for="home_board" class="col-sm-3 control-label">{{t "Home Board" key='home_board'}}</label>
      <div class="col-sm-3">
        <p class='form-control-static'>
          {{#if this.pending_preferences.sync_starred_boards}}
            {{t "All Liked Boards" key='all_starred_boards'}}
            {{#if this.pending_preferences.home_board.key}}
              <br>{{t "(and home board %{hb})" hb=this.pending_preferences.home_board.key key='and_home_board'}}
            {{/if}}
          {{else if this.pending_preferences.home_board.key}}
            {{this.pending_preferences.home_board.key}}
          {{else}}
            {{t "None Set" key='none_set'}}
          {{/if}}
        </p>
      </div>
      <div class='col-sm-2' style='text-align: right;'>
        {{#if this.pending_preferences.home_board.key}}
          <button class='btn btn-default' {{action 'clear_home'}}>{{t "Clear Home Board" key='clear_home_board'}}</button>
        {{/if}}
      </div>
      {{#unless this.pending_preferences.home_board.key}}
        <div class="col-sm-5 col-sm-offset-3">
          <div class="checkbox big_checkbox">
            <label>
              <Input @type="checkbox" @checked={{this.pending_preferences.sync_starred_boards}} id="sync_starred_boards" />
              {{t "Sync my liked boards to use as a home board" key='sync_starred_boards_for_home'}}
            </label>
          </div>
        </div>
      {{/unless}}
    </div>
    <div class="form-group">
      <label for="locale" class="col-sm-3 control-label">{{t "Preferred Language" key='preferred_language'}}</label>
      <div class="col-sm-5">
        {{bound-select select_class="form-control" select_id="locale" content=(readonly this.localeList) selection=this.pending_preferences.locale action=(action (mut this.pending_preferences.locale)) }}
      </div>
    </div>
    <div class="form-group">
      <label for="preferred_symbols" class="col-sm-3 control-label">{{t "Preferred Symbols" key='preferred_symbols'}}</label>
      <div class="col-sm-5">
        {{bound-select select_class="form-control" select_id="preferred_symbols" content=(readonly this.symbolsList) selection=this.pending_preferences.preferred_symbols action=(action (mut this.pending_preferences.preferred_symbols)) }}
        {{#if (get this "premium_symbol_library")}}
          {{#if this.app_state.currentUser.subscription.grace_trial_period}}
            <div class='text-danger'>
              {{t "(requires extra fee after trial period)" key='extra_fee_at_purchase'}}            
            </div>
          {{/if}}
        {{/if}}
      </div>
    </div>
    {{#if (get this "app_state.feature_flags.skin_tones")}}
      <div class="form-group">
        <label for="preferred_skin" class="col-sm-3 control-label">{{t "Preferred Skin Tone" key='preferred_skin_tone'}}</label>
        <div class="col-sm-5">
          <span class="dropdown dropup" style="display: inline-block; width: 100%;">
            <button class='btn btn-default symbol_target small' data-toggle="dropdown" style='width: 100%; text-align: left; white-space: nowrap; overflow: hidden;'>
              <span class='text'>
                {{#each current_skin.image_urls as |url|}}
                  <img src={{url}} >
                {{/each}}
                {{current_skin.label}}
              </span>
              <span class='caret' style='position: absolute; right: 5px; top: 15px;'></span>
            </button>
            <ul class="dropdown-menu" role="menu" aria-labelledby="dLabel" style='max-height: 225px; overflow: auto;'>
              {{#each skin_options as |option|}}
                <li role="presentation">
                  <a role="menuitem" class='symbol_target' href="#" tabindex="-1" {{action "choose_skin" option.id}}>
                    <img src={{option.image_url}} >
                    {{option.label}}
                  </a>
                </li>
              {{/each}}
            </ul>
          </span>
          {{#if current_skin.options}}
            <div style='margin-left: 15px;'>
              {{#each current_skin.options as |option|}}
                <div>
                  <div class='checkbox big_checkbox'>
                    <label>
                      <Input @type="checkbox" @checked={{option.checked}} />
                      <img src={{option.image_url}} style='width: 30px; height: 30px;'>
                      {{option.label}}
                    </label>
                  </div>
                </div>
              {{/each}}
            </div>
          {{/if}}
        </div>
      </div>
    {{/if}}
  {{/preference-box}}
  {{#preference-box title="Notifications" glyph='glyphicon glyphicon-bell' title_key='notifications'}}
    <span style='display: none;'>{{t "Notifications" key='notifications'}}</span>
    <div class="form-group">
      <label for="notification_frequency" class="col-sm-3 control-label">{{t "Usage Summaries" key="notification_frequency"}}</label>
      <div class="col-sm-5">
        {{bound-select select_class="form-control" select_id="notification_frequency" content=this.notification_frequency_options selection=this.pending_preferences.notification_frequency action=(action (mut this.pending_preferences.notification_frequency)) }}
      </div>
    </div>
    <div class="form-group">
      <label for="goal_notifications" class="col-sm-3 control-label">{{t "Goal Updates" key="goal_notifications"}}</label>
      <div class="col-sm-5">
        {{bound-select select_class="form-control" select_id="goal_notifications" content=this.goal_notification_options selection=this.pending_preferences.goal_notifications action=(action (mut this.pending_preferences.goal_notifications)) }}
      </div>
    </div>
    <div class="form-group">
      <label for="share_notifications" class="col-sm-3 control-label">{{t "Share Notifications" key="share_notifications"}}</label>
      <div class="col-sm-5">
        {{bound-select select_class="form-control" select_id="share_notifications" content=this.allow_shares_options selection=this.pending_preferences.share_notifications action=(action (mut this.pending_preferences.share_notifications)) }}
      </div>
    </div>
  {{/preference-box}}
  {{#preference-box title="Styling" glyph='glyphicon glyphicon-picture' title_key='styling'}}
    <span style='display: none;'>{{t "Styling" key='styling'}}</span>
    <div class="form-group">
      <label for="board_background" class="col-sm-3 control-label">{{t "Board Background Color" key='board_background'}}</label>
      <div class="col-sm-5">
        {{bound-select select_class="form-control" select_id="board_background" content=this.buttonBackgroundList selection=this.pending_preferences.board_background action=(action (mut this.pending_preferences.board_background)) }}
      </div>
    </div>
    <div class="form-group">
      <label for="symbol_background" class="col-sm-3 control-label">{{t "Image Background Color" key='symbol_background'}}</label>
      <div class="col-sm-5">
        {{bound-select select_class="form-control" select_id="symbol_background" content=this.symbolBackgroundList selection=this.pending_preferences.symbol_background action=(action (mut this.pending_preferences.symbol_background)) }}
      </div>
    </div>
    <div class="form-group">
      <label for="hidden_buttons" class="col-sm-3 control-label">{{t "Hidden Buttons" key='hidden_buttons'}}</label>
      <div class="col-sm-5">
        {{#if this.buttons_stretched}}
          <p class='form-control-static'><em>{{t "When \"Stretch Buttons\" is enabled, hidden buttons cannot be shown" key='no_hidden_buttons_when_stretching'}}</em></p>
        {{else}}
          {{bound-select select_class="form-control" select_id="hidden_buttons" content=this.hiddenButtonsList selection=this.pending_preferences.hidden_buttons action=(action (mut this.pending_preferences.hidden_buttons)) }}
        {{/if}}
      </div>
      {{#if this.app_state.feature_flags.enable_all_buttons}}
        <div class="col-sm-5 col-sm-offset-3">
          <div class="checkbox big_checkbox">
            <label>
              <Input @type="checkbox" @checked={{this.pending_preferences.prevent_hide_buttons}} id="prevent_hide_buttons" />
              {{t "Disable \"Show Hidden Buttons\" option in Speak Mode" key='prevent_hide_buttons'}}
            </label>
          </div>
        </div>
      {{/if}}
    </div>
    <div class="form-group">
      <label for="dim_level" class="col-sm-3 control-label">{{t "Dimmed Button Brightness" key='dim_level'}}</label>
      <div class="col-sm-5">
        {{bound-select select_class="form-control" select_id="dim_level" content=this.dimLevelList selection=this.pending_preferences.dim_level action=(action (mut this.pending_preferences.dim_level)) }}
      </div>
    </div>
    <div class="form-group">
      <label for="blank_status" class="col-sm-3 control-label">{{t "Status" key='status'}}</label>
      <div class="col-sm-5">
        <div class="checkbox big_checkbox">
          <label>
            <Input @type="checkbox" @checked={{this.pending_preferences.blank_status}} id="blank_status" />
            {{t "Show time, device status and notifications when vocalization box is empty" key='blank_status'}}
          </label>
        </div>
      </div>
    </div>
    <div class="form-group">
      <label for="word_suggestion_images" class="col-sm-3 control-label">{{t "Keyboard Suggestions" key='keyboard_suggestions'}}</label>
      <div class="col-sm-5">
        <div class="checkbox big_checkbox">
          <label>
            <Input @type="checkbox" @checked={{this.pending_preferences.word_suggestion_images}} id="word_suggestion_images" />
            {{t "Show images for keyboard suggestions" key='word_suggestion_images'}}
          </label>
        </div>
      </div>
    </div>
    <div class="form-group">
      <label for="high_contrast" class="col-sm-3 control-label">{{t "High Contrast" key='high_contrast'}}</label>
      <div class="col-sm-5">
        <div class="checkbox big_checkbox">
          <label>
            <Input @type="checkbox" @checked={{this.pending_preferences.high_contrast}} id="high_contrast" />
            {{t "Show all button images in high-contrast mode" key='high_contrast_images'}}
          </label>
        </div>
      </div>
    </div>
    <div class="form-group">
      <label for="dim_header" class="col-sm-3 control-label">{{t "Dim Header" key='dim_header'}}</label>
      <div class="col-sm-5">
        <div class="checkbox big_checkbox">
          <label>
            <Input @type="checkbox" @checked={{this.pending_preferences.dim_header}} id="dim_header" />
            {{t "Make the header and sidebar less bright" key='dim_header_long'}}
          </label>
        </div>
      </div>
    </div>
    <div class="form-group" style="display: none;">
      <label for="stretch_buttons" class="col-sm-3 control-label">{{t "Fill Empty Button Spaces" key='stretch_buttons'}}</label>
      <div class="col-sm-5">
        {{bound-select select_class="form-control" select_id="stretch_buttons" content=this.buttonSpaceList selection=this.pending_preferences.stretch_buttons action=(action (mut this.pending_preferences.stretch_buttons)) }}
      </div>
    </div>
    <div class='form-group'>
      <label class="col-sm-3 control-label">{{t "Editing Colors" key='editing_colors'}}</label>
      <div class="col-sm-6">
        {{extra-colors colors=this.pending_preferences.extra_colors}}
      </div>
    </div>
  {{/preference-box}}
  {{#preference-box title="Selection Settings" glyph='glyphicon glyphicon-hand-up' title_key='selection_settings'}}
    <span style='display: none;'>{{t "Selection Settings" key='selection_settings'}}</span>
    <div class="form-group">
      <label for="auto_home_return" class="col-sm-3 control-label">{{t "On Select" key='on_select'}}</label>
      <div class="col-sm-5">
        <div class="checkbox big_checkbox">
          <label>
            <Input @type="checkbox" @checked={{this.pending_preferences.vocalize_buttons}} id="vocalize_buttons" />
            {{t "Vocalize after each button press" key='vocalize_buttons'}}
          </label>
        </div>
        {{#if this.advanced}}
          {{#if this.pending_preferences.vocalize_buttons}}
            <div class="checkbox big_checkbox">
              <label>
                <Input @type="checkbox" @checked={{this.pending_preferences.vocalize_linked_buttons}} id="vocalize_linked_buttons" />
                {{t "Vocalize when hitting linked buttons" key='vocalize_linked_buttons'}}
              </label>
            </div>
            <div class="checkbox big_checkbox">
              <label>
                <Input @type="checkbox" @checked={{this.pending_preferences.silence_spelling_buttons}} id="silence_spelling_buttons" />
                {{t "Don't vocalize when spelling until the word is completed" key='silence_spelling_buttons'}}
              </label>
            </div>
          {{/if}}
          <div class="checkbox big_checkbox">
            <label>
              <Input @type="checkbox" @checked={{this.pending_preferences.click_buttons}} id="click_buttons" />
              {{t "Make a clicking sound when hitting unspoken buttons" key='click_buttons'}}
            </label>
          </div>
          <div class="checkbox big_checkbox">
            <label>
              <Input @type="checkbox" @checked={{this.pending_preferences.vibrate_buttons}} id="vibrate_buttons" />
              {{t "Vibrate the device when hitting buttons (if supported)" key='vibrate_buttons'}}
            </label>
          </div>
          <div class="checkbox big_checkbox">
            <label>
              <Input @type="checkbox" @checked={{this.pending_preferences.auto_home_return}} id="auto_home_return" />
              {{t "Automatically return to Home board after an unlinked button is selected" key='auto_home_return'}}
            </label>
          </div>
        {{/if}}
      </div>
    </div>
    {{#if this.advanced}}
      <div class="form-group">
        <label for="highlighted_buttons" class="col-sm-3 control-label">{{t "Selection Highlights" key='highlighted_buttons'}}</label>
        <div class="col-sm-5">
          {{bound-select select_class="form-control" select_id="highlighted_buttons" content=this.highlighted_buttons_list selection=this.pending_preferences.highlighted_buttons action=(action (mut this.pending_preferences.highlighted_buttons)) }}
        </div>
      </div>
      {{#if this.some_highlighted_buttons}}
        <div class="form-group">
          <label for="highlight_popup_text" class="col-sm-3 control-label">{{t "Literacy Highlights" key='highlighted_popup_text'}}</label>
          <div class="col-sm-5">
            <div class="checkbox big_checkbox">
              <label>
                <Input @type="checkbox" @checked={{this.pending_preferences.highlight_popup_text}} id="highlighted_popup_text" />
                {{t "Highlight buttons using a text box for developing sight word reading" key='popup_for_sight_reading'}}
              </label>
            </div>
          </div>
        </div>
      {{/if}}
    {{/if}}
    <div class="form-group">
      <label for="activation_on_start" class="col-sm-3 control-label">{{t "Select on Press" key='activation_on_start'}}</label>
      <div class="col-sm-5">
        <div class="checkbox big_checkbox">
          <label>
            <Input @type="checkbox" @checked={{this.pending_preferences.activation_on_start}} id="device_home" />
            {{t "Select the button as soon as it is pressed" key='select_immediately'}}
          </label>
        </div>
      </div>
    </div>
    <div class="form-group">
      <label for="swipe_pages" class="col-sm-3 control-label">{{t "Swipe Pages" key='swipe_pages'}}</label>
      <div class="col-sm-5">
        <div class="checkbox big_checkbox">
          <label>
            <Input @type="checkbox" @checked={{this.pending_preferences.swipe_pages}} id="swipe_pages" />
            {{t "Use long swipe action to toggle between home and sidebar boards" key='swipe_pages_enabled'}}
          </label>
        </div>
      </div>
    </div>
    {{#if this.app_state.feature_flags.auto_inflections}}
      <div class="form-group">
        <label for="auto_inflections" class="col-sm-3 control-label">{{t "Automatic Inflections" key='auto_inflections'}}</label>
        <div class="col-sm-5">
          <div class="checkbox big_checkbox">
            <label>
              <Input @type="checkbox" @checked={{this.pending_preferences.auto_inflections}} id="auto_inflections" />
              {{t "Automatically update button inflections when the default doesn't match" key='enable_auto_inflections'}}
            </label>
          </div>
        </div>
      </div>
    {{/if}}
    {{! Was gated by this.app_state.feature_flags.inflections_overlay - remove #if to restore flag use }}
    <div class="form-group">
      <label for="inflections_overlay" class="col-sm-3 control-label">{{t "Long-Press" key='long_press'}}</label>
      <div class="col-sm-5">
        <div class="checkbox big_checkbox">
          <label>
            <Input @type="checkbox" @checked={{this.pending_preferences.inflections_overlay}} id="inflections_overlay" />
            {{t "Show inflection options on long-press in Speak Mode" key='inflections_overlay'}}
          </label>
        </div>
      </div>
    </div>
    {{#unless this.pending_preferences.activation_on_start}}
      <div class="form-group">
        <label for="activation_location" class="col-sm-3 control-label">{{t "Select Based on" key='activation_location'}}</label>
        <div class="col-sm-5">
          {{bound-select select_class="form-control" select_id="activation_location" content=this.activationLocationList selection=this.pending_preferences.activation_location action=(action (mut this.pending_preferences.activation_location)) }}
        </div>
      </div>
      <div class="form-group">
        <label for="activation_cutoff" class="col-sm-3 control-label">{{t "Select Without Release After" key='activation_cutoff'}}</label>
        <div class="col-sm-5">
          <div style="display: flex; align-items: center; gap: 10px;">
            <div class="md-number-picker">
              <button type="button" class="md-number-picker__btn" {{action "plus_minus" "minus" "this.pending_preferences.activation_cutoff"}}>−</button>
              <Input @value={{this.pending_preferences.activation_cutoff}} class="md-number-picker__input" id="activation_cutoff" placeholder="disabled" />
              <button type="button" class="md-number-picker__btn" {{action "plus_minus" "plus" "this.pending_preferences.activation_cutoff"}}>+</button>
            </div>
            <span class="form-control-static" style="white-space: nowrap;">{{t "milliseconds" key='milliseconds'}}</span>
          </div>
        </div>
      </div>
      <div class="form-group">
        <label for="activation_minimum" class="col-sm-3 control-label">{{t "Must Press Button At Least" key='activation_minimum'}}</label>
        <div class="col-sm-5">
          <div style="display: flex; align-items: center; gap: 10px;">
            <div class="md-number-picker">
              <button type="button" class="md-number-picker__btn" {{action "plus_minus" "minus" "this.pending_preferences.activation_minimum"}}>−</button>
              <Input @value={{this.pending_preferences.activation_minimum}} class="md-number-picker__input" id="activation_minimum" placeholder="disabled" />
              <button type="button" class="md-number-picker__btn" {{action "plus_minus" "plus" "this.pending_preferences.activation_minimum"}}>+</button>
            </div>
            <span class="form-control-static" style="white-space: nowrap;">{{t "milliseconds" key='milliseconds'}}</span>
