              <div style='display: flex; align-items: center; gap: 10px;'>
                <div style='width: 60px;'>
                  {{key-code-text-field id='scanning_select_keycode' class='form-control' value=this.pending_preferences.device.scanning_select_keycode action=(action (mut this.pending_preferences.device.scanning_select_keycode)) placeholder='press a key'}}
                </div>
