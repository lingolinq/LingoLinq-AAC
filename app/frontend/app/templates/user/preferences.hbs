            <div style='max-height: 120px; overflow: auto; padding: 12px 18px; border: 1.5px solid rgba(17, 26, 46, 0.08); border-radius: 10px; background: rgba(248, 250, 252, 0.8); margin-bottom: 14px; line-height: 1.6; font-size: 14px;'>
