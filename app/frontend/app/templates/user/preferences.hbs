  {{else}}
    {{#preference-box title="Voice Settings" glyph='glyphicon glyphicon-volume-up' title_key='voice_settings'}}
      <span style='display: none;'>{{t "Voice Settings" key='voice_settings'}}</span>
      {{#if this.user_voice_list}}
        <div class="form-group">
          <label for="voiceURI" class="col-sm-3 col-xs-12 control-label">{{t "Voice" key='voiceURI'}}</label>
          <div class="col-sm-5">
            <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
              <div style="flex: 1 1 auto; min-width: 180px;">
                {{bound-select select_class="form-control" select_id="voiceURI" content=this.user_voice_list selection=this.pending_preferences.device.voice.voice_uri action=(action (mut this.pending_preferences.device.voice.voice_uri)) }}
              </div>
              <button class='btn btn-default' {{action "premium_voices"}} style="white-space: nowrap;">{{t "Premium Voices" key='premium_voices'}}</button>
            </div>
            {{#if this.ios_app}}
              <p class='form-control-static' style='margin-top: 8px;'><em>{{t "Some system voices may not work due to an Apple speech engine issue. Try a Premium Voice or \"System Default Voice\" if needed." key='apple_tts_bug'}}</em></p>
            {{/if}}
          </div>
        </div>
      {{else if kindle_without_voice}}
        <div class="form-group">
          <label for="voice_pitch" class="col-sm-3 col-xs-12 control-label">{{t "Voice" key='voiceURI'}}</label>
          <div class="col-sm-3 col-xs-7">
            <p class='form-control-static text-info'>
              {{t "NOTE: Some Kindle Fire tablets don't come with text-to-speech pre-installed. To download a voice to go the home screen, hit Settings, Keyboard & Language, Text-To-Speech and Download one or more system voices" key='kindle_voices_missing' }}
            </p>
          </div>
          <div class="col-sm-2 col-xs-5">
            <button class='btn btn-default' {{action "premium_voices"}}>{{t "Premium Voices" key='premium_voices'}}</button>
          </div>
        </div>
      {{/if}}
      <div class="form-group">
        <label for="voice_rate" class="col-sm-3 col-xs-12 control-label">{{t "Voice Rate" key='voice_rate'}}</label>
        <div class="col-sm-5">
          <div class="md-number-picker">
            <button type="button" class="md-number-picker__btn" {{action "plus_minus" "minus" "this.pending_preferences.device.voice.rate"}}>−</button>
            <Input @value={{this.pending_preferences.device.voice.rate}} class="md-number-picker__input" id="voice_rate" placeholder="1.0" />
            <button type="button" class="md-number-picker__btn" {{action "plus_minus" "plus" "this.pending_preferences.device.voice.rate"}}>+</button>
          </div>
        </div>
      </div>
      <div class="form-group">
        <label for="voice_pitch" class="col-sm-3 col-xs-12 control-label">{{t "Voice Pitch" key='voice_pitch'}}</label>
        <div class="col-sm-5">
          <div class="md-number-picker">
            <button type="button" class="md-number-picker__btn" {{action "plus_minus" "minus" "this.pending_preferences.device.voice.pitch"}}>−</button>
            <Input @value={{this.pending_preferences.device.voice.pitch}} class="md-number-picker__input" id="voice_pitch" placeholder="1.0" />
            <button type="button" class="md-number-picker__btn" {{action "plus_minus" "plus" "this.pending_preferences.device.voice.pitch"}}>+</button>
          </div>
        </div>
      </div>
      <div class="form-group">
        <label for="voice_volume" class="col-sm-3 col-xs-12 control-label">{{t "Voice Volume" key='voice_volume'}}</label>
        <div class="col-sm-5">
          <div style="display: flex; align-items: center; gap: 12px;">
            <div class="md-number-picker">
              <button type="button" class="md-number-picker__btn" {{action "plus_minus" "minus" "this.pending_preferences.device.voice.volume"}}>−</button>
              <Input @value={{this.pending_preferences.device.voice.volume}} class="md-number-picker__input" id="voice_volume" placeholder="1.0" />
              <button type="button" class="md-number-picker__btn" {{action "plus_minus" "plus" "this.pending_preferences.device.voice.volume"}}>+</button>
            </div>
            <button class='btn btn-default' {{action "test_voice"}} style="white-space: nowrap;">{{t "Test Voice" key='test_voice'}}</button>
          </div>
          <p class='form-control-static' style='margin-top: 8px;'><em>{{t "Some voices may not support changing pitch or volume" key='voice_pitch_volume_note'}}</em></p>
        </div>
      </div>
      {{#if this.audio_target_available}}
        <div class="form-group">
          <label for="voice_output" class="col-sm-3 control-label">{{t "Voice & Output" key='voice_output'}}</label>
          <div class="col-sm-5">
            {{bound-select select_class="form-control" select_id="voice_output" content=this.audioOutputList selection=this.pending_preferences.device.voice.target action=(action (mut this.pending_preferences.device.voice.target)) }}
            {{#if audio_switching_delays.primary}}
              <em>{{t "There may be a short delay on this device if switching between different outputs" key='possible_output_delay'}}</em>
            {{/if}}
          </div>
        </div>
      {{/if}}

      <div class="form-group">
        <label for="alternate_voice" class="col-sm-3 control-label">{{t "Secondary Voice" key='secondary_voice'}}</label>
        <div class="col-sm-5">
          <div class="checkbox big_checkbox">
            <label>
              <Input @type="checkbox" @checked={{this.pending_preferences.device.alternate_voice.enabled}} id="alternate_voice" />
              {{t "Use My Secondary Voice for Some Prompts" key='use_different_prompting_voice'}}
            </label>
          </div>
        </div>
      </div>
      {{#if this.pending_preferences.device.alternate_voice.enabled}}
        {{#if this.user_voice_list}}
          <div class="form-group">
            <div class="col-sm-3 col-xs-7 col-sm-offset-3">
              {{bound-select select_class="form-control" select_id="alternate_voice_uri" content=this.user_voice_list selection=this.pending_preferences.device.alternate_voice.voice_uri action=(action (mut this.pending_preferences.device.alternate_voice.voice_uri)) }}
            </div>
          </div>
        {{/if}}
        <div class="form-group">
          <label for="alternate_voice_purposes" class="col-sm-3 col-xs-12 control-label">{{t "Secondary Voice Purpose" key='alternate_voice_purpose'}}</label>
          <div class="col-sm-5 col-xs-7">
            <div class="checkbox big_checkbox">
              <label>
                <Input @type="checkbox" @checked={{this.pending_preferences.device.alternate_voice.for_scanning}} disabled={{this.not_scanning}} id="for_scanning" />
                {{t "Use for Scanning Prompts" key='use_for_scanning'}}
              </label>
            </div>
            <div class="checkbox big_checkbox" style='display: none;'>
              <label>
                <Input @type="checkbox" @checked={{this.pending_preferences.device.alternate_voice.for_fishing}} disabled={{this.not_fishing}} id="for_fishing" />
                {{t "Use for Auditory Fishing" key='use_for_fishing'}}
              </label>
            </div>
            <div class="checkbox big_checkbox">
              <label>
                <Input @type="checkbox" @checked={{this.pending_preferences.device.alternate_voice.for_integrations}} id="for_integrations" />
                {{t "Use for Third-Party Integrations" key='use_for_integrations'}}
              </label>
            </div>
            <div class="checkbox big_checkbox">
              <label>
                <Input @type="checkbox" @checked={{this.pending_preferences.device.alternate_voice.for_buttons}} id="for_buttons" />
                {{t "Use for Button Presses" key='use_for_buttons'}}
              </label>
            </div>
            <div class="checkbox big_checkbox">
              <label>
                <Input @type="checkbox" @checked={{this.pending_preferences.device.alternate_voice.for_messages}} id="for_messages" />
                {{t "Use for Inbound Messages" key='use_for_messages'}}
              </label>
            </div>
          </div>
        </div>
        <div class="form-group">
          <label for="alternate_voice_rate" class="col-sm-3 col-xs-12 control-label">{{t "Secondary Voice Rate" key='alternate_voice_rate'}}</label>
          <div class="col-sm-3 col-xs-7">
            <div class="input-group">
              <span class="input-group-btn">
                <button type="button" class="btn btn-default" {{action "plus_minus" "minus" "this.pending_preferences.device.alternate_voice.rate"}}>-</button>
              </span>
              <Input @value={{this.pending_preferences.device.alternate_voice.rate}} class="form-control" id="alternate_voice_rate" placeholder="1.0" />
              <span class="input-group-btn">
                <button type="button" class="btn btn-default" {{action "plus_minus" "plus" "this.pending_preferences.device.alternate_voice.rate"}}>+</button>
              </span>
            </div>
          </div>
        </div>
        <div class="form-group">
          <label for="alternate_voice_pitch" class="col-sm-3 col-xs-12 control-label">{{t "Secondary Voice Pitch" key='secondary_voice_pitch'}}</label>
          <div class="col-sm-3 col-xs-7">
            <div class="input-group">
              <span class="input-group-btn">
                <button type="button" class="btn btn-default" {{action "plus_minus" "minus" "this.pending_preferences.device.alternate_voice.pitch"}}>-</button>
              </span>
              <Input @value={{this.pending_preferences.device.alternate_voice.pitch}} class="form-control" id="alternate_voice_pitch" placeholder="1.0" />
              <span class="input-group-btn">
                <button type="button" class="btn btn-default" {{action "plus_minus" "plus" "this.pending_preferences.device.alternate_voice.pitch"}}>+</button>
              </span>
            </div>
          </div>
        </div>
        <div class="form-group">
          <label for="alternate_voice_volume" class="col-sm-3 col-xs-12 control-label">{{t "Secondary Voice Volume" key='alternate_voice_volume'}}</label>
          <div class="col-sm-3 col-xs-7">
            <div class="input-group">
              <span class="input-group-btn">
                <button type="button" class="btn btn-default" {{action "plus_minus" "minus" "this.pending_preferences.device.alternate_voice.volume"}}>-</button>
              </span>
              <Input @value={{this.pending_preferences.device.alternate_voice.volume}} class="form-control" id="alternate_voice_volume" placeholder="1.0" />
              <span class="input-group-btn">
                <button type="button" class="btn btn-default" {{action "plus_minus" "plus" "this.pending_preferences.device.alternate_voice.volume"}}>+</button>
              </span>
            </div>
          </div>
          <div class="col-sm-2 col-xs-5">
            <button class='btn btn-default' {{action "test_voice" 'alternate'}}>{{t "Test Voice" key='test_voice'}}</button>
          </div>
        </div>
      {{#if this.audio_target_available}}
          <div class="form-group">
            <label for="alternate_voice_output" class="col-sm-3 control-label">{{t "Secondary Voice Output" key='alternate_voice_output'}}</label>
            <div class="col-sm-5">
              {{bound-select select_class="form-control" select_id="alternate_voice_output" content=this.audioOutputList selection=this.pending_preferences.device.alternate_voice.target action=(action (mut this.pending_preferences.device.alternate_voice.target)) }}
              {{#if audio_switching_delays.alternate}}
                <em>{{t "There may be a short delay on this device if switching between different outputs" key='possible_output_delay'}}</em>
              {{/if}}
            </div>
          </div>
        {{/if}}
      {{/if}}
    {{/preference-box}}
  {{/unless}}
  
  {{#if this.pending_preferences.device.allows_home_override}}
    <div class="form-group">
      <label for="hard_sidebar" class="col-sm-3 control-label">{{t "Device Home" key='device_home'}}</label>
      <div class="col-sm-5">
        <div class="checkbox big_checkbox">
          <label>
            <Input @type="checkbox" @checked={{this.pending_preferences.device.device_home}} id="device_home" />
            {{t "Replace the device's home screen with %app_name%" key='device_home_screen'}}
          </label>
        </div>
      </div>
    </div>
  {{/if}}
  {{#unless this.advanced}}
    <div class="form-group">
      <div class="col-sm-5 col-sm-offset-3">
        <a href="#" {{action 'toggle_advanced'}}>{{t "more options" key='more_options'}}</a>
      </div>
    </div>
  {{/unless}}
  <div class="md-preferences__actions">
    <button type="submit" class="btn btn-primary">
      {{#if (get this "status.saving")}}
        {{t "Saving Preferences..." key='saving_preferences'}}
      {{else if (get this "status.error")}}
        {{t "Error Saving Preferences" key='error_saving_preferences'}}
      {{else}}
        {{t "Save Preferences" key='save_preferences'}}
      {{/if}}
    </button>
    <button type="button" class="btn btn-default" {{action "cancelSave"}}>{{t "Cancel" key='cancel'}}</button>
  </div>
  </form>
</div>
{{else if this.session.isAuthenticated}}
  <p>{{t "It looks like you don't have permission to access this information" key='not_authorized_for_access'}}</p>
{{else}}
  {{login-form left=true prompt=true return=true}}
{{/if}}
