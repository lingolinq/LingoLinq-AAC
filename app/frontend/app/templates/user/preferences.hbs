            <label>
              <Input @type="checkbox" @checked={{this.pending_preferences.lock_quick_sidebar}} id="lock_quick_sidebar" />
              {{t "Don't allow hiding quick actions sidebar" key='never_hide_quick_sidebar'}}
            </label>
          </div>
        {{/unless}}
      </div>
    </div>

    {{#unless this.pending_preferences.disable_quick_sidebar}}
      <div class="form-group">
