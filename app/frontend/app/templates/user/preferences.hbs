        {{else if this.core_lists}}
          <p class='form-control-static' style='margin-bottom: 14px;'><em>{{t "Core words are the most common words in a language, and often express multiple intents or meanings. The following list of words will be marked as \"core\" (as opposed to \"fringe\") for this user." key='core_words_explainer'}}</em></p>
          <div style='max-height: 120px; overflow: auto; padding: 12px 18px; border: 1.5px solid rgba(17, 26, 46, 0.08); border-radius: 10px; background: rgba(248, 250, 252, 0.8); margin-bottom: 14px; line-height: 1.6; font-size: 14px;'>
