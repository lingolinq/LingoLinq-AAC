            <div class="col-sm-2">
              {{bound-select select_class="form-control" select_id="dwell_release_distance" content=this.dwellReleaseDistanceList selection=this.pending_preferences.device.dwell_release_distance action=(action (mut this.pending_preferences.device.dwell_release_distance)) }}
            </div>
            <div class="col-sm-3">
              <p class='form-control-static'>{{t "before starting a new selection" key='move_after_select'}}</p>
            </div>
          </div>
          <div class="form-group">
