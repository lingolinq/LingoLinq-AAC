  {{#preference-box title="Sidebar and Shortcuts" glyph='glyphicon glyphicon-link' title_key='sidebar_and_shortcuts'}}
    <span style='display: none;'>{{t "Sidebar and Shortcuts" key='sidebar_and_shortcuts'}}</span>
