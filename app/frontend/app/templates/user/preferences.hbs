          <div class="col-sm-5">
            <div class="checkbox big_checkbox">
              <label>
                <Input @type="checkbox" @checked={{this.pending_preferences.device.dwell_modeling}} id="dwell_modeling" />
                {{t "Mark clicks/touches as modeling events, not user selections" key='touch_as_modeling'}}
              </label>
            </div>
          </div>
        </div>
