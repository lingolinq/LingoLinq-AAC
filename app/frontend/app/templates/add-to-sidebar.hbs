{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="modal-header">
      <button type="button" class="close" {{action "close"}}>&times;</button>
    <h3>
      {{t "Add Board to Sidebar" key="add_board_to_sidebar"}}
    </h3>
  </div>
  <div class="modal-body">
    <form class="form-horizontal" {{action "nothing" on="submit"}}>
      <p>
        {{t "The sidebar is a set of quick links you can use to jump to commonly-used boards other than the home board. It can be useful for school or home-specific board sets, quick phrases, keyboard access, etc." key="sidebar_boards_explanation"}}
      </p>
      <div class="form-group">
        <label for="name" class="col-sm-2 control-label">{{t "Board" key="board"}}</label>
        <div class="col-sm-10">
          <p class='form-control-static'>{{this.model.board.key}}</p>
        </div>
      </div>
      <div class="form-group">
        <label for="name" class="col-sm-2 control-label">{{t "Name" key="name"}}</label>
        <div class="col-sm-10">
          <div style="width: 100px;">
            {{input value=this.model.board.name class="form-control" id="name" placeholder="Board"}}
          </div>
        </div>
      </div>
      <div class="form-group">
        <label for="icon" class="col-sm-2 control-label">{{t "Icon" key="icon"}}</label>
        <div class="col-sm-10">
          {{icon-select selection=this.model.board.image action=(action (mut this.model.board.image)) }}
        </div>
      </div>
      {{#if this.model.board.levels}}
        {{#if this.app_state.feature_flags.board_levels}}
          <div class="form-group">
            <label for="level" class="col-sm-2 control-label">{{t "Level" key="level"}}</label>
            <div class="col-sm-10">
              {{bound-select select_class="form-control" select_id="level" content=this.board_levels selection=this.model.level action=(action (mut this.model.level)) }}
            </div>
          </div>
        {{/if}}
      {{/if}}
      <div class="form-group">
        <label for="home" class="col-sm-2 control-label">{{t "Home" key="home"}}</label>
        <div class="col-sm-10">
          <label id='home'>
            {{input type="checkbox" checked=this.model.board.home_lock}}
            {{t "Set as temporary Home when loaded from the sidebar" key="set_home_lock_sidebar"}}
          </label>
        </div>
      </div>
    </form>

    {{#if this.has_supervisees}}
      <p>
        {{t "For which user would you like to add <b>%{board_key}</b> as a sidebar board?" key="which_user_set_as_sidebar" board_key=this.model.board.key}}
      </p>
      {{user-select select_id="currently_selected_id" buttons=true selection=this.currently_selected_id action=(action (mut this.currently_selected_id)) }}
    {{/if}}

    {{#if this.error}}
      <p class='text-danger'>{{t "Adding to sidebar failed unexpectedly" key="add_to_sidebar_failed"}}</p>
    {{/if}}
  </div>
  <div class="modal-footer">
    <button {{action "add"}} class="btn btn-primary" disabled={{this.loading}}>
      {{#if this.loading}}
        {{t "Adding to Sidebar..." key="adding_to_sidebar"}}
      {{else}}
        {{t "Add Board to Sidebar" key="add_board_to_sidebar"}}
      {{/if}}
    </button>
    <button {{action "close"}} class="btn btn-default" disabled={{this.loading}}>{{t "Cancel" key="cancel"}}</button>
  </div>
{{/modal-dialog}}
