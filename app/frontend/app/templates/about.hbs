<div class="la-wrapper la-wrapper--about">
  <div class="app-shell">
    <main class="la-main" role="main">

      {{!-- ── Hero Intro (same styling as pricing page top) ── --}}
      <section id="about-hero" class="la-section">
        <div class="la-section-header" style="display: block; text-align: center;">
          <span class="la-section-eyebrow-badge">{{t "About" key="about"}} <span class="la-about-hero-brand">Lingo</span><span class="la-about-hero-brand la-about-hero-brand--italic">Linq</span></span>
          <div class="la-hero-title-wrap">
            <h1 class="la-hero-title">
              {{t "Every voice should be" key="every_voice_should_be"}} {{t "heard" key="heard"}}
            </h1>
          </div>
          <hr class="la-about-hero-separator" aria-hidden="true">
          <p class="la-pricing-hero-subtitle">{{t "Open-source AAC that works everywhere—in the cloud, offline, and across every device." key="about_hero_subtitle"}}</p>
        </div>
        <div class="la-feature-grid">
          <div class="la-feature-card">
            <div class="la-feature-icon la-feature-icon--teal" aria-hidden="true">💬</div>
            <h3>{{t "The Challenge" key="about_the_challenge"}}</h3>
            <p>{{t "Some people need help being heard -- and the tools out there? Often clunky, confusing, and way too expensive." key="the_challenge_text"}} <strong>{{t "We're here to change that." key="the_challenge_cta"}}</strong></p>
          </div>
          <div class="la-feature-card">
            <div class="la-feature-icon la-feature-icon--navy" aria-hidden="true">🔗</div>
            <h3>{{t "Our Mission" key="about_our_mission"}}</h3>
            <p>{{t "LingoLinq means linking language to the people who need it most. Everyone deserves a voice that's easy to use, affordable, and just works." key="our_mission_text"}} <strong>{{t "That's what LingoLinq is all about." key="our_mission_closer"}}</strong></p>
          </div>
          <div class="la-feature-card la-feature-card--cta">
            <div class="la-feature-icon la-feature-icon--coral" aria-hidden="true">🚀</div>
            <h3>{{t "Get Started" key="about_get_started"}}</h3>
            <p>{{t "Start with our free tier. No credit card, no hardware, no commitment." key="landing_cta_subtitle_intro"}} <strong>{{t "Just communication tools that work." key="landing_cta_subtitle_closer"}}</strong></p>
            <div class="la-about-hero-actions">
              <LinkTo @route="register" class="la-btn la-btn--primary">{{t "Try LingoLinq Free" key="landing_try_free"}} &rarr;</LinkTo>
              <LinkTo @route="contact" class="la-btn la-btn--ghost">{{t "Contact Us" key="contact_us"}}</LinkTo>
            </div>
          </div>
        </div>
      </section>

      {{!-- ── What We Offer (feature cards, same as landing-alt) ── --}}
      <section id="about-what-we-offer" class="la-section">
        <div class="la-section-header">
          <span class="la-section-eyebrow-badge">{{t "What We Offer" key="about_what_we_offer"}}</span>
          <h2 class="la-section-title">{{t "Built around" key="about_features_title_1"}} <em>{{t "what matters" key="about_features_title_2"}}</em></h2>
          <hr class="la-about-hero-separator" aria-hidden="true">
        </div>
        <div class="la-feature-grid">
          <div class="la-feature-card">
            <div class="la-feature-icon la-feature-icon--teal">📖</div>
            <h3>{{t "Learn as You Go" key="learn_as_you_go"}}</h3>
            <p>{{t "Expert-designed templates and training so you never start from scratch." key="learn_as_you_go_catchphrase"}}</p>
          </div>
          <div class="la-feature-card">
            <div class="la-feature-icon la-feature-icon--coral">☁️</div>
            <h3>{{t "Work Offline" key="work_offline"}}</h3>
            <p>{{t "Communicate anywhere -- boards and logs sync when you reconnect." key="work_offline_catchphrase"}}</p>
          </div>
          <div class="la-feature-card">
            <div class="la-feature-icon la-feature-icon--navy">🔄</div>
            <h3>{{t "Personalization and Sync" key="personalization"}}</h3>
            <p>{{t "Your setup follows you across every device, always up to date." key="personalization_catchphrase"}}</p>
          </div>
          <div class="la-feature-card">
            <div class="la-feature-icon la-feature-icon--coral">🤝</div>
            <h3>{{t "Create, Share and Reuse" key="create_share"}}</h3>
            <p>{{t "Discover boards, share openly, and build on each other's work." key="create_share_catchphrase"}}</p>
          </div>
          <div class="la-feature-card">
            <div class="la-feature-icon la-feature-icon--teal">👥</div>
            <h3>{{t "Team Coordination" key="coordination"}}</h3>
            <p>{{t "Therapists and families collaborate without taking the device away." key="coordination_catchphrase"}}</p>
          </div>
          <div class="la-feature-card">
            <div class="la-feature-icon la-feature-icon--navy">📊</div>
            <h3>{{t "Insights" key="insights"}}</h3>
            <p>{{t "Clear reports that show what's working and where to focus next." key="insights_catchphrase"}}</p>
          </div>
        </div>
      </section>

      {{!-- ── Security & Open Source ── --}}
      <section class="la-plan-section">
        <div class="la-plan-layout">
          <div class="la-plan-text">
            <span class="la-section-eyebrow-badge">{{t "Trust & Transparency" key="about_trust_transparency"}}</span>
            <h2 class="la-plan-title">{{t "Your data deserves" key="about_security_title_1"}}<br><em>{{t "real protection" key="about_security_title_2"}}</em></h2>
            <p class="la-plan-subtitle">{{t "We're talking about someone's voice -- potentially everything they ever say. That's deeply personal, and we treat it that way. Your data is encrypted, never shared without permission, and always yours to export." key="trust_transparency_text"}}</p>
          </div>
          <div class="la-plan-grid-container">
            <ul class="la-plan-grid">
              <li class="la-plan-item">
                <span class="la-plan-check" aria-hidden="true">✓</span>
                <span>{{t "Encrypted data storage" key="about_check_encrypted"}}</span>
              </li>
              <li class="la-plan-item">
                <span class="la-plan-check" aria-hidden="true">✓</span>
                <span>{{t "No sharing without permission" key="about_check_no_sharing"}}</span>
              </li>
              <li class="la-plan-item">
                <span class="la-plan-check" aria-hidden="true">✓</span>
                <span>{{t "Open source codebase" key="about_check_open_source"}}</span>
              </li>
              <li class="la-plan-item">
                <span class="la-plan-check" aria-hidden="true">✓</span>
                <span>{{t "Easy data export" key="about_check_export"}}</span>
              </li>
              <li class="la-plan-item">
                <span class="la-plan-check" aria-hidden="true">✓</span>
                <span>{{t "Open Board Format standard" key="about_check_obf"}}</span>
              </li>
              <li class="la-plan-item">
                <span class="la-plan-check" aria-hidden="true">✓</span>
                <span>{{t "Privacy-first design" key="about_check_privacy"}}</span>
              </li>
            </ul>
          </div>
        </div>
      </section>

      <section class="la-a11y-statement">
        <div class="la-a11y-statement-inner">
          <div class="la-a11y-statement-header">
            <span class="la-a11y-statement-icon" aria-hidden="true">&lt;/&gt;</span>
            <span class="la-section-eyebrow-badge">{{t "Open Source" key="open_source"}}</span>
          </div>
          <div class="la-a11y-statement-content">
            <p>{{t "Proprietary AAC tools lock you in and hide how they work. <a href='https://github.com/lingolinq/LingoLinq-AAC' target='_blank' rel='noopener'>%app_name% is open source</a> — inspect the code, export your data anytime, and never worry about vendor lock-in." key="open_source_content_concise"}}</p>
          </div>
        </div>
      </section>

      {{!-- ── CTA ── --}}
      <section class="la-cta-section">
        <div class="la-cta-inner">
          <span class="la-section-eyebrow-badge">{{t "Ready to start?" key="fsa_ready_to_start"}}</span>
          <h2 class="la-cta-headline">{{t "Give every student" key="landing_cta_title_1"}} <em>{{t "a voice" key="landing_cta_title_2"}}</em></h2>
          <hr class="la-about-hero-separator" aria-hidden="true">
          <p class="la-cta-description">{{t "Start with our free tier. No credit card, no hardware, no commitment." key="landing_cta_subtitle_intro"}} <strong class="la-challenge-cta">{{t "Just communication tools that work." key="landing_cta_subtitle_closer"}}</strong></p>
          <div class="la-cta-buttons">
            <LinkTo @route="register" class="la-btn la-btn--primary la-btn--lg">{{t "Start Free Today" key="landing_cta_start"}} &rarr;</LinkTo>
            <LinkTo @route="contact" class="la-btn la-btn--ghost">{{t "Contact Us" key="contact_us"}}</LinkTo>
          </div>
        </div>
      </section>

      {{!-- ── Attributions ── --}}
      <section class="la-attr-section">
        <div class="la-attr-header">
          <span class="la-section-eyebrow-badge">{{t "Attributions" key="attributions"}}</span>
          <p class="la-attr-meta">
            {{t "app version:" key="version_colon"}} {{this.app_state.version}}
            &middot;
            {{t "recognized device:" key="recognized_device_colon"}} {{this.app_state.device_name}}
          </p>
        </div>

        <div class="la-attr-grid">
          <div class="la-attr-card">
            <h4 class="la-attr-card__title">{{t "Keyboard Data" key="about_attr_keyboard"}}</h4>
            <p class="la-attr-card__body"><a href="http://aactext.org/imagine/" target="_blank" rel="noopener">keyboard suggestion word file</a> by <a href="http://aactext.org/imagine/" target="_blank" rel="noopener">aactext.org</a> / <a href="https://creativecommons.org/licenses/by-nd/3.0/" target="_blank" rel="noopener">CC By-ND</a></p>
          </div>

          <div class="la-attr-card">
            <h4 class="la-attr-card__title">{{t "Board Icons & Suggestions" key="about_attr_icons"}}</h4>
            <p class="la-attr-card__body">
              <a href="https://mulberrysymbols.org/" target="_blank" rel="noopener">Paxtoncrafts Charitable Trust</a> / <a href="https://creativecommons.org/licenses/by-sa/2.0/uk" target="_blank" rel="noopener">CC By-SA</a><br>
              <a href="https://arasaac.org/terms-of-use" target="_blank" rel="noopener">Sergio Palao</a> / <a href="https://creativecommons.org/licenses/by-nc-sa/3.0/" target="_blank" rel="noopener">CC By-NC-SA</a><br>
              <a href="https://thenounproject.com/sherrera" target="_blank" rel="noopener">Silvia Herrera</a> / <a href="https://creativecommons.org/licenses/by-nc/3.0/" target="_blank" rel="noopener">CC By</a><br>
              <a href="https://thenounproject.com/hayley.warren.3726" target="_blank" rel="noopener">Hayley Warren</a> / <a href="https://creativecommons.org/licenses/by-nc/3.0/" target="_blank" rel="noopener">CC By-SA</a><br>
              <a href="https://thenounproject.com/Fhlcreative" target="_blank" rel="noopener">Phil Goodwin</a> / <a href="https://creativecommons.org/licenses/by-nc/3.0/" target="_blank" rel="noopener">CC By-SA</a><br>
              <a href="https://github.com/twitter/twemoji" target="_blank" rel="noopener">Twitter Emoji</a> / <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener">CC By</a>
            </p>
          </div>

          <div class="la-attr-card">
            <h4 class="la-attr-card__title">{{t "Symbol Sets" key="about_attr_symbols"}}</h4>
            <p class="la-attr-card__body">
              <a href="https://www.opensymbols.org" target="_blank" rel="noopener">OpenSymbols</a> / <a href="https://creativecommons.org/licenses/by/3.0" target="_blank" rel="noopener">CC By</a><br>
              <a href="https://arasaac.org/terms-of-use" target="_blank" rel="noopener">Sergio Palao, ARASAAC</a> / <a href="https://creativecommons.org/licenses/by-nc-sa/3.0/" target="_blank" rel="noopener">CC By-NC-SA</a><br>
              <a href="https://mulberrysymbols.org/" target="_blank" rel="noopener">Paxtoncrafts Charitable Trust</a> / <a href="https://creativecommons.org/licenses/by-sa/2.0/uk" target="_blank" rel="noopener">CC By-SA</a><br>
              <a href="https://www.opensymbols.org/repositories/language-craft" target="_blank" rel="noopener">LanguageCraft</a> / <a href="https://creativecommons.org/licenses/by-nc-sa/3.0/" target="_blank" rel="noopener">CC By-NC-SA</a><br>
              <a href="https://www.sclera.be/en/picto/overview" target="_blank" rel="noopener">Sclera</a> / <a href="https://creativecommons.org/licenses/by-nc/2.0/" target="_blank" rel="noopener">CC By-NC</a>
            </p>
          </div>

          <div class="la-attr-card">
            <h4 class="la-attr-card__title">{{t "Word Libraries" key="about_attr_words"}}</h4>
            <p class="la-attr-card__body">
              <a href="https://en.wikipedia.org/wiki/Moby_Project" target="_blank" rel="noopener">Moby Project word lists</a> (Grady Ward)<br>
              <a href="https://words.bighugelabs.com" target="_blank" rel="noopener">words.bighugelabs.com</a>
            </p>
          </div>

          <div class="la-attr-card">
            <h4 class="la-attr-card__title">{{t "Typefaces" key="about_attr_typefaces"}}</h4>
            <p class="la-attr-card__body">
              <a href="https://opendyslexic.org/legal/" target="_blank" rel="noopener">OpenDyslexic by Bitstream, Inc.</a><br>
              <a href="https://kimberlygeswein.com" target="_blank" rel="noopener">Architect's Daughter by Kimberly Geswein</a> / <a href="https://scripts.sil.org/cms/scripts/page.php?site_id=nrsi&id=OFL" target="_blank" rel="noopener">OFL</a>
            </p>
          </div>

          {{#if this.showPhotographyAttribution}}
            <div class="la-attr-card">
              <h4 class="la-attr-card__title">{{t "Photography" key="about_attr_photography"}}</h4>
              <p class="la-attr-card__body"><a href="https://www.flickr.com/photos/56155476@N08/6659988251/in/photostream/" target="_blank" rel="noopener">splash page photo</a> by Lexie Flickinger / <a href="https://creativecommons.org/licenses/by/2.0/" target="_blank" rel="noopener">CC By</a></p>
            </div>
          {{/if}}
        </div>
      </section>

    </main>
  </div>
</div>
