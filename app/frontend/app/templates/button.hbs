<!-- TODO: I think this is only used in Edit Mode -->
<a href='#' style={{this.button.computed_style}} class={{this.button.computed_class}} data-id={{this.button.id}} tabindex="0">
  {{#if this.button.pending}}
    <div class="pending">
      <img src={{path "images/spinner.gif"}} draggable='false' >
    </div>
  {{/if}}
  <div class={{this.button.action_class}}>
    <span class="action">
      <img src={{this.button.action_image}} alt={{this.button.action_alt}} draggable='false' >
    </span>
  </div>
  <span class='img_holder' style={{this.button.image_holder_style}}>
    {{#unless this.app_state.currentUser.hide_symbols}}
      {{#unless this.button.board.text_only}}
        {{#unless this.button.text_only}}
          <img src={{this.button.local_image_url}} rel={{this.button.original_image_url}} draggable='false' onerror="button_broken_image(this);" style={{this.button.image_style}} class={{if this.button.hc_image "symbol hc" "symbol"}}>
        {{/unless}}
      {{/unless}}
    {{/unless}}
  </span>
  <div class={{if this.button.text_only this.text_only_button_symbol_class this.button_symbol_class}}>
    {{#if this.editModeNormalText}}
      {{#if this.button.sound}}
        <div class="sound_container">
          <span class="glyphicon glyphicon-volume-up"></span>
        </div>
      {{/if}}
      {{label-field value=this.button.label class="button-label" placeholder="enter label"}}
      {{#if this.button.levels_list}}
        <span class='levels' style='opacity: 0.7;'>{{this.button.levels_list}}</span>
      {{/if}}
    {{else}}
      {{#unless this.button.hide_label}}
        <span class="button-label">{{this.button.label}}</span>
      {{/unless}}
    {{/if}}
  </div>
</a>
