<div class="md-shell md-shell--home-boards">
  <div class="md-workspace">
    <main class="md-main md-main--home-boards">
      <header class="md-hero md-hero--home-boards">
        <h1 class="md-hero__title">{{t "Finding the Right Home Board" key="finding_a_home_board"}}</h1>
        {{#unless this.advanced}}
          <p class="md-hero__sub">{{t "Choose a layout that fits the communicator, then set it as your home board." key="finding_home_board_hero_sub"}}</p>
        {{/unless}}
      </header>
      <article class="md-card md-card--home-boards">
        {{#if this.advanced}}
          <div class="md-card--home-boards__subheader">
            <p class="md-card--home-boards__subheader-lead">{{t "Your home board is your starting point—for quick phrases and for going deeper. Board styles vary. The right one depends on the person. Here are options with notes on why each might help." key="finding_home_board1"}}</p>
            <p class="md-card--home-boards__subheader-support">{{t "When you find one that fits, use the menu and choose \"Set as Home\" to make it yours." key="finding_home_board2"}}</p>
          </div>
          <div class="md-card--home-boards__picker">
            {{board-picker}}
          </div>
        {{else}}
          {{board-selection-tool search=true loadError=(action "show_advanced") advanced=(action "show_advanced") onSelect=(action "select_board")}}
        {{/if}}
      </article>
    </main>
  </div>
</div>
