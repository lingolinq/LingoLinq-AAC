<div class="search-page ub-boards-page ub-search-page">
  {{!-- Page header: title + search form ──────────────────────── --}}
  <div class="la-section-header ub-boards-page__page-header ub-search-page__header">
    <span class="la-section-eyebrow-badge">{{t "Find Boards" key="find_board"}}</span>
    <div class="la-hero-title-wrap">
      <h1 class="la-hero-title">{{t "Search for " key="search_for_boards_prefix"}}<span class="ub-search-page__title-boards">{{t "Boards" key="boards"}}</span></h1>
    </div>
    <hr class="la-about-hero-separator" aria-hidden="true">
    <div class="ub-search-page__form-wrap">
      <form class="ub-search-page__form" {{action "searchBoards" on="submit"}}>
        <div class="ub-search-page__form-row">
          <label for="search-page-query" class="ub-search-page__label">{{t "Search Boards" key="search_boards"}}</label>
          <Input
            id="search-page-query"
            @type="text"
            @value={{this.searchString}}
            @enter={{action "searchBoards"}}
            class="ub-search-page__input form-control"
            placeholder={{t "Search Boards" key="search_boards"}}
          />
          <div class="ub-search-page__locale-wrap thin_select">
            {{bound-select select_class="form-control ub-search-page__locale" content=this.locales selection=this.locale action=(action (mut this.locale)) }}
          </div>
          <button type="submit" class="md-btn md-btn--primary ub-search-page__go">{{t "Go" key="go"}}</button>
        </div>
        {{#if this.app_state.currentUser}}
          <div class="ub-search-page__actions">
            <a href="#" class="ub-search-page__link" {{action "newBoard"}}>{{t "Create a New Board" key="create_a_new_board"}}</a>
            <span class="ub-search-page__sep" aria-hidden="true">·</span>
            <LinkTo @route="home-boards" class="ub-search-page__link">{{t "Help Me Choose a Home Board" key="help_me_choose_a_home_board"}}</LinkTo>
          </div>
        {{/if}}
      </form>
    </div>
  </div>

  <div class="ub-boards-page__content">
    {{!-- Online Results section (same card/grid as boards page) ── --}}
    <section class="ub-boards-page__boards-section" aria-labelledby="search-online-heading">
      <div class="ub-boards-page__boards-header">
        <h2 id="search-online-heading" class="ub-boards-page__boards-title">{{t "Online Results" key="online_results"}}</h2>
      </div>
      {{#if this.online_results}}
        {{#if this.online_results.loading}}
          <p class="ub-boards-page__loading">{{t "Loading..." key="loading"}}</p>
        {{else if this.online_results.results}}
          <div class="ub-boards-page__board-grid ub-search-page__board-grid">
            {{#each this.online_results.results as |board|}}
              {{#if board.key}}
                <div class="ub-boards-page__board-item board_with_action simple_board_holder">
                  {{board-icon board=board}}
                </div>
              {{/if}}
            {{/each}}
          </div>
        {{else}}
          {{#if (persistence-online)}}
            <p class="ub-search-page__none-found">{{t "None found" key="none_found"}}</p>
          {{else}}
            <p class="ub-boards-page__loading">{{t "Not online, connect to the Internet to see results" key="not_online_connect"}}</p>
          {{/if}}
        {{/if}}
      {{/if}}
    </section>

    {{!-- My Boards section (when logged in and online) ────────── --}}
    {{#if this.app_state.currentUser}}
      {{#if (persistence-online)}}
        <section class="ub-boards-page__boards-section" aria-labelledby="search-my-boards-heading">
          <div class="ub-boards-page__boards-header">
            <h2 id="search-my-boards-heading" class="ub-boards-page__boards-title">{{t "My Boards" key="my_boards"}}</h2>
            <LinkTo @route="user.index" @model={{this.app_state.currentUser.user_name}} class="md-btn ub-search-page__see-all">{{t "See All My Boards" key="see_all_my_boards"}}</LinkTo>
          </div>
          {{#if this.personal_results}}
            {{#if this.personal_results.loading}}
              <p class="ub-boards-page__loading">{{t "Loading..." key="loading"}}</p>
            {{else if this.personal_results.results}}
              <div class="ub-boards-page__board-grid ub-search-page__board-grid">
                {{#each this.personal_results.results as |board|}}
                  {{#if board.key}}
                    <div class="ub-boards-page__board-item board_with_action simple_board_holder">
                      {{board-icon board=board}}
                    </div>
                  {{/if}}
                {{/each}}
              </div>
            {{else}}
              <p class="ub-search-page__none-found">{{t "None found" key="none_found"}}</p>
            {{/if}}
          {{/if}}
        </section>
      {{else}}
        {{!-- Local Results (when logged in but offline) ────────── --}}
        {{#unless this.local_results.impossible}}
          <section class="ub-boards-page__boards-section" aria-labelledby="search-local-heading">
            <div class="ub-boards-page__boards-header">
              <h2 id="search-local-heading" class="ub-boards-page__boards-title">{{t "Local Results" key="local_results"}}</h2>
            </div>
            {{#if this.local_results}}
              {{#if this.local_results.loading}}
                <p class="ub-boards-page__loading">{{t "Loading..." key="loading"}}</p>
              {{else if this.local_results.results}}
                <div class="ub-boards-page__board-grid ub-search-page__board-grid">
                {{#each this.local_results.results as |board|}}
                  {{#if board.key}}
                    <div class="ub-boards-page__board-item board_with_action simple_board_holder">
                      {{board-icon board=board}}
                    </div>
                  {{/if}}
                {{/each}}
              </div>
            {{else}}
              <p class="ub-search-page__none-found">{{t "None found" key="none_found"}}</p>
            {{/if}}
          {{/if}}
        </section>
        {{/unless}}
      {{/if}}
    {{else}}
      {{!-- Local Results (when not logged in) ─────────────────── --}}
      {{#unless this.local_results.impossible}}
        <section class="ub-boards-page__boards-section" aria-labelledby="search-local-heading">
          <div class="ub-boards-page__boards-header">
            <h2 id="search-local-heading" class="ub-boards-page__boards-title">{{t "Local Results" key="local_results"}}</h2>
          </div>
          {{#if this.local_results}}
            {{#if this.local_results.loading}}
              <p class="ub-boards-page__loading">{{t "Loading..." key="loading"}}</p>
            {{else if this.local_results.results}}
              <div class="ub-boards-page__board-grid ub-search-page__board-grid">
                {{#each this.local_results.results as |board|}}
                  {{#if board.key}}
                    <div class="ub-boards-page__board-item board_with_action simple_board_holder">
                      {{board-icon board=board}}
                    </div>
                  {{/if}}
                {{/each}}
              </div>
            {{else}}
              <p class="ub-search-page__none-found">{{t "None found" key="none_found"}}</p>
            {{/if}}
          {{/if}}
        </section>
      {{/unless}}
    {{/if}}
  </div>
</div>
