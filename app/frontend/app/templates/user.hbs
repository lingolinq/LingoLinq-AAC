{{#if this.bareUserOutletLayout}}
  {{outlet}}
{{else}}
<div class="md-user-layout hide_print">
  {{#if (or (is-equal this.app_state.current_route "user.stats") (is-equal this.app_state.current_route "user.logs"))}}
  <div class="md-shell md-shell--reports-view">
    <div class="md-workspace">
      <nav class="md-pillnav md-pillnav--dashboard" aria-label={{t "Primary Navigation" key="primary_navigation"}}>
        <LinkTo @route="user.home" @model={{this.model.user_name}} class="md-pillnav__pill">{{t "Home" key="home"}}</LinkTo>
        <LinkTo @route="user.boards" @model={{this.model.user_name}} class="md-pillnav__pill">{{t "Boards" key="boards"}}</LinkTo>
        {{#if (is-equal this.app_state.current_route "user.stats")}}
        <span class="md-pillnav__pill is-active" aria-current="page">{{t "Reports" key="reports"}}</span>
        {{else}}
        <LinkTo @route="user.stats" @model={{this.model.user_name}} @query={{hash highlighted=null start=null end=null location_id=null device_id=null split=null start2=null end2=null device_id2=null location_id2=null}} class="md-pillnav__pill">{{t "Reports" key="reports"}}</LinkTo>
        {{/if}}
        <LinkTo @route="user.extras" @model={{this.model.user_name}} class="md-pillnav__pill">{{t "Extras" key="extras"}}</LinkTo>
      </nav>
      {{#if (is-equal this.app_state.current_route "user.stats")}}
      <header class="md-hero md-hero--dashboard md-hero--reports-dashboard" aria-label={{t "Dashboard" key="dashboard"}}>
        <h1 class="md-hero__title"><span class="md-hero__title--from-left">{{t "Reports for %{username}" key="reports_for_username" username=this.model.user_name}}</span></h1>
        <p class="md-hero__sub"><span class="md-hero__sub--from-right">{{t "Let's look at some" key="reports_dashboard_hero_sub_pre"}} <em class="md-hero__gradient-text">{{t "useful information..." key="reports_dashboard_hero_sub_em"}}</em></span></p>
      </header>
      {{/if}}
      <div class="md-user-outlet md-user-outlet--in-workspace">
        {{outlet}}
      </div>
    </div>
  </div>
  {{else}}
  <div class="md-shell md-shell--user">
    <div class="md-workspace">
      <nav class="md-pillnav md-pillnav--user" aria-label={{t "User menu" key="user_menu"}}>
        <LinkTo @route="user.account" @model={{this.model.user_name}} class="md-pillnav__pill {{if (or (is-equal this.app_state.current_route 'user.index') (is-equal this.app_state.current_route 'user.account')) 'is-active'}}">{{t "Account" key="account_lower"}}</LinkTo>
        {{#if this.model.permissions.edit}}
          <LinkTo @route="user.edit" @model={{this.model.user_name}} class="md-pillnav__pill {{if (is-equal this.app_state.current_route 'user.edit') 'is-active'}}">{{t "Profile" key="profile_lower"}}</LinkTo>
          <LinkTo @route="user.preferences" @model={{this.model.user_name}} class="md-pillnav__pill {{if (is-equal this.app_state.current_route 'user.preferences') 'is-active'}}">{{t "Preferences" key="preferences_lower"}}</LinkTo>
        {{/if}}
        <LinkTo @route="user.logs" @model={{this.model.user_name}} @query={{hash type="all"}} class="md-pillnav__pill {{if (is-equal this.app_state.current_route 'user.logs') 'is-active'}}">{{t "Logs" key="logs"}}</LinkTo>
      </nav>
      <main class="md-main md-main--user">
        {{outlet}}
      </main>
    </div>
  </div>
  {{/if}}
</div>
{{/if}}
