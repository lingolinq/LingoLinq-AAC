{{#if this.bareUserOutletLayout}}
  {{outlet}}
{{else}}
<div class="md-user-layout hide_print">
  {{#if (or (and this.from_dashboard (or (is-equal this.app_state.current_route "user.stats") (is-equal this.app_state.current_route "user.logs"))) (is-equal this.app_state.current_route "user.boards"))}}
  <div class="md-shell md-shell--reports-view">
    <div class="md-workspace">
      <nav class="md-pillnav md-pillnav--dashboard" aria-label={{t "Primary Navigation" key="primary_navigation"}}>
        <LinkTo @route="user.home" @model={{this.model.user_name}} class="md-pillnav__pill">{{t "Home" key="home"}}</LinkTo>
        {{#if (is-equal this.app_state.current_route "user.boards")}}
        <span class="md-pillnav__pill is-active" aria-current="page">{{t "Boards" key="boards"}}</span>
        {{else}}
        <LinkTo @route="user.boards" @model={{this.model.user_name}} class="md-pillnav__pill">{{t "Boards" key="boards"}}</LinkTo>
        {{/if}}
        {{#if (is-equal this.app_state.current_route "user.stats")}}
        <span class="md-pillnav__pill is-active" aria-current="page">{{t "Reports" key="reports"}}</span>
        {{else}}
        <LinkTo @route="user.stats" @model={{this.model.user_name}} @query={{hash from_dashboard=1 highlighted=null start=null end=null location_id=null device_id=null split=null start2=null end2=null device_id2=null location_id2=null}} class="md-pillnav__pill">{{t "Reports" key="reports"}}</LinkTo>
        {{/if}}
        <LinkTo @route="user.extras" @model={{this.model.user_name}} class="md-pillnav__pill">{{t "Extras" key="extras"}}</LinkTo>
      </nav>
      {{#if (and this.from_dashboard (is-equal this.app_state.current_route "user.stats"))}}
      <header class="md-hero md-hero--dashboard md-hero--reports-dashboard" aria-label={{t "Dashboard" key="dashboard"}}>
        <h1 class="md-hero__title"><span class="md-hero__title--from-left">{{t "Reports for %{username}" key="reports_for_username" username=this.model.user_name}}</span></h1>
        <p class="md-hero__sub"><span class="md-hero__sub--from-right">{{t "Let's look at some" key="reports_dashboard_hero_sub_pre"}} <em class="md-hero__gradient-text">{{t "useful information..." key="reports_dashboard_hero_sub_em"}}</em></span></p>
      </header>
      {{/if}}
      <div class="md-user-outlet md-user-outlet--in-workspace">
        {{outlet}}
      </div>
    </div>
  </div>
  {{else}}
  <div class="md-shell md-shell--user">
    <div class="md-workspace">
      <nav class="md-pillnav md-pillnav--user" aria-label={{t "User menu" key="user_menu"}}>
        <LinkTo @route="user.index" @model={{this.model.user_name}} @query={{hash from_dashboard=null}} class="md-pillnav__pill {{if (is-equal this.app_state.current_route 'user.index') 'is-active'}}">{{t "summary" key="summary_lower"}}</LinkTo>
        <LinkTo @route="user.stats" @model={{this.model.user_name}} @query={{hash from_dashboard=null highlighted=null start=null end=null location_id=null device_id=null split=null start2=null end2=null device_id2=null location_id2=null}} class="md-pillnav__pill {{if (is-equal this.app_state.current_route 'user.stats') 'is-active'}}">{{t "reports" key="reports_lower"}}</LinkTo>
        <LinkTo @route="user.goals" @model={{this.model.user_name}} class="md-pillnav__pill {{if (is-equal this.app_state.current_route 'user.goals') 'is-active'}}">{{t "goals" key="goals_lower"}}</LinkTo>
        {{#if this.app_state.feature_flags.lessons}}
          {{#if this.model.organizations.length}}
            <LinkTo @route="user.lessons" @model={{this.model.user_name}} class="md-pillnav__pill {{if (is-equal this.app_state.current_route 'user.lessons') 'is-active'}}">{{t "trainings" key="trainings_lower"}}</LinkTo>
          {{/if}}
        {{/if}}
        <LinkTo @route="user.recordings" @model={{this.model.user_name}} class="md-pillnav__pill {{if (is-equal this.app_state.current_route 'user.recordings') 'is-active'}}">{{t "recordings" key="recordings_lower"}}</LinkTo>
        <LinkTo @route="speech" class="md-pillnav__pill">{{t "speech" key="speech_lower"}}</LinkTo>
        {{#if this.model.permissions.edit}}
          <LinkTo @route="user.edit" @model={{this.model.user_name}} class="md-pillnav__pill {{if (is-equal this.app_state.current_route 'user.edit') 'is-active'}}">{{t "profile" key="profile_lower"}}</LinkTo>
          <LinkTo @route="user.preferences" @model={{this.model.user_name}} class="md-pillnav__pill {{if (is-equal this.app_state.current_route 'user.preferences') 'is-active'}}">{{t "preferences" key="preferences_lower"}}</LinkTo>
          {{#if this.app_state.feature_flags.subscriptions}}
            <LinkTo @route="user.subscription" @model={{this.model.user_name}} class="md-pillnav__pill {{if (is-equal this.app_state.current_route 'user.subscription') 'is-active'}}">{{t "billing" key="billing_lower"}}</LinkTo>
          {{/if}}
        {{/if}}
        <LinkTo @route="user.logs" @model={{this.model.user_name}} @query={{hash from_dashboard=null type=null}} class="md-pillnav__pill {{if (is-equal this.app_state.current_route 'user.logs') 'is-active'}}">
          {{t "logs &amp; messages" key="logs_messages"}}
          {{#if this.app_state.currentUser.unread_messages}}
            <span class="md-pillnav__badge">{{this.app_state.currentUser.unread_messages}}</span>
          {{/if}}
        </LinkTo>
      </nav>
      <main class="md-main md-main--user">
        {{outlet}}
      </main>
    </div>
  </div>
  {{/if}}
</div>
{{/if}}
