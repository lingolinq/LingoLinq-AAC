<div class="for-schools-page {{if this.scotPalette "for-schools-page--scot-palette"}}">
  {{! Palette toggle – only on this page }}
  <div class="for-schools-palette-toggle-wrap">
    <button type="button" class="for-schools-palette-toggle" {{action "toggleScotPalette"}} aria-pressed={{this.scotPalette}} title={{if this.scotPalette (t "Switch to default palette" key="for_schools_switch_default_palette") (t "Switch to Scot's palette" key="for_schools_switch_scot_palette")}}>
      {{#if this.scotPalette}}
        {{t "Default palette" key="for_schools_palette_default"}}
      {{else}}
        {{t "Scot's palette" key="for_schools_palette_scot"}}
      {{/if}}
    </button>
  </div>
  {{! Hero }}
  <section class="for-schools-hero">
    <div class="for-schools-hero-inner">
      <div class="for-schools-hero-content">
        <div class="for-schools-hero-header">
          <h1 class="for-schools-hero-title">
            {{t "Communication access" key="communication_access"}}<br>
            {{t "for" key="for_lower"}} <span class="for-schools-hero-highlight">{{t "every student" key="for_schools_hero_highlight"}}</span>
          </h1>
        </div>
        <p class="for-schools-hero-subtitle">{{t "LingoLinq is the AI-powered AAC platform that gives students a voice, saves therapists hours each week, and gives districts the management tools they've been asking for. Cloud-based. Open source. Built for real classrooms." key="for_schools_hero_subtitle"}}</p>
        <div class="for-schools-hero-buttons">
          <LinkTo @route="register" class="for-schools-btn for-schools-btn-coral">{{t "Try LingoLinq Free" key="for_schools_try_free"}} →</LinkTo>
          <a href="#" class="for-schools-btn for-schools-btn-outline">{{t "Watch Demo" key="for_schools_watch_demo"}}</a>
        </div>
      </div>
      <div class="for-schools-hero-visual">
        <div class="for-schools-floating-badge for-schools-floating-badge-top-right">
          <div class="for-schools-badge-icon for-schools-badge-icon-teal">🌐</div>
          <div>
            <div class="for-schools-badge-title">{{t "AI Language Support" key="for_schools_ai_language_support"}}</div>
            <div class="for-schools-badge-subtitle">{{t "10+ languages" key="for_schools_10_plus_languages"}}</div>
          </div>
        </div>
        <div class="for-schools-floating-badge for-schools-floating-badge-bottom-left">
          <div class="for-schools-badge-icon for-schools-badge-icon-coral">⚡</div>
          <div>
            <div class="for-schools-badge-title">{{t "Setup in Minutes" key="for_schools_setup_minutes"}}</div>
            <div class="for-schools-badge-subtitle">{{t "No hardware needed" key="for_schools_no_hardware"}}</div>
          </div>
        </div>
        <div class="for-schools-mockup">
          <div class="for-schools-mockup-toolbar">
            <div class="for-schools-mockup-dot for-schools-mockup-dot-r"></div>
            <div class="for-schools-mockup-dot for-schools-mockup-dot-y"></div>
            <div class="for-schools-mockup-dot for-schools-mockup-dot-g"></div>
            <div class="for-schools-mockup-url">app.lingolinq.org</div>
          </div>
          <div class="for-schools-mockup-screen">
            <div class="for-schools-mockup-grid">
              <div class="for-schools-aac-btn for-schools-aac-btn-c1"><span class="for-schools-aac-icon">😊</span>feel</div>
              <div class="for-schools-aac-btn for-schools-aac-btn-c2"><span class="for-schools-aac-icon">🍎</span>eat</div>
              <div class="for-schools-aac-btn for-schools-aac-btn-c3"><span class="for-schools-aac-icon">🏠</span>go</div>
              <div class="for-schools-aac-btn for-schools-aac-btn-c4"><span class="for-schools-aac-icon">👋</span>hi</div>
              <div class="for-schools-aac-btn for-schools-aac-btn-c5"><span class="for-schools-aac-icon">❓</span>want</div>
              <div class="for-schools-aac-btn for-schools-aac-btn-c6"><span class="for-schools-aac-icon">🎮</span>play</div>
              <div class="for-schools-aac-btn for-schools-aac-btn-c7"><span class="for-schools-aac-icon">📚</span>read</div>
              <div class="for-schools-aac-btn for-schools-aac-btn-c8"><span class="for-schools-aac-icon">💬</span>more</div>
            </div>
            <div class="for-schools-mockup-bar">
              <span class="for-schools-mockup-bar-text">{{t "I want to play" key="for_schools_mockup_sentence"}}</span>
              <span class="for-schools-mockup-bar-speak">{{t "Speak" key="for_schools_mockup_speak"}}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {{! Stats }}
  <section class="for-schools-stats-bar">
    <div class="for-schools-stats-inner">
      <div>
        <div class="for-schools-stat-number">{{t "100M+" key="for_schools_stat_100m"}}</div>
        <div class="for-schools-stat-label">{{t "People who could benefit from AAC" key="for_schools_stat_100m_label"}}</div>
      </div>
      <div>
        <div class="for-schools-stat-number">{{t "~4M" key="for_schools_stat_4m"}}</div>
        <div class="for-schools-stat-label">{{t "Currently using AAC tools" key="for_schools_stat_4m_label"}}</div>
      </div>
      <div>
        <div class="for-schools-stat-number">{{t "5-10 hrs" key="for_schools_stat_hours"}}</div>
        <div class="for-schools-stat-label">{{t "Saved per SLP per week" key="for_schools_stat_hours_label"}}</div>
      </div>
      <div>
        <div class="for-schools-stat-number">{{t "90%" key="for_schools_stat_90"}}</div>
        <div class="for-schools-stat-label">{{t "Cost reduction vs. dedicated devices" key="for_schools_stat_90_label"}}</div>
      </div>
    </div>
  </section>

  {{! Features }}
  <section id="features" class="for-schools-features">
    <div class="for-schools-features-inner">
      <div class="for-schools-section-label">{{t "Why LingoLinq" key="for_schools_why_label"}}</div>
      <h2 class="for-schools-section-title">{{t "Built for how schools actually work" key="for_schools_features_title"}}</h2>
      <p class="for-schools-section-subtitle">{{t "Traditional AAC tools weren't designed for modern classrooms. We built LingoLinq from the ground up for the cloud era." key="for_schools_features_subtitle"}}</p>
    </div>
    <div class="for-schools-features-grid-wrap">
      <div class="for-schools-features-grid">
        <div class="for-schools-feature-card">
          <div class="for-schools-feature-header-row">
            <div class="for-schools-feature-icon for-schools-feature-icon-coral">🤖</div>
            <h3>{{t "AI-Powered Board Generation" key="for_schools_feature_ai_title"}}</h3>
          </div>
          <p>{{t "Describe a topic and LingoLinq builds communication boards automatically. What used to take hours now takes minutes." key="for_schools_feature_ai_desc"}}</p>
        </div>
        <div class="for-schools-feature-card">
          <div class="for-schools-feature-header-row">
            <div class="for-schools-feature-icon for-schools-feature-icon-teal">🌍</div>
            <h3>{{t "Multilingual from Day One" key="for_schools_feature_multilingual_title"}}</h3>
          </div>
          <p>{{t "AI-driven language expansion supports 10+ languages with proper grammar inflection, not just word-for-word translation." key="for_schools_feature_multilingual_desc"}}</p>
        </div>
        <div class="for-schools-feature-card">
          <div class="for-schools-feature-header-row">
            <div class="for-schools-feature-icon for-schools-feature-icon-navy">🏫</div>
            <h3>{{t "District-Wide Management" key="for_schools_feature_district_title"}}</h3>
          </div>
          <p>{{t "Google Classroom-style dashboard for managing students, therapists, and devices across your entire district from one screen." key="for_schools_feature_district_desc"}}</p>
        </div>
        <div class="for-schools-feature-card">
          <div class="for-schools-feature-header-row">
            <div class="for-schools-feature-icon for-schools-feature-icon-teal">☁️</div>
            <h3>{{t "Cloud-Native, Any Device" key="for_schools_feature_cloud_title"}}</h3>
          </div>
          <p>{{t "Works on tablets, phones, laptops, and smartboards. Edit boards from your desk. Students access them from anywhere." key="for_schools_feature_cloud_desc"}}</p>
        </div>
        <div class="for-schools-feature-card">
          <div class="for-schools-feature-header-row">
            <div class="for-schools-feature-icon for-schools-feature-icon-coral">📊</div>
            <h3>{{t "Real Analytics for IEPs" key="for_schools_feature_analytics_title"}}</h3>
          </div>
          <p>{{t "Track vocabulary growth, usage patterns, and communication attempts. Generate reports that map directly to IEP goals." key="for_schools_feature_analytics_desc"}}</p>
        </div>
        <div class="for-schools-feature-card">
          <div class="for-schools-feature-header-row">
            <div class="for-schools-feature-icon for-schools-feature-icon-navy">👨‍👩‍👧</div>
            <h3>{{t "Family Access Built In" key="for_schools_feature_family_title"}}</h3>
          </div>
          <p>{{t "Parents and caregivers get free companion access. Same boards, same vocabulary, school to home. No extra cost." key="for_schools_feature_family_desc"}}</p>
        </div>
      </div>
    </div>
  </section>

  {{! Testimonial }}
  <section class="for-schools-testimonial">
    <div class="for-schools-testimonial-inner">
      <div class="for-schools-testimonial-quote">
        {{t "LingoLinq changed how our entire district approaches AAC. The AI board generation alone saved our team dozens of hours in the first month, and the families love being able to access boards at home without buying expensive apps." key="for_schools_testimonial"}}
      </div>
      <div class="for-schools-testimonial-author">{{t "Sarah Chen, M.S., CCC-SLP" key="for_schools_testimonial_author"}}</div>
      <div class="for-schools-testimonial-role">{{t "Lead Speech-Language Pathologist, Marin County Schools" key="for_schools_testimonial_role"}}</div>
    </div>
  </section>

  {{! CTA }}
  <section class="for-schools-cta">
    <div class="for-schools-cta-inner">
      <h2>{{t "Ready to give every student a voice?" key="for_schools_cta_title"}}</h2>
      <p>{{t "Start with our free tier. No credit card, no hardware, no commitment. Just communication tools that work." key="for_schools_cta_subtitle"}}</p>
      <div class="for-schools-cta-buttons">
        <LinkTo @route="register" class="for-schools-btn for-schools-btn-coral">{{t "Start Free Today" key="for_schools_cta_start"}}</LinkTo>
        <LinkTo @route="contact" class="for-schools-btn for-schools-btn-white">{{t "Schedule a District Demo" key="for_schools_cta_demo"}}</LinkTo>
      </div>
    </div>
  </section>

  {{! Accessibility note }}
  <div class="for-schools-a11y-wrapper">
    <div class="for-schools-a11y-note">
      <div class="for-schools-a11y-icon" aria-hidden="true">♿</div>
      <p><strong>{{t "Accessibility-first design." key="accessibility_first"}}</strong> {{t "This site meets WCAG 2.1 AA standards. We use Atkinson Hyperlegible (designed by the Braille Institute) and Lexend (optimized for reading fluency) because we believe our tools should be accessible to everyone, including our website. Need accommodations?" key="for_schools_a11y_note"}} <a href="#" {{action "support"}}>{{t "Let us know." key="for_schools_a11y_let_us_know"}}</a></p>
    </div>
  </div>

  {{! Footer }}
  <footer class="for-schools-footer">
    <div class="for-schools-footer-inner">
      <div class="for-schools-footer-brand">
        <LinkTo @route="index" class="for-schools-footer-logo">
          <img src={{path "images/logo-big.png"}} alt="" class="for-schools-footer-logo-img" aria-hidden="true">
          <span class="for-schools-footer-logo-text">{{t "%app_name%" key="app_name"}}</span>
        </LinkTo>
        <p>{{t "Open-source, AI-powered communication tools for everyone. Built by people who live this work every day." key="for_schools_footer_tagline"}}</p>
      </div>
      <div class="for-schools-footer-col">
        <h4>{{t "Product" key="for_schools_footer_product"}}</h4>
        <a href="#features">{{t "Features" key="for_schools_footer_features"}}</a>
        <LinkTo @route="pricing">{{t "Pricing" key="for_schools_footer_pricing"}}</LinkTo>
        <LinkTo @route="for-schools">{{t "For Schools" key="for_schools_footer_for_schools"}}</LinkTo>
        <LinkTo @route="index">{{t "For Families" key="for_schools_footer_for_families"}}</LinkTo>
      </div>
      <div class="for-schools-footer-col">
        <h4>{{t "Resources" key="for_schools_footer_resources"}}</h4>
        <LinkTo @route="intro">{{t "Getting Started" key="for_schools_footer_getting_started"}}</LinkTo>
        <a href="#" {{action "support"}}>{{t "Help Center" key="for_schools_footer_help"}}</a>
        <a href="https://github.com/LingoLinq" target="_blank" rel="noopener noreferrer">{{t "API Docs" key="for_schools_footer_api"}}</a>
        <a href="https://github.com/LingoLinq" target="_blank" rel="noopener noreferrer">{{t "Open Source" key="for_schools_footer_oss"}}</a>
      </div>
      <div class="for-schools-footer-col">
        <h4>{{t "Company" key="for_schools_footer_company"}}</h4>
        <LinkTo @route="about">{{t "About Us" key="for_schools_footer_about"}}</LinkTo>
        <a href="https://blog.mylingolinq.com" target="_blank" rel="noopener noreferrer">{{t "Blog" key="for_schools_footer_blog"}}</a>
        <LinkTo @route="contact">{{t "Contact" key="for_schools_footer_contact"}}</LinkTo>
        <a href="#" {{action "support"}}>{{t "Accessibility" key="for_schools_footer_accessibility"}}</a>
      </div>
    </div>
    <div class="for-schools-footer-bottom">
      <span>{{t "© 2026 LingoLinq AAC. All rights reserved." key="for_schools_copyright"}}</span>
      <div class="for-schools-footer-badges">
        <span class="for-schools-a11y-badge">{{t "WCAG 2.1 AA" key="for_schools_wcag_badge"}}</span>
        <span class="for-schools-oss-badge">{{t "Open Source" key="for_schools_oss_badge"}}</span>
      </div>
    </div>
  </footer>
</div>
