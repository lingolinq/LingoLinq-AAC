<div class='row'>
  <div class='col-sm-4 col-sm-offset-4'>
    <h2>{{t "Forgot Password" key="forgot_password"}}</h2>
    <form {{action "submitKey" on="submit"}}>
      {{#if this.response.email_sent}}
        <div class='form-group'>
          {{t "Email sent! Be sure to check your spam folder!" key="email_sent"}}
          {{#if this.response.message}}
            {{t "NOTE:" key="note_colon"}} {{this.response.message}}
          {{/if}}
        </div>
      {{else}}
        <div class='form-group'>
          <p>{{t "Please enter your username or email address and we'll email you a link you can use to reset your password." key="password_reset_prompt"}}</p>
        </div>
        <div class='form-group'>
          <Input @value={{this.name}} class="form-control input-lg" id="name" placeholder="User name or email address" />
        </div>
        <div class='form-group'>
          {{#if this.response.message}}
            <p>
              {{this.response.message}}
            </p>
          {{/if}}
          <button class='btn btn-primary btn-lg' type='submit'>{{t "Submit" key="submit"}}</button>
        </div>
      {{/if}}
    </form>
  </div>
</div>
