<div class="login-page-bg">
  <div class="la-bg-orbs" aria-hidden="true">
    <span class="la-bg-orb la-bg-orb--a"></span>
    <span class="la-bg-orb la-bg-orb--b"></span>
    <span class="la-bg-orb la-bg-orb--c"></span>
    <span class="la-bg-orb la-bg-orb--d"></span>
  </div>
  <div class="login-page">
  <div class="login-card">
    <h2>{{t "Forgot Password" key="forgot_password"}}</h2>
    <div class="login-card__divider" aria-hidden="true"></div>
    <form {{action "submitKey" on="submit"}}>
      {{#if this.response.email_sent}}
        <div class='form-group'>
          {{t "Email sent! Be sure to check your spam folder!" key="email_sent"}}
          {{#if this.response.message}}
            {{t "NOTE:" key="note_colon"}} {{this.response.message}}
          {{/if}}
        </div>
      {{else}}
        <p class="login-privacy-note" style="margin: 0 0 16px; font-size: 14px;">{{t "Please enter your username or email address and we'll email you a link you can use to reset your password." key="password_reset_prompt"}}</p>
        <div class='form-group'>
          <label for="name">{{t "Username or Email" key="username_or_email"}}</label>
          <Input @value={{this.name}} class="form-control" id="name" placeholder="User name or email address" />
        </div>
        <div class='form-group'>
          {{#if this.response.message}}
            <div class="login-error">
              {{this.response.message}}
            </div>
          {{/if}}
          <button class='login-btn' type='submit'>{{t "Submit" key="submit"}}</button>
          <div class="login-links">
            <LinkTo @route="login">{{t "Back" key="back"}}</LinkTo>
            |
            <LinkTo @route="forgot_login">{{t "Forgot username" key="forgot_username"}}</LinkTo>
          </div>
        </div>
      {{/if}}
    </form>
  </div>
</div>
</div>
