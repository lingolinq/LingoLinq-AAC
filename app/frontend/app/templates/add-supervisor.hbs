{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="modal-header">
    <button type="button" class="close" {{action "close"}}>&times;</button>
    <h3>{{t "Add Supervisor" key="add_supervisor"}}</h3>
  </div>
  <div class="modal-body">
    <p>{{t "Supervisors are linked to a user's account and can have full access to the user's account. They can change their home board, see and edit their private boards, see reports, etc. It can be valuable for therapists, parents, etc. to be added as supervisors, but remember that supervisors have full account access, so be aware of who you add as supervisors." key="supverisor_intro"}}</p>
    <form class="form-horizontal" {{action "add" on="submit"}} style='margin-top: 20px;'>
      <div class="form-group">
        <div class="col-sm-12">
          <div class="btn-group btn-group-lg" role="group" aria-label="user type">
            <button type="button" class={{if this.existing_user "btn btn-primary" "btn btn-default"}} {{action "set_user_type" "existing"}}>{{t "Add an Existing User" key="add_existing_user"}}</button>
            <button type="button" class={{if this.new_user "btn btn-primary" "btn btn-default"}} {{action "set_user_type" "new"}}>{{t "Add a New User" key="add_new_user"}}</button>
            <button type="button" class={{if this.start_code "btn btn-primary" "btn btn-default"}} {{action "set_user_type" "start_code"}}>{{t "Add Start Code" key="add_start_code"}}</button>
          </div>
        </div>
      </div>
      {{#if this.existing_user}}
        <div class="form-group">
          <label for="add_supervisee_key" class="col-sm-3 control-label">{{t "Supervisor" key="supervisor"}}</label>
          <div class="col-sm-6">
            <Input @value={{this.supervisor_key}} class="form-control" id="add_supervisee_key" placeholder="User name" />
          </div>
        </div>
      {{else if this.start_code}}
        <div class="form-group">
          <label for="add_start_code_key" class="col-sm-3 control-label">{{t "Start Code" key="start_code"}}</label>
          <div class="col-sm-6">
            <Input @value={{this.start_code_key}} class="form-control" id="add_start_code" placeholder="start code" />
          </div>
          <div class="col-sm-9 col-sm-offset-3">
            <p class='form-control-static'><em>{{t "In addition to adding supervision access, start codes may update some of your settings based on the pre-set configuration by the supervisor, so make sure to check with them before entering a start code." key="start_code_warning"}}</em></p>
          </div>
        </div>
      {{else}}
        <div class="form-group">
          <label for="supervisor_name" class="col-sm-3 control-label">{{t "Supervisor" key="supervisor"}}</label>
          <div class="col-sm-6">
            <Input @value={{this.model.supervisor.name}} class="form-control" id="supervisor_name" placeholder="Full name" />
          </div>
        </div>
        <div class="form-group">
          <div class="col-sm-6 col-sm-offset-3">
            <Input @value={{this.model.supervisor.user_name}} class="form-control" placeholder="User name" />
            {{#if this.model.supervisor.user_name_check.checking}}
            {{else if this.model.supervisor.user_name_check.exists}}
              <span class='text-danger'>{{t "\"%{user_name}\" already exists" user_name=this.model.supervisor.user_name}}</span>
            {{/if}}
          </div>
        </div>
        <div class="form-group">
          <div class="col-sm-6 col-sm-offset-3">
            <Input @value={{this.model.supervisor.email}} class="form-control" placeholder="Email address" />
          </div>
        </div>
        <div class="form-group">
          <div class="col-sm-6 col-sm-offset-3">
            <Input @type="password" @value={{this.model.supervisor.password}} class="form-control" placeholder="Password" />
          </div>
        </div>
      {{/if}}
      {{#unless this.start_code}}
        <div class="form-group">
          <label for="supervisor_type" class="col-sm-3 control-label">{{t "Access" key="access"}}</label>
          <div class="col-sm-8">
            {{bound-select select_class="form-control" select_id="supervisor_type" content=this.supervisor_types selection=this.supervisor_permission action=(action (mut this.supervisor_permission)) }}
          </div>
        </div>
        {{#if this.supervisor_sponsorships}}
          <div class="form-group" style="margin-top: -15px;">
            <div class="col-sm-8 col-sm-offset-3">
              <div class="checkbox big_checkbox">
                <label>
                  <Input @checked={{this.premium_supporter}} @type="checkbox" />
                  {{t "use one of my supervisor credits (%{n} left) to make this person a premium supporter" n=this.supervisor_sponsorships key="grant_premium_supporter"}}
                </label>
              </div>
            </div>
          </div>
        {{/if}}
      {{/unless}}
      <div class="form-group">
        <div class="col-sm-9 col-sm-offset-3">
          <button type="submit" class='btn btn-primary' disabled={{this.linking}}>
            {{#if this.linking.start_code}}
              {{t "Handling Start Code..." key="handling_start_code"}}
            {{else if this.linking}}
              {{t "Adding Supervisor..." key="adding_supervisor"}}
            {{else}}
              {{#if this.error}}
                {{t "Adding Supervisor Failed" key="adding_supervisor_failed"}}
              {{else}}
                {{#if this.start_code}}
                  {{t "Add From Start Code" key="add_from_start_code"}}
                {{else}}
                  {{t "Add Supervisor" key="add_supervisor"}}
                {{/if}}
              {{/if}}
            {{/if}}
          </button>
          <a href="#" class="btn btn-default" {{action "close"}}>{{t "Cancel" key="cancel"}}</a>
          {{#if this.error}}
            <p class="text-danger">{{this.error}}</p>
          {{/if}}
        </div>
      </div>
    </form>
  </div>
{{/modal-dialog}}
