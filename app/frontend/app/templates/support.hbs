<div class="la-wrapper la-wrapper--pricing la-wrapper--support">
  <div class="app-shell">
    <main class="la-main" role="main">
      <div class="md-workspace md-workspace--support">
      {{!-- Hero (same structure as Contact page): badge, header, divider, subheader --}}
      <section id="support-hero" class="la-section">
        <div class="la-section-header" style="display: block; text-align: center;">
          <span class="la-section-eyebrow-badge"><span class="la-about-hero-brand">Lingo</span><span class="la-about-hero-brand la-about-hero-brand--italic">Linq</span> {{t "SUPPORT" key="support_eyebrow"}}</span>
          <div class="la-hero-title-wrap">
            <h1 class="la-hero-title">{{t "Report an " key="report_an_issue_prefix"}}<span class="hero-gradient">{{t "Issue" key="report_an_issue_highlight"}}</span></h1>
          </div>
          <hr class="la-about-hero-separator" aria-hidden="true">
          <p class="la-pricing-hero-subtitle">
            {{t "Running into an issue or have an idea to share? We want to hear from you." key="support_intro"}}
          </p>
        </div>

        <div class="la-support-content-wrapper">
          <article class="la-about-glass-card la-support-page-card" aria-label={{t "Report an Issue" key="report_an_issue"}}>
            <div class="la-support-page-card__body md-support-content la-support-resources">
              {{#unless this.appState.no_linky}}
                <h2 class="la-support-resources__heading">{{t "Below are some resources that might help:" key="support_resources"}}</h2>
              {{/unless}}

              {{#if this.appState.no_linky}}
                {{#if this.ios}}
                  <ul class="la-support-list la-support-list--cards md-support-list">
                    <li class="la-support-resource-card"><a href="https://lingolinq.zendesk.com/hc/en-us/articles/115000379246" target="_blank" rel="noopener" class="la-support-list__link"><span class="la-support-list__icon la-feature-icon la-feature-icon--teal" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg></span> <span class="la-support-list__text">{{t "Not Hearing Anything in Speak Mode?" key="not_hearing_speech"}}</span></a></li>
                    <li class="la-support-resource-card"><LinkTo @route="faq" class="la-support-list__link"><span class="la-support-list__icon la-feature-icon la-feature-icon--teal" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></span> <span class="la-support-list__text">{{t "Support and Helpful How-To Articles" key="how_to_link"}}</span></LinkTo></li>
                    {{#if this.appState.currentUser}}
                      <li class="la-support-resource-card"><button type="button" class="la-support-list__card-action" {{action "show_speak_mode_intro_again"}}><span class="la-support-list__icon la-feature-icon la-feature-icon--navy" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></span> <span class="la-support-list__text">{{t "Show Speak Mode intro again" key="show_speak_mode_intro_again"}}</span></button></li>
                    {{/if}}
                  </ul>
                {{/if}}
              {{else}}
                <ul class="la-support-list la-support-list--cards md-support-list">
                  {{#if this.ios}}
                    <li class="la-support-resource-card"><a href="https://lingolinq.zendesk.com/hc/en-us/articles/115000379246" target="_blank" rel="noopener" class="la-support-list__link"><span class="la-support-list__icon la-feature-icon la-feature-icon--teal" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg></span> <span class="la-support-list__text">{{t "Not Hearing Anything in Speak Mode?" key="not_hearing_speech"}}</span></a></li>
                  {{/if}}
                  <li class="la-support-resource-card"><LinkTo @route="faq" class="la-support-list__link"><span class="la-support-list__icon la-feature-icon la-feature-icon--teal" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></span> <span class="la-support-list__text">{{t "Support and Helpful How-To Articles" key="how_to_link"}}</span></LinkTo></li>
                  {{#if this.appState.domain_settings.youtube_url}}
                    <li class="la-support-resource-card"><a href={{this.appState.domain_settings.youtube_url}} target="_blank" rel="noopener" class="la-support-list__link"><span class="la-support-list__icon la-feature-icon la-feature-icon--coral" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m22 8-6 4 6 4V8Z"/><rect x="2" y="6" width="14" height="12" rx="2" ry="2"/></svg></span> <span class="la-support-list__text">{{t "YouTube Walkthrough Videos" key="how_to_videos"}}</span></a></li>
                  {{/if}}
                  {{#if this.appState.currentUser}}
                    <li class="la-support-resource-card"><button type="button" class="la-support-list__card-action" {{action "show_speak_mode_intro_again"}}><span class="la-support-list__icon la-feature-icon la-feature-icon--navy" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></span> <span class="la-support-list__text">{{t "Show Speak Mode intro again" key="show_speak_mode_intro_again"}}</span></button></li>
                  {{/if}}
                </ul>
              {{/if}}
            </div>

            <div class="la-support-page-card__divider" aria-hidden="true"></div>

            <div class="la-support-page-card__section">
              <div class="la-support-page-card__body md-support-content">
                <form class="la-contact-form la-support-form md-support-form" {{action "submit_message" on="submit"}}>
                  {{#if this.appState.sessionUser}}
                    {{#if this.appState.sessionUser.supervisors}}
                      <div class="la-contact-form__row">
                        <label for="support_author_id" class="la-contact-form__label">{{t "Send Reply To" key="send_reply_to"}}</label>
                        {{bound-select select_class="la-contact-input" select_id="support_author_id" content=this.author_ids selection=this.author_id action=(action "updateAuthorId") }}
                      </div>
                    {{/if}}
                  {{/if}}
                  {{#if this.prompt_user}}
                    <div class="la-contact-form__row">
                      <label for="support_name" class="la-contact-form__label">{{t "Name" key="name"}}</label>
                      <Input @value={{this.name}} class="la-contact-input" id="support_name" placeholder={{t "Your Name" key="your_name"}} />
                    </div>
                    <div class="la-contact-form__row">
                      <label for="support_email" class="la-contact-form__label">{{t "Email" key="email"}}</label>
                      <Input @value={{this.email}} class="la-contact-input" id="support_email" placeholder="you@example.com" />
                    </div>
                  {{/if}}
                  <div class="la-contact-form__row">
                    <label for="support_subject" class="la-contact-form__label">{{t "Subject" key="subject"}}</label>
                    <Input @value={{this.subject}} class="la-contact-input" id="support_subject" placeholder="" />
                  </div>
                  <div class="la-contact-form__row">
                    <label for="support_message" class="la-contact-form__label">{{t "Message" key="message"}}</label>
                    <Textarea @value={{this.message}} class="la-contact-input la-contact-input--textarea" id="support_message" placeholder="" rows={{4}} />
                  </div>
                  {{#if this.error}}
                    <p class="la-support-form-error">{{t "Submission failed, please try again" key="ticket_failed"}}</p>
                  {{/if}}
                  <div class="la-contact-form__actions la-support-form__actions md-support-form__actions">
                    <button disabled={{this.disabled}} type="submit" class="la-btn la-btn--primary">{{t "Send Message" key="send_message"}}</button>
                    <LinkTo @route="troubleshooting" class="la-btn la-btn--ghost" style="display: none;">{{t "Troubleshooting" key="troubleshooting"}}</LinkTo>
                  </div>
                </form>
              </div>
            </div>

            <div class="la-support-page-card__body md-support-content">
              <p class="la-support-cookies">
                <button type="button" class="la-support-cookies__btn la-support-cookies-btn" {{action "toggle_cookies"}} aria-pressed={{if this.cookies "true" "false"}}>
                  <span class="la-support-cookies__icon {{unless this.cookies "la-support-cookies__icon--off"}}" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5"/><path d="M8.5 8.5v.01"/><path d="M16 15.5v.01"/><path d="M12 12v.01"/><path d="M11 17v.01"/><path d="M7 14v.01"/></svg></span>
                  {{#if this.cookies}}
                    {{t "disable cookies" key="disable_cookies"}}
                  {{else}}
                    {{t "enable cookies" key="enable_cookies"}}
                  {{/if}}
                </button>
              </p>
            </div>
          </article>
        </div>
      </section>
      </div>

    </main>
  </div>
</div>
