                    <li><a href="#" {{action "assessment_settings"}}><span class='glyphicon glyphicon-cog'></span> {{t "Eval Settings" key="eval_settings"}}</a></li>
                  {{else}}
                    {{#if this.app_state.currentBoardState.translatable}}
                      <li><a href="#" {{action "switch_languages"}}>{{t "Switch Languages" key="switch_languages"}}</a></li>
                    {{/if}}
                    {{#if this.stashes.sticky_board}}
                      <li><a href="#" {{action "toggle_sticky_board"}}>{{t "Release Board Lock" key="release_board_lock"}}</a></li>
                    {{else}}
                      <li><a href="#" {{action "toggle_sticky_board"}}>{{t "Stay on this Board" key="stay_on_board"}}</a></li>
                    {{/if}}
                    {{#if this.stashes.temporary_root_board_state}}
                      <li><a href="#" {{action "toggle_home_lock"}}>{{t "Release Home Lock" key="release_home_lock"}}</a></li>
                    {{else}}
                      {{#unless this.app_state.current_board_is_speak_mode_home}}
                        <li><a href="#" {{action "toggle_home_lock"}}>{{t "Set As Temporary Home" key="temporary_home"}}</a></li>
                      {{/unless}}
                    {{/if}}
                    {{#if this.app_state.feature_flags.find_multiple_buttons}}
                      {{#if this.has_board_intro}}
                        <li><a href="#" {{action "board_intro"}}>{{t "Board Intro" key="board_intro"}}</a></li>
                      {{/if}}
                    {{/if}}
                    {{#if this.app_state.currentUser.preferences.logging}}
                      {{#if this.app_state.logging_paused}}
                        <li><a href="#" {{action "toggle_pause_logging"}}>
                          <span class="label label-primary" style='padding: 3px;'><span class='glyphicon glyphicon-play'></span></span>
                          {{t "Resume Logging" key="resume_logging"}}
                        </a></li>
                      {{else}}
                        <li><a href="#" {{action "toggle_pause_logging"}}>
                          <span class="" style='padding: 3px;'><span class='glyphicon glyphicon-briefcase'></span></span>
                          {{t "Pause Logging" key="pause_logging"}}
                        </a></li>
                      {{/if}}
                    {{else}}
                      <!-- TODO: option to log temporarily/conclude temp log -->
                    {{/if}}
                  {{/if}}
                {{/if}}
              {{/if}}
            {{/if}}
          {{/unless}}
          {{#unless this.app_state.limited_speak_mode_options}}
            {{#if this.isSessionAuthenticated}}
              {{#unless this.app_state.speak_mode}}
                <li><LinkTo @route="search" @models={{array "any" "_"}}>{{t "Find Board" key="find_board"}}</LinkTo></li>
                {{#if this.app_state.currentUser.permissions.delete}}
                  <li><a href="#" {{action "newBoard"}}>{{t "Create a New Board" key="create_a_new_board"}}</a></li>
                {{/if}}
              {{/unless}}
              {{#if this.app_state.currentUser.permissions.delete}}
                <li><LinkTo @route="user.preferences" @model={{this.app_state.currentUser.user_name}}>{{t "Preferences" key="preferences"}}</LinkTo></li>
                <li><LinkTo @route="user.logs" @model={{this.app_state.currentUser.user_name}} @query={{hash type="note"}}>
                  {{#if this.app_state.currentUser.unread_messages}}
                    <span class="label label-danger" style="border-radius: 5px;">{{this.app_state.currentUser.unread_messages}}</span>
                  {{/if}}
                  {{t "Messages" key="messages"}}
                </LinkTo></li>
              {{/if}}
              {{#if this.session.as_user_id}}
                <li><a href="#" {{action "stopMasquerading"}}>{{t "Stop Masquerading" key="stop_masquerading"}}</a></li>
              {{/if}}
              {{#unless this.app_state.speak_mode}}
                <li><a href="#" {{action "invalidateSession"}}>{{t "Sign Out" key="logout"}}</a></li>
              {{/unless}}
            {{else}}
              <li role="presentation">
                <LinkTo @route="login">{{t "Sign In" key="login"}}</LinkTo>
              </li>
              {{#unless this.app_state.no_linky}}
                {{#if this.app_state.domain_settings.full_domain}}
                  <li role="presentation">
                    <LinkTo @route="register">{{t "Register" key="register"}}</LinkTo>
                  </li>
                {{/if}}
              {{/unless}}
              {{#if this.app_state.feature_flags.emergency_boards}}              
                <li role="presentation">
                  <LinkTo @route="offline_boards" class="critical_access">{{t "Basic Access" key="critical_access"}}</LinkTo>
                </li>
              {{/if}}
            {{/if}}
          {{/unless}}
        </ul>
      </span>
      {{/unless}}
      {{else}}
    {{#unless this.app_state.currentBoardState.id}}
    {{#if this.app_state.currentUser}}
      <LinkTo @route="user.subscription" @model={{this.app_state.currentUser.user_name}} class="md-pillnav__upgrade-nav" aria-label={{t "Upgrade" key="upgrade"}} title={{t "Upgrade" key="upgrade"}}>
        {{t "Upgrade" key="upgrade"}}
      </LinkTo>
    {{/if}}
    {{/unless}}
    {{#if this.app_state.currentBoardState.id}}
      {{#unless this.app_state.speak_mode}}
        {{#unless this.app_state.edit_mode}}
        {{/unless}}
      {{/unless}}
    {{/if}}
    {{style-switcher}}
    {{#if this.app_state.currentUser}}
    <LinkTo @route="beta-feedback" class="app-navbar__beta-feedback-link">{{t "Beta feedback" key="beta_feedback_nav"}}</LinkTo>
    <LinkTo @route="support" class="ll-bento-help-btn ll-bento-help-btn--nav ll-bento-help-btn--nav-icon-only ll-bento-help-btn--support" aria-label={{t "Support" key="support"}} title={{t "Support" key="support"}}>
      <div class="ll-bento-help-btn__support-inner">
        <span class="ll-bento-help-btn__icon" aria-hidden="true">
          <svg class="ll-bento-help-btn__nav-icon ll-bento-help-btn__support-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
        </span>
      </div>
    </LinkTo>
    {{/if}}
    <span style="display: inline-block;" class="dropdown">
      {{#if this.app_state.currentUser}}
      <a class={{if (persistence-online) "btn btn-default online" "btn btn-default offline"}} id="identity_button" href="#" data-toggle="dropdown">
        <span class="user_holder">
          <img src={{this.app_state.currentUser.avatar_url_with_fallback}} class="user" onerror="button_broken_image(this);">
        </span>
        {{#if this.session.invalid_token}}
          <span class="label label-danger unread">{{t "!" key="exclaim"}}</span>
        {{else if (persistence-value "syncing")}}
          <span class="spinning unread">
            <span class="glyphicon glyphicon-refresh" style="z-index: 2;"></span>
            <span class="glyphicon glyphicon-refresh" style="color: #fff; position: absolute; left: 2px; top: 2px;"></span>
          </span>
        {{else if (persistence-value "app_needs_update")}}
          <span class="label label-danger unread">{{t "!" key="exclaim"}}</span>
        {{else if this.app_state.currentUser.unread_messages}}
          <span class="label label-danger unread">{{this.app_state.currentUser.unread_messages}}</span>
        {{else}}
          <span class="status unread"></span>
        {{/if}}
        <span class="caret"></span>
      </a>
      <ul class="dropdown-menu" role="menu" aria-labelledby="dLabel" style="right: 0; left: auto; text-align: left;">
        <li class="dropdown-header">{{this.app_state.currentUser.name}}</li>
        <li role="presentation">
          <LinkTo @route="user" @model={{this.app_state.currentUser.user_name}}>{{t "My Account" key="my_account"}}</LinkTo>
        </li>
        <li><LinkTo @route="user.index" @model={{this.app_state.currentUser.user_name}}>{{t "My Boards" key="my_boards"}}</LinkTo></li>
        <li><LinkTo @route="user.preferences" @model={{this.app_state.currentUser.user_name}}>{{t "Preferences" key="preferences"}}</LinkTo></li>
        <li><LinkTo @route="user.logs" @model={{this.app_state.currentUser.user_name}} @query={{hash type="note"}}>
          {{#if this.app_state.currentUser.unread_messages}}
            <span class="label label-danger" style="border-radius: 5px;">{{this.app_state.currentUser.unread_messages}}</span>
          {{/if}}
          {{t "Messages" key="messages"}}
        </LinkTo></li>
        <li><a href="#" {{action "support" preventDefault=true}}>{{t "Help" key="help"}}</a></li>
        <li class="divider" role="separator"></li>
        <li>
          <LinkTo @route="about" class="dropdown-menu__company-link">{{t "LingoLinq" key="app_name"}}</LinkTo>
        </li>
        <li>
          <a href="#" {{action "language" preventDefault=true}} class="dropdown-menu__language-link">
            {{this.app_state.current_locale_string}}
            <img src={{path "images/icon-language-new2.png"}} class="dropdown-menu__language-icon" alt="" aria-hidden="true">
          </a>
        </li>
        <li class="divider" role="separator"></li>
        <li class="dropdown-header ll-theme-picker-dropdown-label">{{t "Color Tone" key="color_tone"}}</li>
        <li class="ll-bento-theme-picker-dropdown">
          <div class="ll-bento-theme-picker ll-bento-theme-picker--in-dropdown" role="group" aria-label={{t "Choose theme" key="choose_theme"}}>
            <div class="ll-bento-theme-picker__row">
              <div class="ll-bento-theme-picker__options">
                <button type="button" class="ll-bento-theme-picker__option {{if (is-equal this.app_state.themeMode "light") "ll-bento-theme-picker__option--active"}}" {{action "selectThemeMode" "light"}} title={{t "Light" key="light"}} aria-pressed={{is-equal this.app_state.themeMode "light"}}>
                  <span class="ll-bento-theme-picker__icon" aria-hidden="true"><svg class="ll-bento-theme-picker__light-teal-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="36" height="36"><defs><linearGradient id="ll-light-teal-grad-picker-dropdown" x1="0%" y1="100%" x2="100%" y2="0%"><stop offset="0%" stop-color="#64b9bc"/><stop offset="100%" stop-color="#82afdc"/></linearGradient></defs><path fill="url(#ll-light-teal-grad-picker-dropdown)" fill-rule="evenodd" d="M12 4.5L19.5 12 12 19.5 4.5 12 12 4.5z" clip-rule="evenodd"/></svg></span>
                </button>
                <button type="button" class="ll-bento-theme-picker__option {{if (is-equal this.app_state.themeMode "midDay") "ll-bento-theme-picker__option--active"}}" {{action "selectThemeMode" "midDay"}} title={{t "Midday" key="midday"}} aria-pressed={{is-equal this.app_state.themeMode "midDay"}}>
                  <span class="ll-bento-theme-picker__icon" aria-hidden="true"><svg class="ll-bento-theme-picker__midday-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="36" height="36"><defs><radialGradient id="ll-eclipse-sun-picker-dropdown" cx="35%" cy="35%" r="65%"><stop offset="0%" stop-color="#ffe082"/><stop offset="25%" stop-color="#ffc107"/><stop offset="50%" stop-color="#ff8f00"/><stop offset="75%" stop-color="#e65100"/><stop offset="100%" stop-color="#bf360c"/></radialGradient><radialGradient id="ll-eclipse-moon-picker-dropdown" cx="35%" cy="35%" r="65%"><stop offset="0%" stop-color="#d4dce8"/><stop offset="50%" stop-color="#a8b4c8"/><stop offset="100%" stop-color="#64748b"/></radialGradient></defs><path fill="url(#ll-eclipse-sun-picker-dropdown)" fill-rule="evenodd" d="M20 12L15.7 10.5 17.66 6.34 13.5 8.3 12 4 10.5 8.3 6.34 6.34 8.3 10.5 4 12 8.3 13.5 6.34 17.66 10.5 15.7 12 20 13.5 15.7 17.66 17.66 15.7 13.5 20 12z" clip-rule="evenodd"/><circle cx="15" cy="12" r="5.5" fill="url(#ll-eclipse-moon-picker-dropdown)"/></svg></span>
                </button>
                <button type="button" class="ll-bento-theme-picker__option {{if (is-equal this.app_state.themeMode "dark") "ll-bento-theme-picker__option--active"}}" {{action "selectThemeMode" "dark"}} title={{t "Dark" key="dark"}} aria-pressed={{is-equal this.app_state.themeMode "dark"}}>
                  <span class="ll-bento-theme-picker__icon" aria-hidden="true"><svg class="ll-bento-dark-toggle__moon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24"><defs><radialGradient id="ll-moon-grad-picker-dropdown" cx="35%" cy="35%" r="65%"><stop offset="0%" stop-color="#d4dce8"/><stop offset="50%" stop-color="#a8b4c8"/><stop offset="100%" stop-color="#64748b"/></radialGradient></defs><path fill="url(#ll-moon-grad-picker-dropdown)" fill-rule="evenodd" d="M9.528 1.718a.75.75 0 01.162.819A8.97 8.97 0 009 6a9 9 0 009 9 8.97 8.97 0 003.463-.69.75.75 0 01.981.98 10.503 10.503 0 01-9.694 6.46c-5.799 0-10.5-4.701-10.5-10.5 0-4.368 2.667-8.112 6.46-9.694a.75.75 0 01.818.162z" clip-rule="evenodd"/></svg></span>
                </button>
                <button type="button" class="ll-bento-theme-picker__option {{if (is-equal this.app_state.themeMode "default") "ll-bento-theme-picker__option--active"}}" {{action "selectThemeMode" "default"}} title={{t "Default" key="default_theme"}} aria-pressed={{is-equal this.app_state.themeMode "default"}}>
                  <span class="ll-bento-theme-picker__icon" aria-hidden="true"><svg class="ll-bento-theme-picker__gold-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="36" height="36"><defs><linearGradient id="ll-gold-grad-picker-dropdown" x1="0%" y1="100%" x2="100%" y2="0%"><stop offset="0%" stop-color="#4ECDC4"/><stop offset="50%" stop-color="#F0F0F0"/><stop offset="100%" stop-color="#FF6B47"/></linearGradient></defs><path fill="url(#ll-gold-grad-picker-dropdown)" fill-rule="evenodd" d="M12 4.5L19.5 12 12 19.5 4.5 12 12 4.5z" clip-rule="evenodd"/></svg></span>
                </button>
              </div>
            </div>
          </div>
        </li>
        <li class="divider" role="separator"></li>
        <li><a href="#" {{action "invalidateSession"}}>{{t "Sign Out" key="logout"}}</a></li>
      </ul>
      {{else}}
      {{#unless this.useAppNavbarInHeader}}
      <a class={{if (persistence-online) "btn btn-default online" "btn btn-default offline"}} id="identity_button" href="#" data-toggle="dropdown" aria-label={{t "Sign In" key="login"}} aria-haspopup="true">
        {{t "Sign In" key="login"}}
        <span class="caret"></span>
      </a>
      <ul class="dropdown-menu" role="menu" aria-labelledby="dLabel" style="right: 0; left: auto; text-align: left;">
        {{#unless this.app_state.index_or_landing_view}}
        <li role="presentation">
          <LinkTo @route="index">{{t "Dashboard" key="dashboard"}}</LinkTo>
        </li>
        {{/unless}}
        <li role="presentation">
          <LinkTo @route="login">{{t "Sign In" key="login"}}</LinkTo>
        </li>
        <li role="presentation">
          <LinkTo @route="register">{{t "Register" key="register"}}</LinkTo>
        </li>
      </ul>
      {{/unless}}
      {{/if}}
    </span>
      {{/if}}
    </span>
  {{/if}}
  </div>
</header>
<div id="content" class={{this.content_class}}>
  {{ outlet }}
</div>
{{#if this.app_state.sidebar_visible}}
  <div id="sidebar" class='noselect advanced_selection' style={{this.sidebar_style}}>
    <span style="display: block; text-align: center; padding: 5px;">
      <button id='sidebar_close' class='btn btn-default' style="width: 90%;" {{action (if this.app_state.currentUser.preferences.quick_sidebar "stickSidebar" "toggleSidebar")}}>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true" style="pointer-events: none;">
          <polyline points="18 15 12 9 6 15" style="pointer-events: none;"></polyline>
          <polyline points="18 20 12 14 6 20" style="pointer-events: none;"></polyline>
        </svg>
      </button>
    </span>
    {{#each this.app_state.sidebar_boards as |board|}}
      {{#if board.alert}}
        <a href="#" {{action "alert" "sidebar"}} class='sidebar_item'>
          <span class="glyphicon glyphicon-bullhorn"></span>
          <img src={{board.image}} class='pic' alt="">
          {{board.name}}
        </a>
      {{else if board.special}}
        <a href="#" {{action "special" board}} class='sidebar_item'>
          <span class="glyphicon glyphicon-flash"></span>
          <img src={{board.image}} class='pic' alt="">
          {{board.name}}
        </a>
      {{else}}
        <a href="#" class='sidebar_item' {{action "jump" board.key "sidebar" board}} data-key={{board.key}}>
          {{#if board.home_lock}}
            <span class="glyphicon glyphicon-home"></span>
          {{/if}}
          {{#if board.fenced}}
            <span class="glyphicon glyphicon-map-marker"></span>
          {{/if}}
          <img src={{board.image}} class='pic' alt="">
          {{board.name}}
        </a>
      {{/if}}
    {{/each}}
    {{#if this.board_alt_username}}
      {{#if this.board_alt_boardname}}
        {{#if this.on_board_alt}}
          <LinkTo @route="board" @model={{this.board.model}} class="sidebar_item sidebar_item--board-alt sidebar_item--board-alt-active">
            <span class="sidebar_item__icon sidebar_item__icon--board-alt" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="100%" height="100%" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M3 3h8v8H3V3zm10 0h8v8h-8V3zM3 13h8v8H3v-8zm10 0h8v8h-8v-8z" clip-rule="evenodd"/></svg>
            </span>
            {{t "Option" key="board_alt_return"}}
          </LinkTo>
        {{else}}
          <LinkTo @route="user.board-alt" @models={{array this.board_alt_username this.board_alt_boardname}} class="sidebar_item sidebar_item--board-alt">
            <span class="sidebar_item__icon sidebar_item__icon--board-alt" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="100%" height="100%" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M3 3h8v8H3V3zm10 0h8v8h-8V3zM3 13h8v8H3v-8zm10 0h8v8h-8v-8z" clip-rule="evenodd"/></svg>
            </span>
            {{t "Board Alt" key="board_alt"}}
          </LinkTo>
        {{/if}}
      {{/if}}
    {{/if}}
  </div>
{{else}}
  {{#if this.app_state.speak_mode}}
    {{#unless this.app_state.currentUser.preferences.disable_quick_sidebar}}
      {{#unless this.app_state.sidebar_relegated}}
        {{#unless this.app_state.eval_mode}}
          <div id="sidebar_tease" class={{if this.app_state.skinny_sidebar "advanced_selection noselect skinny" "advanced_selection noselect"}} {{action "toggleSidebar"}} {{action "toggleSidebarTeaseKeydown" on="keyDown"}} role="button" tabindex="0">
            {{#if this.app_state.fenced_sidebar_board}}
              <span class='glyphicon glyphicon-map-marker' style='font-size: 20px; vertical-align: middle;'></span>
            {{/if}}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true" style="pointer-events: none;">
              <polyline points="6 9 12 15 18 9" style="pointer-events: none;"></polyline>
              <polyline points="6 14 12 20 18 14" style="pointer-events: none;"></polyline>
            </svg>
          </div>
        {{/unless}}
      {{/unless}}
    {{/unless}}
  {{/if}}
{{/if}}

{{modal-container}}
{{outlet "highlight"}}
{{outlet "highlight-secondary"}}
{{#if this.modalService.boardPreview}}
  {{board-preview-overlay}}
{{else}}
  {{outlet "board-preview"}}
{{/if}}
<FlashOutlet />
{{outlet "flash-message"}}
{{! Page footer: show on index/dashboard/setup and when not viewing a board (setup_footer no longer used; setup uses same page footer as other pages) }}
{{#if this.footer}}
  {{page-footer support=(action "support") language=(action "language")}}
{{/if}}

{{#if this.boardPickerVisible}}
  <div id="board_picker_backdrop" {{action "closeBoardPicker"}} style="position: fixed; inset: 0; background: rgba(0,0,0,0.32); z-index: 900;"></div>
  <div id="board_picker" role="dialog" aria-label={{t "My Boards" key="my_boards"}}>
    <div id="board_picker_header">
      <span class="la-section-eyebrow-badge">{{t "My Boards" key="my_boards"}}</span>
      <button type="button" class="board-picker__close" {{action "closeBoardPicker"}} aria-label={{t "Close" key="close"}}>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" width="20" height="20" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div id="board_picker_inner">
      {{#if this.boardPickerLoading}}
        <p class="board-picker__loading">{{t "Loading boards..." key="loading_boards"}}</p>
      {{else}}
        {{#each this.boardPickerBoards as |board|}}
          <a href="#" {{action "pickBoard" board.key}} class="board-picker__item">
            <span class="board-picker__thumb">
              <img src={{board.icon_url_with_fallback}} alt="" onerror="this.style.visibility='hidden';">
            </span>
            <span class="board-picker__name">{{board.name}}</span>
          </a>
        {{/each}}
      {{/if}}
    </div>
  </div>
{{/if}}

</div>
{{button-tracker}}
