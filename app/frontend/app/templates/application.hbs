<div id="within_ember" class="{{this.background_class}} {{if this.app_state.index_or_landing_view "index-or-landing-view"}} {{if (is-equal this.app_state.current_route "landing") "landing-route"}}  {{if (is-equal this.app_state.current_route "speech") "speech-route"}} {{if (is-equal this.app_state.current_route "landing-alt") "landing-alt-route"}} {{if (is-equal this.app_state.current_route "pricing") "pricing-route"}} {{if (is-equal this.app_state.current_route "features") "features-route"}} {{if this.showBentoPageWithFooter "bento-page-with-footer"}} {{if (and this.app_state.index_or_landing_view this.app_state.darkMode) "bento-dark-mode-active"}} {{if (and this.app_state.index_or_landing_view this.app_state.midDayMode) "bento-midday-mode-active"}} {{if (and this.app_state.index_or_landing_view this.app_state.defaultMode) "bento-default-mode-active"}} {{if this.on_board_alt "board-alt-view"}} {{if this.on_board "board-view"}} {{if this.on_board_detail "board-detail-view"}}" style={{if this.speak_mode_needing_hammer_js "touch-action: auto;" }}>
<div id="audio"></div>
<header class="{{this.header_class}} {{if this.useAppNavbarInHeader "header-index-with-dark-toggle"}} {{unless this.isSessionAuthenticated "header--unauthenticated"}}">
  <div id="inner_header">
  {{#if this.useAppNavbarInHeader}}
    {{app-navbar onSupport=(action "support")}}
  {{else}}
  {{#if this.app_state.speak_mode}}
    <span id="speak">
      <span class="speak-header__home-marker">
        {{#triple-click-listener triple_click="meta_home_click"}}
          {{#if this.on_board_or_alt}}
            <button class='btn btn-default access {{if this.boardPickerVisible "board-picker-btn--open"}}' id="home_button" {{action (if this.boardPickerVisible "closeBoardPicker" "openBoardPicker")}} style='position: relative;' aria-label={{t "My Boards" key="my_boards"}} aria-expanded={{if this.boardPickerVisible "true" "false"}}>
              {{#if this.boardPickerVisible}}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" width="20" height="20" aria-hidden="true" style="pointer-events: none; display: block;">
                  <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
              {{else}}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-hidden="true" style="pointer-events: none; display: block;">
                  <path fill-rule="evenodd" d="M3 3h8v8H3V3zm10 0h8v8h-8V3zM3 13h8v8H3v-8zm10 0h8v8h-8v-8z" clip-rule="evenodd"/>
                </svg>
              {{/if}}
            </button>
          {{else}}
            <button class={{if this.on_home "btn btn-default access dim" "btn btn-default access"}} id="home_button" {{action "home"}} style='position: relative;'>
              <span class="sr-only">{{t "Home" key="home"}}</span>
              <span class="glyphicon glyphicon-home button_icon"></span>
              {{#unless this.app_state.eval_mode}}
                {{#if this.stashes.temporary_root_board_state}}
                  <span class="glyphicon glyphicon-lock" style="float: left; width: 0; height: 0; color: #aaa; margin-top: 15px; margin-left: -5px;" title={{t "Home or Board Lock Set" key="home_or_board_lock_set"}}></span>
                {{else if this.stashes.sticky_board}}
                  <span class="glyphicon glyphicon-lock" style="float: left; width: 0; height: 0; color: #aaa; margin-top: 15px; margin-left: -5px;" title={{t "Board Lock Set" key="board_lock_set"}}></span>
                {{/if}}
              {{/unless}}
            </button>
          {{/if}}
        {{/triple-click-listener}}
      </span>
      {{#if this.show_back}}
        <button class="btn btn-default access skinnier" id="back_button" {{action "back"}}>
          <span class="sr-only">{{t "Back" key="back"}}</span>
          <span class="glyphicon glyphicon-arrow-left button_icon"></span>
        </button>
      {{/if}}
      <div class="speak-bar__button-list-wrap">
        <a href='#' tabindex="0" id="button_list" class={{this.button_list_class}} {{ action "vocalize" on="select"}} data-placement="bottom" data-trigger="manual">
          {{#unless this.app_state.button_list}}
            {{#if this.app_state.embedded}}
              <div style='float: left; margin: 5px; opacity: 0.7;'>
                {{app-logo size="xs" imgAlt="LingoLinq"}}
                {{t "Powered by %app_name%" key="powered_by_app"}}
              </div>
            {{else if this.app_state.currentUser.preferences.blank_status}}
              <div id="blank_status" class='text-muted'>
                {{time this.app_state.current_time}}
                {{#if this.app_state.battery.level}}
                  <div class="progress">
                    <div class={{this.app_state.battery.progress_class}} role="progressbar" aria-valuenow={{this.app_state.battery.level}} aria-valuemin="0" aria-valuemax="100" style={{this.app_state.battery.progress_style}}>
                      {{#if this.app_state.battery.charging}}
                        <span class="glyphicon glyphicon-flash"></span>
                      {{/if}}
                      <span class="sr-only">{{t "%{pct}% battery" key="percent_battery" pct=this.app_state.battery.level}} {{#if this.app_state.battery.charging}}{{t "charging" key="charging"}}{{/if}}</span>
                    </div>
                    {{#if this.app_state.battery.low}}
                      {{#unless this.app_state.battery.charging}}
                        <span class="glyphicon glyphicon-exclamation-sign" style="margin-top: 2px;"></span>
                      {{/unless}}
                    {{/if}}
                  </div>
                {{/if}}
                {{#if this.show_board_intro}}
                  <div {{action "board_intro"}} class='extra-btn' style='position: absolute; top: 3px; bottom: 3px; border: 1px solid #ccc;  background: #eee; margin-top: 0; margin-bottom: 0; border-radius: 5px; padding: 5px 10px; max-height: 75px; cursor: pointer;'>
                    <img src={{path "images/learn.png"}} style='height: 100%; max-height: 50px;'>
                    {{t "Intro" key="intro"}}
                  </div>
                {{else if this.app_state.eye_gaze_state}}
                  <div class="eye_status" title={{this.app_state.eye_gaze_state.status}}>
                    {{#if this.app_state.eye_gaze_state.active}}
                      <span class="glyphicon glyphicon-eye-open"></span>
                    {{else if this.app_state.eye_gaze_state.dormant}}
                      <span class="glyphicon glyphicon-eye-open" style='opacity: 0.4;'></span>
                    {{else}}
                      <span class="glyphicon glyphicon-eye-close text-muted"></span>
                    {{/if}}
                  </div>
                {{/if}}
              </div>
            {{/if}}
          {{/unless}}
          {{#let this.app_state.button_list as |button_list|}}
            {{button-list buttonList=button_list}}
          {{/let}}
        </a>
        {{#unless this.app_state.eval_mode}}
          {{#unless this.app_state.currentUser.preferences.device.disable_speak_options}}
            <button class="btn btn-default pass_to_btn_list" {{action "speakOptions"}} id="speak_options">
              {{#if this.app_state.referenced_user.unread_alerts}}
                <span class='label label-danger' style='position: absolute; top: -5px; right: -5px; border-radius: 10px;'>{{this.app_state.referenced_user.unread_alerts}}</span>
              {{else if this.app_state.referenced_user.request_alert}}
                <span class='label label-danger' style='position: absolute; top: -5px; right: -5px; border-radius: 10px;'>*</span>
              {{/if}}
              <span class="sr-only">{{t "speak options" key="speak_options"}}</span><span class="glyphicon glyphicon-chevron-down"></span>
            </button>
          {{/unless}}
        {{/unless}}
        {{#unless this.app_state.eval_mode}}
          {{#if this.app_state.pairing}}
            <button class={{if this.app_state.pairing.user.online "btn over pair access online" "btn over pair access"}} {{action "remote_modeling"}} id='reply_icon'>
              {{#if this.app_state.pairing.model}}
                <span class='glyphicon glyphicon-road'></span>
              {{else}}
                <span class='glyphicon glyphicon-search'></span>
              {{/if}}
              {{#if this.app_state.pairing.user}}
                <img src={{this.app_state.pairing.user.avatar_url_with_fallback}} >
              {{/if}}
            </button>
          {{else if this.app_state.reply_note}}
            <div class='label label-info over' id='reply_icon'><span class='glyphicon glyphicon-envelope'></span></div>
          {{else if this.app_state.inflection_shift}}
            <div class='label label-info over' id='reply_icon'><span class='glyphicon glyphicon-adjust'></span></div>
          {{else if this.app_state.insertion}}
            <div class='label label-info over' id='reply_icon'><span class='glyphicon glyphicon-console'></span></div>
          {{else if this.app_state.flipped}}
            <div class='label label-info over' id='reply_icon'><span class='glyphicon glyphicon-repeat'></span></div>
          {{else if this.app_state.followers.active}}
            <div class='label label-info over clear' id='reply_icon'>
              {{#each this.app_state.followers.active as |user|}}
                <img src={{user.avatar_url}} class='follower' >
              {{/each}}
            </div>
          {{else if this.app_state.clearable_history}}
            <div class='label label-warning over' id='reply_icon' style='width: 60px; margin-right: -65px; border-radius: 10px;'><span class='glyphicon glyphicon-remove'></span> {{this.app_state.clearable_history}}</div>
          {{else if this.app_state.shift}}
            <div class='label label-info over' id='reply_icon'><span class='glyphicon glyphicon-font'></span></div>
          {{/if}}
        {{/unless}}
      </div>
      {{#unless this.app_state.button_list}}
        {{#if this.app_state.currentUser.preferences.blank_status}}
          {{#unless this.app_state.eval_mode}}
            <!-- TODO: these popups should be dwellable, but if opened via dwell they should auto-close after like ten seconds -->
            <button id='speak_mode_notification' class='btn btn-default' {{action "speak_mode_notification"}}>
              {{#if this.stashes.board_level}}
                <span style='color: #ddd; font-size: 12px; position: absolute; top: 3px; text-align: right;'>L{{this.stashes.board_level}}</span>
              {{/if}}
              {{#if this.app_state.speak_mode_modeling_ideas.enabled}}
                <span class='notification' style='height: 100%; position: absolute; top: 5px; left: 0; right: 0; bottom: 5px; height: auto;'>
                  <img src={{path "images/modeling_ideas.svg"}} style='height: 100%; width: 100%; opacity: 0.7;' class='fit_image'>
                  {{#if this.app_state.speak_mode_modeling_ideas.word}}
                    <div style='position: absolute; left: 0; top: 3px; width: 100%; text-align: center;'>
                      <span style='border: 3px solid rgba(255, 255, 255, 0.7); border-radius: 3px;'>
                        <span style='background: rgba(255, 255, 255, 0.9);'>"{{this.app_state.speak_mode_modeling_ideas.word}}"</span>
                      </span>
                    </div>
                  {{/if}}
                </span>
              {{else if this.app_state.user_badge}}
                <span class='notification'>
                  {{#if this.app_state.user_badge.earned}}
                    {{badge-earned badge=this.app_state.user_badge inline=true}}
                  {{else}}
                    {{badge-progress badge=this.app_state.user_badge inline=true}}
                  {{/if}}
                </span>
              {{else if this.app_state.speak_mode_modeling_ideas.timeout}}
                <span class='notification' style='height: 100%; position: absolute; top: 5px; left: 0; right: 0; bottom: 5px; height: auto;'>
                  <img src={{path "images/modeling_ideas.svg"}} style='height: 100%; width: 100%; opacity: 0.3;' class='fit_image'>
                </span>
              {{/if}}
            </button>
          {{/unless}}
        {{/if}}
      {{/unless}}
      <button class="btn btn-default access skinnier" id="backspace_button" {{action "backspace"}}>
        <span class="sr-only">{{t "backspace" key="backspace_lower"}}</span>
        <img src={{path "images/delete.svg"}}>
      </button>
      {{#triple-click-listener triple_click="toggle_modeling"}}
        <button class="btn btn-default access" id="clear_button" {{action "clear"}} style='position: relative;'>
          <span class="sr-only">{{t "clear" key="clear_lower"}}</span>
          <span class="glyphicon glyphicon-remove button_icon" style="margin: 5px -5px 0;"></span>
          {{#if this.app_state.modeling}}
            <div style="position: absolute; bottom: 2px; left: 2px;">
              <span class="glyphicon glyphicon-hand-up"></span>
            </div>
          {{/if}}
        </button>
      {{/triple-click-listener}}
    </span>
  {{else}}
    <span id="nav_header" class={{this.app_state.nav_header_class}}>
    {{#if this.app_state.currentUser}}
      {{#unless this.app_state.speak_mode}}
        {{#unless this.app_state.edit_mode}}
          {{#unless this.app_state.embedded}}
            {{#unless this.showBentoStyleHeader}}
              {{! Hide Help when on a board in normal mode so Done with Boards is flush left }}
              {{#if this.app_state.currentBoardState.id}}
                {{! On board, not edit: no Help (normal mode bar) }}
              {{/if}}
            {{/unless}}
          {{/unless}}
        {{/unless}}
      {{/unless}}
    {{/if}}
    {{#if this.app_state.currentUser.single_org.image_url}}
      {{#if this.showBentoStyleHeader}}
        {{#unless (is-equal this.app_state.current_route "landing")}}
          <img style="position: absolute; top: 50px; left: 19px; width: 50px; height: 50px; border-radius: 50px; object-fit: contain; object-position: center;" src={{this.app_state.currentUser.single_org.image_url}} onerror="this.style.display='none';">
        {{/unless}}
      {{/if}}
    {{/if}}
    <h1 class={{this.app_state.h1_class}} style='position: relative; z-index: 1;'>

      <span class="nav-header__brand">
        <a href="#" {{action "index"}} class="nav-header__logo-link">
          <img src={{if this.app_state.domain_settings.logo_url this.app_state.domain_settings.logo_url (path "images/LL_Logo_Line_Bright.png")}} alt="LingoLinq" class="nav-header__logo-svg">
        </a>
      </span>
    </h1>
    {{#if this.app_state.currentBoardState.id}}
      {{#unless this.app_state.edit_mode}}
        {{! Done with Boards + normal_mode + board_id in flex layout: col1 = Done (2 rows), col2 = normal_mode then board_id }}
        <div class="nav-header__board-bar">
        <button id='board_done' class='btn btn-default' {{action "back_to_from_route"}}>
          {{#if this.on_board_alt}}
            <span class='board-done__exit-icon'></span>
            <span class='board-done__exit-label'>{{t "Exit Boards" key="exit_boards"}}</span>
          {{else}}
            <span style='font-size: 30px; line-height: 14px; vertical-align: bottom; padding-right: 5px;'>&times;</span>
            <span style='font-size: 16px;'>{{t "Done" key="done"}}</span>
            <span style='font-size: 11px; display: block; padding-left: 27px; margin-top: -4px;'>{{t "with boards" key="with_boards"}}</span>
          {{/if}}
        </button>
        <div class="nav-header__board-bar-right">
        <span id="normal_mode">
          {{#unless this.app_state.empty_board_history}}
            <a class="btn btn-default" href="#" {{action "back"}}>
              <span class="glyphicon glyphicon-arrow-left"></span>
              <span class="hidden">{{t "back" key="back_lower"}}</span>
            </a>
          {{/unless}}
          {{#if this.app_state.currentBoardState.id}}
            {{#if this.simple_board_header}}
              <a class="btn btn-default" href="#" {{action "toggleSpeakMode" "goBrowsedHome"}} id="speak_mode" data-placement="bottom" data-trigger="manual">
                <span class="wide">{{t "Try in Speak Mode" key="try_in_speak_mode"}}</span><span class="skinny real_skinny glyphicon glyphicon-volume-up"></span>
              </a>
              {{#if this.app_state.currentUser}}
                {{#if this.app_state.root_board_is_home}}
                  <a class="btn btn-default" href="#" {{action "setAsHome" "starting"}}>
                    <span class="wide"><span class='glyphicon glyphicon-ok'></span> {{t "Set as Home Board" key="set_as_home_board"}}</span><span class="skinny real_skinny glyphicon glyphicon-home"></span>
                  </a>
                {{else}}
                  <a class="btn btn-primary" href="#" {{action "setAsHome" "starting"}}>
                    <span class="wide">{{t "Make This my Home Board" key="make_home_board"}}</span><span class="skinny real_skinny glyphicon glyphicon-home"></span>
                  </a>
                {{/if}}
              {{/if}}
            {{else}}
              {{#if this.app_state.speak_mode_possible}}
                {{#if this.app_state.currentUser.supporter_view}}
                  <div class="btn-group">
                    <a class="btn btn-primary dropdown-toggle" data-toggle="dropdown" href="#" id="speak_mode" data-placement="bottom" data-trigger="manual">
                      <span class="wide">{{t "Speak Mode" key="speak_mode"}}</span><span class="skinny real_skinny glyphicon glyphicon-volume-up"></span>
                      <span class="caret"></span>
                    </a>
                    <ul class="dropdown-menu" role="menu">
                      {{#if this.app_state.currentUser.communicator_in_supporter_view}}
                        <li><a href="#" {{action "setSpeakModeUser" "self" "modeling"}}>{{t "model for me" key="model_for_me"}}</a></li>
                      {{/if}}
                      <li><a href="#" {{action "setSpeakModeUser" "self"}}>{{t "speak as me" key="speak_as_me"}}</a></li>
                      {{#if this.app_state.currentUser.permissions.delete}}
                        {{#if this.few_supervisees}}
                          {{#each this.few_supervisees.list as |supervisee|}}
                            <li><a href="#" {{action "setSpeakModeUser" supervisee.id "modeling"}}>{{t "model for" key="model_for_lower"}} {{supervisee.user_name}}</a></li>
                            <li><a href="#" {{action "setSpeakModeUser" supervisee.id}}>{{t "speak as" key="speak_as_lower"}} {{supervisee.user_name}}</a></li>
                          {{/each}}
                          {{#if this.few_supervisees.more}}
                            <li><a href="#" {{action "pickSpeakModeUser" "modeling"}}>{{t "model for..." key="model_for_ellipsis"}}</a></li>
                            <li><a href="#" {{action "pickSpeakModeUser" "speak"}}>{{t "speak as..." key="speak_as_ellipsis"}}</a></li>
                          {{/if}}
                        {{else}}
                          <li><a href="#" {{action "pickSpeakModeUser" "modeling"}}>{{t "model for..." key="model_for_ellipsis"}}</a></li>
                          <li><a href="#" {{action "pickSpeakModeUser" "speak"}}>{{t "speak as..." key="speak_as_ellipsis"}}</a></li>
                        {{/if}}
                      {{/if}}
                    </ul>
                  </div>
                {{else}}
                  <a class="btn btn-primary" href="#" {{action "toggleSpeakMode"}} id="speak_mode" data-placement="bottom" data-trigger="manual">
                    <span class="wide">{{t "Speak Mode" key="speak_mode"}}</span><span class="skinny real_skinny glyphicon glyphicon-volume-up"></span>
                  </a>
                {{/if}}
              {{/if}}
              {{#if this.app_state.currentUser}}

                {{#if this.board.model.levels}}
                  {{#if this.app_state.feature_flags.board_levels}}
                    <span class="dropdown" style="display: inline-block;">
                      <a class='btn btn-default' id='level_dropdown' data-toggle="dropdown" href="#" >
                        <span style='padding: 8px; border-radius: 100px; border: 1px solid #96ceff; background: #eaf5ff; margin-left: -5px'>L{{this.board.current_level}}</span>
                        <b class="caret"></b>
                      </a>
                      <ul class="dropdown-menu" role="menu" aria-labelledby="dLabel">
                        <li role="presentation">
                          <button class='skippy btn btn-default' {{action "adjust_level" "minus"}}><span class='glyphicon glyphicon-minus'></span></button>
                          <span style='display: inline-block; width: 200px; vertical-align: top; text-align: center;'>
                            {{t "Board Communication" key="board_level"}}<br>
                            {{#if this.level_description}}
                              <b>{{t "Level" key="level"}} {{this.level_description}}</b>
                            {{else}}
                              <b>{{t "Level" key="level"}} {{this.board.current_level}}</b>
                            {{/if}}
                            {{#if this.level_buttons}}
                              <div style='font-size: 12px;'>{{t "visible button" key="n_visible_buttons" count=this.level_buttons}}</div>
                            {{/if}}
                          </span>
                          <button class='skippy btn btn-default' {{action "adjust_level" "plus"}}><span class='glyphicon glyphicon-plus'></span></button>
                        </li>
                        <li>
                          <div style='width: calc(100% - 10px); font-size: 12px; white-space: normal; margin: 15px 10px 5px;'>
                            {{t "Some boards are built with progressive levels in mind, so you can start basic and grow the vocabulary over time without having to rebuild everything. Find a level that works for your communicator, you can easily change it later." key="board_levels_explainer"}}
                          </div>
                        </li>
                        {{#if this.board.model.has_overrides}}
                          {{#if this.board.model.permissions.edit}}
                            <li>
                              <button class='btn btn-default' style='width: 100%;' {{action "clear_overrides"}}>{{t "Clear Level Overrides" key="clear_level_overrides"}}</button>
                            </li>
                          {{/if}}
                        {{/if}}
                      </ul>
                    </span>
                  {{/if}}
                {{else}}
                  {{#if this.board.model.multiple_copies}}
                    <span style="margin-right: -1px;">
                    <a href="#" class='btn btn-info' {{action "list_copies"}}>
                      <span class="wide">{{t "Copies" key="copies"}}</span><span class="skinny real_skinny glyphicon glyphicon-file"></span>
                    </a>
                    </span>
                  {{else if this.board.model.copy.key}}
                    <!-- TODO: no idea why this is necessary -->
                    <span style="margin-right: -1px;">
                    <LinkTo @route="board" @model={{this.board.model.copy.key}} class="btn btn-info">
                      <span class="wide">{{t "My Copy" key="my_copy"}}</span><span class="skinny real_skinny glyphicon glyphicon-file"></span>
                    </LinkTo>
                    </span>
                  {{else if this.board.model.original.key}}
                    <!-- TODO: no idea why this is necessary -->
                    <span style="margin-right: -1px;">
                    <LinkTo @route="board" @model={{this.board.model.original.key}} class="btn btn-info">
                      <span class="wide">{{t "Original" key="original"}}</span><span class="skinny real_skinny glyphicon glyphicon-certificate"></span>
                    </LinkTo>
                    </span>
                  {{/if}}
                {{/if}}

                {{#if this.app_state.currentBoardState.translatable}}
                  <span class="dropdown" style="display: inline-block;">
                    <a class='btn btn-default' data-toggle="dropdown" href="#" >
                      <span class='glyphicon glyphicon-globe'></span>
                      {{this.app_state.label_locale}}
                      <b class="caret"></b>
                    </a>
                    <ul class="dropdown-menu" role="menu" aria-labelledby="dLabel">
                      {{#each this.board.model.readable_locales as |loc|}}
                        <li role="presentation">
                          <a role="menuitem" tabindex="-1" href="#" {{action "set_locale" loc.locale}}>{{loc.string}}</a>
                        </li>
                      {{/each}}
                    </ul>
                  </span>
                {{/if}}

                {{#if this.board.model.permissions.edit}}
                  <a class='btn btn-default not_really_skinny' href="#" {{action "toggleEditMode"}}>
                    <span class="wide">{{t "Edit Board" key="edit_board"}}</span><span class="skinny real_skinny glyphicon glyphicon-pencil"></span>
                  </a>
                {{else if this.board.model.for_sale}}
                  <a class='btn btn-default not_really_skinny' href="#" {{action "purchase_board"}}>
                    <span class="wide">{{t "Purchase Board" key="purchase_board"}}</span><span class="skinny real_skinny glyphicon glyphicon-usd"></span>
                  </a>
                {{else}}
                  {{#unless this.board.model.uncopyable}}
                    <a class='btn btn-default not_really_skinny' href="#" {{action "toggleEditMode"}}>
                      <span class="wide">{{t "Edit Board" key="edit_board"}}</span><span class="skinny real_skinny glyphicon glyphicon-pencil"></span>
                    </a>
                  {{/unless}}
                {{/if}}
