<span style='display: block;' title={{this.board.long_preview}}>
    <span class="icon" style='display: block;'>
      <img src={{this.board.icon_url_with_fallback}} onerror="button_broken_image(this);">
    </span>
    <span style="display: block; height: 50px">
      <span style="color: #666; padding-left: 8px; display: block;">
        {{this.board.grid.rows}} x {{this.board.grid.columns}}
      </span>
      {{#if this.board.unlinked_buttons}}
        <span style="color: #888; padding-left: 8px; display: block;">
          <span class="glyphicon glyphicon-th"></span>
          {{this.board.unlinked_buttons}}
        </span>
      {{/if}}
      {{#if this.board.stars}}
        <span style="color: #222; padding-left: 8px; display: block;">
          <span class="glyphicon glyphicon-star"></span>
          {{this.board.stars}}
        </span>
      {{/if}}
      {{#if this.board.different_locale}}
        <span style='color: #888; padding-left: 8px; display: block;'>
          {{this.board.shortened_locale}}
        </span>
      {{/if}}
    </span>
    <span style="display: block; clear: both;"></span>
</span>
<span class="names" title={{this.board.long_preview}}>
  <span class="name">
    {{#unless this.board.public}}<span class="glyphicon glyphicon-lock"></span>{{/unless}}
    {{this.board.name}}{{#if this.board.copy_version}} <span style='color: #666; font-size: 10px;'>({{this.board.copy_version}})</span>{{/if}}
  </span><br>
  <span class="labels">{{this.board.labels}}</span>
</span><br>
<span class="user_name">{{this.board.user_name}}</span><br>
