{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="md-modal-header">
    <button type="button" class="close" {{action "close"}}>&times;</button>
    <h3 class="md-modal-title">{{t "Manage Start Codes" key="manage_start_codes"}} — {{this.org_or_user.name}}</h3>
  </div>
  <div class="md-modal-body" style="text-align: left;">
    {{#if this.link_code}}
      <h4 class="md-org-settings-card__title" style="margin-bottom: 12px;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        {{t "Registration Link for Start Code - " key="link_for_start_code"}} {{this.link_code.code}}
      </h4>
      <p class="md-modal-message" style="text-align: left; margin-bottom: 16px;">{{t "The following link can be shared with new users. You can save the QR code below to embed in additional resources, or copy the registration link directly to your clipboard. When users follow that link, the start code will be automatically generated for them." key="start_code_link_explainer"}}</p>
      <div style="text-align: center; margin-bottom: 16px;">
        {{qr-code text=this.link_code.url}}
      </div>
      <div class="md-modal-footer" style="border: none; padding: 0; justify-content: center;">
        <button class="md-modal-btn md-modal-btn--primary" {{action "copy_link"}}>{{t "Copy Registration Link" key="copy_registration_link"}}</button>
        <button class="md-modal-btn md-modal-btn--secondary" {{action "copy_code"}}>{{t "Copy QR Code" key="copy_qr_code"}}</button>
        <button class="md-modal-btn md-modal-btn--cancel" {{action "back"}}>{{t "Back to List" key="back_to_list"}}</button>
      </div>
    {{else}}
      {{#if this.model.user}}
        <p class="md-modal-hint" style="margin-bottom: 16px;">{{t "Start codes are unique codes you can share with users who are new to LingoLinq. When they sign up they can optionally enter a start code, and if they do, then they will automatically see you added as a supervisor. You can also optionally set some preferences for them, like a default starting board." key="start_codes_user_explainer"}}</p>
      {{else}}
        <p class="md-modal-hint" style="margin-bottom: 16px;">{{t "Start codes are unique codes you can share with users who are new to LingoLinq. When they sign up they can optionally enter a start code, and if they do, then they will automatically be added to your organization. You can also optionally set some preferences for them, like a default starting board, and these settings will be set for each user who uses the start code." key="start_codes_org_explainer"}}</p>
      {{/if}}

      <h4 class="md-org-settings-card__title" style="font-size: 15px;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        {{t "Existing Codes" key="existing_codes"}}
      </h4>

      {{#if this.org_or_user.start_codes}}
        <div class="md-sc-list">
          {{#each this.sorted_start_codes as |code|}}
            <div class="md-sc-row {{if code.disabled 'md-sc-row--disabled'}}">
              <div class="md-sc-row__code">
                {{#if code.disabled}}
                  <del class="md-sc-row__code-text md-sc-row__code-text--disabled">{{code.code}}</del>
                {{else}}
                  <a href="#" class="md-sc-row__code-text" {{action "copy" code.code}}>{{code.code}}</a>
                  {{#if code.to_delete}}
                    <button class="md-modal-btn md-modal-btn--cancel" style="padding: 4px 10px; font-size: 12px; margin-top: 4px;" {{action "delete" code}}>
                      {{#if code.status.deleting}}
                        {{t "deleting..." key="deleting"}}
                      {{else if code.status.error}}
                        {{t "error deleting" key="error_deleting"}}
                      {{else}}
                        {{t "confirm delete" key="confirm_delete"}}
                      {{/if}}
                    </button>
                  {{else}}
                    <button class="md-org-btn md-org-btn--outline md-org-btn--sm" style="margin-top: 4px;" {{action "code_link" code}}>{{t "generate link" key="generate_link"}}</button>
                  {{/if}}
                {{/if}}
              </div>
              <div class="md-sc-row__settings">
                {{#if this.model.org}}
                  <span class="md-sc-tag">{{t "Add to Organization" key="add_to_organization"}}</span>
                {{else if this.model.user}}
                  <span class="md-sc-tag">{{t "Add me as Supervisor" key="add_me_as_supervisor"}}</span>
                {{/if}}
                {{#if code.home_board_key}}
                  <span class="md-sc-detail">{{t "Home Board:" key="home_board_colon"}} {{code.home_board_key}}{{#if code.shallow_clone}}*{{/if}}</span>
                {{/if}}
                {{#if code.locale}}
                  <span class="md-sc-detail">{{t "Language:" key="language_colon"}} {{code.locale}}</span>
                {{/if}}
                {{#if code.symbol_library}}
                  <span class="md-sc-detail">{{t "Symbols:" key="symbols_colon"}} {{code.symbol_library}}</span>
                {{/if}}
                <span class="md-sc-detail">
                  {{#if code.premium}}
                    <strong>{{t "Sponsored" key="sponsored"}}</strong>
                  {{/if}}
                  {{#if code.supporter_type}}
                    <strong>{{t "Supporter" key="supporer"}}</strong>
                  {{else}}
                    <strong>{{t "Communicator" key="communicator"}}</strong>
                  {{/if}}
                </span>
                {{#if code.premium_symbols}}
                  <span class="md-sc-detail"><strong>{{t "Premium Symbols" key="premium_symbols"}}</strong></span>
                {{/if}}
                {{#if code.supervisors}}
                  <span class="md-sc-detail">
                    {{t "Add Supervisors:" key="add_supervisors"}}
                    {{#each code.supervisors as |sup|}}
                      <span style="margin-right: 8px;">{{sup}}</span>
                    {{/each}}
                  </span>
                {{/if}}
              </div>
              <div class="md-sc-row__actions">
                {{#unless code.disabled}}
                  <button type="button" class="md-org-room-card__action-btn md-org-room-card__action-btn--danger" {{action "delete" code "check"}} title={{t "Delete" key="delete"}}>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                  </button>
                {{/unless}}
              </div>
            </div>
          {{/each}}
        </div>
      {{else}}
        <p class="md-muted">{{t "None generated" key="none_generated"}}</p>
      {{/if}}

      <hr class="md-org-report-divider" style="margin: 24px 0;">

      {{#if this.new_start_code}}
        <h4 class="md-org-settings-card__title" style="font-size: 15px;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          {{t "Generate a New Start Code" key="generate_new_start_code"}}
        </h4>
        <form class="md-sc-form" {{action "generate" on="submit"}}>
          <div class="md-org-settings-field">
            <label for="code" class="md-org-settings-field__label">{{t "Code" key="code"}}</label>
            <Input class="md-org-settings-input" type="text" @value={{this.code}} placeholder="(optional)" />
            {{#if this.invalid_code}}
              <span class="md-org-settings-field__hint md-org-settings-field__hint--warn">{{t "codes must be 7+ characters long and start with a letter" key="codes_must_start_with_letter"}}</span>
            {{/if}}
          </div>
          {{#if this.model.org}}
            <div class="md-org-settings-field">
              <label for="user_type" class="md-org-settings-field__label">{{t "User Type" key="user_type"}}</label>
              {{bound-select select_class="md-org-report-select" select_id="user_type" content=this.user_types selection=this.user_type action=(action (mut this.user_type)) }}
            </div>
            <div class="md-org-settings-field">
              <label class="md-org-settings-field__label">{{t "Sponsored" key="sponsored"}}</label>
              <label class="md-org-settings-toggle">
                <Input id="premium" type="checkbox" @checked={{this.premium}} class="md-org-settings-toggle__input" />
                <span class="md-org-settings-toggle__label">{{t "Sponsor any users who use this start code" key="sponsors_users_with_start_code"}}</span>
              </label>
            </div>
            {{#if this.premium}}
              <div class="md-org-settings-field">
                <label class="md-org-settings-field__label">{{t "Premium Symbols" key="premium_symbols"}}</label>
                <label class="md-org-settings-toggle">
                  <Input id="premium_symbols" type="checkbox" @checked={{this.premium_symbols}} class="md-org-settings-toggle__input" />
                  <span class="md-org-settings-toggle__label">{{t "Add premium symbols to users" key="add_premium_symbols_to_users"}}</span>
                </label>
              </div>
            {{/if}}
          {{/if}}
          <div class="md-org-settings-field">
            <label for="locale" class="md-org-settings-field__label">{{t "Language" key="language"}}</label>
            {{bound-select select_class="md-org-report-select" select_id="locale" content=this.locales selection=this.locale action=(action (mut this.locale)) }}
          </div>
          <div class="md-org-settings-field">
            <label for="symbol_library" class="md-org-settings-field__label">{{t "Default Symbols" key="default_symbols"}}</label>
            {{bound-select select_class="md-org-report-select" select_id="symbol_library" content=this.symbol_libraries selection=this.symbol_library action=(action (mut this.symbol_library)) }}
          </div>
          {{#if this.model.org}}
            <div class="md-org-settings-field">
              <label for="supervisor" class="md-org-settings-field__label">{{t "Supervisor" key="supervisor"}}</label>
              <Input class="md-org-settings-input" type="text" @value={{this.supervisors}} placeholder="(optional supervisor user names, comma-separated)" />
            </div>
          {{/if}}
          <div class="md-org-settings-field">
            <label for="home_board" class="md-org-settings-field__label">{{t "Home Board" key="home_board"}}</label>
            <Input class="md-org-settings-input" type="text" @value={{this.home_board_key}} placeholder="(optional board key to copy)" />
            {{#if this.home_board_key}}
              <label class="md-org-settings-toggle" style="margin-top: 8px;">
                <Input id="shallow_clone" type="checkbox" @checked={{this.shallow_clone}} class="md-org-settings-toggle__input" />
                <span class="md-org-settings-toggle__label">{{t "Apply shallow clones" key="apply_shallow_clones"}}</span>
              </label>
            {{/if}}
          </div>
          {{#if this.model.board.downstream_boards}}
            <div class="md-org-settings-field">
              <label class="md-org-settings-field__label">{{t "Linked Boards" key="linked_boards"}}</label>
              <label class="md-org-settings-toggle">
                <Input @type="checkbox" @checked={{this.downstream}} class="md-org-settings-toggle__input" />
                <span class="md-org-settings-toggle__label">{{t "Categorize all Linked Boards in the same category" key="categorize_linked_board"}}</span>
              </label>
            </div>
          {{/if}}
          <div style="margin-top: 16px;">
            <button class="md-modal-btn md-modal-btn--primary" type="submit" disabled={{this.status.generating}}>
              {{#if this.status.generating}}
                {{t "Generating..." key="generating"}}
              {{else if this.status.taken}}
                {{t "Code is Not Available" key="code_not_available"}}
              {{else if this.status.invalid_home}}
                {{t "Invalid Home Board" key="invalid_home_board"}}
              {{else if this.status.error}}
                {{t "Error Generating" key="error_generating"}}
              {{else}}
                {{t "Generate" key="generate"}}
              {{/if}}
            </button>
          </div>
        </form>
      {{else}}
        <div style="text-align: center;">
          <button class="md-modal-btn md-modal-btn--primary" {{action "new"}}>{{t "New Start Code" key="new_start_code"}}</button>
        </div>
      {{/if}}
    {{/if}}
  </div>
  <div class="md-modal-footer">
    <button type="button" class="md-modal-btn md-modal-btn--cancel" {{action "close"}}>{{t "Close" key="close"}}</button>
  </div>
{{/modal-dialog}}
