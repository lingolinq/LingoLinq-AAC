{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="modal-header md-modal-header">
      <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h3 class="md-modal-title">
      {{#if this.selected_tool}}
        {{t "Add %{tool}" tool=this.selected_tool.name key="add_tool"}}
      {{else}}
        {{t "Browse Tools" key="browse_tools"}}
      {{/if}}
    </h3>
  </div>
  <div class="modal-body md-modal-body">
    {{#if this.selected_tool}}
      <h3>
        <img src={{this.selected_tool.icon_url}} style='height: 50px; max-width: 70px; padding-right: 10px;'>
        {{this.selected_tool.name}}
      </h3>
      {{#if this.selected_tool.integration_key}}
        {{#if this.selected_tool.uses}}
          <div class='text-muted' style='margin-top: -10px; margin-bottom: 10px;'>{{t "installed by" key="installed_by"}} {{t "user" key="n_users" count=this.selected_tool.uses}}</div>
        {{/if}}
      {{/if}}
      <span style='white-space: pre-line'>{{safe this.selected_tool.description}}</span>
      {{#if this.user_parameters}}
        <form class="form-horizontal" {{action "nothing" on="submit"}}>
          <div class="form-group">
            <div class='col-sm-8 col-sm-offset-3'>
              <h4 class='form-control-static'>{{t "Tool Settings" key="tool_settings"}}</h4>
            </div>
          </div>
          {{#each this.user_parameters as |param|}}
            <div class="form-group">
              <label for={{param.name}} class="col-sm-3 control-label">{{param.label}}</label>
              <div class="col-sm-6">
                <Input @type={{param.type}} @value={{param.value}} class="form-control" id={{param.name}} placeholder={{param.hint}} />
              </div>
            </div>
          {{/each}}
        </form>
      {{/if}}
    {{else}}
      {{#if this.tools.loading}}
        <p>{{t "Loading tools..." key="loading_tools"}}</p>
      {{else if this.tools.error}}
        <p>{{t "Error loading tools" key="error_loading_tools"}}</p>
      {{else if this.tools}}
        {{#each this.tools as |tool|}}
          <div class='well' {{action "select_tool" tool}} style='cursor: pointer;'>
            <div>
              <img src={{tool.icon_url}} style='height: 30px; max-width: 50px;'>
              <span style='font-weight: bold; font-size: 20px; vertical-align: middle; padding-left: 5px;'>{{tool.name}}</span>
            </div>
            <div style='max-height: 43px; overflow: hidden;'>{{safe tool.description}}</div>
          </div>
        {{/each}}
      {{else}}
        <p>{{t "No tools available" key="no_tools_available"}}</p>
      {{/if}}
    {{/if}}
  </div>
  <div class="modal-footer md-modal-footer">
    {{#if this.selected_tool}}
      <button type="button" {{action "install"}} disabled={{this.not_ready}} class="btn md-modal-btn md-modal-btn--primary">
        {{#if this.selected_tool.installing}}
          {{t "Installing Tool..." key="installing_tool"}}
        {{else if this.selected_tool.error}}
          {{t "Error Installing Tool" key="error_installing_tool"}}
        {{else}}
          {{t "Install Tool" key="install_tool"}}
        {{/if}}
      </button>
      {{#unless this.hide_list}}
        <button type="button" {{action "browse"}} class="btn md-modal-btn md-modal-btn--cancel">{{t "Back to List" key="back_to_list"}}</button>
      {{/unless}}
    {{/if}}
    <button type="button" {{action "close"}} class="btn md-modal-btn md-modal-btn--cancel">{{t "Cancel" key="cancel"}}</button>
    {{#if this.selected_tool.error}}
      <div>
        {{#if this.selected_tool.error.bad_credentials}}
          <em class='text-danger'>{{t "Please check that you have entered the correct settings" key="please_check_settings"}}</em>
        {{else if this.selected_tool.error.credential_collision}}
          <em class='text-danger'>{{t "It looks like those settings are already being used by a different %app_name% user" key="credentials_already_in_use"}}</em>
        {{else if this.selected_tool.error.bad_webhook}}
          <em class='text-danger'>{{t "The URL you entered doesn't seem to match the value needed for this integration" key="bad_webhook_url"}}</em>
        {{/if}}
      </div>
    {{/if}}
  </div>
{{/modal-dialog}}
