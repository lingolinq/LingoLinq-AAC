{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="md-modal-header">
    <button type="button" class="close" {{action "close"}}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h3 class="md-modal-title">
      {{t "Find a Button" key="find_a_button"}}
    </h3>
  </div>
  <div class="md-modal-body">
    {{focus-input force="true" type="text" id="button_search_string" value=this.searchString class="md-modal-input" select="pick_result" placeholder="Word or phrase you're looking for"}}
    {{#if this.searchString}}
      <div id="button_results" style="margin-top: 12px;">
        {{#if this.results}}
          {{#each this.results as |result|}}
            <div {{action "pick_result" result}} class="result" style="padding: 8px 0; border-bottom: 1px solid rgba(27, 54, 93, 0.08); cursor: pointer;">
              {{#if result.sequence}}
                <div class='img_holder'>
                  {{#each result.steps as |step|}}
                    <img src={{step.button.image}} data-fallback={{step.button.fallback_image}} onerror="button_broken_image(this);" >
                  {{/each}}
                </div>
                {{result.text}}
                <div class='location'>
                  {{#if result.extra_steps}}
                    {{t "Get there through: " key="get_there_through"}}
                    {{#each result.steps as |step|}}
                      {{#if step.sequence.pre}}
                        <span class='link_list'>{{t "Home" key="home"}}</span>
                      {{/if}}
                      {{#each step.sequence.buttons as |btn|}}
                        <span class='link_list'>
                          {{#if btn.label}}
                            {{btn.label}}
                          {{else}}
                            {{btn.vocaliationl}}
                          {{/if}}
                        </span>
                      {{/each}}
                      <span class='link_list'><em>
                        {{#if step.button.label}}
                          {{step.button.label}}
                        {{else}}
                          {{step.button.vocaliationl}}
                        {{/if}}
                      </em></span>
                    {{/each}}
                  {{else}}
                    {{t "On this board" key="on_this_board"}}
                  {{/if}}
                </div>
              {{else}}
                <div class="img_holder">
                  <img src={{result.image}} data-fallback={{result.fallback_image}} onerror="button_broken_image(this);" >
                </div>
                {{result.label}}
                <div class="location">
                  {{#if result.on_this_board}}
                    {{t "On this board" key="on_this_board"}}
                  {{else}}
                    {{t "Get there through: " key="get_there_through"}}
                    {{#if result.pre_action}}
                      <span class="link_list">{{t "Home" key="home"}}</span>
                    {{/if}}
                    {{#each result.pre_buttons as |pre|}}
                      <span class="link_list">
                        {{#if pre.label}}
                          {{pre.label}}
                        {{else}}
                          {{pre.vocalization}}
                        {{/if}}
                      </span>
                    {{/each}}
                  {{/if}}
                </div>
              {{/if}}
            </div>
          {{/each}}
        {{else}}
          <div style="padding: 16px 0; color: var(--md-muted, #6b7280);">
            {{#if this.loading}}
              {{t "Loading..." key="loading"}}
            {{else}}
              {{#if this.error}}
                {{this.error}}
              {{else}}
                {{#if this.button_set.buttons.length}}
                  {{t "No buttons found" key="no_buttons_found"}}
                {{else if this.button_set}}
                  {{t "No buttons loaded" key="no_buttons_loaded"}}
                {{else if this.model.board}}
                  {{t "Couldn't load button set" key="couldnt_load_button_set"}}
                {{else}}
                  {{t "No board found for searching" key="no_board_found"}}
                {{/if}}
                <div style='margin-top: 30px; display: none;'>
                  <a href="#" {{action "request_button"}}>{{t "Request this phrase as a new button" key="request_as_a_new_button"}}</a>
                </div>
              {{/if}}
            {{/if}}
          </div>
        {{/if}}
      </div>
    {{/if}}
  </div>
  <div class="md-modal-footer">
    <button class="md-modal-btn md-modal-btn--cancel" {{action "close"}}>{{t "Cancel" key="cancel"}}</button>
  </div>
{{/modal-dialog}}
