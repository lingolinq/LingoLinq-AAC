<div class='col-sm-12'>
  <h4>{{t "Usage Logging and Reports" key="usage_logging_and_reports"}}</h4>
</div>
<div class='col-sm-6'>
  <img src={{path "images/reports.png"}} alt="" style='width: 100%;' >
</div>
<div class='col-sm-6'>
  <ul class="usage-checklist">
    <li class="usage-checklist__item">{{t "Tracks which words are used and how often they appear across sessions." key="logging_check_1"}}</li>
    <li class="usage-checklist__item">{{t "Monitors session activity so you can see when and how the device is being used." key="logging_check_2"}}</li>
    <li class="usage-checklist__item">{{t "Measures progress toward communication goals — giving your whole team clear, actionable insight." key="logging_check_3"}}</li>
  </ul>
  {{#if this.setup.setup_user}}
    <p style='margin-top: 20px;'><button class='btn btn-default btn-lg' {{action "set_preference" "logging" true target=this.setup}}>
      {{#if this.setup.setup_user.preferences.logging}}
        {{t "Logging is Enabled" key="logging_is_enabled"}}
      {{else}}
        {{t "Enable Logging" key="enable_logging"}}
      {{/if}}
    </button></p>
  {{/if}}
</div>
