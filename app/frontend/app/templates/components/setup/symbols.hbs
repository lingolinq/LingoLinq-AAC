<div class='col-sm-10 col-sm-offset-1'>
  {{#if (is-equal this.setup.mode "layout")}}
    <p class='setup-symbols-subheader'>{{t "Board Layout" key="board_layout"}}</p>
  {{else}}
    <p class='setup-symbols-subheader'>{{t "Set Starter Preferences" key="setup_symbols_subheader"}}</p>
    <p class='prompt'>{{t "In addition to selecting a board, there are some other settings that can change based on the communicator's situation. Keep in mind that you can always change these settings later under \"Preferences\"." key="start_deciding"}}</p>
  {{/if}}
</div>
<div class='col-sm-10 col-sm-offset-1'>
  <div class="setup-symbols-card-row">
    <div class="setup-symbols-preference-card">
      <div class="setup-symbols-rows">
        {{!-- 1. How do you want buttons to appear? --}}
        <div class="setup-symbols-row">
          <span class="setup-symbols-row__label">
            <span class="setup-symbols-row__icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" stroke="#2A9D8F"/><line x1="3" y1="9" x2="21" y2="9" stroke="#46505F"/><line x1="9" y1="21" x2="9" y2="9" stroke="#46505F"/></svg>
            </span>
            {{t "How do you want buttons to appear?" key="text_placement"}}
          </span>
          <div class="setup-symbols-options-group">
            <div class="setup-symbols-pills" role="group" aria-label={{t "How do you want buttons to appear?" key="text_placement"}}>
            <button type="button" class="setup-symbols-pill {{if this.setup.text_position.text_on_top "is-active"}}" {{action "selectButtonAppearance" "top"}}>{{t "Text above" key="text_above_pictures"}}</button>
            <button type="button" class="setup-symbols-pill {{if this.setup.text_position.text_on_bottom "is-active"}}" {{action "selectButtonAppearance" "bottom"}}>{{t "Text below" key="text_below_pictures"}}</button>
            <button type="button" class="setup-symbols-pill {{if this.setup.text_position.text_only "is-active"}}" {{action "selectButtonAppearance" "text_only"}}>{{t "Text only" key="no_pictures"}}</button>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="setup-symbols-card-sample">
      <div class="setup-symbols-preview" style="max-width: 200px; margin-bottom: 0;">
        <span class="setup-symbols-sample-pill">{{t "Sample" key="sample_label"}}</span>
        <div style='width: 120px; height: 120px; border-radius: 10px; border: 3px solid rgba(0, 98, 246, 0.6); text-align: center; background-color: rgba(144, 189, 255, 0.4);'>
          {{#if this.setup.text_position.text_only}}
            <div style='font-size: 18px; text-align: center; margin-top: 48px;'>{{t "happy" key="happy"}}</div>
          {{else}}
            {{#if this.setup.text_position.text_on_top}}
              <div style='font-size: 16px; text-align: center;'>{{t "happy" key="happy"}}</div>
            {{/if}}
            <span class={{this.setup.image_preview_class}}>
              {{#if this.setup.symbols.twemoji}}
                <img src='https://d18vdu4p71yql0.cloudfront.net/libraries/twemoji/1f60a.svg' style="max-width: 60px; max-height: 60px;">
              {{else if this.setup.symbols.noun_project}}
                <img src='https://d18vdu4p71yql0.cloudfront.net/libraries/noun-project/Happy_213_g.svg' style="max-width: 60px; max-height: 60px;">
              {{else if this.setup.symbols.tawasol}}
                <img src='https://d18vdu4p71yql0.cloudfront.net/libraries/tawasol/Happy%20(M).png' style="max-width: 60px; max-height: 60px;">
              {{else if this.setup.symbols.pcs}}
                <img src='https://d18vdu4p71yql0.cloudfront.net/libraries/pcs/00047/5fc50fd308c61df38e26e426845a6c055b9b900f2fec0936f916bf104172ab020da82c0a598c7df0d834310223644d93ffb2e802e0df75b6a6c0dcb61a6fe3f0/00047.svg' style="max-width: 60px; max-height: 60px;">
              {{else if this.setup.symbols.symbolstix}}
                <img src='https://d18vdu4p71yql0.cloudfront.net/libraries/symbolstix/00002700/de1f3688edc80e746edce198f0fc089edd738d2af559ada9f3195a5956ade1e404ec43a21af72003fc0ab5366d58cbad76f090a7b39eba1ed01305b9a3eafa9a/c-descriptives-feelings-symbol00002700.png' style="max-width: 60px; max-height: 60px;">
              {{else if this.setup.symbols.lessonpix}}
                <img src='https://lessonpix.com/drawings/13748/150x150/13748.png' style="max-width: 60px; max-height: 60px;">
              {{else}}
                <img src='https://opensymbols.s3.amazonaws.com/libraries/arasaac/happy.png' style="max-width: 60px; max-height: 60px;">
              {{/if}}
              {{#if this.setup.text_position.text_on_bottom}}
                <div style='font-size: 16px; text-align: center;'>{{t "happy" key="happy"}}</div>
              {{/if}}
            </span>
          {{/if}}
        </div>
      </div>
    </div>
  </div>
</div>
{{#unless this.setup.text_position.text_only}}
<div class='col-sm-10 col-sm-offset-1'>
  <div class="setup-symbols-card-row">
    <div class="setup-symbols-preference-card">
      <div class="setup-symbols-rows">
        <div class="setup-symbols-row">
          <span class="setup-symbols-row__label">
            <span class="setup-symbols-row__icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" stroke="#2A9D8F"/><circle cx="12" cy="12" r="6" stroke="#46505F"/><circle cx="12" cy="12" r="2" stroke="#4C86D8"/></svg>
            </span>
            {{t "Which symbols do you prefer?" key="which_symbols"}}
          </span>
          <div class="setup-symbols-options-group">
            <div class="setup-symbols-pills" role="group" aria-label={{t "Which symbols do you prefer?" key="which_symbols"}}>
            {{#each this.setup.symbol_library_options as |opt|}}
              {{#if opt.expand}}
                <button type="button" class="setup-symbols-pill setup-symbols-pill--expand" {{action "showMoreSymbols"}}>{{opt.label}}</button>
              {{else}}
                <button type="button" class="setup-symbols-pill {{if (is-equal this.setup.current_symbol_value opt.value) "is-active"}}" {{action "selectSymbolLibrary" opt.value}}>
                  {{opt.label}}{{#if opt.subNote}} <span class="setup-symbols-pill__subnote">{{opt.subNote}}</span>{{/if}}
                </button>
              {{/if}}
            {{/each}}
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="setup-symbols-card-sample" aria-hidden="true">
    </div>
  </div>
</div>
<div class='col-sm-10 col-sm-offset-1'>
  {{#if this.setup.premium_but_not_allowed}}
    <p class='text-warning' style='font-size: 14px; margin-bottom: 1rem;'>{{t "NOTE: You will need to purchase the premium symbols upgrade on your billing page before you can use these symbols." key="premium_upgrade_required"}}</p>
  {{else if this.setup.lessonpix_but_not_allowed}}
    <p class='text-warning' style='font-size: 14px; margin-bottom: 1rem;'>{{t "NOTE: You will need to connect your LessonPix account to your %app_name% account on your Profile page before you can use these symbols." key="lessonpix_upgrade_required"}}</p>
  {{/if}}
</div>
{{/unless}}
{{#if this.setup.app_state.feature_flags.skin_tones}}
<div class='col-sm-10 col-sm-offset-1'>
  <div class="setup-symbols-card-row setup-symbols-card-row--skin-tone">
    <div class="setup-symbols-preference-card">
      <div class="setup-symbols-rows">
        <div class="setup-symbols-row">
          <span class="setup-symbols-row__label">
            <span class="setup-symbols-row__icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4" stroke="#4C86D8"/><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke="#46505F"/></svg>
            </span>
            {{t "What skin tone(s) would you like to see on people-based pictures?" key="symbol_skin_question"}}
          </span>
          <div class="setup-symbols-options-group">
            <div class="setup-symbols-pills setup-symbols-pills--skin" role="group" aria-label={{t "What skin tone(s) would you like to see on people-based pictures?" key="symbol_skin_question"}}>
            {{#each this.setup.skin_option_list as |opt|}}
              <button type="button" class="setup-symbols-pill setup-symbols-pill--with-image {{if (is-equal opt.value "limit") "setup-symbols-pill--optional"}} {{if (get this.setup.skin opt.value) "is-active"}}" {{action "selectSkin" opt.value}}>
                <img src={{opt.image_url}} alt="" class="setup-symbols-pill__img {{opt.image_class}}" width="28" height="28">
                <span class="setup-symbols-pill__text">{{opt.label}}</span>
              </button>
            {{/each}}
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="setup-symbols-card-sample">
      <div class="setup-symbols-preview" style="max-width: 200px; margin-bottom: 0;">
        <span class="setup-symbols-sample-pill">{{t "Sample" key="sample_label"}}</span>
        <div style="width: 120px; height: 120px; border-radius: 10px; border: 3px solid rgba(246, 98, 0, 0.5); text-align: center; background-color: rgba(255, 189, 144, 0.35); display: flex; align-items: center; justify-content: center;">
          {{#if this.setup.text_position.text_only}}
            <span style="font-size: 16px;">{{t "hello" key="hello"}}</span>
          {{else}}
            <img src={{this.setup.hello_skin_url}} alt="" style="max-width: 86px; max-height: 86px; object-fit: contain;">
          {{/if}}
        </div>
      </div>
    </div>
  </div>
</div>
{{/if}}
{{#unless this.setup.text_position.text_only}}
<div class='col-sm-10 col-sm-offset-1'>
  <div class="setup-symbols-card-row">
    <div class="setup-symbols-preference-card">
      <div class="setup-symbols-rows">
        <div class="setup-symbols-row">
          <span class="setup-symbols-row__label">
            <span class="setup-symbols-row__icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6" stroke="#2A9D8F"/><polyline points="8 6 2 12 8 18" stroke="#46505F"/></svg>
            </span>
            {{t "How do you want to see words combined?" key="utterance_layout"}}
          </span>
          <div class="setup-symbols-options-group">
            <div class="setup-symbols-pills" role="group" aria-label={{t "How do you want to see words combined?" key="utterance_layout"}}>
            <button type="button" class="setup-symbols-pill {{if this.setup.utterance_layout.text_only "is-active"}}" {{action "selectUtteranceLayout" true}}>{{t "Words only" key="show_words"}}</button>
            <button type="button" class="setup-symbols-pill {{if this.setup.utterance_layout.text_with_symbols "is-active"}}" {{action "selectUtteranceLayout" false}}>{{t "Symbol buttons" key="show_symbols"}}</button>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="setup-symbols-card-sample">
      <div class="setup-symbols-preview-section">
        <span class="setup-symbols-sample-pill">{{t "Sample" key="sample_label"}}</span>
        <div class="setup-symbols-utterance-sample">
          <div class="setup-symbols-utterance-sample__box">
            {{#if this.setup.utterance_layout.text_only}}
              <span class="setup-symbols-utterance-sample__text">{{t "This is what the sentence box will look like" key="sentence_box_preview_text"}}</span>
            {{else}}
              <div class="setup-symbols-utterance-sample__chip">
                {{#if this.setup.symbols.twemoji}}
                  <img src="https://d18vdu4p71yql0.cloudfront.net/libraries/twemoji/1f44d.svg" style="width: 36px; height: 36px;" alt="">
                {{else if this.setup.symbols.noun_project}}
                  <img src="https://d18vdu4p71yql0.cloudfront.net/libraries/noun-project/good_274_g.svg" style="width: 36px; height: 36px;" alt="">
                {{else if this.setup.symbols.pcs}}
                  <img src="https://d18vdu4p71yql0.cloudfront.net/libraries/pcs/10180/480905273ecca528b3312edee90bc54a514591e90461d6431529644d56284ab48302ccfe76060398468d5b9207541278ea53722300ef47f281b6571d7d081cc7/10180.svg" style="width: 36px; height: 36px;" alt="">
                {{else if this.setup.symbols.symbolstix}}
                  <img src="https://d18vdu4p71yql0.cloudfront.net/libraries/symbolstix/00002688/1778b2858583568b64c6bb323e12ef1dc4b5df913f9a3c31097d8014e9733f4c0a36cfa2063fcab05b111c75d05fa95ccf8e6d486520e195c7620c464d9d9720/c-descriptives-feelings-good.png" style="width: 36px; height: 36px;" alt="">
                {{else if this.setup.symbols.lessonpix}}
                  <img src="https://lessonpix.com/drawings/20335/100x100/20335.png" style="width: 36px; height: 36px;" alt="">
                {{else}}
                  <img src="https://d18vdu4p71yql0.cloudfront.net/libraries/arasaac/good.png" style="width: 36px; height: 36px;" alt="">
                {{/if}}
                <div class="setup-symbols-utterance-sample__label">{{t "good" key="good"}}</div>
              </div>
              <div class="setup-symbols-utterance-sample__chip">
                {{#if this.setup.symbols.twemoji}}
                  <img src="https://d18vdu4p71yql0.cloudfront.net/libraries/twemoji/1f305.svg" style="width: 36px; height: 36px;" alt="">
                {{else if this.setup.symbols.noun_project}}
                  <img src="https://d18vdu4p71yql0.cloudfront.net/libraries/noun-project/sunrise_856_g.svg" style="width: 36px; height: 36px;" alt="">
                {{else}}
                  <img src="https://d18vdu4p71yql0.cloudfront.net/libraries/arasaac/morning.png" style="width: 36px; height: 36px;" alt="">
                {{/if}}
                <div class="setup-symbols-utterance-sample__label">{{t "morning" key="morning"}}</div>
              </div>
            {{/if}}
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="setup-symbols-card-row setup-symbols-card-row--picture-display">
    <div class="setup-symbols-preference-card">
      <div class="setup-symbols-rows">
        <div class="setup-symbols-row">
          <span class="setup-symbols-row__label">
            <span class="setup-symbols-row__icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" stroke="#46505F"/><circle cx="8.5" cy="8.5" r="1.5" stroke="#2A9D8F"/><path d="M21 15l-5-5L5 21" stroke="#7693B9"/></svg>
            </span>
            {{t "How do you want pictures to display?" key="symbol_background_question"}}
          </span>
          <div class="setup-symbols-options-group">
            <div class="setup-symbols-pills" role="group" aria-label={{t "How do you want pictures to display?" key="symbol_background_question"}}>
            <button type="button" class="setup-symbols-pill {{if this.setup.background.clear "is-active"}}" {{action "selectSymbolBackground" "clear"}}>{{t "Color background" key="clear_background"}}</button>
            <button type="button" class="setup-symbols-pill {{if this.setup.background.white "is-active"}}" {{action "selectSymbolBackground" "white"}}>{{t "White background" key="always_white_background"}}</button>
            <button type="button" class="setup-symbols-pill {{if this.setup.background.black "is-active"}}" {{action "selectSymbolBackground" "black"}}>{{t "Black background" key="always_black_background"}}</button>
            <button type="button" class="setup-symbols-pill {{if this.setup.background.black_with_high_contrast "is-active"}}" {{action "selectSymbolBackground" "black_with_high_contrast"}}>{{t "High contrast" key="high_contrast_black_background"}}</button>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="setup-symbols-card-sample">
      <div class="setup-symbols-preview" style="max-width: 200px; margin-bottom: 0;">
        <span class="setup-symbols-sample-pill">{{t "Sample" key="sample_label"}}</span>
        <div class="setup-symbols-preview-bg {{if this.setup.background.white 'setup-symbols-preview-bg--white'}} {{if this.setup.background.black 'setup-symbols-preview-bg--black'}} {{if this.setup.background.black_with_high_contrast 'setup-symbols-preview-bg--black'}} {{if this.setup.background.black_with_high_contrast 'setup-symbols-preview-bg--high-contrast'}}">
          {{#if this.setup.text_position.text_only}}
            <span class="setup-symbols-preview-bg__text {{if this.setup.background.black_with_high_contrast 'setup-symbols-preview-bg__text--high-contrast'}}">{{t "frog" key="frog"}}</span>
          {{else}}
            <span class="symbol_preview {{if this.setup.background.white 'white'}} {{if this.setup.background.black 'black'}} {{if this.setup.background.black_with_high_contrast 'black'}}">
              {{#if this.setup.symbols.twemoji}}
                <img src="https://d18vdu4p71yql0.cloudfront.net/libraries/twemoji/1f438.svg" style="max-width: 84px; max-height: 84px;" alt="">
              {{else if this.setup.symbols.noun_project}}
                <img src="https://d18vdu4p71yql0.cloudfront.net/libraries/noun-project/Green-frog_582_g.svg" style="max-width: 84px; max-height: 84px;" alt="">
              {{else if this.setup.symbols.pcs}}
                <img src="https://d18vdu4p71yql0.cloudfront.net/libraries/pcs/02086/70f88a99a243736c9f554808cbff30c26a8b74a25f06d58e31dd392a89f6586ebe03d6ff2d617e71e98c3901689c833d56e96e5e48dbb1cf51da8336d46b5728/02086.svg" style="max-width: 84px; max-height: 84px;" alt="">
              {{else if this.setup.symbols.symbolstix}}
                <img src="https://d18vdu4p71yql0.cloudfront.net/libraries/symbolstix/00001114/fabde031d3fb14205b35670fc5b66ddfe187344c73f1edcbc756525c6d6834bcad0b4791eebec7f38367ac3369282156ab08ba1e92b155930b8e4dcc14142add/c-animals-symbol00001114.png" style="max-width: 84px; max-height: 84px;" alt="">
              {{else if this.setup.symbols.lessonpix}}
                <img src="https://lessonpix.com/drawings/1283/150x150/1283.png" style="max-width: 84px; max-height: 84px;" alt="">
              {{else}}
                <img src="https://opensymbols.s3.amazonaws.com/libraries/arasaac/frog.png" style="max-width: 84px; max-height: 84px;" alt="">
              {{/if}}
            </span>
          {{/if}}
        </div>
      </div>
    </div>
  </div>
</div>
{{/unless}}
