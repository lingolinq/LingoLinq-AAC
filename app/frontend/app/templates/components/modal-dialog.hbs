{{#if this.standalone}}
  <div class="modal-content modal-content--standalone">
    {{yield}}
  </div>
{{else}}
<div class="modal fade in" style="display: block;" data-uncloseable={{this.uncloseable}} role="dialog" aria-modal="true">
  <div class="modal-dialog">
    {{#touch-listener select=(action "any_select")}}
      <div class={{if this.auto_close "modal-content auto_close" "modal-content"}}>
        {{yield}}
      </div><!-- /.modal-content -->
    {{/touch-listener}}
  </div><!-- /.modal-dialog -->
</div><!-- /.modal -->
{{/if}}
