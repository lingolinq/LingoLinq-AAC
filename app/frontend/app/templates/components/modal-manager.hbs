{{!-- Modal Manager Component Template --}}
{{!-- Renders modals based on modal service state --}}

{{#if currentModal}}
  {{#unless isHighlight}}
    <div class="modal-backdrop fade in"></div>
  {{/unless}}

  <div class="modal fade in" style="display: block;" role="dialog">
    <div class="modal-dialog">
      <div class="modal-content">
        {{!-- Dynamically render the current modal component --}}
        {{!-- The modal template will be looked up by name --}}
        {{#if isComponent}}
          {{component currentModal options=modalOptions close=(action "closeModal")}}
        {{else}}
          <div class="modal-body">
            <p class="text-danger">Error: Modal "{{currentModal}}" is not converted to a component yet.</p>
            <p>Please move its template to <code>app/templates/components/{{currentModal}}.hbs</code></p>
          </div>
        {{/if}}
      </div>
    </div>
  </div>
{{/if}}
