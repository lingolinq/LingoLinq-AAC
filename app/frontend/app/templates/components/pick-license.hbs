{{#if this.license.uneditable}}
  <div class="form-group">
    <label for="license" class="col-sm-2 control-label">{{t "License" key="license"}}</label>
    <div class="col-sm-10">
      <p class='form-control-static'>
        {{license-attribution license=this.license}}
      </p>
    </div>
  </div>
{{else}}
  <div class="form-group">
    <label for="license" class="col-sm-2 control-label">{{t "License" key="license"}}</label>
    <div class="col-sm-10">
      {{bound-select select_class="form-control" select_id="license" content=this.licenseOptions selection=this.license.type action=(action (mut this.license.type)) }}
    </div>
  </div>
  {{#unless this.private_license}}
    <div class="form-group">
      <label for="license_author" class="col-sm-2 control-label">{{t "Author" key="author"}}</label>
      <div class="col-sm-4">
        <!-- Ember is now barfing if I add more than one element with the same id, so changed to refid for now -->
        {{input value=this.license.author_name class="form-control" refid="license_author" placeholder="Name"}}
      </div>
      <div class="col-sm-6">
        {{input value=this.license.author_url class="form-control" title="Author URL" placeholder="Author URL"}}
      </div>
    </div>
  {{/unless}}
{{/if}}
