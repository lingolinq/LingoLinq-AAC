{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="modal-header md-modal-header">
    <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h3>
      <img src={{path "images/learn.png"}} style='height: 70px; margin: -10px 0;'>
      {{t "Board Intro" key="board_intro"}}
    </h3>
  </div>
  <div class="modal-body md-modal-body">
    {{#if this.current_step.description}}
      <div style='white-space: pre-line;'>{{this.current_step.description}}</div>
    {{else if this.current_step}}
      {{t "No content provided" key="no_content_provided"}}
    {{else}}
      {{t "That's it! If you want to go through this intro again, just hit the menu in the top right corner and choose \"Board Intro\"" key="done_board_intro"}}
    {{/if}}
    {{#if this.current_step.prompt}}
      <div style='margin-top: 20px;'>
        {{t "Try It Yourself! Find the buttons to say:" key="try_for_buttons"}}<br>
        <span style='font-size: 20px; font-weight: bold; padding-left: 20px;'>"{{this.current_step.prompt}}"</span>
      </div>
    {{/if}}
  </div>
  <div class='modal-footer'>
    {{#if this.current_step.prompt}}
      <button class='btn btn-primary btn-lg' {{action "start"}}>{{t "I'm Ready to Try" key="ready_to_try"}}</button>
      {{#if this.next_step}}
        <button class='btn btn-default btn-lg' {{action "next"}}>{{t "Skip" key="skip"}}</button>
      {{/if}}
    {{else if this.next_step}}
      <button class='btn btn-primary btn-lg' {{action "next"}}>{{t "Continue" key="continue"}}</button>
    {{/if}}
    <button class='btn btn-default btn-lg' {{action "close"}}>{{t "Close" key="close"}}</button>
  </div>
{{/modal-dialog}}
