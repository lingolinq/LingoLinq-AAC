{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="modal-header md-modal-header">
    <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h3 class="md-modal-title">{{t "Set Home Board" key="set_home_board"}}</h3>
  </div>
  <div class="modal-body md-modal-body">
    <div class="md-modal-icon-row">
      <div class="md-modal-icon-circle">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true">
          <path d="M12 3L2 12h3v8h6v-6h2v6h6v-8h3L12 3z"/>
        </svg>
      </div>
    </div>

    {{#if this.multiple_users}}
      <p class="md-modal-message">{{t "For which user would you like to set <b>%{board_key}</b> as the new home board?" key="which_user_set_as_home" board_key=this.model.board.key}}</p>
      {{user-select select_id="currently_selected_id" buttons=true selection=this.currently_selected_id action=(action "updateCurrentlySelectedId") }}
    {{/if}}
    {{#if this.owned_by_user}}
      {{#unless this.multiple_users}}
        <p class="md-modal-message">{{t "Would you like to set <b>%{board_key}</b> as your home board?" key="confirm_set_as_home" board_key=this.model.board.key}}</p>
      {{/unless}}
    {{else}}
      <p class="md-modal-message">{{t "This board is not owned by the user. You will probably want to make a new copy to allow for personalization and edits, but you can also just use the existing board if you don't plan to make changes." key="copy_or_keep"}}</p>
    {{/if}}

    <div class="md-modal-field">
      <label class="md-modal-label" for="symbol_library">{{t "Preferred Symbols" key="preferred_symbols"}}</label>
      <p class="md-modal-hint">{{t "Select the symbol library to display for the user's new copy:" key="symbol_library_explainer"}}</p>
      {{bound-select select_class="md-modal-select" select_id="symbol_library" content=this.symbol_libraries selection=this.symbol_library action=(action "updateSymbolLibrary") }}
    </div>

    {{#if this.model.board.levels}}
      {{#if this.appState.feature_flags.board_levels}}
        <div class="md-modal-field">
          <label class="md-modal-label" for="board_level">{{t "Communication Level" key="communication_level"}}</label>
          <p class="md-modal-hint">{{t "This board supports multiple display levels. You can set it to a starting level that makes sense for the communicator. Don't worry, it's easy to change later." key="board_level_explainer"}}</p>
          {{bound-select select_class="md-modal-select" select_id="board_level" content=this.board_levels selection=this.board_level action=(action "updateBoardLevel") }}
        </div>
      {{/if}}
    {{/if}}
  </div>
  <div class="modal-footer md-modal-footer">
    {{#if this.owned_by_user}}
      <button {{action "set_as_home"}} disabled={{this.pending}} class="btn md-modal-btn md-modal-btn--primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true">
          <path d="M12 3L2 12h3v8h6v-6h2v6h6v-8h3L12 3z"/>
        </svg>
        {{t "Set as Home Board" key="set_as_home_board"}}
      </button>
    {{else}}
      <button {{action "copy_as_home"}} disabled={{this.pending}} class="btn md-modal-btn md-modal-btn--primary">
        {{#if this.multiple_users}}
          {{t "Make a New Copy" key="make_a_new_copy"}}
        {{else}}
          {{t "Make My Own Copy" key="make_my_own_copy"}}
        {{/if}}
      </button>
      <button {{action "set_as_home"}} disabled={{this.pending_or_copy_only}} class="btn md-modal-btn md-modal-btn--secondary">{{t "Use the Existing Board" key="dont_copy_just_set_as_home_board"}}</button>
    {{/if}}
    <button {{action "close"}} class="btn md-modal-btn md-modal-btn--cancel">{{t "Cancel" key="cancel"}}</button>
    {{#if this.status.errored}}
      <p class="md-modal-status md-modal-status--error">{{t "Setting home board failed, please try again." key="setting_home_failed"}}</p>
    {{else if this.status.updating}}
      <p class="md-modal-status md-modal-status--info">{{t "Updating user settings..." key="updating_user_settings"}}</p>
    {{else if this.status.copying}}
      <p class="md-modal-status md-modal-status--info">{{t "Copying boards..." key="copying_boards"}}</p>
    {{/if}}
  </div>
{{/modal-dialog}}
