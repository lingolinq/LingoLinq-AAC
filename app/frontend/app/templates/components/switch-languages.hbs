{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="modal-header">
    <button type="button" class="close" {{action "close"}}>&times;</button>
    <h3>{{t "Switch Languages" key="switch_languages"}}</h3>
  </div>
  <div class="modal-body" id='languages_prompt'>
    <form class="form-horizontal" {{action "nothing" on="submit"}}>
      <div class="form-group">
        <div class="col-sm-12">
          <p class='form-control-static'>
            {{t "This board supports multiple languages. You can quickly switch between languages for both the text labels and the system-generated speech." key="select_a_language_for_switching"}}
          </p>
        </div>
      </div>
      <div class="form-group">
        <label class="col-sm-4 control-label" for="vocalization_locale">
          {{#if this.same_locale}}
            <span class='glyphicon glyphicon-globe'></span>
            {{t "Language" key="language"}}
          {{else}}
            <span class='glyphicon glyphicon-volume-up'></span>
            {{t "Spoken Language" key="speech_generation"}}
          {{/if}}
        </label>
        <div class="col-sm-8">
          {{#if this.two_languages}}
            <div class='btn-group' style='width: 100%;'>
              {{#each this.locales as |locale|}}
                <button type='button' style='max-width: 50%; overflow: hidden; text-overflow: ellipsis;' {{action "set_locale" "vocalization" locale.id}} class={{if (is-equal this.vocalization_locale locale.id) "btn btn-primary btn-lg" "btn btn-default btn-lg"}}>{{locale.name}}</button>
              {{/each}}
            </div>
          {{else}}
            <div class='input-group input-group-lg' style='min-width: 200px;'>
              {{bound-select select_class="form-control big_select" select_id="vocalization_locale" content=this.locales selection=this.vocalization_locale action=(action "set_locale" "vocalization") }}
            </div>
          {{/if}}
        </div>
      </div>
      <div class="form-group">
        <div class='col-sm-8 col-sm-offset-4'>
          <div class="checkbox big_checkbox">
            <label>
              <Input @type="checkbox" @checked={{this.same_locale}} />
              {{t "Use the same language for button labels and speech generation" key="use_same_language"}}
            </label>
          </div>
        </div>
      </div>
      {{#unless this.same_locale}}
        <div class="form-group">
          <label class="col-sm-4 control-label" for="label_locale">
            <span class='glyphicon glyphicon-text-background'></span>
            {{t "Text Language" key="text_language"}}
          </label>
          <div class="col-sm-8">
            {{#if this.two_languages}}
              <div class='btn-group' style='width: 100%;'>
                {{#each this.locales as |locale|}}
                  <button type='button' style='max-width: 50%; overflow: hidden; text-overflow: ellipsis;' {{action "set_locale" "label" locale.id}} class={{if (is-equal this.label_locale locale.id) "btn btn-primary btn-lg" "btn btn-default btn-lg"}}>{{locale.name}}</button>
                {{/each}}
              </div>
            {{else}}
              <div class='input-group input-group-lg' style='min-width: 200px;'>
                {{bound-select select_class="form-control big_select" select_id="label_locale" content=this.locales selection=this.label_locale action=(action "set_locale" "label") }}
              </div>
            {{/if}}
          </div>
        </div>
      {{/unless}}
    </form>
  </div>
  <div class="modal-footer">
    <button class='btn btn-lg btn-primary' {{action "set_languages"}}>{{t "Switch Languages" key="switch_languages"}}</button>
    <a href="#" class="btn btn-lg btn-default" {{action "close"}}>{{t "Cancel" key="cancel"}}</a>
  </div>
{{/modal-dialog}}
