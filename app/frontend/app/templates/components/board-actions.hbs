{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="la-board-actions-wrap">
  <div class="modal-header">
    <button type="button" class="close" {{action "close"}}>&times;</button>
    <h3>{{t "Board Actions" key="board_actions"}}</h3>
  </div>
  <div class="modal-body">
    {{#unless this.model.board.permissions.edit}}
      <div class="la-board-actions-notice">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
        </svg>
        <span>{{t "Some of these actions are not available because you don't have editing permission for this board. If you make a copy of the board set then you can make more of these changes." key="edit_permission_required_for_board_actions"}}</span>
      </div>
    {{/unless}}

    <div class="la-board-actions-list">
      <button type="button" class="la-board-actions-item" {{action "categorize"}} disabled={{this.cannot_categorize}}>
        <div class="la-board-actions-item__icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
          </svg>
        </div>
        <div class="la-board-actions-item__content">
          <span class="la-board-actions-item__label">{{t "Categorize Board" key="categorize_board"}}</span>
          <span class="la-board-actions-item__desc">{{t "Organize boards in your personal account based on personalized tags or categories" key="categorize_explainer"}}</span>
        </div>
        <svg class="la-board-actions-item__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>

      <button type="button" class="la-board-actions-item" {{action "langs"}} disabled={{this.cannot_edit}}>
        <div class="la-board-actions-item__icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
        </div>
        <div class="la-board-actions-item__content">
          <span class="la-board-actions-item__label">{{t "Manage Languages" key="manage_languages"}}</span>
          <span class="la-board-actions-item__desc">{{t "Select which languages are available during Speak Mode for this board set" key="manage_languages_explainer"}}</span>
        </div>
        <svg class="la-board-actions-item__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>

      <button type="button" class="la-board-actions-item" {{action "privacy"}} disabled={{this.cannot_edit}}>
        <div class="la-board-actions-item__icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
        </div>
        <div class="la-board-actions-item__content">
          <span class="la-board-actions-item__label">{{t "Change Privacy" key="change_privacy"}}</span>
          <span class="la-board-actions-item__desc">{{t "Change a board (or set of boards) to public, private, or unlisted, all in a single action" key="change_privacy_explainer"}}</span>
        </div>
        <svg class="la-board-actions-item__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>

      <button type="button" class="la-board-actions-item" {{action "translate"}} disabled={{this.cannot_edit}}>
        <div class="la-board-actions-item__icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 8l6 6"/><path d="M4 14l6-6 2-3"/><path d="M2 5h12"/><path d="M7 2h1"/><path d="M22 22l-5-10-5 10"/><path d="M14 18h6"/>
          </svg>
        </div>
        <div class="la-board-actions-item__content">
          <span class="la-board-actions-item__label">{{t "Translate Board" key="translate_board"}}</span>
          <span class="la-board-actions-item__desc">{{t "Change or add an additional language to the buttons on a set of boards" key="translate_explainer"}}</span>
        </div>
        <svg class="la-board-actions-item__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>

      <button type="button" class="la-board-actions-item" {{action "swap_images"}} disabled={{this.cannot_edit}}>
        <div class="la-board-actions-item__icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/>
          </svg>
        </div>
        <div class="la-board-actions-item__content">
          <span class="la-board-actions-item__label">{{t "Swap Images" key="swap_images"}}</span>
          <span class="la-board-actions-item__desc">{{t "Change the image library displayed for a board or set of boards" key="swap_images_explainer"}}</span>
        </div>
        <svg class="la-board-actions-item__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>

      <button type="button" class="la-board-actions-item" {{action "download"}}>
        <div class="la-board-actions-item__icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
        </div>
        <div class="la-board-actions-item__content">
          <span class="la-board-actions-item__label">{{t "Download Board" key="download_board"}}</span>
          <span class="la-board-actions-item__desc">{{t "Download an .obf or .obz file that can be shared with other users, or impored into apps that support obf" key="download_explainer"}}</span>
        </div>
        <svg class="la-board-actions-item__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>

      <button type="button" class="la-board-actions-item" {{action "batch_recording"}} disabled={{this.cannot_edit}}>
        <div class="la-board-actions-item__icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/>
          </svg>
        </div>
        <div class="la-board-actions-item__content">
          <span class="la-board-actions-item__label">{{t "Record Messages" key="record_messages"}}</span>
          <span class="la-board-actions-item__desc">{{t "Batch-record audio files for buttons on this board" key="record_messages_explainer"}}</span>
        </div>
        <svg class="la-board-actions-item__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>

      {{#if this.model.board.permissions.delete}}
        <button type="button" class="la-board-actions-item la-board-actions-item--danger" {{action "delete"}}>
          <div class="la-board-actions-item__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
            </svg>
          </div>
          <div class="la-board-actions-item__content">
            <span class="la-board-actions-item__label">{{t "Delete Board" key="delete_board"}}</span>
          </div>
          <svg class="la-board-actions-item__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      {{/if}}
    </div>

  </div>
  <div class="modal-footer">
    <button type="button" class="btn btn-lg" {{action "close"}}>{{t "Cancel" key="cancel"}}</button>
  </div>
  </div>
{{/modal-dialog}}
