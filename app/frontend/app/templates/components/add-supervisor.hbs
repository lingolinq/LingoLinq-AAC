{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="md-add-supervisor">
    <div class="modal-header md-modal-header">
      <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <h3 class="md-modal-title">{{t "Add Supervisor" key="add_supervisor"}}</h3>
    </div>
    <div class="modal-body md-modal-body" style="text-align: left;">
      <p class="md-modal-hint">
        {{t "Supervisors have full access to boards, reports, and settings. Only add people you trust." key="add_supervisor_intro_before"}}
        <LinkTo @route="privacy" class="md-modal-link">{{t "Privacy Policy" key="privacy_policy"}}</LinkTo>
      </p>
      <form class="md-add-supervisor__form" {{action "add" on="submit"}}>
        <div class="md-add-supervisor__field">
          <div class="md-add-supervisor__options" role="group" aria-label={{t "user type" key="user_type"}}>
            <button type="button" class="md-btn {{if this.existing_user "md-btn--primary" "md-btn--ghost"}}" {{action "set_user_type" "existing"}}>{{t "Add an Existing User" key="add_existing_user"}}</button>
            <button type="button" class="md-btn {{if this.new_user "md-btn--primary" "md-btn--ghost"}}" {{action "set_user_type" "new"}}>{{t "Add a New User" key="add_new_user"}}</button>
            <button type="button" class="md-btn {{if this.start_code "md-btn--primary" "md-btn--ghost"}}" {{action "set_user_type" "start_code"}}>{{t "Add Start Code" key="add_start_code"}}</button>
            <button type="button" class="md-btn {{if this.consent_request "md-btn--primary" "md-btn--ghost"}}" {{action "set_user_type" "consent_request"}}>{{t "Request via Email" key="request_via_email"}}</button>
          </div>
        </div>
        {{#if this.consent_request}}
          {{#if this.consent_submitted}}
            <div class="md-add-supervisor__field" role="status">
              <p class="md-modal-hint">{{t "A consent request has been sent. You'll be notified when they respond." key="consent_request_sent_message"}}</p>
            </div>
          {{else}}
            <p class="md-modal-hint" style="font-style: italic;">{{t "Enter their email address. They'll receive a consent request and must approve before access is granted." key="consent_request_intro"}}</p>
            <div class="md-add-supervisor__field">
              <label for="owner_email" class="md-add-supervisor__label">{{t "Email" key="email"}}</label>
              <Input @value={{this.owner_email}} class="md-add-supervisor__input" id="owner_email" placeholder={{t "Supervisor's email address" key="supervisor_email_placeholder"}} />
            </div>
          {{/if}}
        {{else if this.existing_user}}
          <div class="md-add-supervisor__field">
            <label for="add_supervisee_key" class="md-add-supervisor__label">{{t "Supervisor" key="supervisor"}}</label>
            <Input @value={{this.supervisor_key}} class="md-add-supervisor__input" id="add_supervisee_key" placeholder="User name" />
          </div>
        {{else if this.start_code}}
          <div class="md-add-supervisor__field">
            <label for="add_start_code_key" class="md-add-supervisor__label">{{t "Start Code" key="start_code"}}</label>
            <Input @value={{this.start_code_key}} class="md-add-supervisor__input" id="add_start_code" placeholder="start code" />
            <p class="md-modal-hint" style="font-style: italic;">{{t "Start codes may also update some of your preferences — check with the supervisor before entering one." key="start_code_warning"}}</p>
          </div>
        {{else}}
          <div class="md-add-supervisor__field">
            <label for="supervisor_name" class="md-add-supervisor__label">{{t "Supervisor" key="supervisor"}}</label>
            <Input @value={{this.model.supervisor.name}} class="md-add-supervisor__input" id="supervisor_name" placeholder="Full name" />
          </div>
          <div class="md-add-supervisor__field">
            <Input @value={{this.model.supervisor.user_name}} class="md-add-supervisor__input" placeholder="User name" />
            {{#if this.model.supervisor.user_name_check.checking}}
            {{else if this.model.supervisor.user_name_check.exists}}
              <span class="md-add-supervisor__error">{{t "\"%{user_name}\" already exists" user_name=this.model.supervisor.user_name}}</span>
            {{/if}}
          </div>
          <div class="md-add-supervisor__field">
            <Input @value={{this.model.supervisor.email}} class="md-add-supervisor__input" placeholder="Email address" />
          </div>
          <div class="md-add-supervisor__field">
            <Input @type="password" @value={{this.model.supervisor.password}} class="md-add-supervisor__input" placeholder="Password" />
          </div>
        {{/if}}
        {{#unless this.start_code}}
          {{#unless this.consent_submitted}}
            <div class="md-add-supervisor__field">
              <label for="supervisor_type" class="md-add-supervisor__label">{{t "Access" key="access"}}</label>
              {{bound-select select_class="md-add-supervisor__input md-add-supervisor__select" select_id="supervisor_type" content=this.supervisor_types selection=this.supervisor_permission action=(action "updateSupervisorPermission") }}
            </div>
            {{#if this.supervisor_sponsorships}}
              {{#unless this.consent_request}}
                <div class="md-add-supervisor__field md-add-supervisor__field--checkbox">
                  <label class="md-add-supervisor__checkbox-label">
                    <Input @checked={{this.premium_supporter}} @type="checkbox" />
                    <span>{{t "use one of my supervisor credits (%{n} left) to make this person a premium supporter" n=this.supervisor_sponsorships key="grant_premium_supporter"}}</span>
                  </label>
                </div>
              {{/unless}}
            {{/if}}
          {{/unless}}
        {{/unless}}
      </form>
    </div>
    {{#unless this.consent_submitted}}
      <div class="modal-footer md-modal-footer">
        {{#if this.error}}
          <p class="md-modal-status md-modal-status--error" role="alert">{{this.error}}</p>
        {{/if}}
        {{#if this.consent_request}}
          <button type="button" class="btn md-modal-btn md-modal-btn--primary" {{action "send_consent_request"}} disabled={{this.consent_submitting}}>
            {{#if this.consent_submitting}}
              {{t "Sending Request..." key="sending_consent_request"}}
            {{else}}
              {{t "Send Consent Request" key="send_consent_request"}}
            {{/if}}
          </button>
        {{else}}
          <button type="button" class="btn md-modal-btn md-modal-btn--primary" {{action "add"}} disabled={{this.linking}}>
            {{#if this.linking.start_code}}
              {{t "Handling Start Code..." key="handling_start_code"}}
            {{else if this.linking}}
              {{t "Adding Supervisor..." key="adding_supervisor"}}
            {{else}}
              {{#if this.error}}
                {{t "Adding Supervisor Failed" key="adding_supervisor_failed"}}
              {{else}}
                {{#if this.start_code}}
                  {{t "Add From Start Code" key="add_from_start_code"}}
                {{else}}
                  {{t "Add Supervisor" key="add_supervisor"}}
                {{/if}}
              {{/if}}
            {{/if}}
          </button>
        {{/if}}
        <button type="button" class="btn md-modal-btn md-modal-btn--cancel" {{action "close"}}>{{t "Cancel" key="cancel"}}</button>
      </div>
    {{/unless}}
  </div>
{{/modal-dialog}}
