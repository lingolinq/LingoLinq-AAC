{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="modal-header md-modal-header">
    <button type="button" class="close" {{action "close"}}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h3 class="md-modal-title">
      {{#if this.pdf_download}}
        {{t "Print Board" key="print_board"}}
      {{else}}
        {{t "Download Board" key="download_board"}}
      {{/if}}
    </h3>
  </div>
  <div class="modal-body md-modal-body">
    <div class="md-modal-icon-row">
      <div class="md-modal-icon-circle">
        {{#if this.pdf_download}}
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/>
          </svg>
        {{else}}
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
        {{/if}}
      </div>
    </div>

    {{#if (persistence-online)}}
      {{#if this.finished}}
        <div class="md-modal-status md-modal-status--success">{{this.status_message}}</div>
        <p class="md-modal-message" style="margin-top: 14px;">
        {{#if this.pdf_download}}
          <a target="_blank" href={{this.progress.result.download_url}} rel="noopener" class="md-modal-link">{{t "Open board(s) for printing" key="open_board_for_printing"}}</a>
        {{else}}
          <a target="_blank" href={{this.progress.result.download_url}} rel="noopener" download class="md-modal-link">{{t "Download board(s) to your computer" key="board_download_available"}}</a>
        {{/if}}
        </p>
      {{else}}
        {{#if this.errored}}
          <div class="md-modal-status md-modal-status--error">{{this.status_message}}{{#if this.error_detail}}<br><br>{{this.error_detail}}{{/if}}</div>
        {{else}}
          {{#if this.progress}}
            <p class="md-modal-message">
              {{#if this.pdf_download}}
                {{t "Generating PDF for download. This could take around %{n} minutes." n=this.minutes_estimate key="print_board_generating"}}
              {{else}}
                {{t "Generating file for download. This could take around %{n} minutes." n=this.minutes_estimate key="download_board_generating"}}
              {{/if}}
            </p>
            <div class="md-modal-status md-modal-status--info">{{this.status_message}}</div>
            {{#if this.progress.percent}}
              <div class="md-modal-progress">
                <div class="md-modal-progress__bar" role="progressbar" aria-value={{this.num_percent}} aria-valuemin="0" aria-valuemax="100" style={{this.num_style}}>
                </div>
              </div>
            {{/if}}
          {{else}}
            {{#if this.multi_download_type}}
              <p class="md-modal-message">{{t "Boards are downloaded using the Open Board Format, which is an open-licensed format that can be imported and exported using compatible AAC apps like LingoLinq." key="download_board_explainer"}}</p>
              <p class="md-modal-message">{{t "This board contains links to sub-boards. Would you like to download a file containing all available sub-boards, or just the current board?" key="confirm_download_board"}}</p>
            {{else if this.single_download_type}}
              <p class="md-modal-message">{{t "Boards are downloaded using the Open Board Format, which is an open-licensed format that can be imported and exported using compatible AAC apps like LingoLinq." key="download_board_explainer"}}</p>
            {{else}}
              <p class="md-modal-message">{{t "You can print off a physical copy of any board set in LingoLinq. Printed copies can work as an effective backup or for places where you may not want to take a physical device." key="print_explanation"}}</p>
              {{#if this.model.has_links}}
                <p class="md-modal-message">{{t "This board contains links to sub-boards. Would you like to print a packet containing all available sub-boards, or just the current board?" key="confirm_print_board"}}</p>
              {{/if}}
              <div class="md-modal-field">
                <div class="md-modal-toggle-group">
                  <button type="button" {{action "set_attribute" "include_header" false}} class={{if this.include_header "md-modal-toggle-btn" "md-modal-toggle-btn md-modal-toggle-btn--active"}}>{{t "No Header" key="no_header"}}</button>
                  <button type="button" {{action "set_attribute" "include_header" true}} class={{if this.include_header "md-modal-toggle-btn md-modal-toggle-btn--active" "md-modal-toggle-btn"}}>{{t "Vocalization Header" key="vocalization_header"}}</button>
                </div>
              </div>
              {{#unless this.appState.currentUser}}
                <div class="md-modal-field">
                  <div class="md-modal-toggle-group">
                    <button type="button" {{action "set_attribute" "text_below" false}} class={{if this.text_below "md-modal-toggle-btn" "md-modal-toggle-btn md-modal-toggle-btn--active"}}>{{t "Text Below Images" key="text_below_images"}}</button>
                    <button type="button" {{action "set_attribute" "text_below" true}} class={{if this.text_below "md-modal-toggle-btn md-modal-toggle-btn--active" "md-modal-toggle-btn"}}>{{t "Text Above Images" key="text_above_images"}}</button>
                  </div>
                </div>
                <div class="md-modal-field">
                  <div class="md-modal-toggle-group">
                    <button type="button" {{action "set_attribute" "white_background" false}} class={{if this.white_background "md-modal-toggle-btn" "md-modal-toggle-btn md-modal-toggle-btn--active"}}>{{t "Color Backgrounds" key="transparent_image_background"}}</button>
                    <button type="button" {{action "set_attribute" "white_background" true}} class={{if this.white_background "md-modal-toggle-btn md-modal-toggle-btn--active" "md-modal-toggle-btn"}}>{{t "White Backgrounds" key="white_behind_images"}}</button>
                  </div>
                </div>
              {{/unless}}
            {{/if}}
          {{/if}}
        {{/if}}
      {{/if}}
    {{else}}
      <p class="md-modal-message">{{t "Downloading and printing are only available when online" key="download_only_online"}}</p>
    {{/if}}
  </div>
  <div class="modal-footer md-modal-footer">
    {{#if (persistence-online)}}
      {{#if this.finished}}
      {{else}}
        {{#if this.errored}}
        {{else}}
          {{#if this.progress}}
          {{else}}
            {{#if this.multi_download_type}}
              <button {{action "startDownload" "all"}} class="btn md-modal-btn md-modal-btn--primary" title={{t "Download this board and all linked sub-boards as a single archive" key="download_all_boards_tooltip"}}>{{t "Download full board set" key="download_all_boards"}}</button>
              <button {{action "startDownload" "this"}} class="btn md-modal-btn md-modal-btn--secondary" title={{t "Download only this board as a single file, without linked sub-boards" key="download_just_this_board_tooltip"}}>{{t "Download just this board" key="download_just_this_board"}}</button>
            {{else if this.single_download_type}}
              <button {{action "startDownload" "this"}} class="btn md-modal-btn md-modal-btn--primary" title={{t "Single file format. Downloads just this board." key="download_obf_tooltip"}}>{{t "Download as .obf" key="download_as_obf"}}</button>
              <button {{action "startDownload" "all"}} class="btn md-modal-btn md-modal-btn--secondary" title={{t "Archive format. Same content as .obf, packaged as a zip for compatibility with other AAC apps." key="download_obz_tooltip"}}>{{t "Download as .obz" key="download_as_obz"}}</button>
            {{else if this.model.has_links}}
              <button {{action "startDownload" "all"}} class="btn md-modal-btn md-modal-btn--primary" title={{t "Print this board and all linked sub-boards" key="print_all_boards_tooltip"}}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/>
                </svg>
                {{t "Print full board set" key="print_all_boards"}}
              </button>
              <button {{action "startDownload" "this"}} class="btn md-modal-btn md-modal-btn--secondary" title={{t "Print only this board, without linked sub-boards" key="print_just_this_board_tooltip"}}>{{t "Print just this board" key="print_just_this_board"}}</button>
            {{else}}
              <button {{action "startDownload" "this"}} class="btn md-modal-btn md-modal-btn--primary" title={{t "Print this board" key="print_this_board_tooltip"}}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/>
                </svg>
                {{t "Print this board" key="print_this_board"}}
              </button>
            {{/if}}
          {{/if}}
        {{/if}}
      {{/if}}
    {{/if}}
    <button class="btn md-modal-btn md-modal-btn--cancel" {{action "close"}}>{{t "Close" key="close"}}</button>
  </div>
{{/modal-dialog}}
