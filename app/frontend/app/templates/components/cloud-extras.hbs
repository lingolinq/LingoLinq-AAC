{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="la-support-modal-wrap la-cloud-extras-modal-wrap">
    <div class="la-modal-header">
      <span class="la-modal-header-label">{{t "LingoLinq Cloud Extras" key="cloud_extras_title"}}</span>
      <div class="la-support-modal-header-meta">
        <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>✕</button>
      </div>
    </div>
    <div class="la-support-modal-body">
      <p class="la-support-intro">
        {{t "LingoLinq goes beyond basic AAC features. Cloud Extras are built-in tools that help communication teams support growth, track progress, and stay connected." key="cloud_extras_intro"}}
      </p>
      <h3 class="la-cloud-extras-features-heading">{{t "Included features" key="cloud_extras_included_features"}}</h3>
      <ul class="la-cloud-extras-feature-list">
        <li class="la-cloud-extras-feature-item">
          <span class="la-cloud-extras-check" aria-hidden="true">✓</span>
          <div class="la-cloud-extras-feature-content">
            <span class="la-cloud-extras-feature-title">{{t "Speech Logs" key="cloud_extras_speech_logs_title"}}</span>
            <p class="la-cloud-extras-feature-desc">{{t "Track all spoken words to see vocabulary growth over time" key="cloud_extras_speech_logs_desc"}}</p>
          </div>
        </li>
        <li class="la-cloud-extras-feature-item">
          <span class="la-cloud-extras-check" aria-hidden="true">✓</span>
          <div class="la-cloud-extras-feature-content">
            <span class="la-cloud-extras-feature-title">{{t "Usage Reports" key="cloud_extras_usage_reports_title"}}</span>
            <p class="la-cloud-extras-feature-desc">{{t "View most-used words, core vs fringe usage, time-of-day activity, heat maps, and more" key="cloud_extras_usage_reports_desc"}}</p>
          </div>
        </li>
        <li class="la-cloud-extras-feature-item">
          <span class="la-cloud-extras-check" aria-hidden="true">✓</span>
          <div class="la-cloud-extras-feature-content">
            <span class="la-cloud-extras-feature-title">{{t "Built-in AAC Evaluation Tool" key="cloud_extras_eval_tool_title"}}</span>
            <p class="la-cloud-extras-feature-desc">{{t "Assess button size, layout, graphics, and system fit" key="cloud_extras_eval_tool_desc"}}</p>
          </div>
        </li>
        <li class="la-cloud-extras-feature-item">
          <span class="la-cloud-extras-check" aria-hidden="true">✓</span>
          <div class="la-cloud-extras-feature-content">
            <span class="la-cloud-extras-feature-title">{{t "Team Messaging" key="cloud_extras_team_messaging_title"}}</span>
            <p class="la-cloud-extras-feature-desc">{{t "Secure communication between parents, teachers, and therapists" key="cloud_extras_team_messaging_desc"}}</p>
          </div>
        </li>
        <li class="la-cloud-extras-feature-item">
          <span class="la-cloud-extras-check" aria-hidden="true">✓</span>
          <div class="la-cloud-extras-feature-content">
            <span class="la-cloud-extras-feature-title">{{t "Goals & Badges" key="cloud_extras_goals_badges_title"}}</span>
            <p class="la-cloud-extras-feature-desc">{{t "Set speech goals, track progress, and celebrate milestones" key="cloud_extras_goals_badges_desc"}}</p>
          </div>
        </li>
        <li class="la-cloud-extras-feature-item">
          <span class="la-cloud-extras-check" aria-hidden="true">✓</span>
          <div class="la-cloud-extras-feature-content">
            <span class="la-cloud-extras-feature-title">{{t "Location Insights (Optional)" key="cloud_extras_location_insights_title"}}</span>
            <p class="la-cloud-extras-feature-desc">{{t "Understand communication patterns across home, school, or therapy settings" key="cloud_extras_location_insights_desc"}}</p>
          </div>
        </li>
      </ul>
      <p class="la-cloud-extras-evolving">
        {{t "LingoLinq is always evolving — new Cloud Extras are added regularly." key="cloud_extras_evolving"}}
      </p>
      <p class="la-cloud-extras-lifetime-note">
        {{t "Lifetime Communicator purchases include 5 years of Cloud Extras at no additional cost." key="cloud_extras_lifetime_note"}}
      </p>
    </div>
  </div>
{{/modal-dialog}}
