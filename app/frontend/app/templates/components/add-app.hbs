{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="la-add-app-modal-wrap">
    <div class="la-modal-header">
      <div class="la-modal-header-icon la-modal-header-icon--app" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2" stroke="#4C86D8"/><line x1="12" y1="18" x2="12.01" y2="18" stroke="#46505F" stroke-width="2"/></svg>
      </div>
      <h3 class="la-modal-header-label">{{t "Add the %app_name% App" key="add_the_cough_drop_app"}}</h3>
      <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>&times;</button>
    </div>
    <div class="la-add-app-modal-body">
      <p class="la-add-app-modal-desc">{{t "Get %app_name% on your device from the app stores below, or use it directly in your browser." key="app_stores_option"}}</p>

      <div class="la-add-app-modal-stores">
        {{#if this.appState.domain_settings.ios_store_url}}
          <a href={{this.appState.domain_settings.ios_store_url}} class="la-add-app-modal-store-link">
            <img src={{path "images/ios_app_store.svg"}} alt="ios app store" class="la-add-app-modal-store-img">
          </a>
        {{/if}}
        {{#if this.appState.domain_settings.play_store_url}}
          <a href={{this.appState.domain_settings.play_store_url}} class="la-add-app-modal-store-link">
            <img src={{path "images/google_play.png"}} alt="google play" class="la-add-app-modal-store-img">
          </a>
        {{/if}}
        {{#if this.appState.domain_settings.kindle_store_url}}
          <a href={{this.appState.domain_settings.kindle_store_url}} target="_blank" rel="noopener" class="la-add-app-modal-store-link">
            <img src={{path "images/amazon.png"}} alt="amazon" class="la-add-app-modal-store-img">
          </a>
        {{/if}}
        <LinkTo @route="download" class="la-add-app-modal-store-link">
          <img src={{path "images/windows.svg"}} alt="windows" class="la-add-app-modal-store-img">
        </LinkTo>
      </div>

      <p class="la-add-app-modal-hint">{{t "You can also install the web version on mobile devices by hitting share or settings and selecting \"Add to Home Screen\"." key="add_to_home_screen"}}</p>
    </div>
  </div>
{{/modal-dialog}}
