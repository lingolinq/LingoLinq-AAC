{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="la-eval-status-wrap">
    <div class="la-modal-header">
      <span class="la-modal-header-label">{{t "Evaluation Status" key="eval_status"}}</span>
      <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>✕</button>
    </div>
    <div class="la-eval-status-body">
      {{#if this.choice.reset}}
        {{#if this.user.can_reset_eval}}
          <p class="la-eval-status-desc">
            {{t "Are you sure you want to reset the evaluation period for the account, <b>%{user_name}</b>? This will erase any personalizations and logs created on the account before now." user_name=this.user.user_name key="confirm_reset_eval"}}
          </p>
          <p class="la-eval-status-desc">
            {{t "To confirm the reset, please enter the user name for this evaluation account (%{user_name}), as well as a new email address to be used during the next eval." key="parameters_for_reset" user_name=this.user.user_name}}
            {{t "NOTE: You should also change the password on the account for each new eval, otherwise previous trial users would be able to log in and see content and logs for the current trial user." key="password_should_be_reset"}}
          </p>
          <div class="la-eval-status-form">
            <div class="la-eval-status-field">
              <label class="la-eval-status-field__label">{{t "Current User Name" key="current_user_name"}}</label>
              <Input type="text" @value={{this.reset_user_name}} class="la-eval-status-field__input" />
            </div>
            <div class="la-eval-status-field">
              <label class="la-eval-status-field__label">{{t "New Email Address" key="new_email"}}</label>
              <Input type="text" @value={{this.reset_email}} class="la-eval-status-field__input" />
              {{#if this.status.reset_email_used}}
                <p class="la-eval-status-error">{{t "Must be a different email address than last time" key="must_be_different_email"}}</p>
              {{/if}}
            </div>
            {{#if this.org_board_keys}}
              <div class="la-eval-status-field">
                <label class="la-eval-status-field__label" for="home_board">{{t "New Home Board" key="new_home_board"}}</label>
                {{bound-select select_class="la-eval-status-field__input" select_id="home_board" content=this.org_board_keys selection=this.home_board_key action=(action (mut this.home_board_key)) }}
              </div>
              {{#if this.org_board_set}}
                <div class="la-eval-status-field">
                  <label class="la-eval-status-field__label" for="symbol_library">{{t "Preferred Symbols:" key="preferred_symbols_colon"}}</label>
                  {{bound-select select_class="la-eval-status-field__input" select_id="symbol_library" content=this.symbol_libraries selection=this.symbol_library action=(action (mut this.symbol_library)) }}
                </div>
              {{/if}}
            {{/if}}
            <div class="la-eval-status-field">
              <label class="la-eval-status-field__label">{{t "New Expiration" key="new_expiration"}}</label>
              <Input type="date" @value={{this.eval_expires}} class="la-eval-status-field__input" />
            </div>
            <div class="la-eval-status-field">
              <label class="la-eval-status-field__label">{{t "New Password" key="new_password"}}</label>
              <Input type="password" placeholder="(optional)" @value={{this.reset_password}} class="la-eval-status-field__input" />
            </div>
          </div>
        {{else}}
          <p class="la-eval-status-desc">{{t "You don't have permission to reset this evaluation" key="reset_not_allowed"}}</p>
        {{/if}}
      {{else if this.choice.transfer}}
        <p class="la-eval-status-desc">
          {{t "Once you are ready to use %app_name% long-term, it will make sense to transfer your boards and logs out of this evaluation account and into a new, permanent account. To do this, sign up for a free trial account and the enter the login information for that new account below. The boards and logs created during the evaluation will all be transferred to the new account." key="how_to_transfer"}}
        </p>
        <div class="la-eval-status-form">
          <div class="la-eval-status-field">
            <label class="la-eval-status-field__label">{{t "New User Name" key="new_user_name"}}</label>
            <Input type="text" @value={{this.transfer_user_name}} class="la-eval-status-field__input" />
            {{#if this.status.transfer_bad_credentials}}
              <p class="la-eval-status-error">{{t "No account found with that user name and password" key="no_account_found"}}</p>
            {{/if}}
          </div>
          <div class="la-eval-status-field">
            <label class="la-eval-status-field__label">{{t "New Password" key="new_password"}}</label>
            <Input type="password" @value={{this.transfer_password}} class="la-eval-status-field__input" />
          </div>
        </div>
      {{else if this.choice.extend}}
        <p class="la-eval-status-desc">
          {{#if this.user.can_reset_eval}}
            {{t "You can extend an existing evaluation as needed for the current communicator. Please enter a new expiration date and the evaluation account will update the next time it syncs." key="set_new_eval_expiration"}}
          {{else}}
            {{t "You can extend an extra week if you need a little more time, but you will only be able to extend the evaluation once. After that you'll need to talk to the group who gave you this account about extending your evaluation longer." key="one_week_extension_or_talk_to_supervisors"}}
          {{/if}}
        </p>
        {{#if this.user.can_reset_eval}}
          <div class="la-eval-status-form">
            <div class="la-eval-status-field">
              <label class="la-eval-status-field__label">{{t "Current Expiration" key="current_expiration"}}</label>
              <span class="la-eval-status-field__value">{{date this.user.subscription.eval_expires "day"}}</span>
            </div>
            <div class="la-eval-status-field">
              <label class="la-eval-status-field__label">{{t "Updated Expiration" key="updated_expiration"}}</label>
              <Input type="date" @value={{this.extend_date}} class="la-eval-status-field__input" />
            </div>
          </div>
        {{/if}}
      {{else}}
        {{#if this.user.eval_end_date}}
          <div class="la-eval-status-info">
            <div class="la-eval-status-info__icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" stroke="#4C86D8"/><line x1="12" y1="8" x2="12" y2="12" stroke="#46505F"/><line x1="12" y1="16" x2="12.01" y2="16" stroke="#46505F"/>
              </svg>
            </div>
            <p class="la-eval-status-desc">
              {{#if this.user.eval_ended}}
                {{t "The evaluation period for <b>%{user_name}</b> expired" key="eval_expired_for_user" user_name=this.user.user_name}}
                {{date this.user.eval_end_date "day"}}{{t "." key="period"}}
              {{else}}
                {{t "The evaluation period for <b>%{user_name}</b> will end on" key="eval_expiring_for_user" user_name=this.user.user_name}}
                {{date this.user.eval_end_date "day"}}{{t "." key="period"}}
              {{/if}}
              {{#if this.user.can_reset_eval}}
                {{t "You can reset or extend the current evaluation period, or wipe the account clean to start a new evaluation." key="reset_or_extend"}}
              {{else if this.user.subscription.eval_extendable}}
                {{t "You can extend an extra week if you need a little extra time or to transfer content to a different account." key="extend_or_transfer"}}
              {{/if}}
              {{#if this.user.permissions.supervise}}
                {{t "If there are boards and logs you would like to preserve from this evaluation, you can also transfer all evaluation content to a different %app_name% account." key="can_transfer_content"}}
              {{/if}}
            </p>
          </div>
          <div class="la-eval-status-choices">
            {{#if this.user.can_reset_eval}}
              <button class="la-eval-status-choice-btn" {{action "choose" "reset"}}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="1 4 1 10 7 10" stroke="#2A9D8F"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10" stroke="#46505F"/></svg>
                {{t "Reset Account" key="reset_account"}}
              </button>
              <button class="la-eval-status-choice-btn" {{action "choose" "extend"}}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="#4C86D8"/><polyline points="12 6 12 12 16 14" stroke="#46505F"/></svg>
                {{t "Extend Evaluation" key="extend_evaluation"}}
              </button>
            {{else if this.user.subscription.eval_extendable}}
              <button class="la-eval-status-choice-btn" {{action "choose" "extend"}}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="#4C86D8"/><polyline points="12 6 12 12 16 14" stroke="#46505F"/></svg>
                {{t "Extend Evaluation" key="extend_evaluation"}}
              </button>
            {{/if}}
            {{#if this.user.permissions.supervise}}
              <button class="la-eval-status-choice-btn" {{action "choose" "transfer"}}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="17 1 21 5 17 9" stroke="#2A9D8F"/><path d="M3 11V9a4 4 0 0 1 4-4h14" stroke="#46505F"/><polyline points="7 23 3 19 7 15" stroke="#2A9D8F"/><path d="M21 13v2a4 4 0 0 1-4 4H3" stroke="#46505F"/></svg>
                {{t "Transfer Account" key="transfer_account"}}
              </button>
            {{/if}}
          </div>
        {{else}}
          <p class="la-eval-status-desc">{{t "This is not an evaluation account." key="not_eval_account"}}</p>
        {{/if}}
      {{/if}}
    </div>
    <div class="la-eval-status-footer">
      {{#if this.choice.reset}}
        <button {{action "reset"}} class="la-eval-status-submit">
          {{#if this.status.reset_error}}
            {{t "Reset Failed" key="reset_failed"}}
          {{else if this.status.resetting}}
            {{t "Resetting..." key="resetting"}}
          {{else if this.status.reset_finished}}
            {{t "Reset Complete! Waiting to reload..." key="reset_complete"}}
          {{else}}
            {{t "Confirm Reset" key="confirm_reset"}}
          {{/if}}
        </button>
        <button class="la-eval-status-cancel" {{action "choose"}}>{{t "Back" key="back"}}</button>
      {{else if this.choice.transfer}}
        <button {{action "transfer"}} class="la-eval-status-submit">
          {{#if this.status.transfer_error}}
            {{t "Transfer Failed" key="transfer_failed"}}
          {{else if this.status.transferring}}
            {{t "Transferring..." key="transferring"}}
          {{else if this.status.transfer_finished}}
            {{t "Transfer Complete! Logging Out..." key="transfer_complete_logging_out"}}
          {{else}}
            {{t "Confirm Transfer" key="confirm_transfer"}}
          {{/if}}
        </button>
        <button class="la-eval-status-cancel" {{action "choose"}}>{{t "Back" key="back"}}</button>
      {{else if this.choice.extend}}
        <button {{action "extend"}} class="la-eval-status-submit">
          {{#if this.status.extend_error}}
            {{t "Extension Failed" key="extension_failed"}}
          {{else if this.status.extending}}
            {{t "Extending Evaluation..." key="extending_evaluation"}}
          {{else if this.status.cant_extend}}
            {{t "Can't Extend Evaluation" key="cant_extend_evaluation"}}
          {{else}}
            {{t "Confirm Extension" key="confirm_extension"}}
          {{/if}}
        </button>
        <button class="la-eval-status-cancel" {{action "choose"}}>{{t "Back" key="back"}}</button>
      {{/if}}
      <button type="button" class="la-eval-status-close" {{action "close"}}>{{t "Close" key="close"}}</button>
    </div>
  </div>
{{/modal-dialog}}
