{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="md-modal-header">
    <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>&times;</button>
    <h3 class="md-modal-title">{{t "Note Templates" key="note_templates"}}</h3>
  </div>
  <div class="md-modal-body" style="text-align: left;">
    <p class="md-modal-hint" style="margin-bottom: 16px;">{{t "When recording notes to a user's log, it can be useful to have a template to ensure consistent record-keeping across the organization. Here you can define templates that any supervisor or manager can use when recording notes to a user's log." key="note_templates_explainer"}}</p>

    <div class="md-org-settings-field__row" style="margin-bottom: 16px;">
      <div style="flex: 1;">
        {{bound-select select_class="md-org-report-select" select_id="template" content=this.template_list selection=this.current_template_id action=(action "updateTemplateId") }}
      </div>
      <button type="button" class="md-modal-btn md-modal-btn--secondary" {{action "add_row"}}>{{t "Add New" key="add_new"}}</button>
    </div>

    {{#if this.current_template}}
      <div class="md-sc-form">
        <div class="md-org-settings-field">
          <label class="md-org-settings-field__label">{{t "Template Name" key="template_name"}}</label>
          <Input @value={{this.current_template.title}} class="md-org-settings-input" type="text" placeholder="Template Name" />
        </div>
        <div class="md-org-settings-field">
          <label class="md-org-settings-field__label">{{t "Template Contents" key="template_contents"}}</label>
          <Textarea @value={{this.current_template.text}} rows={{8}} class="md-org-settings-textarea" placeholder="Template Contents" />
        </div>
        <div style="text-align: right; margin-top: 8px;">
          <button type="button" class="md-modal-btn md-modal-btn--cancel" {{action "remove" this.current_template}}>{{t "Remove Template" key="remove_template"}}</button>
        </div>
      </div>
    {{/if}}
  </div>
  <div class="md-modal-footer">
    <button type="button" class="md-modal-btn md-modal-btn--primary" {{action "confirm"}}>{{t "Update" key="update"}}</button>
    <button type="button" class="md-modal-btn md-modal-btn--cancel" {{action "close"}}>{{t "Close" key="close"}}</button>
  </div>
{{/modal-dialog}}
