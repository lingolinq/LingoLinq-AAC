{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="la-support-modal-wrap la-modify-core-modal-wrap">
    <div class="la-modal-header">
      <span class="la-modal-header-label">{{t "Modify Core Word List" key="modify_core_word_list"}}</span>
      <div class="la-support-modal-header-meta">
        <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>✕</button>
      </div>
    </div>
    <div class="la-support-modal-body">
      <p class="la-modify-core-intro">
        {{t "Select from one of the precompiled core word lists below, or customize one, or create your own. %app_name% uses this list to track which button pressed are core vs. fringe to help with long-term language development." key="choose_a_word_list"}}
        <a href="https://praacticalaac.org/strategy/join-together-core-fringe-vocabulary/" target="_blank" rel="noopener" class="la-modify-core-learn-link">{{t "Learn more about core/fringe words." key="learn_more_about_core_fringe_words"}}</a>
      </p>
      <div class="row la-modify-core-row">
        <div class="col-sm-6">
          {{bound-select select_class="la-contact-input" select_id="core_list" content=this.core_lists selection=this.core_list action=(action "updateCoreList") }}
        </div>
        <div class="col-sm-6">
          {{#if this.default_core_list}}
            <button type="button" class="la-btn la-btn--ghost" {{action "modify_list"}}>{{t "Customize This List" key="customize_this_list"}}</button>
          {{/if}}
        </div>
      </div>
      <div class="la-modify-core-list-area">
        {{#if this.editing}}
          <Textarea @value={{this.word_lines}} class="la-contact-input la-contact-input--textarea" placeholder="Type or paste in a list of words, either separated by commas or one per line" rows={{6}} />
        {{else}}
          <div class="la-modify-core-words-preview">{{this.raw_words_list}}</div>
        {{/if}}
        <div class="la-modify-core-word-count">{{t "word" count=this.parsed_words.length key="n_words"}}</div>
      </div>
      <p class="la-modify-core-note"><em>{{t "Keep in mind that changes to the core word list will only affect new logs, past logs will still use the same core list they were configured for." key="core_update_only_affects_new_logs"}}</em></p>
      <div class="la-modify-core-actions">
        <button type="button" class="la-btn la-btn--primary" disabled={{this.save_disabled}} {{action "save"}}>
          {{#if this.state.saving}}
            {{t "Updating Core Word List..." key="updating_core_word_list"}}
          {{else if this.state.error}}
            {{t "Error Updating Core Word List" key="error_updating_core_word_list"}}
          {{else}}
            {{t "Update Core Word List" key="update_core_word_list"}}
          {{/if}}
        </button>
        <button type="button" class="la-btn la-btn--ghost" {{action "close"}}>{{t "Cancel" key="cancel"}}</button>
      </div>
    </div>
  </div>
{{/modal-dialog}}
