{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="la-support-modal-wrap">
    <div class="la-modal-header">
      <span class="la-modal-header-label">{{t "Support" key="support"}}</span>
      <div class="la-support-modal-header-meta">
        {{#if this.appState.version}}
          {{#unless (is-equal this.appState.version "unknown")}}
            <span class="la-support-version">v{{this.appState.version}}</span>
          {{/unless}}
        {{/if}}
        <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>✕</button>
      </div>
    </div>
    <div class="la-support-modal-body">
      <p class="la-support-intro">
        {{t "Running into an issue or have an idea to share? We want to hear from you." key="support_intro"}}
        {{#unless this.appState.no_linky}}
          {{t "Below are some resources that might help:" key="support_resources"}}
        {{/unless}}
      </p>

      {{#if this.appState.no_linky}}
        {{#if this.ios}}
          <ul class="la-support-list">
            <li><a href="https://lingolinq.zendesk.com/hc/en-us/articles/115000379246" target="_blank" rel="noopener" class="la-support-list__link"><span class="la-support-list__icon" aria-hidden="true">🔊</span> {{t "Not Hearing Anything in Speak Mode?" key="not_hearing_speech"}}</a></li>
            {{#if this.appState.domain_settings.support_url}}
              <li><a href={{this.appState.domain_settings.support_url}} target="_blank" rel="noopener" class="la-support-list__btn la-btn la-btn--ghost"><span class="la-support-list__icon la-support-list__icon--question" aria-hidden="true">❓</span> {{t "Support and Helpful How-To Articles" key="how_to_link"}}</a></li>
            {{/if}}
            {{#if this.appState.currentUser}}
              <li><button type="button" class="la-support-list__btn la-btn la-btn--ghost" {{action "show_speak_mode_intro_again"}}><span class="la-support-list__icon" aria-hidden="true">💬</span> {{t "Show Speak Mode intro again" key="show_speak_mode_intro_again"}}</button></li>
            {{/if}}
          </ul>
        {{/if}}
      {{else}}
        <ul class="la-support-list">
          {{#if this.ios}}
            <li><a href="https://lingolinq.zendesk.com/hc/en-us/articles/115000379246" target="_blank" rel="noopener" class="la-support-list__link"><span class="la-support-list__icon" aria-hidden="true">🔊</span> {{t "Not Hearing Anything in Speak Mode?" key="not_hearing_speech"}}</a></li>
          {{/if}}
          {{#if this.appState.domain_settings.support_url}}
            <li><a href={{this.appState.domain_settings.support_url}} target="_blank" rel="noopener" class="la-support-list__btn la-btn la-btn--ghost"><span class="la-support-list__icon la-support-list__icon--question" aria-hidden="true">❓</span> {{t "Support and Helpful How-To Articles" key="how_to_link"}}</a></li>
          {{/if}}
          {{#if this.appState.domain_settings.youtube_url}}
            <li><a href={{this.appState.domain_settings.youtube_url}} target="_blank" rel="noopener" class="la-support-list__link"><span class="la-support-list__icon" aria-hidden="true">🎬</span> {{t "YouTube Walkthrough Videos" key="how_to_videos"}}</a></li>
          {{/if}}
          {{#if this.appState.currentUser}}
            <li><button type="button" class="la-support-list__btn la-btn la-btn--ghost" {{action "show_speak_mode_intro_again"}}><span class="la-support-list__icon" aria-hidden="true">💬</span> {{t "Show Speak Mode intro again" key="show_speak_mode_intro_again"}}</button></li>
          {{/if}}
        </ul>
      {{/if}}

      <div class="la-support-form-section">
        <h3 class="la-support-form-title">{{t "Report a Problem/Share Feedback" key="problem_or_feedback"}}</h3>
        <form class="la-contact-form" {{action "submit_message" on="submit"}}>
          {{#if this.appState.sessionUser}}
            {{#if this.appState.sessionUser.supervisors}}
              <div class="la-contact-form__row">
                <label for="author_id" class="la-contact-form__label">{{t "Send Reply To" key="send_reply_to"}}</label>
                {{bound-select select_class="la-contact-input" select_id="author_id" content=this.author_ids selection=this.author_id action=(action "updateAuthorId") }}
              </div>
            {{/if}}
          {{/if}}
          {{#if this.prompt_user}}
            <div class="la-contact-form__row">
              <label for="name" class="la-contact-form__label">{{t "Name" key="name"}}</label>
              <Input @value={{this.name}} class="la-contact-input" id="name" placeholder={{t "Your Name" key="your_name"}} />
            </div>
            <div class="la-contact-form__row">
              <label for="email" class="la-contact-form__label">{{t "Email" key="email"}}</label>
              <Input @value={{this.email}} class="la-contact-input" id="email" placeholder="you@example.com" />
            </div>
          {{/if}}
          <div class="la-contact-form__row">
            <label for="subject" class="la-contact-form__label">{{t "Subject" key="subject"}}</label>
            <Input @value={{this.subject}} class="la-contact-input" id="subject" placeholder="" />
          </div>
          <div class="la-contact-form__row">
            <label for="message" class="la-contact-form__label">{{t "Message" key="message"}}</label>
            <Textarea @value={{this.message}} class="la-contact-input la-contact-input--textarea" id="message" placeholder="" rows={{3}} />
          </div>
          {{#if this.error}}
            <p class="la-support-form-error">{{t "Submission failed, please try again" key="ticket_failed"}}</p>
          {{/if}}
          <div class="la-contact-form__actions">
            <button disabled={{this.disabled}} type="submit" class="la-btn la-btn--primary">{{t "Send Message" key="send_message"}}</button>
            <LinkTo @route="troubleshooting" class="la-support-troubleshooting-link login-btn">{{t "Troubleshooting" key="troubleshooting"}}</LinkTo>
            <button type="button" class="la-btn la-btn--ghost" {{action "close"}}>{{t "Cancel" key="cancel"}}</button>
          </div>
        </form>
      </div>

      <p class="la-support-cookies">
        <button type="button" class="la-support-cookies__btn" {{action "toggle_cookies"}} aria-pressed={{if this.cookies "true" "false"}}>
          <span class="la-support-cookies__icon {{unless this.cookies "la-support-cookies__icon--off"}}" aria-hidden="true">🍪</span>
          {{#if this.cookies}}
            {{t "disable cookies" key="disable_cookies"}}
          {{else}}
            {{t "enable cookies" key="enable_cookies"}}
          {{/if}}
        </button>
      </p>
    </div>
  </div>
{{/modal-dialog}}
