{{!-- Modern two-tone stroke icons, 28x28, 1.5px --}}
{{#if (is-equal this.iconName "check")}}
  <svg class="md-getting-started-modal__icon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="10" stroke="#2A9D8F"/>
    <path d="M8 12l3 3 5-6" stroke="#46505F"/>
  </svg>
{{else if (is-equal this.iconName "learn")}}
  <svg class="md-getting-started-modal__icon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" stroke="#2A9D8F"/>
    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" stroke="#46505F"/>
  </svg>
{{else if (is-equal this.iconName "home")}}
  <svg class="md-getting-started-modal__icon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M3 10.5L12 3l9 7.5" stroke="#46505F"/>
    <path d="M5 12v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-7" stroke="#2A9D8F"/>
    <rect x="9" y="14" width="6" height="7" rx="1" stroke="#46505F"/>
  </svg>
{{else if (is-equal this.iconName "device")}}
  <svg class="md-getting-started-modal__icon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="5" y="2" width="14" height="20" rx="2" ry="2" stroke="#4C86D8"/>
    <line x1="12" y1="18" x2="12.01" y2="18" stroke="#46505F" stroke-width="2"/>
  </svg>
{{else if (is-equal this.iconName "preferences")}}
  <svg class="md-getting-started-modal__icon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="3" stroke="#46505F"/>
    <path d="M12 3v1.5M12 19.5V21M3 12h1.5M19.5 12H21M5.64 5.64l1.06 1.06M17.3 17.3l1.06 1.06M5.64 18.36l1.06-1.06M17.3 6.7l1.06-1.06" stroke="#7693B9"/>
  </svg>
{{else if (is-equal this.iconName "profile")}}
  <svg class="md-getting-started-modal__icon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke="#46505F"/>
    <circle cx="12" cy="7" r="4" stroke="#4C86D8"/>
  </svg>
{{else if (is-equal this.iconName "subscription")}}
  <svg class="md-getting-started-modal__icon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="2" y="5" width="20" height="14" rx="2" stroke="#C9AD7A"/>
    <line x1="2" y1="10" x2="22" y2="10" stroke="#46505F"/>
    <path d="M6 15h.01" stroke="#46505F" stroke-width="2"/>
    <path d="M10 15h4" stroke="#46505F"/>
  </svg>
{{else}}
  {{!-- fallback: learn --}}
  <svg class="md-getting-started-modal__icon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" stroke="#2A9D8F"/>
    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" stroke="#46505F"/>
  </svg>
{{/if}}
