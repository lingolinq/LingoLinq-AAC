{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="modal-header md-modal-header">
    <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h3>{{t "App Update Available" key="app_update_available"}}</h3>
  </div>
  <div class="modal-body md-modal-body">
    <p>
      {{t "An updated version of %app_name% has been downloaded and installed. Would you like to restart now? If you don't restart now, you should very soon." key="confirm_update"}}
      <span class='text-muted'>{{t "Updating to %{version}" key="updating_to" version=this.version}}</span>
    </p>
    <p>{{t "Please note: Any premium voices you have downloaded may no longer work until after you restart the app." key="premium_voices_need_update"}}</p>
    {{#if this.error}}
      <p class='text-danger'>{{t "There was an error trying to restart the app, please close and reopen manually." key="error_restarting_app"}}</p>
    {{/if}}
  </div>
  <div class="modal-footer md-modal-footer">
    <button class='btn btn-primary' {{action "restart"}}>{{t "Restart %app_name%" key="restart_app"}}</button>
    <button class='btn btn-default' {{action "close"}}>{{t "I'll Do it in a Minute" key="restart_soon"}}</button>
  </div>
{{/modal-dialog}}
