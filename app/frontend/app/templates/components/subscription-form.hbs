{{#if this.trial_choice}}
  <div style='margin-top: 30px;'>
    <button class='btn btn-default btn-lg' {{action "skip_subscription"}} style='height: 75px; width: calc(50% - 7px); margin-right: 10px;'>{{t "Start with a<br>2-month trial" key="start_with_two_month_trial"}}</button>
    <button class='btn btn-primary btn-lg' {{action "check_pricing"}} style='height: 75px; width: calc(50% - 7px);'>{{t "See Purchasing<br>Options" key="see_purchasing"}}</button>
  </div>
{{else}}
  <form {{action "purchase" on="submit"}} class="row subscription-form-with-cards">
    <div class="form-group"><div class="col-sm-12">
    {{#unless this.see_pricing}}
      {{#if this.trial_option}}
        {{#if this.subscription.user.really_expired}}
        {{else}}
          <div style='margin-bottom: 10px;'>
            <button class='btn btn-default' {{action "skip_subscription"}}>{{t "Start with a full-featured 2-month trial, no credit card required" key="two_month_trial_no_credit_card"}}</button>
          </div>
        {{/if}}
      {{/if}}
    {{/unless}}
    <div class="subscription-form-cards la-pricing-preview-grid">
      {{!-- Communicator card (columns 1 + 2) --}}
      <div class="la-about-glass-card la-pricing-card subscription-form-card subscription-form-card--communicator">
        <div class="la-about-glass-card__header">
          <span class="la-about-glass-card__icon" aria-hidden="true">💬</span>
          <h3 class="la-about-glass-card__title">{{t "Communicator" key="communicator"}}</h3>
        </div>
        <p class="la-about-glass-card__text">
          {{#if this.subscription.app_pricing_override}}
            {{t "Add premium communicator access using this login across all devices." key="premium_communicator_across_devices"}}
          {{/if}}
          {{t "Works as a general communication app for one user on multiple devices, and can be linked to many free supporters" key="general_communication"}}
        </p>
        <div class="la-pricing-card__prices">
          {{#unless this.subscription.app_pricing_override_no_monthly}}
            <div class="la-pricing-card__price-row">
              <span class="la-pricing-card__amount">
                {{#if this.subscription.app_pricing_override}}
                  {{this.subscription.monthly_app_price}} {{this.subscription.app_currency}}
                {{else}}
                  <span class="la-pricing-card__currency">US$</span>9
                {{/if}}
              </span>
              <span class="la-pricing-card__term">{{t "per month" key="per_month_lower"}}</span>
            </div>
            <span class="la-pricing-card__or">{{t "- or -" key="dash_or_dash"}}</span>
          {{/unless}}
          <div class="la-pricing-card__price-row">
            <span class="la-pricing-card__amount">
              {{#if this.subscription.app_pricing_override}}
                {{this.subscription.long_term_app_price}} {{this.subscription.app_currency}}
              {{else if this.subscription.user.lapsed}}
                <span class="la-pricing-card__currency">US$</span>50
              {{else if this.subscription.much_cheaper_offer}}
                <span class="sale">{{t "sale! 50% off" key="save_50_percent"}}</span>
                <span style="text-decoration: line-through;">$295</span>
                <span class="la-pricing-card__currency">US$</span>145
              {{else if this.subscription.cheaper_offer}}
                <span class="sale">{{t "save 25%" key="save_25_percent"}}</span>
                <span style="text-decoration: line-through;">$295</span>
                <span class="la-pricing-card__currency">US$</span>150
              {{else}}
                <span class="la-pricing-card__currency">US$</span>295
              {{/if}}
            </span>
            <span class="la-pricing-card__term">
              {{#if this.subscription.user.lapsed}}
                {{t "cloud re-purchase" key="cloud_re_purchase"}}
              {{else}}
                {{t "lifetime purchase" key="lifetime_purchase"}}
              {{/if}}
            </span>
          </div>
        </div>
        <ul class="la-pricing-card__features">
          <li>{{t "run on multiple devices" key="run_on_multiple_devices"}}</li>
          <li>{{t "full communication system" key="full_communication_system"}}</li>
          <li>{{t "premium voices, reports, modeling ideas, etc." key="premium_features_for_upgrade"}}</li>
          {{#unless this.subscription.app_pricing_override_no_monthly}}
            <li><button type="button" class="btn-link subscription-form__cloud-extras-link" {{action "openCloudExtras"}}>{{t "cloud extras" key="cloud_extras"}}</button> {{t "included in subscription" key="included_in_subscription_suffix"}}</li>
          {{/unless}}
          <li>
            {{#if this.subscription.user.lapsed}}
              <button type="button" class="btn-link subscription-form__cloud-extras-link" {{action "openCloudExtras"}}>{{t "cloud extras" key="cloud_extras"}}</button><br>{{t "5-year credit" key="5_year_credit"}}<br>{{t "added" key="5_years_added_word"}}
            {{else}}
              <button type="button" class="btn-link subscription-form__cloud-extras-link" {{action "openCloudExtras"}}>{{t "cloud extras" key="cloud_extras"}}</button><br>{{t "5-year credit" key="5_year_credit"}}<br>{{t "included" key="5_years_included_word"}}
            {{/if}}
          </li>
        </ul>
        <div class="subscription-form-card__body">
          {{#unless this.pricing_only}}
            <div class="subscription-form-card__buttons subscription-table__row--plan-buttons">
              {{#unless this.subscription.app_pricing_override_no_monthly}}
                <div class="subscription-table__cell--first-plan">
                  <button style='width: 100%;' rel='monthly' class={{this.communicator_monthly_subscription_class}} type="button" {{action "set_subscription_type" "monthly_communicator"}}>
                    {{#if this.subscription.app_pricing_override}}
                      <b>{{t "add to my account" key="add_to_my_account"}}</b><br>
                    {{else}}
                      <b>{{t "select this plan" key="select_this_plan"}}</b><br>
                    {{/if}}
                    {{#if this.subscription.app_pricing_override}}
                      {{this.subscription.monthly_app_price}} {{this.subscription.app_currency}}<br>{{t "per month" key="per_month_lower"}}
                    {{else}}
                      <span class="subscription-currency-us">US</span>$9 {{t "per month" key="per_month_lower"}}
                    {{/if}}
                  </button>
                </div>
              {{/unless}}
              <div>
                <button style='width: 100%;' rel='long_term' class={{this.communicator_long_term_subscription_class}} type="button" {{action "set_subscription_type" "long_term_communicator"}}>
                  {{#if this.subscription.app_pricing_override}}
                    <b>{{t "add to my account" key="add_to_my_account"}}</b><br>
                  {{else}}
                    <b>{{t "select this plan" key="select_this_plan"}}</b><br>
                  {{/if}}
                  {{#if this.subscription.app_pricing_override}}
                    {{this.subscription.long_term_app_price}} {{this.subscription.app_currency}}<br>{{t "purchase" key="purchase_lower"}}
                  {{else}}
                    <span class="subscription-currency-us">US</span>${{this.subscription.long_term_amount}} {{t "purchase" key="purchase_lower"}}
                  {{/if}}
                </button>
              </div>
            </div>
            {{#unless this.subscription.gift_type}}
              <div class="subscription-form-card__row subscription-table__row--light-gray-bg">
                {{#if this.subscription.user.subscription.extras_enabled}}
                  <div>{{t "premium symbols already added" key="premium_symbols_added"}}</div>
                {{else if this.subscription.app_pricing_override}}
                  <div>{{t "premium symbols included" key="premium_symbols_included"}}</div>
                {{else}}
                  <div>
                    {{#if this.subscription.communicator_type}}
                      <label>
                        <img src="https://d18vdu4p71yql0.cloudfront.net/libraries/pcs/03601/773cfc7cdbfa6770803a334b3089deff6eafca6d003d81bb21b08ae6ea75665c898bccbb25e46eed03592ca2d9b3e471bcd54fc7b4395e06984357e1a0bd976e/03601.svg" class="subscription-form__premium-symbol-image" alt="">
                        <Input type="checkbox" @checked={{this.subscription.extras}} />
                        {{t "add symbols from LessonPix, PCS (BoardMaker) Tobii Dynavox & SymbolStix for US$25" key="add_premium_symbols2"}}
                      </label>
                    {{/if}}
                  </div>
                {{/if}}
              </div>
            {{else if this.subscription.free_extras}}
              {{#if this.subscription.extras}}
                <div class="subscription-form-card__row subscription-table__row--light-gray-bg">
                  <div>{{t "premium symbols included" key="premium_symbols_included"}}</div>
                </div>
              {{/if}}
            {{/unless}}
            {{#unless this.subscription.gift_type}}
              <div class="subscription-form-card__row subscription-table__row--blue-bg">
                {{#if this.subscription.app_pricing_override}}
                  <div>{{t "2 premium supervisor credits included" key="premium_supporters_included"}}</div>
                {{else}}
                  <div>
                    {{#if this.subscription.communicator_type}}
                      {{t "include" key="include"}}
                      <span style='display: inline-block; width: 75px;'>
                        {{bound-select select_class="form-control" select_id="supervisors" content=this.supervisor_options selection=this.subscription.included_supporters action=(action (mut this.subscription.included_supporters)) }}
                      </span>
                      {{t "supervisor credits" key="supervisor_credits"}}
                    {{else}}
                      <span class='text-muted'>
                        {{t "optionally add supervisor credits" key="add_supervisor_credits"}}
                      </span>
                    {{/if}}
                  </div>
                {{/if}}
              </div>
            {{else if this.subscription.free_supporters}}
              {{#if this.subscription.included_supporters}}
                <div class="subscription-form-card__row">
                  <div>{{t "%{n} premium supervisor credits included" key="premium_supervisors_included"}}</div>
                </div>
              {{/if}}
            {{/unless}}
            <div class="subscription-form-card__row subscription-table__row--navy-bg" style='text-align: center;'>
              {{#if this.move_gift_option}}
                {{#if this.trial_option}}
                  <button type="button" class="subscribe-trial-btn" rel='free_trial' {{action "skip_subscription"}}>{{t "Start with a 2-month trial" key="start_two_month_trial"}}</button>
                {{/if}}
              {{else if this.subscription.app_pricing_override}}
                {{#if this.trial_option}}
                  <button type="button" class="subscribe-trial-btn" rel='free_trial' {{action "skip_subscription"}}>{{t "Start with a 2-month trial" key="start_two_month_trial"}}</button>
                {{/if}}
              {{else}}
                {{#if this.subscription.gift_type}}
                  <button class='btn btn-primary btn-sm'>{{t "I have a gift/discount code" key="have_a_gift_code"}}</button>
                  <div style='margin-top: 5px; text-align: center;'>
                    <span style="display: inline-block; width: 100px; margin-left: 5px;">
                      <Input type="text" @value={{this.subscription.gift_code}} class="form-control input-lg" placeholder="CODE" />
                    </span>
                    <button {{action "check_gift"}} style='display: inline-block; width: 100px; margin-top: -4px;' class='btn btn-lg btn-default'>
                      {{#if this.subscription.gift_status.checking}}
                        {{t "..." key="ellipsis"}}
                      {{else if this.subscription.gift_status.error}}
                        {{t "Invalid" key="invalid"}}
                      {{else}}
                        {{t "Check" key="check"}}
                      {{/if}}
                    </button>
                  </div>
                {{else}}
                  <a href="#" {{action "set_subscription_type" "gift_code"}}>
                    {{t "I have a gift/discount code" key="have_a_gift_code"}}
                  </a>
                {{/if}}
              {{/if}}
            </div>
          {{/unless}}
        </div>
      </div>

      {{!-- Supporter card (column 3) --}}
      <div class="la-about-glass-card la-pricing-card subscription-form-card subscription-form-card--supporter">
        <div class="la-about-glass-card__header">
          <span class="la-about-glass-card__icon" aria-hidden="true">🤝</span>
          <h3 class="la-about-glass-card__title">{{t "Supporter" key="supporter"}}</h3>
        </div>
        <p class="la-about-glass-card__text">
          {{#if this.subscription.app_pricing_override}}
            {{t "Add premium supporter access using this login across all devices." key="premium_supporter_across_devices"}}
          {{/if}}
          {{t "Used for supporting communicators." key="supporting_communicators"}}
        </p>
        <div class="la-pricing-card__prices">
          <div class="la-pricing-card__price-row">
            <span class="la-pricing-card__amount">
              {{#if this.subscription.app_pricing_override}}
                {{this.subscription.supporter_app_price}} {{this.subscription.app_currency}}
              {{else}}
                <span class="la-pricing-card__currency">US$</span>25
              {{/if}}
            </span>
            <span class="la-pricing-card__term">{{t "one-time purchase" key="one_time_purchase"}}</span>
          </div>
        </div>
        <ul class="la-pricing-card__features">
          <li>{{t "run on multiple devices" key="run_on_multiple_devices"}}</li>
          <li>{{t "support, edit & model" key="works_for_communicators"}}</li>
          <li>{{t "track usage, get alerts & modify boards" key="track_for_communicators"}}</li>
          <li><button type="button" class="btn-link subscription-form__cloud-extras-link" {{action "openCloudExtras"}}>{{t "cloud extras" key="cloud_extras"}}</button> {{t "for communicators" key="for_supported_communicators_suffix"}}</li>
        </ul>
        <div class="subscription-form-card__body">
          {{#unless this.pricing_only}}
            <div class="subscription-form-card__buttons subscription-table__row--plan-buttons semi_dim">
              {{#if this.subscription.minimal_premium}}
                <div>{{t "already available for this account" key="already_available_for_this_account"}}</div>
              {{else}}
                <button type="button" rel='slp_paid' class={{this.slp_long_term_class}} style='width: 100%;' {{action "set_subscription" "long_term_slp"}}>
                  {{#if this.subscription.app_pricing_override}}
                    <b>{{t "add to my account" key="add_to_my_account"}}</b><br>
                  {{else}}
                    <b>{{t "select this plan" key="select_this_plan"}}</b><br>
                  {{/if}}
                  {{#if this.subscription.app_pricing_override}}
                    {{this.subscription.supporter_app_price}} {{this.subscription.app_currency}}<br>{{t "purchase" key="purchase_lower"}}
                  {{else}}
                    <span class="subscription-currency-us">US</span>$25 {{t "purchase" key="purchase_lower"}}
                  {{/if}}
                </button>
              {{/if}}
            </div>
            {{#unless this.subscription.gift_type}}
              <div class="subscription-form-card__row subscription-table__row--light-gray-bg semi_dim">
                {{#if this.subscription.user.subscription.extras_enabled}}
                  <div>{{t "premium symbols already added" key="premium_symbols_added"}}</div>
                {{else if this.subscription.app_pricing_override}}
                  <div></div>
                {{else}}
                  <div>
                    {{#if this.subscription.supporter_type}}
                      {{#if this.subscription.minimal_premium}}
                        <label>
                          <img src="https://d18vdu4p71yql0.cloudfront.net/libraries/pcs/03601/773cfc7cdbfa6770803a334b3089deff6eafca6d003d81bb21b08ae6ea75665c898bccbb25e46eed03592ca2d9b3e471bcd54fc7b4395e06984357e1a0bd976e/03601.svg" class="subscription-form__premium-symbol-image" alt="">
                          {{t "premium symbols can be purchased separately" key="premium_purchased_separately"}}
                        </label>
                      {{else}}
                        <label>
                          <img src="https://d18vdu4p71yql0.cloudfront.net/libraries/pcs/03601/773cfc7cdbfa6770803a334b3089deff6eafca6d003d81bb21b08ae6ea75665c898bccbb25e46eed03592ca2d9b3e471bcd54fc7b4395e06984357e1a0bd976e/03601.svg" class="subscription-form__premium-symbol-image" alt="">
                          <Input type="checkbox" @checked={{this.subscription.extras}} />
                          {{t "add symbols from LessonPix, PCS (BoardMaker) Tobii Dynavox & SymbolStix for US$25" key="add_premium_symbols2"}}
                        </label>
                      {{/if}}
                    {{/if}}
                  </div>
                {{/if}}
              </div>
            {{/unless}}
            {{#unless this.subscription.gift_type}}
              <div class="subscription-form-card__row subscription-table__row--blue-bg semi_dim">
                {{#if this.subscription.app_pricing_override}}
                  <div></div>
                {{else}}
                  <div>
                    {{#unless this.subscription.app_pricing_override}}
                      <a href="#" {{action "bulk_purchase"}} style='display: inline-block;'>
                        {{t "Bulk Purchase, PO or PCard?" key="bulk_purchase_or_po"}}
                      </a>
                    {{/unless}}
                  </div>
                {{/if}}
              </div>
            {{/unless}}
            <div class="subscription-form-card__row subscription-table__row--navy-bg semi_dim" style='text-align: center;'>
              {{#if this.subscription.modeling_long_term}}
                <button class='btn btn-primary' style='width: auto;'>{{t "set as a free<br> modeling-only account" key="set_as_free_modeling_only_two_lines"}}</button>
              {{else}}
                <a href="#" {{action "set_subscription" "slp_monthly_free"}}>{{t "set as a free modeling-only account" key="set_as_free_modeling_only"}}</a>
              {{/if}}
            </div>
          {{/unless}}
        </div>
      </div>

      {{!-- Eval card (column 4) --}}
      <div class="la-about-glass-card la-pricing-card subscription-form-card subscription-form-card--eval">
        <div class="la-about-glass-card__header">
          <span class="la-about-glass-card__icon" aria-hidden="true">📋</span>
          <h3 class="la-about-glass-card__title">{{t "Eval" key="eval"}}</h3>
        </div>
        <p class="la-about-glass-card__text">
          {{#if this.subscription.app_pricing_override}}
            {{t "Add premium evaluator access using this login across all devices." key="premium_eval_across_devices"}}
          {{/if}}
          {{t "Used for loaner/ evaluation devices." key="eval_descriptor"}}
        </p>
        <div class="la-pricing-card__prices">
          <div class="la-pricing-card__price-row">
            <span class="la-pricing-card__amount">
              {{#if this.subscription.app_pricing_override}}
                {{this.subscription.eval_app_price}} {{this.subscription.app_currency}}
              {{else}}
                <span class="la-pricing-card__currency">US$</span>25
              {{/if}}
            </span>
            <span class="la-pricing-card__term">{{t "one-time purchase" key="one_time_purchase"}}</span>
          </div>
        </div>
        <ul class="la-pricing-card__features">
          <li>{{t "run on one device" key="run_on_one_device"}}</li>
          <li>{{t "full communication system for evals" key="full_communication_system_for_evals"}}</li>
          <li>{{t "premium voices on request" key="premium_voices_on_request"}}</li>
          <li><button type="button" class="btn-link subscription-form__cloud-extras-link" {{action "openCloudExtras"}}>{{t "cloud extras" key="cloud_extras"}}</button> {{t "reset after every eval" key="for_supported_communicators2_suffix"}}</li>
        </ul>
        <div class="subscription-form-card__body">
          {{#unless this.pricing_only}}
            <div class="subscription-form-card__buttons subscription-table__row--plan-buttons semi_dim">
              {{#if this.subscription.minimal_premium}}
                <div>{{t "already available for this account" key="already_available_for_this_account"}}</div>
              {{else}}
                <button type="button" rel='eval_paid' class={{this.eval_long_term_class}} style='width: 100%;' {{action "set_subscription" "long_term_eval"}}>
                  {{#if this.subscription.app_pricing_override}}
                    <b>{{t "add to my account" key="add_to_my_account"}}</b><br>
                  {{else}}
                    <b>{{t "select this plan" key="select_this_plan"}}</b><br>
                  {{/if}}
                  {{#if this.subscription.app_pricing_override}}
                    {{this.subscription.eval_app_price}} {{this.subscription.app_currency}}<br>{{t "purchase" key="purchase_lower"}}
                  {{else}}
                    <span class="subscription-currency-us">US</span>$25 {{t "purchase" key="purchase_lower"}}
                  {{/if}}
                </button>
              {{/if}}
            </div>
          {{/unless}}
        </div>
      </div>
    </div>
    </div></div>
    {{#if this.show_bulk_purchase}}
      <div class='form-group'>
        <div class='col-sm-12' style='margin-top: 30px; padding-bottom: 20px;'>
          <p>
            <span class='glyphicon glyphicon-paperclip' style='float: left; font-size: 30px; margin-right: 10px;'></span>
            {{t "We love working with school districts and organizations who want to support multiple communicators! If you're interested in purchasing multiple licenses, using a PCard, or purchasing without using a credit card, please <a href='/contact?to=sales'>contact our sales team for more information</a>. Note that many PCards will work with our online credit card processing system as well." key="bulk_purchase_explainer"}}
          </p>
        </div>
      </div>
    {{/if}}
    {{#if this.pricing_only}}
      {{#unless this.show_bulk_purchase}}
        {{#if this.show_expiration_notes}}
          <p class="explanation" style="margin-top: 10px;">
            {{t "We don't want to shut off anyone's voice, even if funding unexpectedly becomes an issue down the line. When a user's subscription expires %app_name% will still work as a communication system but premium features like reporting and video notes will be disabled." key="expiration_notes_pre"}}
            {{#if this.app_state.domain_settings.support_url}}
              {{t "If you need help with funding please" key="expiration_notes_support"}}
              <a href={{this.app_state.domain_settings.support_url}}>{{t "contact our support team" key="contact_support_team"}}</a> {{t "for more information." key="expiration_notes"}}
            {{/if}}
          </p>
        {{/if}}
      {{/unless}}
    {{else}}
      <div class="form-group">
        <div class="col-sm-12 subscription-activate-row" style='margin-top: 20px;'>
          {{#if this.not_authenticated}}
            {{#unless this.subscription.confirmation}}
              <p class='text-danger'>{{t "There appears to be an issue with your session that could prevent your purchase from completing. Please try logging out and back in. If that doesn't correct the problem, please try a different browser or contact our support team." key="error_subscription_wont_word"}}</p>
            {{/unless}}
          {{/if}}
          <button type="submit" rel='activate' class="btn btn-lg btn-primary subscription-activate-btn">
            {{#if this.subscription.discount_percent}}
              <div class="subscription-activate-btn__discount">
                <span class="subscription-activate-btn__icon glyphicon glyphicon-ok-sign"></span>
                {{t "Discount Applied!" key="discount_applied"}}
              </div>
            {{/if}}
            <span class="subscription-activate-btn__heading-row">
            {{#if this.purchase_state.pending}}
              <span class="subscription-activate-btn__heading">{{t "Checking..." key="checking"}}</span>
            {{else if this.subscription.user.grace_period}}
              <span class="subscription-activate-btn__heading">{{t "Activate Account" key="activate_account"}}</span>
            {{else}}
              <span class="subscription-activate-btn__heading">{{t "Update Account" key="update_account"}}</span>
            {{/if}}
              <span class="subscription-activate-btn__arrow glyphicon glyphicon-arrow-right" aria-hidden="true"></span>
            </span>
            <div class="subscription-activate-btn__price">
            {{#if this.subscription.amount_in_dollars}}
              <span class="subscription-activate-btn__paren">(</span>{{#if this.subscription.long_term_subscription}}
                {{t "process" key="process"}}
                {{#if this.subscription.app_pricing_override}}
                  {{this.subscription.long_term_app_price}}
                  {{this.subscription.app_currency}}
                {{else}}
                  US${{this.subscription.amount_in_dollars}}
                {{/if}}
              {{else}}
                <span class="subscription-activate-btn__paying-line">{{t "paying" key="paying"}}
                {{#if this.subscription.app_pricing_override}}
                  {{this.subscription.monthly_app_price}}
                  {{this.subscription.app_currency}}
                  {{t "monthly" key="monthly"}}
                {{else}}
                  US${{this.subscription.amount_in_dollars}}
                  {{t "monthly" key="monthly"}}
                  {{#if this.subscription.extras_in_dollars}}
                    {{t "+ US$%{n} one-time fee" n=this.subscription.extras_in_dollars key="plus_one_time_extras"}}
                  {{/if}}
                {{/if}}
                </span>
              {{/if}}<span class="subscription-activate-btn__paren">)</span>
            {{else if this.subscription.extras}}
              {{#unless this.subscription.free_extras}}
                {{t "(process one-time US$25 fee)" key="process_one_time_extras"}}
              {{/unless}}
            {{/if}}
            {{#if this.subscription.user.grace_period}}
              {{#if this.subscription.monthly_subscription}}
                {{#if this.subscription.communicator_type}}
                  {{#unless this.subscription.app_pricing_override}}
                    <br><em class="subscription-activate-btn__subtext">{{t "monthly fee starts after your free trial" key="billing_after_trial"}}</em>
                  {{/unless}}
                {{/if}}
              {{/if}}
            {{/if}}
            </div>
          </button>
          {{#if this.trial_option}}
            {{#if this.subscription.user.really_really_expired}}
              &nbsp;&nbsp;<a href="#" class='btn btn-default btn-lg' {{action "reload"}}>{{t "Reload, I've updated my account" key="reload_subscription_updated"}}</a>
              &nbsp;&nbsp;<a href="#" class='btn btn-default btn-lg' {{action "logout"}}>{{t "Log Out" key="log_out"}}</a>
            {{else if this.subscription.user.really_expired}}
              &nbsp;&nbsp;<a href="#" rel='skip_subscription' class='btn btn-default btn-lg' {{action "skip_subscription"}}>{{t "I need more time" key="i_need_more_time"}}</a>
            {{else}}
              <a href="#" rel='free_trial' class="subscribe-trial-btn" {{action "skip_subscription"}}>{{t "Start with a 2-month trial" key="start_two_month_trial"}}</a>
            {{/if}}
          {{else}}
            <button type="button" rel='cancel' class="btn btn-lg btn-default" {{action "reset"}}>{{t "Cancel Changes" key="cancel_changes"}}</button>
          {{/if}}
        </div>
      </div>
    {{/if}}
  </form>
{{/if}}
