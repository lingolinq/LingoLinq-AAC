{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="md-modal-header">
    <button type="button" class="close" {{action "close"}}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h3 class="md-modal-title">{{t "Discard Changes?" key="discard_changes_title"}}</h3>
  </div>
  <div class="md-modal-body">
    <div class="md-modal-icon-row">
      <div class="md-modal-icon-circle" style="background: rgba(192, 57, 43, 0.10); color: #c0392b;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      </div>
    </div>
    <p class="md-modal-message">
      {{t "Any unsaved changes to this board will be lost. This action cannot be undone." key="confirm_discard_changes"}}
    </p>
  </div>
  <div class="md-modal-footer">
    <button class="md-modal-btn md-modal-btn--cancel" {{action "close"}}>{{t "Keep Editing" key="keep_editing"}}</button>
    <button class="md-modal-btn md-modal-btn--danger" {{action "discard"}}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
      {{t "Discard Changes" key="discard_changes"}}
    </button>
  </div>
{{/modal-dialog}}
