{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="modal-header md-modal-header">
    <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h3>{{t "Remove Goal from Room?" key="remove_goal_from_room"}}</h3>
  </div>
  <div class="modal-body md-modal-body">
    <div class="form-horizontal">
      <div class="form-group">
        <div class="col-sm-8 col-sm-offset-3">
          <p class="form-control-static">
            {{t "Are you sure you want to conclude this goal for the room?" key="confirm_conclude_goal"}}
          </p>
        </div>
      </div>
      <div class='form-group'>
        <div class='col-sm-3'>
          {{t "Goal:" key="goal_colon"}}
        </div>
        <div class='col-sm-8'>
          <strong>{{this.model.goal.summary}}</strong>
        </div>
      </div>
      <div class='form-group'>
        <div class='col-sm-3'>
          {{t "Room:" key="room_colon"}}
        </div>
        <div class='col-sm-8'>
          <strong>{{this.model.source.name}}</strong>
        </div>
      </div>
      <div class="form-group">
        <div class="col-sm-8 col-sm-offset-3">
          <div class="checkbox big_checkbox">
            <label>
              <Input @type="checkbox" @checked={{this.auto_conclude}} />
              {{t "Auto-conclude the goal for all users in the room" key="auto_conclude_goal_in_room"}}
            </label>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="modal-footer md-modal-footer">
    <button class='btn btn-primary btn-lg' disabled={{this.status.saving}} {{action "confirm"}}>
      {{#if this.status.saving}}
        {{t "Removing Goal..." key="removing_goal"}}
      {{else if this.status.error}}
        {{t "Error Removing Goal" key="error_removing_goal"}}
      {{else}}
        {{t "Remove Goal" key="remove_goal"}}
      {{/if}}
    </button>
    <button class='btn btn-default btn-lg' {{action "close"}}>{{t "Cancel" key="cancel"}}</button>
  </div>
{{/modal-dialog}}
