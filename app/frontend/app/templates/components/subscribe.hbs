{{#modal-dialog opening=(action "opening") closing=(action "closing") uncloseable="true"}}
  <div class="modal-header subscribe-modal-header">
    {{#unless (and this.model.subscription this.model.subscription.finalizing_purchase)}}
      <button type="button" class="la-modal-close subscribe-modal-header__close" {{action "dismiss_subscribe_modal"}} aria-label={{t "Close" key="close"}}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    {{/unless}}
    <button type="button" class="subscribe-trial-btn" {{action "really_subscription_skip"}}>{{t "Start w/ 2-Month Trial" key="start_with_2_month_trial_brief"}}</button>
    <div class="subscribe-modal-header__title-wrap">
      {{#unless this.model.user.really_expired}}
        {{app-logo size="auto" imgClass="subscribe-modal-header__logo" imgAlt=""}}
      {{/unless}}
      {{#if this.model.user.really_expired}}
        <h3>{{t "Purchase Update" key="subscription_update"}}</h3>
      {{else}}
        <h3>{{t "Welcome to %app_name%!" key="welcome_to_app"}}</h3>
      {{/if}}
    </div>
  </div>
  <div class="modal-body md-modal-body" id="button_settings">
    {{#if this.model.user.really_expired}}
      <p>
        {{t "Your %app_name% trial period has expired. Please update your billing settings to continue using LingoLinq." key="welcome_fill_out_subscription"}}
      </p>
    {{else}}
      <p>
        {{t "We're excited you're here! Every user account starts with 2 months of free access to our cloud extras so you can try %app_name% out and see if it's going to work before making a commitment, or you're welcome to sign up for one of our purchase plans right away." key="welcome_fill_out_subscription2"}}
      </p>
      {{#if this.model.subscription.discount_period}}
        <p>
          {{t "<strong>Discount available!</strong> If you purchase within the first 24 hours after signing up you're eligible for a <strong>25% discount</strong> on your account. You'll still get your 2-month trial included as well." key="welcome_fill_out_subscription_free_trial"}}
        </p>
      {{else if this.model.subscription.sale}}
        <p>
          {{t "<strong>%app_name% is on sale!</strong> Sign up now to receive a discount, the sale ends" key="welcome_fill_out_subscription_sale"}}
          {{date this.model.subscription.sale_ends "day"}}{{t "." key="period"}}
        </p>
      {{/if}}
    {{/if}}
    {{#if this.model.subscription.finalizing_purchase}}
      <h4>{{t "Confirming purchase..." key="finalizing_subscription"}}</h4>
    {{else if this.error}}
      <h4 class='text-danger'>{{this.error}}</h4>
    {{else}}
      {{subscription-form user=this.model.user subscription=this.model.subscription trial_option=true subscription_skip=(action "subscription_skip") subscription_error=(action "subscription_error") subscription_success=(action "subscription_success")}}
    {{/if}}
  </div>
{{/modal-dialog}}
