{{#if (or this.appState.speak_mode this.alwaysShow)}}
  {{#unless this.appState.currentUser.preferences.disable_quick_sidebar}}
    {{#unless this.appState.sidebar_relegated}}
      {{#unless this.appState.eval_mode}}
        <button type="button" id="sidebar_tease" class={{if this.appState.skinny_sidebar "advanced_selection noselect skinny" "advanced_selection noselect"}} {{action "toggleSidebar"}} aria-label={{t "Open sidebar" key="open_sidebar"}}>
          {{#if this.appState.fenced_sidebar_board}}
            <span class='glyphicon glyphicon-map-marker' style='font-size: 20px; vertical-align: middle;' aria-hidden="true"></span>
          {{/if}}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true" style="pointer-events: none;">
            <polyline points="6 9 12 15 18 9" style="pointer-events: none;"></polyline>
            <polyline points="6 14 12 20 18 14" style="pointer-events: none;"></polyline>
          </svg>
        </button>
      {{/unless}}
    {{/unless}}
  {{/unless}}
{{/if}}
