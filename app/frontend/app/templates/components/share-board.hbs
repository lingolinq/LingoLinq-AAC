{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="modal-header md-modal-header">
    <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h3 class="md-modal-title">{{t "Share Board" key="share_board"}}</h3>
  </div>
  <div class="modal-body md-modal-body" style="text-align: left;">
    <div class="md-modal-icon-row">
      <div class="md-modal-icon-circle">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="18" cy="5" r="3" stroke="#2a9d8f"/><circle cx="6" cy="12" r="3" stroke="#46505f"/><circle cx="18" cy="19" r="3" stroke="#2a9d8f"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49" stroke="#46505f"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49" stroke="#46505f"/>
        </svg>
      </div>
    </div>

    {{#if this.board.public}}
      <p class="md-modal-hint">{{t "This board is public, and available to share with anyone. Copy the link to this board to share it on other apps/sites.<br><!--TODO: (for better sharing install the  mobile app).-->" key="copy_board_link"}}</p>

      <div class="md-modal-field">
        <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 10px;">
          <img src={{this.board.icon_url_with_fallback}} alt="" style="height: 30px; border-radius: 6px;">
          {{#if this.board.link}}
            <a href={{this.board.link}} target="_blank" rel="noopener" class="md-modal-link">{{this.board.name}} ({{this.board.key}}) <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle;"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg></a>
            <span id="board_link" style="position: absolute; height: 0; left: -1000px;">{{this.board.link}}</span>
          {{/if}}
        </div>
        {{share-bar url=this.board.link user=this.appState.currentUser element_id="board_link" board=this.board copy_event=(action "copy_event")}}
        <div aria-live="polite" aria-atomic="true">
          {{#if this.copy_result.succeeded}}
            <p class="md-modal-status md-modal-status--success">{{t "Link Copied to the Clipboard!" key="link_copied_to_clipboard"}}</p>
          {{else if this.copy_result.failed}}
            <p class="md-modal-status md-modal-status--error" role="alert">{{t "Copying to the clipboard failed." key="copy_failed"}}</p>
          {{else}}
            {{#unless this.appState.installed_app}}
              <p class="md-modal-hint"><button type="button" class="md-link-btn md-modal-link" {{action "show_embed_board"}}>{{t "embed board" key="embed_board"}}</button></p>
            {{/unless}}
          {{/if}}
        </div>
        {{#if this.show_embed}}
          <div class="md-modal-field">
            <p class="md-modal-hint">{{t "You can embed your %app_name% boards in other web sites like blogs or how-to's so people can try them out more easily. Just copy and paste the code below into your web site:" key="copy_html_embed_code"}}</p>
            {{focus-input type="text" value=this.board.embed_code class="md-modal-input"}}
          </div>
        {{/if}}
      </div>
    {{else}}
      <p class="md-modal-hint">{{t "This board is private, only shared users, supervisors and admins can see it." key="board_is_private_limited_users"}}</p>
      {{#if this.board.copying_state}}
        <p class="md-modal-hint">{{t "This board contains protected material, and can't be made public. However, you can share it with other users who have purchased access to the same content." key="protected_material_shareable"}}</p>
      {{else if this.board.permissions.edit}}
        {{#if this.error_confirming_public_board}}
          <p class="md-modal-status md-modal-status--error" role="alert">{{t "There was an unexpected error while trying to update the board" key="board_update_error"}}</p>
        {{/if}}
        {{#if this.confirm_public_board}}
          <p class="md-modal-hint">{{t "Are you sure you want to make this board public? Anyone will be able to search for and see it. This is not recommended for boards containing any personal information." key="confirm_make_public"}}</p>
          {{#if this.board.protected_material}}
            <p class="md-modal-status md-modal-status--warning">{{t "NOTE: This board has premium content, any users who access it without the same premium access will see free alternatives instead." key="protected_material_reminder"}}</p>
          {{/if}}
          {{#if this.board.downstream_boards}}
            <div class="md-modal-field">
              <label class="md-modal-checkbox-label">
                <Input @checked={{this.board.update_visibility_downstream}} @type="checkbox" class="md-modal-checkbox" />
                <span>{{t "Make all linked boards public as well" key="make_all_public"}}</span>
              </label>
            </div>
          {{/if}}
          <div style="display: flex; gap: 8px; margin-top: 12px;">
            <button class="btn md-modal-btn md-modal-btn--primary" {{action "make_public" "confirm"}}>{{t "Make the Board Public" key="make_it_public"}}</button>
            <button class="btn md-modal-btn md-modal-btn--cancel" {{action "make_public" "cancel"}}>{{t "Cancel" key="cancel"}}</button>
          </div>
        {{else}}
          <button class="btn md-modal-btn md-modal-btn--primary" {{action "make_public"}}>{{t "Make the Board Public" key="make_it_public"}}</button>
        {{/if}}
      {{/if}}
    {{/if}}

    {{#if this.board.permissions.share}}
      <div style="margin-top: 20px;">
        {{#if this.board.shared_users}}
          <h4 class="md-modal-section-title">{{t "Shared with" key="shared_with_others"}}</h4>
          <div class="md-modal-shared-users-list">
            {{#each this.board.shared_users as |user|}}
              <div class="md-modal-shared-user">
                <img src={{user.avatar_url}} class="md-modal-avatar" style="width: 40px; height: 40px;" alt="">
                <div class="md-modal-shared-user__info">
                  <div class="md-modal-shared-user__name">
                    {{user.name}}
                    {{#if user.pending}}
                      <span class="md-modal-shared-user__badge">{{t "(pending approval)" key="pending_approval"}}</span>
                    {{/if}}
                  </div>
                  <div class="md-modal-shared-user__detail">
                    <LinkTo @route="user" @model={{user.id}}>{{user.user_name}}</LinkTo>
                    {{#if user.include_downstream}}
                      <span class="md-modal-shared-user__badge">{{t "(includes downstream boards)" key="downstream"}}</span>
                    {{/if}}
                    {{#if user.allow_editing}}
                      <span class="md-modal-shared-user__badge">{{t "(editing allowed)" key="editing_allowed"}}</span>
                    {{/if}}
                  </div>
                </div>
                <button type="button" class="md-modal-shared-user__remove" {{action "unshare" user.id}} title="Remove">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                </button>
              </div>
            {{/each}}
          </div>
        {{/if}}
        <h4 class="md-modal-section-title">{{t "Share with other users" key="share_with_others"}}</h4>
        <form {{action "share_with_user" on="submit"}}>
          <div class="md-modal-field">
            <div style="display: flex; align-items: center; gap: 8px;">
              <label for="share_board_user_name" class="sr-only">{{t "User name to add" key="user_name_to_add"}}</label>
              <Input id="share_board_user_name" @value={{this.share_user_name}} class="md-modal-input" placeholder="user name to add" style="flex: 1;" />
              {{#if this.appState.currentUser.known_supervisees}}
                <div class="btn-group">
                  <button class="btn md-modal-btn md-modal-btn--cancel dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" type="button">
                    {{t "user" key="user_lower"}} <span class="caret"></span>
                  </button>
                  <ul class="dropdown-menu" style="right: 0; left: inherit; text-align: left;">
                    {{#each this.appState.currentUser.known_supervisees as |user|}}
                      <li><button type="button" {{action "set_share_user_name" user.user_name}}>{{user.user_name}}</button></li>
                    {{/each}}
                  </ul>
                </div>
              {{/if}}
            </div>
          </div>
          <div class="md-modal-field">
            <label class="md-modal-checkbox-label">
              <Input @type="checkbox" @checked={{this.share_include_downstream}} class="md-modal-checkbox" />
              <span>{{t "also share any linked boards" key="include_downstream_boards"}}</span>
            </label>
          </div>
          <div class="md-modal-field">
            <label class="md-modal-checkbox-label">
              <Input @type="checkbox" @checked={{this.share_allow_editing}} class="md-modal-checkbox" />
              <span>{{t "allow editing (and deleting) as well" key="include_editing_downstream_boards"}}</span>
            </label>
          </div>
          {{#if this.share_include_downstream}}
            {{#if this.share_allow_editing}}
              <p class="md-modal-hint" style="font-style: italic;">{{t "for security reasons, this type of sharing will have to be approved by the user" key="user_approval_sharing_required"}}</p>
            {{/if}}
          {{/if}}
          <div style="display: flex; gap: 8px; margin-top: 12px;">
            <button type="submit" class="btn md-modal-btn md-modal-btn--primary">{{t "Share This Board" key="share_this_board"}}</button>
            {{#if this.supervisee_share}}
              {{#if this.not_copyable}}
                <span class="md-modal-hint">{{t "You are a read-only supervisor for this user" key="read_only_supervisor"}}</span>
              {{else}}
                <button type="button" class="btn md-modal-btn md-modal-btn--cancel" {{action "copy_board"}} disabled={{this.not_copyable}}>{{t "Make a Copy For %{user_name}" key="make_a_copy_for_user" user_name=this.share_user_name}}</button>
              {{/if}}
            {{/if}}
          </div>
        </form>
      </div>
    {{/if}}
  </div>
  <div class="modal-footer md-modal-footer">
    <button class="btn md-modal-btn md-modal-btn--cancel" {{action "close"}}>{{t "Close" key="close"}}</button>
  </div>
{{/modal-dialog}}
