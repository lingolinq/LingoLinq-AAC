{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="modal-header md-modal-header">
    <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h3>{{t "Share Message" key="share_message"}}</h3>
  </div>
  <div class="modal-body md-modal-body">
    <p>
      <img src={{this.model.user.avatar_url}} style="height: 50px; max-width: 100px;">
      {{t "The following message will be sent to <strong>%{sup}</strong>:" key="user_notification_explanation" sup=this.model.user.user_name}}
    </p>

    <div class="well">
      {{this.model.sentence}}
    </div>

    <div class="row">
      <div class="col-sm-10">
        {{#if this.loading}}
          <button class='btn btn-lg btn-primary' disabled='true'>
            {{t "Sending Message..." key="sending_message"}}
          </button>
        {{else}}
          <button class='btn btn-lg btn-primary' {{action "confirm"}}>
            {{t "Send Message" key="send_message"}}
            {{#if this.seconds}}
              {{t "in" key="in"}}
              {{this.seconds}}s
            {{/if}}
          </button>
          <button class='btn btn-lg btn-default' {{action "close"}}>{{t "Cancel" key="cancel"}}</button>
        {{/if}}
        {{#if this.error}}
          <p class='text-danger'>{{t "There was an unexpected problem sending the message" key="error_sending_message"}}</p>
        {{/if}}
      </div>
    </div>
  </div>
{{/modal-dialog}}
