{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="la-support-modal-wrap la-limit-skin-tones-modal-wrap">
    <div class="la-modal-header">
      <span class="la-modal-header-label">{{t "Limit Tones To..." key="limit_tones_to"}}</span>
      <div class="la-support-modal-header-meta">
        <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>✕</button>
      </div>
    </div>
    <div class="la-support-modal-body">
      <p class="la-support-intro">
        {{t "Select which skin tones to show in people-based symbols. Only the selected tones will be used." key="limit_tones_modal_intro"}}
      </p>
      <ul class="la-limit-skin-tones-list" role="list">
        {{#each this.toneOptions as |opt idx|}}
          <li class="la-limit-skin-tones-list__item">
            <label class="la-limit-skin-tones-list__label">
              <input type="checkbox" checked={{opt.checked}} {{action "toggleChecked" idx on="change"}} class="la-limit-skin-tones-list__checkbox" />
              <img src={{opt.image_url}} alt="" class="la-limit-skin-tones-list__img" width="28" height="28" />
              <span class="la-limit-skin-tones-list__text">{{opt.label}}</span>
            </label>
          </li>
        {{/each}}
      </ul>
      <div class="la-contact-form__actions la-limit-skin-tones-actions">
        <button type="button" class="la-btn la-btn--primary" {{action "confirm"}}>{{t "Confirm selection" key="confirm_selection"}}</button>
        <button type="button" class="la-btn la-btn--ghost" {{action "close"}}>{{t "Cancel" key="cancel"}}</button>
      </div>
    </div>
  </div>
{{/modal-dialog}}
