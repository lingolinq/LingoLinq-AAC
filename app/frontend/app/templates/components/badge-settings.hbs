{{#if this.in_list}}
  <div class="form-group" style='border-top: 1px solid #ddd; padding-top: 10px;'>
    <label class="col-sm-2 control-label">
      {{t "Level %{level}" key="level_n" level=index increment="level" }}
      <div style='margin-top: 5px;'>
        <button class='btn btn-default' type='button' {{action "delete_badge"}}><span class='glyphicon glyphicon-trash'></span></button>
      </div>
    </label>
    <div class='col-sm-4'>
      <img src={{this.badge.image_url}} style='height: 75px; max-width: 75px; vertical-align: bottom;'>
      <button class='btn btn-default' type='button' {{action "change_image"}}>{{t "Change Image" key="new_image"}}</button>
    </div>
    <div class='col-sm-4'>
      {{#if this.badge.sound_url}}
        <audio src={{this.badge.sound_url}} style='display: block; height: 40px; max-width: 100%;' controls='true'/>
      {{else}}
        <span class='glyphicon glyphicon-volume-off' style='display: block; height: 40px; font-size: 30px;'></span>
      {{/if}}
        <button class='btn btn-default' type='button' {{action "change_sound"}}>
          {{#if this.badge.sound_url}}
            {{t "Change Sound" key="change_sound"}}
          {{else}}
            {{t "New Sound" key="new_sound"}}
          {{/if}}
        </button>
        {{#if this.badge.sound_url}}
          <button class='btn btn-default' type='button' {{action "delete_sound"}}><span class='glyphicon glyphicon-remove'></span></button>
        {{/if}}
    </div>
  </div>
  <div class="form-group">
    <div class="col-sm-5 col-sm-offset-2">
      {{bound-select select_class="form-control" content=this.simple_types selection=this.badge.simple_type action=(action (mut this.badge.simple_type)) }}
    </div>
  </div>
  {{#if this.custom_badge}}
    <div class="form-group">
      <div class="col-sm-8 col-sm-offset-2">
        <div class="checkbox big_checkbox">
          <label>
            <Input type="checkbox" @checked={{this.badge.enable_auto_tracking}} />
            {{t "This badge is automatically awarded based on user activity" key="auto_tracking"}}
          </label>
        </div>
      </div>
    </div>
  {{/if}}
{{else}}
  <div class="form-group">
    <div class="col-sm-5 col-sm-offset-2">
      {{bound-select select_class="form-control" content=this.simple_assessment_types selection=this.badge.simple_type action=(action (mut this.badge.simple_type)) }}
    </div>
  </div>
{{/if}}
{{#if this.custom_badge}}
  {{#if this.badge.enable_auto_tracking}}
    <div class="form-group">
      <div class='col-sm-4 col-sm-offset-2'>
        <p class='form-control-static'>
          {{#if this.in_list}}
            {{t "For awarding this badge," key="for_awarding_badge"}}
          {{else}}
            {{t "For tracking daily success," key="for_daily_tracking"}}
          {{/if}}
        </p>
      </div>
      <div class='col-sm-4'>
        {{bound-select select_class="form-control" content=this.tracking_types selection=this.badge.tracking_type action=(action (mut this.badge.tracking_type)) }}
      </div>
    </div>
    {{#if this.badge.watchlist}}
      <div class='form-group'>
        <div class='col-sm-4 col-sm-offset-2'>
          <p class='form-control-static'>
            {{#if this.in_list}}
              {{t "To earn this badge, the user must use some of the following" key="user_must_use"}}
            {{else}}
              {{t "The user should daily use some of the following" key="userMust_daily_user"}}
            {{/if}}
          </p>
        </div>
        <div class={{if this.in_list "col-sm-2" "col-sm-4"}}>
          {{bound-select select_class="form-control" content=this.watchlist_types selection=this.badge.watchlist_type action=(action (mut this.badge.watchlist_type)) }}
        </div>
        {{#if this.in_list}}
          <div class='col-sm-2'>
            {{bound-select select_class="form-control" content=this.unit_type_list selection=this.badge.interval action=(action (mut this.badge.interval)) }}
          </div>
        {{/if}}
      </div>
      <div class='form-group'>
        <label for='string_list' class='col-sm-2 col-sm-offset-2'>
          <p class='form-control-static'>{{t "list of %{types}:" types=this.watchlist_type_plural key="list_of_watchlist_types"}}</p>
        </label>
        <div class='col-sm-6'>
          <Input @value={{this.badge.string_list}} class="form-control" placeholder="comma-separated list" />
        </div>
      </div>
      <div class='form-group'>
        <div class='col-sm-3 col-sm-offset-2'>
          <div class='checkbox big_checkbox'>
            <label>
              <Input type="checkbox" @checked={{this.badge.enable_watch_type_minimum}} />
              {{t "limit to %{types} used at least" types=this.watchlist_type_plural key="watch_type_minimum"}}
            </label>
          </div>
        </div>
        <div class={{if this.in_list "col-sm-1" "col-sm-2"}}>
          <Input @value={{this.badge.watch_type_minimum}} class="form-control" placeholder="#" />
        </div>
        <div class='col-sm-3'>
          <p class='form-control-static'>{{t "times per %{unit_type}" unit_type=this.unit_type key="from_the_type_list"}}</p>
        </div>
      </div>
      <div class='form-group'>
        <div class='col-sm-3 col-sm-offset-2'>
          <div class="checkbox big_checkbox">
            <label>
              <Input type="checkbox" @checked={{this.badge.enable_watch_total}} />
              {{t "require a total every %{unit_type} of" unit_type=this.unit_type key="watch_total"}}
            </label>
          </div>
        </div>
        <div class={{if this.in_list "col-sm-1" "col-sm-2"}}>
          <Input @value={{this.badge.watch_total}} class="form-control" placeholder="#" />
        </div>
        <div class='col-sm-3'>
          <p class='form-control-static'>{{t "of any %{types} from the list" types=this.watchlist_type_plural key="type_from_the_list"}}</p>
        </div>
      </div>
      <div class='form-group'>
        <div class='col-sm-3 col-sm-offset-2'>
          <div class="checkbox big_checkbox">
            <label>
              <Input type="checkbox" @checked={{this.badge.enable_watch_type_count}} />
              {{t "require different %{types}, at least" types=this.watchlist_type_plural key="watch_type_count"}}
            </label>
          </div>
        </div>
        <div class={{if this.in_list "col-sm-1" "col-sm-2"}}>
          <Input @value={{this.badge.watch_type_count}} class="form-control" placeholder="#" />
        </div>
        <div class='col-sm-3'>
          <p class='form-control-static'>
            {{t "different %{types}" types=this.watchlist_type_plural key="different_types"}}
            {{t "per %{unit_type}" unit_type=this.unit_type key="per_unit_type"}}
          </p>
        </div>
      </div>
      {{#if this.in_list}}
        <div class='form-group'>
          <div class='col-sm-3 col-sm-offset-2'>
            <div class="checkbox big_checkbox">
              <label>
                <Input type="checkbox" @checked={{this.badge.enable_watch_type_interval}} />
                {{t "also require different %{types}, at least" types=this.watchlist_type_plural key="watch_type_interval_count"}}
              </label>
            </div>
          </div>
          <div class='col-sm-1'>
            <Input @value={{this.badge.watch_type_interval_count}} class="form-control" placeholder="#" />
          </div>
          <div class='col-sm-2'>
            <p class='form-control-static'>{{t "different %{types} used" types=this.watchlist_type_plural key="different_types_used"}}</p>
          </div>
          <div class='col-sm-2'>
            {{bound-select select_class="form-control" content=this.unit_type_list selection=this.badge.watch_type_interval action=(action (mut this.badge.watch_type_interval)) }}
          </div>
        </div>
      {{/if}}
    {{else if this.badge.instance_count}}
      <div class="form-group">
        <div class='col-sm-3 col-sm-offset-2'>
          <p class='form-control-static'>
            {{#if this.in_list}}
              {{t "To earn this badge, the user must have at least" key="to_earn_must_have_at_least"}}
            {{else}}
              {{t "The user should daily have at least" key="user_should_daily_have_at_least"}}
            {{/if}}
          </p>
        </div>
        <div class={{if this.in_list "col-sm-1" "col-sm-2"}}>
          <Input @value={{this.badge.instance_count}} class="form-control" placeholder="#" />
        </div>
        <div class={{if this.in_list "col-sm-3" "col-sm-4"}}>
          {{bound-select select_class="form-control" content=this.instance_metric_list selection=this.badge.instance_metric action=(action (mut this.badge.instance_metric)) }}
        </div>
        {{#if this.in_list}}
          <div class='col-sm-2'>
            {{bound-select select_class="form-control" content=this.unit_type_list selection=this.badge.interval action=(action (mut this.badge.interval)) }}
          </div>
        {{/if}}
      </div>
    {{/if}}
    {{#if this.badge.interval}}
      {{#if this.in_list}}
        <div class="form-group">
          <div class="col-sm-3 col-sm-offset-2">
            <p class='form-control-static'>{{t "The user must meet the criteria" key="must_meet_criteria"}}</p>
          </div>
          <div class='col-sm-3'>
            {{bound-select select_class="form-control" content=this.criteria_type_list selection=this.badge.criteria_type action=(action (mut this.badge.criteria_type)) }}
          </div>
          {{#if this.badge.for_consecutive_units}}
            <div class='col-sm-1'>
              <Input @value={{this.badge.consecutive_units}} class="form-control" placeholder="#" />
            </div>
            <div class='col-sm-2'>
              <p class='form-control-static'>{{this.unit_type_plural}}</p>
            </div>
          {{else if this.badge.for_matching_units}}
            <div class='col-sm-1'>
              <Input @value={{this.badge.matching_units}} class="form-control" placeholder="#" />
            </div>
            <div class='col-sm-2'>
              <p class='form-control-static'>{{this.unit_type_plural}}</p>
            </div>
          {{else if this.badge.for_matching_instances}}
            <div class='col-sm-1'>
              <Input @value={{this.badge.matching_instances}} class="form-control" placeholder="#" />
            </div>
            <div class='col-sm-2'>
              <p class='form-control-static'>{{this.event_type_plural}}</p>
            </div>
          {{/if}}
        </div>
      {{/if}}
    {{/if}}
  {{/if}}
{{else if this.simple_badge}}
  <div class='form-group'>
    {{#if this.simple_word_badge}}
      <label for='string_list' class={{if this.in_list "col-sm-2 col-sm-offset-2" "col-sm-4 col-sm-offset-2"}} style='font-weight: normal;'>
        <p class='form-control-static'>{{t "list of words:" key="list_of_words"}}</p>
      </label>
      <div class='col-sm-5'>
          <Input @value={{this.badge.string_list}} class="form-control" placeholder="list, of, words" />
      </div>
    {{/if}}
    <div class='col-sm-10 col-sm-offset-2'>
      <p class='form-control-static'>
        {{#if this.simple_word_badge}}
          {{t "must use the words at least" key="use_words_at_least"}}
        {{else if this.simple_button_badge}}
          {{t "must hit at least" key="must_hit_at_least"}}
        {{else if this.simple_modeling_badge}}
          {{t "must have at least" key="must_have_at_least"}}
        {{else}}
          {{t "Unrecognized badge type" key="unrecognized_badge_type"}}
        {{/if}}
        <span style='display: inline-block; width: 50px; margin: 0 5px;'>
          {{#if this.simple_word_badge}}
            <Input @value={{this.badge.watch_total}} class="form-control" placeholder="#" />
          {{else}}
            <Input @value={{this.badge.instance_count}} class="form-control" placeholder="#" />
          {{/if}}
        </span>
        {{#if this.simple_word_badge}}
          {{t "times" key="times"}}
        {{else if this.simple_button_badge}}
          {{t "buttons" key="buttons"}}
        {{else if this.simple_modeling_badge}}
          {{t "modeling events" key="modeling_events"}}
        {{else}}
          {{t "events" key="events"}}
        {{/if}}
        {{#if this.in_list}}
          {{t "for" key="for_lower"}}
          <span style='display: inline-block; width: 50px; margin: 0 5px;'><Input @value={{this.badge.consecutive_units}} class="form-control" placeholder="#" /></span>
          {{this.simple_badge_unit}} {{t "in a row" key="in_a_row"}}
        {{else}}
          {{t "each day" key="each_day"}}
        {{/if}}
      </p>
    </div>
  </div>
  <!--
    WORDS:
      words to watch for ______
      must use the word(s) at least _____ times for _____ days/weeks in a row
    BUTTONS:
      must hit at least _____ buttons for ____ days/weeks in a row
    MODELINGS:
      must have at least _____ modeling events for _____ days/weeks in a row
  -->
{{/if}}
