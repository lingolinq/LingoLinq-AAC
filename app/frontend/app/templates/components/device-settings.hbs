{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="la-devices-modal-wrap">
    <div class="la-modal-header">
      <div class="la-modal-header-icon la-modal-header-icon--devices" aria-hidden="true">
        <svg class="md-extras-card__svg-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2" stroke="#2A9D8F"/><line x1="8" y1="21" x2="16" y2="21" stroke="#46505F"/><line x1="12" y1="17" x2="12" y2="21" stroke="#46505F"/></svg>
      </div>
      <h3 class="la-modal-header-label">{{t "My Devices" key="my_devices"}}</h3>
      <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>&times;</button>
    </div>
    <div class="la-devices-modal-body">
      {{#if this.model.devices}}
        <ul class="la-devices-list">
          {{#each this.model.devices as |device|}}
            <li class="la-devices-item {{if device.current_device 'la-devices-item--current'}}">
              <div class="la-devices-item__icon-wrap {{if device.mobile 'la-devices-item__icon-wrap--mobile' 'la-devices-item__icon-wrap--web'}}" aria-hidden="true">
                {{#if device.mobile}}
                  <svg class="md-extras-card__svg-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2" stroke="#4C86D8"/><line x1="12" y1="18" x2="12.01" y2="18" stroke="#46505F" stroke-width="2"/></svg>
                {{else}}
                  <svg class="md-extras-card__svg-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" stroke="#2A9D8F"/><line x1="2" y1="12" x2="22" y2="12" stroke="#46505F"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" stroke="#46505F"/></svg>
                {{/if}}
              </div>
              <div class="la-devices-item__info">
                {{#if device.renaming}}
                  <div class="la-devices-item__rename">
                    {{focus-input type="text" value=device.new_name action="update_device" class="la-devices-rename-input"}}
                    <button {{action "update_device"}} class="la-btn la-btn--primary la-btn--sm">{{t "Save" key="save"}}</button>
                  </div>
                {{else}}
                  {{#if (persistence-online)}}
                    <div class="la-devices-item__name" {{action "rename_device" device.id}}>
                      {{device.name}}
                      <svg class="la-devices-item__edit-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9" stroke="#46505F"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" stroke="#7693B9"/></svg>
                    </div>
                  {{else}}
                    <div class="la-devices-item__name">{{device.name}}</div>
                  {{/if}}
                {{/if}}
                <div class="la-devices-item__meta">
                  {{t "last used" key="last_used"}} {{date device.last_used}}
                </div>
                <div class="la-devices-item__meta">
                  {{device.ip_address}}
                </div>
              </div>
              <div class="la-devices-item__actions">
                {{#if this.model.permissions.edit}}
                  {{#unless device.current_device}}
                    {{#if (persistence-online)}}
                      <button type="button" class="la-devices-remove-btn" {{action "remove_device" device.id}} aria-label={{t "Remove device" key="remove_device"}}>
                        <svg class="md-extras-card__svg-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#374151" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                      </button>
                    {{/if}}
                  {{/unless}}
                {{/if}}
              </div>
            </li>
          {{/each}}
        </ul>
      {{else}}
        <div class="la-devices-empty">
          <svg class="md-extras-card__svg-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2" stroke="#2A9D8F"/><line x1="8" y1="21" x2="16" y2="21" stroke="#46505F"/><line x1="12" y1="17" x2="12" y2="21" stroke="#46505F"/></svg>
          <p>{{t "None found" key="none_found"}}</p>
        </div>
      {{/if}}
    </div>
    <div class="la-devices-modal-footer">
      <button type="button" class="la-btn la-btn--ghost" {{action "close"}}>{{t "Close" key="close"}}</button>
    </div>
  </div>
{{/modal-dialog}}
