{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="la-confirm-edit-wrap">
  <div class="modal-header md-modal-header">
    <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h3>{{t "Edit this Board" key="edit_this_board"}}</h3>
  </div>
  <div class="modal-body md-modal-body">
    <div class="la-confirm-edit__notice">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <p>
        {{#if this.model.definitely_in_use}}
          {{t "Other people are currently using this board, and making changes directly to the board will affect their communication sets. Do you want to make a copy of this board instead?" key="in_use_make_copy_instead"}}
        {{else}}
          {{t "Other people may be using this board, and making changes could affect their communication sets. Do you want to make a copy of this board instead?" key="maybe_in_use_make_copy_instead"}}
        {{/if}}
      </p>
    </div>
  </div>
  <div class="modal-footer md-modal-footer">
    <button type="button" class="la-confirm-edit__btn la-confirm-edit__btn--secondary" {{action "close"}}>{{t "Cancel" key="cancel"}}</button>
    <button type="button" class="la-confirm-edit__btn la-confirm-edit__btn--default" {{action "editBoard"}}>{{t "Edit this Board" key="edit_this_board"}}</button>
    <button type="button" class="la-confirm-edit__btn la-confirm-edit__btn--primary" {{action "tweakBoard"}}>{{t "Make a Copy" key="make_a_copy"}}</button>
  </div>
  </div>
{{/modal-dialog}}
