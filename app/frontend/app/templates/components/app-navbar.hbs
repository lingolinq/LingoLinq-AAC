<div class="app-navbar__inner">
  {{#if (has-block)}}
    {{yield}}
  {{else if this.isAuthenticated}}
    {{!-- Single baseline: reusable authenticated inner (index + modern-dashboard). Modern Dashboard link only on authenticated view (index). --}}
    <AppNavbarAuthenticatedInner @onSupport={{this.onSupport}} @showModernDashboardLink={{this.showModernDashboardLink}} />
  {{else}}
    {{!-- Unauthenticated: brand (logo + app name) + landing-alt style (Features, Pricing, About, Try Free). Reuses LaMobileDrawer for collapse. --}}
    {{#unless this.appState.installed_app}}
      {{#unless this.appState.embedded}}
        {{#unless this.appState.no_linky}}
          <span class="app-navbar__nav-header">
            <h1 class="app-navbar__brand">
              <span class="nav-header__brand">
                <LinkTo @route="index" class="nav-header__logo-link">
                  <span class="nav-header__logo">
                    <img src={{if this.appState.domain_settings.logo_url this.appState.domain_settings.logo_url (path "images/logo-big-blue-gold.png")}} alt="LingoLinq">
                  </span>
                </LinkTo>
                <LinkTo @route="index" class="nav-header__app-name-link">
                  <span class="nav-header__app-name"><span class="nav-header__app-name-primary">{{t "Lingo" key="app_name_lingo"}}</span><span class="nav-header__app-name-accent">{{t "Linq" key="app_name_linq"}}</span></span>
                </LinkTo>
              </span>
            </h1>
          </span>
          <div class="la-topbar-nav header-unauth-nav" role="menubar" aria-label={{t "Page sections" key="fsa_page_sections"}}>
            <LinkTo @route="features" class="la-topbar-link" role="menuitem">{{t "Features" key="fsa_nav_features"}}</LinkTo>
            <LinkTo @route="pricing" class="la-topbar-link" role="menuitem">{{t "Pricing" key="fsa_nav_pricing"}}</LinkTo>
            <LinkTo @route="about" class="la-topbar-link" role="menuitem">{{t "About" key="fsa_nav_about"}}</LinkTo>
          </div>
          <div class="la-topbar-right header-unauth-right">
            <LinkTo @route="register" class="la-topbar-cta">{{t "Try Free" key="fsa_try_free"}}</LinkTo>
            <button class="la-topbar-hamburger" type="button" aria-label={{t "Open menu" key="fsa_open_menu"}} aria-expanded={{this.isLandingDrawerOpen}} {{action "toggleLandingDrawer"}}>
              <span class="la-topbar-hamburger__bar"></span>
              <span class="la-topbar-hamburger__bar"></span>
              <span class="la-topbar-hamburger__bar"></span>
            </button>
          </div>
          <LaMobileDrawer @isOpen={{this.isLandingDrawerOpen}} @onClose={{action "closeLandingDrawer"}}>
            <LinkTo @route="features" class="la-mobile-drawer__link" {{action "closeLandingDrawer"}}>{{t "Features" key="fsa_nav_features"}}</LinkTo>
            <LinkTo @route="pricing" class="la-mobile-drawer__link" {{action "closeLandingDrawer"}}>{{t "Pricing" key="fsa_nav_pricing"}}</LinkTo>
            <LinkTo @route="about" class="la-mobile-drawer__link" {{action "closeLandingDrawer"}}>{{t "About" key="fsa_nav_about"}}</LinkTo>
            <div class="la-mobile-drawer__divider"></div>
            <LinkTo @route="login" class="la-mobile-drawer__link" {{action "closeLandingDrawer"}}>{{t "Sign In" key="login"}}</LinkTo>
            <LinkTo @route="register" class="la-mobile-drawer__link" {{action "closeLandingDrawer"}}>{{t "Register" key="register"}}</LinkTo>
            <LinkTo @route="register" class="la-mobile-drawer__cta" {{action "closeLandingDrawer"}}>{{t "Try Free" key="fsa_try_free"}} →</LinkTo>
          </LaMobileDrawer>
        {{/unless}}
      {{/unless}}
    {{/unless}}
  {{/if}}
</div>
