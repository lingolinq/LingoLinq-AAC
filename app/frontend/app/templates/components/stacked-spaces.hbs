<div class="ll-shell">
  <header class="ll-topbar ll-topbar--stacked">
    <div class="ll-topbar__inner">
      <div class="ll-title">{{t "Home Page" key="home_page"}}</div>

      <div class="ll-tabs" role="tablist" aria-label={{t "Primary pages" key="primary_pages"}}>
        <button type="button" class="ll-tab {{if (is-equal this.tab "home") "is-active"}}" {{action "goTab" "home"}}>
          {{t "Home" key="home"}}
        </button>
        <button type="button" class="ll-tab {{if (is-equal this.tab "boards") "is-active"}}" {{action "goTab" "boards"}}>
          {{t "Boards" key="boards"}}
        </button>
        <button type="button" class="ll-tab {{if (is-equal this.tab "speak") "is-active"}}" {{action "goTab" "speak"}}>
          {{t "Supervisors" key="supervisors"}}
        </button>
        <button type="button" class="ll-tab {{if (is-equal this.tab "reports") "is-active"}}" {{action "goTab" "reports"}}>
          {{t "Reports" key="reports"}}
        </button>
      </div>

      <div class="ll-actions">
        <button type="button" class="ll-iconBtn" {{action "openSearch"}} aria-label={{t "Search" key="search"}}>
          &#8981;
        </button>
        <button type="button" class="ll-upgrade ll-upgrade--topbar" {{action "onUpgrade"}}>{{t "Upgrade" key="upgrade"}}</button>
      </div>
    </div>
  </header>

  <div class="ll-stack-bg ll-stack-bg--stacked">
  <main class="ll-main ll-stack">
    <a href="#" class="ll-getting-started ll-getting-started--stacked" {{action "gettingStarted"}}>
      <img src={{path "images/pastel-getting-started.svg"}} alt="" class="ll-getting-started__image" aria-hidden="true">
      <div class="ll-getting-started__body">
        <div class="ll-getting-started__header">
          <span class="ll-getting-started__title">{{t "Getting Started" key="getting_started"}}</span>
          <span class="ll-getting-started__hint">{{t "Finish setting up your account" key="on_your_way"}}</span>
        </div>
        <div class="ll-getting-started__progress" role="progressbar" aria-valuenow={{this.getting_started_percent}} aria-valuemin="0" aria-valuemax="100">
          <div class="ll-getting-started__progress-fill" style={{this.getting_started_percent_style}}></div>
          <span class="sr-only">{{t "%{pct}% Complete" key="percent_complete" pct=this.getting_started_percent}}</span>
        </div>
        <span class="ll-getting-started__stage">{{t "Step %{current} of %{total}" key="step_current_of_total" current=this.getting_started_step total=5}}</span>
        <div class="ll-getting-started__divider" aria-hidden="true"></div>
      </div>
      <span class="ll-getting-started__btn">{{t "Help me Setup my Account" key="help_me_setup_account"}}</span>
    </a>
    <div class="ll-group ll-group--actions">
      <div class="ll-sectionHead">
        <div class="ll-sectionTitle">{{t "Actions" key="actions"}}</div>
        <button type="button" class="ll-link ll-seeAll" {{action "go" "speak"}}>{{t "See all" key="see_all"}}</button>
      </div>
      <section class="ll-hero">
        <div class="ll-heroLeft">
          <div class="ll-heroIcon ll-bento-action-card__icon ll-bento-action-card__icon--speak" aria-hidden="true">
            <img src={{path "images/pastel-sound.png"}} class="ll-heroIcon__img" alt="" aria-hidden="true">
          </div>
          <div class="ll-heroText">
            <div class="ll-heroTitle">{{t "Speak Mode" key="speak_mode"}}</div>
            <div class="ll-heroSub">{{t "Start communication" key="start_communication"}}</div>
          </div>
        </div>
        <div class="ll-heroActions">
          <div class="ll-pill ll-heroActions-pill">
            {{t "Last Board: Beginner Lessons" key="stacked_spaces_last_board"}}
          </div>
          <button type="button" class="ll-primaryBtn ll-heroActions-btn" {{action "go" "speak"}}>
            {{t "Start Speaking" key="start_speaking"}}
          </button>
        </div>
        <div class="ll-heroBg" aria-hidden="true"></div>
      </section>
      <div class="ll-grid2 ll-groupActionsGrid">
        <button type="button" class="ll-softCard" {{action "go" "modeling"}}>
          <div class="ll-softCard__icon ll-softCard__icon--modeling" aria-hidden="true">
            <img src={{path "images/pastel-lightbulb.png"}} class="ll-softCard__img" alt="" aria-hidden="true">
          </div>
          <div class="ll-softCard__body">
            <div class="ll-softTitle">{{t "Modeling Ideas" key="modeling_ideas"}}</div>
            <div class="ll-softSub">{{t "Explore new concepts" key="explore_new_concepts"}}</div>
          </div>
        </button>
        <button type="button" class="ll-softCard" {{action "go" "extras"}}>
          <div class="ll-softCard__icon ll-softCard__icon--extras" aria-hidden="true">
            <img src={{path "images/pastel-extras.png"}} class="ll-softCard__img" alt="" aria-hidden="true">
          </div>
          <div class="ll-softCard__body">
            <div class="ll-softTitle">{{t "Extras" key="extras"}}</div>
            <div class="ll-softSub">{{t "More resources & games" key="more_resources_games"}}</div>
          </div>
        </button>
      </div>
    </div>

    <div class="ll-group ll-group--boards">
      <div class="ll-sectionHead">
        <div class="ll-sectionTitle">{{t "Your Boards" key="your_boards"}}</div>
        <button type="button" class="ll-link ll-seeAll" {{action "go" "boards"}}>{{t "See all" key="see_all"}}</button>
      </div>
      <div class="ll-carousel ll-carousel--even" role="list">
        <button type="button" class="ll-boardCard" role="listitem" {{action "go" "boards"}}>
          <div class="ll-boardName">{{t "Make Small Talk" key="stacked_spaces_board_small_talk"}}</div>
        </button>
        <button type="button" class="ll-boardCard" role="listitem" {{action "go" "boards"}}>
          <div class="ll-boardName">{{t "Beginner Lessons" key="stacked_spaces_board_beginner"}}</div>
        </button>
        <button type="button" class="ll-boardCard" role="listitem" {{action "go" "boards"}}>
          <div class="ll-boardName">{{t "Conversation Practice" key="stacked_spaces_board_conversation"}}</div>
        </button>
        <button type="button" class="ll-boardCard ll-boardCard--new" role="listitem" {{action "onNewBoard"}}>
          <div class="ll-boardName">{{t "New Board" key="new_board"}}</div>
        </button>
      </div>
    </div>

    <section class="ll-section ll-section--supervisors">
      <div class="ll-supervisorsBox">
        <div class="ll-sectionHead ll-sectionHead--withSupervisor">
          <div class="ll-sectionHeadLeft">
            <div class="ll-sectionTitle">{{t "Supervisors" key="supervisors"}}</div>
            <span class="ll-sectionHeadSeparator" aria-hidden="true"></span>
          </div>
          <div class="ll-sectionHeadSupervisors">
            <button type="button" class="ll-mainSupervisor" {{action "go" "speak"}}>
              <span class="ll-mainSupervisorName">{{t "Sarah Chen" key="stacked_spaces_supervisor_1"}}</span>
            </button>
            <button type="button" class="ll-mainSupervisor" {{action "go" "speak"}}>
              <span class="ll-mainSupervisorName">{{t "James Wilson" key="stacked_spaces_supervisor_2"}}</span>
            </button>
          </div>
          <button type="button" class="ll-link ll-seeAll" {{action "go" "speak"}}>{{t "See all" key="see_all"}}</button>
        </div>
      </div>
    </section>

    <div class="ll-group ll-group--reports">
      <div class="ll-sectionHead">
        <div class="ll-sectionTitle">{{t "Reports" key="reports"}}</div>
        <button type="button" class="ll-link ll-seeAll" {{action "go" "reports"}}>{{t "See all" key="see_all"}}</button>
      </div>
      <div class="ll-grid2">
        <button type="button" class="ll-metricCard" {{action "go" "reports"}}>
          <div class="ll-metricTitle">{{t "Usage" key="usage"}}</div>
          <div class="ll-sparkline ll-sparkline--usage" aria-hidden="true">
            <svg class="ll-sparklineChart" viewBox="0 0 200 60" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
              <defs>
                <linearGradient id="ll-usage-fill" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="rgba(78, 205, 196, 0.35)"/><stop offset="100%" stop-color="rgba(78, 205, 196, 0.02)"/></linearGradient>
              </defs>
              <path fill="url(#ll-usage-fill)" d="M0,45 L25,38 L50,42 L75,28 L100,32 L125,22 L150,26 L175,18 L200,24 L200,60 L0,60 Z"/>
              <path fill="none" stroke="#4ECDC4" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" d="M0,45 L25,38 L50,42 L75,28 L100,32 L125,22 L150,26 L175,18 L200,24"/>
              <circle cx="200" cy="24" r="3.5" fill="#2A9D8F"/>
            </svg>
          </div>
        </button>
        <button type="button" class="ll-metricCard" {{action "go" "reports"}}>
          <div class="ll-metricTitle">{{t "Sessions" key="sessions"}}</div>
          <div class="ll-sparkline ll-sparkline--sessions" aria-hidden="true">
            <svg class="ll-sparklineChart" viewBox="0 0 200 60" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
              <defs>
                <linearGradient id="ll-sessions-fill" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="rgba(255, 107, 71, 0.3)"/><stop offset="100%" stop-color="rgba(255, 107, 71, 0.02)"/></linearGradient>
              </defs>
              <path fill="url(#ll-sessions-fill)" d="M0,50 L0,60 L200,60 L200,50 Z"/>
              <rect x="8" y="35" width="18" height="25" rx="3" fill="#FF6B47" fill-opacity="0.85"/>
              <rect x="38" y="28" width="18" height="32" rx="3" fill="#FF6B47" fill-opacity="0.85"/>
              <rect x="68" y="42" width="18" height="18" rx="3" fill="#FF6B47" fill-opacity="0.85"/>
              <rect x="98" y="22" width="18" height="38" rx="3" fill="#FF6B47" fill-opacity="0.85"/>
              <rect x="128" y="32" width="18" height="28" rx="3" fill="#FF6B47" fill-opacity="0.85"/>
              <rect x="158" y="18" width="18" height="42" rx="3" fill="#FF6B47" fill-opacity="0.9"/>
            </svg>
          </div>
        </button>
      </div>
    </div>
  </main>
  </div>

  {{!-- Profile Sheet (Users/Settings) --}}
  {{#if this.isProfileOpen}}
    <div class="ll-overlay" role="presentation" {{action "closeProfile"}}></div>
    <section class="ll-sheet" role="dialog" aria-label={{t "Account" key="account"}}>
      <div class="ll-sheetHandle" aria-hidden="true"></div>

      <button type="button" class="ll-sheetRow" {{action "goAndCloseProfile" "users"}}>
        {{t "Users" key="users"}}
      </button>
      <button type="button" class="ll-sheetRow" {{action "goAndCloseProfile" "settings"}}>
        {{t "Settings" key="settings"}}
      </button>
      <button type="button" class="ll-sheetRow ll-sheetRow--danger" {{action "onUpgrade"}}>
        {{t "Purchase / Upgrade" key="purchase_upgrade"}}
      </button>
    </section>
  {{/if}}

  {{!-- Search Overlay --}}
  {{#if this.isSearchOpen}}
    <section class="ll-searchOverlay" role="dialog" aria-label={{t "Search" key="search"}}>
      <div class="ll-searchTop">
        <input class="ll-searchInput" placeholder={{t "Search boards, reports, users…" key="stacked_spaces_search_placeholder"}} autofocus
          onkeydown={{action "onSearchKeydown"}} />
        <button type="button" class="ll-ghost" {{action "closeSearch"}}>{{t "Close" key="close"}}</button>
      </div>
      <div class="ll-searchBody">
        <div class="ll-searchGroup">
          <div class="ll-searchGroupTitle">{{t "Quick actions" key="quick_actions"}}</div>
          <button type="button" class="ll-searchRow" {{action "goAndCloseSearch" "speak"}}>{{t "Start Speak" key="start_speak"}}</button>
          <button type="button" class="ll-searchRow" {{action "goAndCloseSearch" "boards"}}>{{t "Open Boards" key="open_boards"}}</button>
          <button type="button" class="ll-searchRow" {{action "goAndCloseSearch" "reports"}}>{{t "View Reports" key="view_reports"}}</button>
        </div>
      </div>
    </section>
  {{/if}}
</div>
