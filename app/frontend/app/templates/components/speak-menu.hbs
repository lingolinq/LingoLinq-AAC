{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="modal-body advanced_selection modal_targets md-speak-menu" id="speak_menu">
    {{!-- SVG gradient for two-toned icons --}}
    <svg width="0" height="0" style="position:absolute">
      <defs>
        <linearGradient id="md-speak-icon-grad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#2A9D8F"/>
          <stop offset="100%" stop-color="#4C86D8"/>
        </linearGradient>
      </defs>
    </svg>

    {{!-- Header with close button --}}
    <div class="md-speak-menu__header">
      <span class="md-speak-menu__title">{{t "Speak Options" key="speak_options"}}</span>
      <button type="button" class="md-speak-menu__close pass_to_btn_list" {{action 'close'}}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    {{#if this.app_state.feature_flags.new_speak_menu}}
      {{#button-listener buttonEvent=(action "button_event")}}
        {{#if this.repeat_menu}}
          {{!-- Repeat / Volume group --}}
          <div class="md-speak-menu__section">
            <div class="md-speak-menu__section-label">{{t "Volume & Repeat" key="volume_repeat"}}</div>
            <div class="md-speak-menu__row md-speak-menu__row--3">
              <div class='md-speak-menu__btn' id='menu_repeat_quieter'>
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/></svg>
                <span class="md-speak-menu__btn-label">{{t "Quiet" key="quiet"}}</span>
              </div>
              <div class='md-speak-menu__btn radial radial_on_click' id='menu_repeat_button'>
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                <span class="md-speak-menu__btn-label">{{t "Back" key="back"}}</span>
              </div>
              <div class='md-speak-menu__btn' id='menu_repeat_louder'>
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
                <span class="md-speak-menu__btn-label">{{t "Loud" key="loud"}}</span>
              </div>
            </div>
          </div>
          <div class="md-speak-menu__section">
            <div class="md-speak-menu__section-label">{{t "More Options" key="more_options"}}</div>
            <div class="md-speak-menu__row md-speak-menu__row--3">
              <div class='md-speak-menu__btn' id='menu_repeat_text'>
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                <span class="md-speak-menu__btn-label">{{t "Button" key="Button"}}</span>
              </div>
              <div class='md-speak-menu__btn' id='menu_repeat_flip'>
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
                <span class="md-speak-menu__btn-label">{{t "Flip Text" key="flip_text"}}</span>
              </div>
              {{#if this.app_state.referenced_user.preferences.hide_gif}}
                <div class='md-speak-menu__btn' id='menu_share_button'>
                  <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                  <span class="md-speak-menu__btn-label">{{t "Share" key="share"}}</span>
                </div>
              {{else}}
                <div class='md-speak-menu__btn' id='menu_repeat_gif'>
                  <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                  <span class="md-speak-menu__btn-label">{{t "GIF" key="gif"}}</span>
                </div>
              {{/if}}
            </div>
          </div>

        {{else if this.punctuation_menu}}
          {{!-- Punctuation group --}}
          <div class="md-speak-menu__section">
            <div class="md-speak-menu__section-label">{{t "Punctuation" key="punctuation"}}</div>
            <div class="md-speak-menu__row md-speak-menu__row--3">
              <div class='md-speak-menu__btn' id='menu_contraction_button'>
                <span class="md-speak-menu__punctuation md-speak-menu__punctuation--sm">{{this.contraction.label}}</span>
              </div>
              <div class='md-speak-menu__btn' id='menu_quote_button'>
                <span class="md-speak-menu__punctuation">"</span>
              </div>
              <div class='md-speak-menu__btn' id='menu_colon_button'>
                <span class="md-speak-menu__punctuation">:</span>
              </div>
              <div class='md-speak-menu__btn' id='menu_exclamation_button'>
                <span class="md-speak-menu__punctuation">!</span>
              </div>
              <div class='md-speak-menu__btn' id='menu_comma_button'>
                <span class="md-speak-menu__punctuation">,</span>
              </div>
              <div class='md-speak-menu__btn' id='menu_question_button'>
                <span class="md-speak-menu__punctuation">?</span>
              </div>
            </div>
          </div>

        {{else}}
          {{!-- Main actions group --}}
          <div class="md-speak-menu__section">
            <div class="md-speak-menu__section-label">{{t "Actions" key="actions_lower"}}</div>
            <div class="md-speak-menu__row md-speak-menu__row--3">
              <div class='md-speak-menu__btn' id='menu_share_button'>
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                <span class="md-speak-menu__btn-label">{{t "Share" key='share'}}</span>
              </div>
              <div class='md-speak-menu__btn radial radial_on_click' id='menu_repeat_button'>
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
                <span class="md-speak-menu__btn-label">{{t "Repeats" key='repeats'}}</span>
              </div>
              <div class='md-speak-menu__btn' id='menu_repair_button'>
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                <span class="md-speak-menu__btn-label">{{t "Repairs" key='repairs'}}</span>
              </div>
            </div>
          </div>

          <div class="md-speak-menu__section">
            <div class="md-speak-menu__section-label">{{t "Tools" key="tools"}}</div>
            <div class="md-speak-menu__row md-speak-menu__row--3">
              <div class='md-speak-menu__btn' id='menu_inbox_button'>
                {{#if this.app_state.referenced_user.unread_alerts}}
                  <span class='md-speak-menu__badge'>{{this.app_state.referenced_user.unread_alerts}}</span>
                {{else if this.app_state.referenced_user.request_alert}}
                  <span class='md-speak-menu__badge'>*</span>
                {{/if}}
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
                <span class="md-speak-menu__btn-label">{{t "Alerts" key='alerts'}}</span>
              </div>
              <div class='md-speak-menu__btn' id='menu_phrases_button'>
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><line x1="8" y1="8" x2="16" y2="8"/><line x1="8" y1="12" x2="13" y2="12"/></svg>
                <span class="md-speak-menu__btn-label">{{t "Phrases" key='phrases'}}</span>
              </div>
              <div class='md-speak-menu__btn' id='menu_hold_thought_button'>
                <svg width="26" height="26" viewBox="0 0 24 24" fill="url(#md-speak-icon-grad)" stroke="none"><rect x="7" y="4" width="3.5" height="16" rx="1"/><rect x="13.5" y="4" width="3.5" height="16" rx="1"/></svg>
                <span class="md-speak-menu__btn-label">{{t "Hold Thought" key='hold_thought'}}</span>
              </div>
            </div>
          </div>
        {{/if}}
      {{/button-listener}}

      {{!-- Punctuation sidebar --}}
      <div class="md-speak-menu__section md-speak-menu__section--punctuation">
        <div class="md-speak-menu__section-label">{{t "Punctuation" key="punctuation"}}</div>
        {{#button-listener buttonEvent=(action "button_event")}}
          <div class="md-speak-menu__row md-speak-menu__row--5">
            <div class='md-speak-menu__btn' id='menu_period_button'>
              <span class="md-speak-menu__punctuation">.</span>
            </div>
            <div class='md-speak-menu__btn' id='menu_comma_button'>
              <span class="md-speak-menu__punctuation">,</span>
            </div>
            <div class='md-speak-menu__btn' id='menu_question_button'>
              <span class="md-speak-menu__punctuation">?</span>
            </div>
            <div class='md-speak-menu__btn' id='menu_exclamation_button'>
              <span class="md-speak-menu__punctuation">!</span>
            </div>
            <div class='md-speak-menu__btn' id='menu_punctuation_button'>
              {{#if this.punctuation_menu}}
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                <span class="md-speak-menu__btn-label">{{t "Back" key='back'}}</span>
              {{else}}
                <span class="md-speak-menu__punctuation md-speak-menu__punctuation--sm">...</span>
                <span class="md-speak-menu__btn-label">{{t "More" key='more'}}</span>
              {{/if}}
            </div>
          </div>
        {{/button-listener}}
      </div>

    {{else}}
      {{!-- Legacy menu --}}
      <ul class="md-speak-menu__legacy-list">
        <li class="md-speak-menu__legacy-context">
          {{this.working_vocalization_text}}
        </li>
        <li>
          <a href="#" {{action "selectButton" "remember"}}>{{t "Remember this" key='remember_this'}}</a>
        </li>
        {{#if this.sharing_allowed}}
          <li>
            <a href="#" {{action "selectButton" "share"}}>{{t "Share this" key='share_this'}}</a>
          </li>
        {{/if}}
        <li>
          <a href="#" {{action "selectButton" "sayLouder"}}>{{t "Say this Louder" key='say_this_louder'}}</a>
        </li>
      </ul>
    {{/if}}

    {{!-- Bottom actions --}}
    <div class='md-speak-menu__bottom'>
      {{#if this.app_state.feature_flags.new_speak_menu}}
        {{#if this.working_vocalization_text}}
          <button type="button" class="md-speak-menu__bottom-btn md-speak-menu__bottom-btn--remember" {{action "selectButton" "remember"}}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
            {{t "Remember this" key="remember_this"}}
          </button>
        {{/if}}
      {{/if}}
      {{#if this.app_state.reply_note}}
        <button type="button" class="md-speak-menu__bottom-btn md-speak-menu__bottom-btn--action" {{action 'reply_note'}}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          {{t "Send Reply" key='send_rely'}}
          {{#if this.app_state.reply_note.author}}
            {{t "to" key='to'}} {{this.app_state.reply_note.author.name}}
          {{/if}}
        </button>
      {{else if this.app_state.insertion}}
        <button type="button" class="md-speak-menu__bottom-btn md-speak-menu__bottom-btn--action" {{action 'end_insertion'}}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          {{t "Done Inserting Text" key='done_inserting_text'}}
        </button>
      {{else if this.app_state.flipped}}
        <button type="button" class="md-speak-menu__bottom-btn md-speak-menu__bottom-btn--action" {{action 'flip_text'}}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
          {{t "Un-Flip Text" key='unflip_text'}}
        </button>
      {{/if}}
      {{#each this.rememberedUtterances as |utterance|}}
        <button type="button" class="md-speak-menu__bottom-btn md-speak-menu__bottom-btn--remembered" {{action "selectButton" utterance}}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          {{#if utterance.stash}}
            {{t "Resume: " key="resume_colon"}}
          {{else}}
            {{t "Say: " key="say_colon"}}
          {{/if}}
          <span class="md-speak-menu__remembered-text">"{{utterance.sentence}}"</span>
        </button>
      {{/each}}
    </div>
  </div>
{{/modal-dialog}}
