{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="md-modal-header">
    <button type="button" class="close" {{action "close"}}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h3 class="md-modal-title">{{t "Recolor Board?" key="recolor_board_title"}}</h3>
  </div>
  <div class="md-modal-body">
    <div class="md-modal-icon-row">
      <div class="md-modal-icon-circle" style="background: rgba(42, 157, 143, 0.12); color: #2a9d8f;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
      </div>
    </div>
    <p class="md-modal-message">
      {{t "This will look up each button's word type and reassign colors based on the current color scheme. All existing button colors will be overwritten." key="recolor_board_message"}}
    </p>
    <p class="md-modal-message" style="font-size: 13px; color: #8896a7;">
      {{t "Folder buttons will not be changed. You can undo this action before saving." key="recolor_board_hint"}}
    </p>
  </div>
  <div class="md-modal-footer">
    <button class="md-modal-btn md-modal-btn--cancel" {{action "close"}}>{{t "Cancel" key="cancel"}}</button>
    <button class="md-modal-btn md-modal-btn--primary" {{action "confirm"}}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
      {{t "Recolor Board" key="recolor_board"}}
    </button>
  </div>
{{/modal-dialog}}
