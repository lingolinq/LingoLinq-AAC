{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing") uncloseable="true"}}
  <div class="modal-header md-modal-header">
    <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h3>{{t "Premium Membership Required" key="premium_required"}}</h3>
  </div>
  <div class="modal-body md-modal-body">
    {{#if this.show_reason}}
      {{this.model.reason}} -- {{this.model.action}} -- {{this.model.user_name}}
    {{/if}}
    <span class="glyphicon glyphicon-info-sign" style="float: left; margin-right: 10px; font-size: 30px;"></span>
    {{#if this.model.remind_to_upgrade}}
      <p>
        {{#if this.model.limited_supervisor}}
          {{#if this.appState.sessionUser.modeling_only}}
            {{t "This account is limited to modeling-only, and so will not have full access to this feature except when working with premium communicators." key="limited_modeling_only"}}
          {{else}}
            {{t "This account is not currently tied to any premium communicator accounts, and as a result will currently have limited access to this feature." key="limited_supervisor_limited_accesss"}}
          {{/if}}
          {{t "If you need personal access to this feature, please" key="please_subscribe_a1"}}
          {{#if this.appState.sessionUser.modeling_only}}
            <LinkTo @route="user.subscription" @model={{this.model.user_name}}>{{t "purchase a premium supporter account" key="please_subscribe_a2"}}</LinkTo>
          {{else}}
            <LinkTo @route="user.subscription" @model={{this.model.user_name}}>{{t "purchase a premium communicator account" key="please_subscribe_2"}}</LinkTo>
          {{/if}}
          {{t "to support this good cause." key="please_subscribe_3"}}
        {{else}}
          {{t "This user's premium access has ended. %app_name% is a powerful service that helps many users communicate. Please " key="please_subscribe_1"}}
          <LinkTo @route="user.subscription" @model={{this.model.user_name}}>{{t "purchase a premium communicator account" key="please_subscribe_2"}}</LinkTo>
          {{t "to support this good cause." key="please_subscribe_3"}}
        {{/if}}
      </p>
      {{#if this.model.user.limited_paid_supervisor}}
        <p>
          {{t "Are you a professional using %app_name% to do evals for your clients? We want you to be able to show your clients everything %app_name% can do! Please consider purchasing a discounted eval account to show off all of LingoLinq's features." key="update_to_eval_if_needed"}}
        </p>
      {{else}}
        <p>
          {{t "Therapists, parents and other supporting users can also sign up for a free modeling-only account used for supporting premium communicators. If you need help with your account, please don't hesitate to reach out to us." key="please_subscribe_4"}}
        </p>
      {{/if}}
    {{else}}
      <p>
        {{t "%app_name% is a powerful, flexible communication tool with lots of great features. Some features, including this one, are only available to users who have a paid communicator account. Please " key="purchase_subscription_1a"}}
        {{#if this.model.user_name}}
          <LinkTo @route="user.subscription" @model={{this.model.user_name}}>{{t "purchase a premium account" key="purchase_subscription_2"}}</LinkTo>
        {{else}}
          {{t "purchase a premium account" key="purchase_subscription_2"}}
        {{/if}}
        {{t "to support this good cause and to unlock this feature." key="purchase_subscription_3"}}
      </p>
      <p>
        {{t "Therapists, parents and other supporting users can also sign up for a free modeling-only account used for supporting communicators." key="purchase_subscription_4"}}
      </p>
    {{/if}}
    <div style="clear: left;"></div>
  </div>
  <div class="modal-footer md-modal-footer">
    {{#if this.model.remind_to_upgrade}}
      <a href="#" class="btn btn-default btn-lg" {{action "close"}}>{{t "Okay" key="okay"}}</a>
    {{else}}
      <a href="#" class="btn btn-default btn-lg" {{action "close"}}>{{t "Close" key="close"}}</a>
    {{/if}}
    <LinkTo @route="user.subscription" @model={{this.model.user_name}} class="btn btn-lg btn-primary">{{t "Update Account Settings" key="update_my_subscription"}}</LinkTo>
  </div>
{{/modal-dialog}}
