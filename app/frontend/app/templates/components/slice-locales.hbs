{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="md-modal-header">
    <button type="button" class="close" {{action "close"}}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h3 class="md-modal-title">{{t "Manage Languages" key="manage_languages"}}</h3>
  </div>
  <div class="md-modal-body" style="text-align: left;">
    <p class="md-modal-message" style="text-align: left; margin-bottom: 20px;">
      {{t "Select the boards you would like modified, and the languages you would like to keep for those boards. If no matching languages are found, the board will not be changed. Note that any unselected languages will be removed from the board." key="slice_languages_instructions"}}
    </p>

    <div class="md-manage-lang-section">
      <label class="md-modal-label">{{t "Boards" key="boards"}}</label>
      {{#if this.hierarchy.loading}}
        <div class="md-manage-lang-placeholder">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          {{t "Loading linked boards..." key="loading_linked_boards"}}
        </div>
      {{else if this.hierarchy.error}}
        <div class="md-swap-alert md-swap-alert--error">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
          {{t "There was an error trying to retrieve linked boards" key="error_getting_linked_boards"}}
        </div>
      {{else if this.hierarchy}}
        <div class="md-manage-lang-boards">
          {{board-hierarchy hierarchy=this.hierarchy selectable=true}}
        </div>
      {{else}}
        <div class="md-manage-lang-placeholder">
          {{t "No linked boards" key="no_linked_boards"}}
        </div>
      {{/if}}
    </div>

    <div class="md-manage-lang-section" style="margin-top: 20px;">
      <label class="md-modal-label">{{t "Languages" key="languages"}}</label>
      <div class="md-manage-lang-list">
        {{#each this.langs as |lang|}}
          <label class="md-manage-lang-item {{if lang.keep 'md-manage-lang-item--active'}}">
            <Input @type="checkbox" @checked={{lang.keep}} class="md-manage-lang-checkbox" />
            <span class="md-manage-lang-name">{{lang.str}}</span>
            <span class="md-manage-lang-code">{{lang.loc}}</span>
          </label>
        {{/each}}
      </div>
    </div>

    {{#if this.status.error}}
      <div class="md-swap-alert md-swap-alert--error" style="margin-top: 16px;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        {{t "Updating Languages Failed" key="updating_languages_failed"}}
      </div>
    {{/if}}
  </div>
  <div class="md-modal-footer">
    <button class="md-modal-btn md-modal-btn--cancel" {{action "close"}}>{{t "Cancel" key="cancel"}}</button>
    <button class="md-modal-btn md-modal-btn--primary" {{action "confirm"}} disabled={{this.status.loading}}>
      {{#if this.status.loading}}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        {{t "Updating..." key="updating_languages"}}
      {{else}}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        {{t "Update Languages" key="update_languages"}}
      {{/if}}
    </button>
  </div>
{{/modal-dialog}}
