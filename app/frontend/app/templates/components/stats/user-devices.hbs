<div class={{this.elem_class}} style={{this.elem_style}}>
  <div style={{this.inner_elem_style}}>
    <table class="table table-hover table-condensed">
      <thead>
        <tr>
          <th>
            {{t "Devices" key="devices"}}
            <div class="text-muted" style="font-size: 0.85em; font-weight: normal; margin-top: 4px;">
              {{t "Click a device to filter the report by that device." key="device_filter_hint"}}
            </div>
          </th>
        </tr>
      </thead>
      <tbody>
        {{#if this.usage_stats.devices}}
          {{#each this.usage_stats.devices as |device|}}
            <tr>
              <td>
                <strong>
                  <a href="#" title={{t "Filter report by this device" key="filter_report_by_device"}} {{action "filter" device}}>
                    {{device.name}}
                  </a>
                </strong><br>
                <span class="text-muted" style="padding-left: 10px;">{{t "%{term} sessions" key="term_session_count" term=device.total_sessions}}</span>
              </td>
            </tr>
          {{/each}}
        {{else}}
          <tr>
            <td>{{t "No data available" key="no_data"}}</td>
          </tr>
        {{/if}}
      </tbody>
    </table>
  </div>
</div>
