<div class={{this.elem_class}} style={{this.elem_style}}>
  <div style={{this.inner_elem_style}}>
    <table class="table table-hover table-condensed">
      <thead>
        <tr>
          <th>
            {{t "IP Addresses" key="ip_addresses"}}
            <div class="text-muted" style="font-size: 14px; font-weight: normal; margin-top: 4px;">
              {{t "Click an IP address to filter the report by that location." key="ip_address_filter_hint"}}
            </div>
          </th>
        </tr>
      </thead>
      <tbody>
        {{#if this.usage_stats.ip_locations}}
          {{#each this.usage_stats.ip_locations as |location|}}
            <tr>
              <td>
                <strong>
                  <a href="#" title={{t "Filter report by this location" key="filter_report_by_location"}} {{action "filter" location}}>
                    {{location.readable_ip_address}}
                  </a>
                </strong><br>
                <span class="text-muted" style="padding-left: 10px;">{{t "%{term} sessions" key="term_session_count" term=location.total_sessions}}</span>
              </td>
            </tr>
          {{/each}}
        {{else}}
          <tr>
            <td>{{t "No data available" key="no_data"}}</td>
          </tr>
        {{/if}}
      </tbody>
    </table>
  </div>
</div>
