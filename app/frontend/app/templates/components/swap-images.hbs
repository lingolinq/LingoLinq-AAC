{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="la-swap-images-wrap">
  <div class="modal-header md-modal-header">
    <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h3>{{t "Swap Board Images" key="swap_board_images"}}</h3>
  </div>
  <div class="modal-body md-modal-body">
    {{#if this.model.confirmation}}
      <p class="la-swap-images-desc">{{t "Would you like to update your home board to use the symbol library you've selected? You can update all the linked boards or pick and choose which to change." key="confirm_swap_images"}}</p>
    {{else}}
      <p class="la-swap-images-desc">{{t "Select the boards you would like modified and an image library to use for image replacements. If no results are found in that library, the image will not be changed." key="swap_instructions"}}</p>
    {{/if}}

    <div class="la-swap-images-section">
      <label class="la-swap-images-label">{{t "Boards" key="boards"}}</label>
      <div class="la-swap-images-boards">
        {{#if this.hierarchy.loading}}
          <span class="la-swap-images-loading">{{t "Loading linked boards..." key="loading_linked_boards"}}</span>
        {{else if this.hierarchy.error}}
          <span class="la-swap-images-error">{{t "There was an error trying to retrieve linked boards" key="error_getting_linked_boards"}}</span>
        {{else if this.hierarchy}}
          {{board-hierarchy hierarchy=this.hierarchy selectable=true}}
        {{else}}
          <span class="la-swap-images-empty">{{t "No linked boards" key="no_linked_boards"}}</span>
        {{/if}}
      </div>
    </div>

    <div class="la-swap-images-section">
      <label class="la-swap-images-label" for="libraries">{{t "Library" key="library"}}</label>
      {{bound-select select_class="la-swap-images-select" select_id="libraries" content=this.libraries selection=this.library action=(action "updateLibrary") }}
      {{#if this.premium_symbol_library}}
        {{#if this.appState.currentUser.subscription.grace_trial_period}}
          <div class="la-swap-images-warning">
            {{t "(requires extra fee after trial period)" key="extra_fee_at_purchase"}}
          </div>
        {{/if}}
      {{/if}}
    </div>
  </div>
  <div class="modal-footer md-modal-footer">
    <button class='la-swap-images-submit' {{action "swap"}} disabled={{this.status.loading}}>
      {{#if this.status.loading}}
        {{t "Swapping Images..." key="swapping_images"}}
      {{else if this.status.error}}
        {{t "Swapping Images Failed" key="swapping_images_failed"}}
      {{else}}
        {{t "Swap Images" key="swap_images"}}
      {{/if}}
    </button>
    <a href="#" class="la-swap-images-cancel" {{action "close"}}>{{t "Cancel" key="cancel"}}</a>
  </div>
  </div>
{{/modal-dialog}}
