{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="landing-features-modal-wrap">
    <div class="landing-modal-header">
      <span class="landing-modal-header-label">{{t "Features" key='fsa_nav_features'}}</span>
      <button type="button" class="landing-modal-close" {{action "close"}} aria-label="Close">✕</button>
    </div>
    <div class="landing-features-modal-body">
      <div class="landing-features-modal-header">
        <span class="landing-section-label">{{t "Why LingoLinq" key="landing_why_label"}}</span>
        <h2 class="landing-section-title">{{t "Built for how schools actually work" key="landing_features_title"}}</h2>
        <p class="landing-section-subtitle">{{t "Traditional AAC tools weren't designed for modern classrooms. We built LingoLinq from the ground up for the cloud era." key="landing_features_subtitle"}}</p>
      </div>
      <div class="landing-features-grid">
        <div class="landing-feature-card">
          <div class="landing-feature-header-row">
            <div class="landing-feature-icon landing-feature-icon-coral">🤖</div>
            <h3>{{t "AI-Powered Board Generation" key="landing_feature_ai_title"}}</h3>
          </div>
          <p>{{t "Describe a topic and LingoLinq builds communication boards automatically. What used to take hours now takes minutes." key="landing_feature_ai_desc"}}</p>
        </div>
        <div class="landing-feature-card">
          <div class="landing-feature-header-row">
            <div class="landing-feature-icon landing-feature-icon-teal">🌍</div>
            <h3>{{t "Multilingual from Day One" key="landing_feature_multilingual_title"}}</h3>
          </div>
          <p>{{t "AI-driven language expansion supports 10+ languages with proper grammar inflection, not just word-for-word translation." key="landing_feature_multilingual_desc"}}</p>
        </div>
        <div class="landing-feature-card">
          <div class="landing-feature-header-row">
            <div class="landing-feature-icon landing-feature-icon-navy">🏫</div>
            <h3>{{t "District-Wide Management" key="landing_feature_district_title"}}</h3>
          </div>
          <p>{{t "Google Classroom-style dashboard for managing students, therapists, and devices across your entire district from one screen." key="landing_feature_district_desc"}}</p>
        </div>
        <div class="landing-feature-card">
          <div class="landing-feature-header-row">
            <div class="landing-feature-icon landing-feature-icon-teal">☁️</div>
            <h3>{{t "Cloud-Native, Any Device" key="landing_feature_cloud_title"}}</h3>
          </div>
          <p>{{t "Works on tablets, phones, laptops, and smartboards. Edit boards from your desk. Students access them from anywhere." key="landing_feature_cloud_desc"}}</p>
        </div>
        <div class="landing-feature-card">
          <div class="landing-feature-header-row">
            <div class="landing-feature-icon landing-feature-icon-coral">📊</div>
            <h3>{{t "Real Analytics for IEPs" key="landing_feature_analytics_title"}}</h3>
          </div>
          <p>{{t "Track vocabulary growth, usage patterns, and communication attempts. Generate reports that map directly to IEP goals." key="landing_feature_analytics_desc"}}</p>
        </div>
        <div class="landing-feature-card">
          <div class="landing-feature-header-row">
            <div class="landing-feature-icon landing-feature-icon-navy">👨‍👩‍👧</div>
            <h3>{{t "Family Access Built In" key="landing_feature_family_title"}}</h3>
          </div>
          <p>{{t "Parents and caregivers get free companion access. Same boards, same vocabulary, school to home. No extra cost." key="landing_feature_family_desc"}}</p>
        </div>
      </div>
    </div>
  </div>
{{/modal-dialog}}
