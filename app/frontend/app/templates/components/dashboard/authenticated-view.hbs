                <button class='btn big_button btn-default middle_row' {{action "intro"}}>
                  <img src={{path "images/learn.png"}} >
                  {{t "Learn<br>and Setup" key="learn_and_setup"}}
                </button>
              </div>
              <div class='col-md-3 col-xs-4 big_button_holder'>
                <button class='btn big_button btn-default middle_row' {{action "newBoard"}}>
                  <img src={{path "images/new.svg"}} >
                  {{t "New Board" key="new_board"}}
                </button>
              </div>
            {{else}}
              <div class='col-md-3 col-xs-4 big_button_holder'>
                <button class='btn big_button btn-default middle_row' {{action "newBoard"}}>
                  <img src={{path "images/new.svg"}} >
                  {{t "New Board" key="new_board"}}
                </button>
              </div>
              <div class='col-md-3 col-xs-4 big_button_holder'>
                <button class='btn big_button btn-default middle_row' {{action "searchBoards"}}>
                <span class='glyphicon glyphicon-search'></span>
                  {{t "Search Boards" key="search_boards"}}
                </button>
              </div>
            {{/if}}
          {{/unless}}
          {{#if this.app_state.currentUser.permissions.delete}}
            <div class='col-md-3 col-xs-4 big_button_holder'>
              <button class='btn big_button btn-default middle_row' {{action "manage_supervisors"}}>
                <span class='glyphicon glyphicon-user'></span>
                {{t "Supervisors" key="supervisors"}}
              </button>
            </div>
          {{/if}}
          {{#if this.sync_able}}
            <div class='col-md-3 col-xs-4 big_button_holder'>
              <button class='btn big_button btn-default middle_row' {{action "sync_details"}}>
                <span class='glyphicon glyphicon-refresh'></span>
                {{t "Sync" key="sync"}}
              </button>
            </div>
          {{/if}}
          {{#if this.app_state.currentUser.permissions.delete}}
            <div class='col-md-3 col-xs-4 big_button_holder'>
              <button class='btn big_button btn-default bottom_row' {{action "goals"}}>
                <span class='glyphicon glyphicon-flag'></span>
                {{t "Goals" key="goals"}}
              </button>
            </div>
          {{/if}}
          {{#unless this.app_state.currentUser.modeling_only}}
            <div class='col-md-3 col-xs-4 big_button_holder'>
              <button class='btn big_button btn-default bottom_row' {{action "record_note"}}>
                <span class='glyphicon glyphicon-file'></span>
                {{t "New Note" key="new_note"}}
              </button>
            </div>
            <div class='col-md-3 col-xs-4 big_button_holder'>
              <button class='btn big_button btn-default bottom_row' {{action "run_eval" "pick"}}>
                <span class='glyphicon glyphicon-list-alt'></span>
                {{t "Run Evaluation" key="run_eval"}}
              </button>
            </div>
          {{/unless}}
          {{#if this.app_state.currentUser.permissions.delete}}
            <div class='col-md-3 col-xs-4 big_button_holder'>
              <LinkTo @route="user" @model={{this.app_state.currentUser.user_name}} class="btn big_button btn-default bottom_row">
                <img src={{this.app_state.currentUser.avatar_url_with_fallback}} onerror='button_broken_image(this);' >
                {{t "My Account" key="my_account"}}
              </LinkTo>
            </div>
          {{/if}}
          {{#if this.app_state.feature_flags.emergency_boards}}
            <div class='col-md-3 col-xs-4 big_button_holder'>
              <LinkTo @route="offline_boards" class="btn big_button btn-default emergency_button">
                <span class='glyphicon glyphicon-exclamation-sign'></span>
                {{t "Basic Access" key="critical_access"}}
              </LinkTo>
            </div>
