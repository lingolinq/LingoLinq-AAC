            {{t "current home board:" key="current_home_board"}}<br>
            {{#if this.app_state.currentUser.preferences.home_board}}
              {{#link-to "board" this.app_state.currentUser.preferences.home_board.key}}
                <strong style='font-size: 20px;'>{{this.app_state.currentUser.preferences.home_board.key}}</strong>
              {{/link-to}}
            {{else}}
              {{#link-to "home-boards"}}
                <span style='font-size: 20px;'>
                  {{t "Help Me Choose a Home Board" key="help_me_choose_a_home_board"}}
                </span>
              {{/link-to}}
            {{/if}}
            <div style='clear: left;'></div>
          </div>
