<div class={{if this.left_nav_expanded "col col-sm-4 col-md-3 expanded" "col col-sm-4 col-md-3"}} id='new_left' >
  <div class="">
    <button class='expand btn btn-default' style='float: right; margin-right: 5px;' {{action "expand_left_nav"}}><span class={{if this.left_nav_expanded "caret" "caret-right"}}></span></button>
  <h2 style='padding-left: 5px;'>
    {{#if this.app_state.currentUser.permissions.delete}}
      <LinkTo @route="user" @model={{this.app_state.currentUser.user_name}} class="hidden_link">
        <img src={{this.app_state.currentUser.avatar_url_with_fallback}} class='fit_image' style="height: 45px; width: 45px; margin-bottom: -5px; border: 1px solid rgba(0, 0, 0, 0.5); border-radius: 100%; padding: 1px; background: #fff; box-shadow: 0px 0px 3px;">
        <span style='vertical-align: middle'>{{this.app_state.currentUser.user_name}}</span>
      </LinkTo>
    {{else}}
      <span>
        <img src={{this.app_state.currentUser.avatar_url_with_fallback}} class='fit_image' style="height: 45px; width: 45px; margin-bottom: -5px; border: 1px solid rgba(0, 0, 0, 0.5); border-radius: 100%; padding: 1px; background: #fff; box-shadow: 0px 0px 3px;">
        <span style='vertical-align: middle'>{{this.app_state.currentUser.user_name}}</span>
      </span>
    {{/if}}
  </h2>
  <div class="left_links list-group no_curve">
    {{#if this.blank_slate}}
      <a class="list-group-item" href="#" style="height: 80px;" {{action "getting_started"}}>
        <span class="glyphicon glyphicon-user"></span>
        <strong>{{t "Welcome to %app_name%!" key="welcome_to_app"}}</strong>
        <div class="progress" style="margin-bottom: 0;">
          <div class="progress-bar" role="progressbar" aria-valuenow={{this.blank_slate_percent}} aria-valuemin="0" aria-valuemax="100" style={{this.blank_slate_percent_style}}>
            <span class="sr-only">{{t "%{pct}% Complete" key="percent_complete" pct=this.blank_slate_percent}}</span>
          </div>
        </div>
        {{t "Finish setting up your account" key="on_your_way"}}
      </a>
    {{else if this.app_state.feature_flags.subscriptions}}
      {{#if this.app_state.currentUser.modeling_only}}
        <LinkTo @route="user.subscription" @model={{this.app_state.currentUser.user_name}} class="list-group-item half_size">
          <span class="glyphicon glyphicon-info-sign"></span>
          {{#if this.app_state.currentUser.permissions.delete}}
            <strong>{{t "This is a modeling-only account" key="modeling_only_account"}}</strong>
          {{else}}
            <strong>{{t "This is a modeling-only session" key="modeling_only_session"}}</strong>
          {{/if}}
        </LinkTo>
      {{else if this.app_state.currentUser.expired_or_grace_period}}
        <LinkTo @route="user.subscription" @model={{this.app_state.currentUser.user_name}} class="list-group-item">
          <span class={{if this.app_state.currentUser.expired "glyphicon glyphicon-info-sign expired" "glyphicon glyphicon-info-sign"}}></span>
          {{#if this.app_state.currentUser.expired}}
            <strong class='text-danger'>{{t "Tap here to update your subscription" key="tap_to_subscribe"}}</strong><br>
            {{t "your free preview has ended" key="preview_expired"}}
          {{else}}
            <strong>{{t "Please update your license" key="update_license"}}</strong>
            <div style='font-size: 12px; line-height: 13px;'>{{t "your free preview ends" key="preview_expires"}}<br>{{date this.app_state.currentUser.subscription.expires "day"}}</div>
          {{/if}}
        </LinkTo>
      {{/if}}
    {{/if}}
    {{#if this.app_state.currentUser.home_board_pending}}
      <div class="list-group-item collapsible">
        <span class="glyphicon glyphicon-home"></span>
        {{t "current home board:" key="current_home_board"}}<br>
        <strong>{{t "copying %{brd}..." key="copying_board" brd=this.app_state.currentUser.home_board_pending}}</strong>
      </div>
    {{else if this.home_board_or_supporter}}
      {{#if this.app_state.currentUser.supporter_view}}
        {{#unless this.app_state.currentUser.modeling_only}}
          {{#if this.app_state.currentUser.preferences.home_board.key}}
            <LinkTo @route="board" @model={{this.app_state.currentUser.preferences.home_board.key}} class="list-group-item half_size collapsible">
              <span class="glyphicon glyphicon-home"></span>
              {{t "home:" key="home_colon"}}
              <strong>{{this.app_state.currentUser.preferences.home_board.key}}</strong>
            </LinkTo>
          {{/if}}
        {{/unless}}
        {{#if this.sync_able}}
          <a href="#" class={{this.small_needs_sync_class}} {{action "sync"}}>
            <span>
            <span class={{this.refreshing_class}}></span>
            {{#if (persistence-value 'sync_succeeded')}}
              {{#if this.session.invalid_token}}
                {{t "Please re-login and sync again" key="please_resync"}}
              {{else}}
                {{t "Sync Done!" key="sync_done"}}
              {{/if}}
            {{else if (persistence-value 'sync_finished')}}
              {{t "Done with " key="done_with"}}
              {{t "error" key="n_errors_lower" count=(persistence-value 'sync_errors')}}
              {{t "(see log)" key="see_log"}}
            {{else}}
              {{#if (persistence-value 'sync_failed')}}
                {{t "Sync Failed, see details below" key="sync_failed"}}
                {{#if (persistence-value 'sync_status_error')}}
                  <span title={{persistence-value 'sync_status_error'}}>{{persistence-value 'sync_status_error'}}</span>
                {{/if}}
              {{else}}
                {{#if (persistence-value 'syncing')}}
                  {{t "Syncing..." key="syncing_ellipsis"}}
                  {{#if (persistence-value 'sync_progress')}}
                    {{#if (persistence-value 'sync_progress.total')}}
                      {{persistence-value 'sync_progress.visited'}} /
                      {{t "board" key="communication_set_board" count=(persistence-value 'sync_progress.total')}}
                    {{else if (persistence-value 'sync_progress.pre_total')}}
                      {{t "checking" key="checking_lower"}}
                      {{persistence-value 'sync_progress.pre_visited'}} /
                      {{t "board" key="communication_set_board" count=(persistence-value 'sync_progress.pre_total')}}
                    {{else}}
                      {{t "initializing..." key="initializing_lower"}}
                    {{/if}}
                  {{/if}}
                {{else}}
                  {{#if this.needs_sync}}
                    {{#if this.app_state.installed_app}}
                      {{t "Sync before going offline!" key="needs_update"}}
                    {{else}}
                      {{t "Sync if planning to go offline" key="sync_if_planning_offline"}}
                    {{/if}}
                  {{else}}
                    {{t "Synced and ready for offline" key="up_to_date"}}
                  {{/if}}
                {{/if}}
              {{/if}}
            {{/if}}
            </span>
          </a>
        {{/if}}
      {{else}}
        <LinkTo @route="board" @model={{this.app_state.currentUser.preferences.home_board.key}} class="list-group-item collapsible">
          <span class="glyphicon glyphicon-home"></span>
          {{t "current home board:" key="current_home_board"}}<br>
          <strong>{{this.app_state.currentUser.preferences.home_board.key}}</strong>
        </LinkTo>
        {{#unless this.app_state.currentUser.any_limited_supervisor}}
          {{#if this.app_state.currentUser.currently_premium}}
            <div class="list-group-item" style={{if this.app_state.currentUser.currently_premium "height: 85px;" "height: 60px;"}}>
              <span class="glyphicon glyphicon-volume-up"></span>
              <span class="btn btn-primary" {{action "homeInSpeakMode"}} style="padding-top: 13px; padding-bottom: 13px; margin-top: -5px;">
              {{t "Open In Speak Mode" key="open_in_speak_mode"}}
              </span>
              {{#if this.app_state.currentUser.currently_premium_or_fully_purchased}}
                <div style="margin: 5px 0 5px 60px;">
                  <label style="font-weight: normal;">
                    <Input @type="checkbox" @checked={{this.autoOpenSpeakMode}} />
                    {{t "always start in Speak Mode" key="auto_open_speak_mode"}}
                  </label>
                </div>
              {{/if}}
            </div>
          {{/if}}
        {{/unless}}
        {{#if this.sync_able}}
          <a href="#" class={{this.needs_sync_class}} {{action "sync"}}>
            <span>
            <span class={{this.refreshing_class}}></span>
            {{#if (persistence-value 'sync_succeeded')}}
              {{t "Sync Done!" key="sync_done"}}
            {{else}}
              {{#if (persistence-value 'sync_failed')}}
                {{t "Sync Failed, see details below" key="sync_failed"}}
              {{else}}
                {{#if (persistence-value 'syncing')}}
                  {{t "Syncing..." key="syncing_ellipsis"}}
                {{else}}
                  {{#if this.needs_sync}}
                    {{#if this.app_state.installed_app}}
                      {{t "Sync before going offline!" key="needs_update"}}
                    {{else}}
                      {{t "Sync if planning to go offline" key="sync_if_planning_offline"}}
                    {{/if}}
                  {{else}}
                    {{t "Synced and ready for offline" key="up_to_date"}}
                  {{/if}}
                {{/if}}
              {{/if}}
            {{/if}}
            {{#if this.app_state.currentUser.stats.board_set_ids}}
              <br>
              {{#if (persistence-value 'sync_progress')}}
                {{persistence-value 'sync_progress.visited'}} /
                {{t "board" key="communication_set_board" count=(persistence-value 'sync_progress.total')}}
              {{else if (persistence-value 'sync_status_error')}}
                {{persistence-value 'sync_status_error'}}
              {{else}}
                {{t "board" key="communication_set_board" count=this.app_state.currentUser.stats.board_set_ids}}
              {{/if}}
            {{/if}}
            </span>
          </a>
        {{/if}}
      {{/if}}
    {{else}}
      {{#unless this.app_state.currentUser.modeling_only}}
        <LinkTo @route="home-boards" class="list-group-item collapsible">
          <span class="glyphicon glyphicon-home"></span>
          <strong>{{t "You haven't set a home board yet" key="choose_home_board"}}</strong><br>
          {{t "Let us help you choose one." key="let_us_help_choose_home"}}
        </LinkTo>
      {{/unless}}
    {{/if}}

    {{#unless this.app_state.currentUser.supporter_role}}
      {{#unless this.app_state.currentUser.modeling_only}}
        <a href="#" class="list-group-item collapsible" {{action "manage_supervisors"}}>
          <span>
          <span class="glyphicon glyphicon-user"></span>
          {{#if this.supervisors_count}}
            {{t "Supervisor" key="n_supervisors" count=this.supervisors_count}}
          {{else}}
            {{t "No Supervisors" key="no_supervisors"}}
          {{/if}}
          </span>
        </a>
      {{/unless}}
    {{/unless}}
    {{#unless this.app_state.currentUser.modeling_only}}
      {{#if this.app_state.currentUser.supervised_units}}
        <div class="list-group-item half_size" style='height: auto; line-height: 18px; padding-bottom: 3px;'>
          <span style='white-space: normal;'>
            <span class='glyphicon glyphicon-tower'></span>
            {{t "rooms:" key="rooms_colon"}}
            {{#each this.app_state.currentUser.supervised_units as |unit|}}
              <span style='margin-right: 10px; white-space: nowrap;'>
                {{#link-to "organization.room" unit.organization_id unit.id}}
                  {{unit.name}}
                {{/link-to}}
              </span>
            {{/each}}
          </span>
        </div>
      {{/if}}
      {{#if this.has_management_responsibility}}
        {{#if this.manages_multiple_orgs}}
          <div class="list-group-item half_size" style='height: auto; line-height: 18px; padding-bottom: 3px;'>
            <span class="glyphicon glyphicon-paperclip"></span>
            <span style='white-space: normal;'>
              {{#each this.managed_orgs as |org|}}
                <span style="margin-right: 10px; white-space: nowrap;">
                  {{#link-to "organization" org.id}}
                    {{org.name}}
                  {{/link-to}}
                </span>
              {{/each}}
            </span>
          </div>
        {{else}}
          {{#each this.managed_orgs as |org|}}
            <LinkTo @route="organization" @model={{org.id}} class="list-group-item half_size">
              <span class="glyphicon glyphicon-paperclip"></span>
              <span style="margin-right: 10px;">
                {{t "Organization Management" key="org_management"}}
              </span>
            </LinkTo>
          {{/each}}
        {{/if}}
      {{/if}}
    {{/unless}}

    {{#if this.app_state.currentUser.modeling_only}}
    {{else if this.app_state.currentUser}}
      <a href="#" class={{if this.app_state.currentUser.supporter_role "list-group-item collapsible half_size" "list-group-item collapsible"}} {{action "session_select"}} style='height: auto;'>
        <span>
        <span class="glyphicon glyphicon-list-alt"></span>
        {{#unless this.app_state.currentUser.supporter_role}}
          {{t "Logging is " key="logging_is"}}
          {{#if this.app_state.currentUser.preferences.logging}}
            {{#if this.app_state.currentUser.preferences.geo_logging}}
              {{t "fully enabled" key="fully_enabled"}}
            {{else}}
              {{t "enabled (no geo)" key="logging_no_geo_is_enabled"}}
            {{/if}}
          {{else}}
            {{t "disabled" key="logging_is_disabled"}}
          {{/if}}<br>
        {{/unless}}

        {{#if this.allow_logs}}
          <span class='text-muted' style='font-size: 12px; margin-top: 10px;'>
            {{t "Last Log" key="latest_session"}}
            {{#if this.logs.[0]}}
              <span title={{date log.started_at}}>
                {{date_ago this.logs.[0].started_at}}
              </span>
            {{/if}}
          </span>
          <br>
          {{#if this.logs.loading}}
            {{t "Loading..." key="loading"}}
          {{else if this.logs.eror}}
            {{t "Failed to load" key="failed_to_load"}}
          {{else if this.logs.[0]}}
            <div style='padding-right: 10px; white-space: normal; max-height: 40px; overflow: hidden;'>
            {{#if this.app_state.currentUser.supporter_role}}
              {{this.logs.[0].user.user_name}}:
            {{/if}}
            {{this.logs.[0].summary}}
            </div>
          {{else}}
            {{t "No recent sessions" key="no_recent_sessions"}}
          {{/if}}
        {{else if this.app_state.currentUser.supporter_role}}
            {{t "No session data" key="no_session_data"}}
        {{/if}}
        </span>
      </a>
    {{/if}}

  </div>
  <div style='padding: 0 10px;' class='collapsible'>
    <div style="float: right;">
      <a href="#" {{action "reload"}}>{{t "reload" key="reload"}}</a>
    </div>
    {{#if (persistence-value 'sync_log')}}
      <br><a href="#" {{action "sync_details"}}>{{t "recent sync details log" key="recent_sync_details"}}</a>
    {{/if}}
  </div>
  <div style="clear: both;"></div>
  </div>
</div>
<div class='col col-sm-8 col-md-9' id="new_right">
  <div class='row big_buttons' style='padding-right: 10px;'>
    <div class='col-xs-12' style='position: absolute; top: -40px;'>
      <ul class="nav nav-pills new_pills">
        <li role="presentation" class={{if this.index_nav.main "active"}}><a href="#" {{action "set_index_nav" "main"}}>{{t "Actions" key="actions"}}</a></li>
        {{#unless this.app_state.currentUser.modeling_only}}
          {{#if this.show_communicators_tab}}
            <li role="presentation" class={{if this.index_nav.supervisees "active"}}><a href="#" {{action "set_index_nav" "supervisees"}}>{{t "Communicators" key="communicators"}}</a></li>
          {{/if}}
        {{/unless}}
        <li role="presentation" class={{if this.index_nav.boards "active"}}><a href="#" {{action "set_index_nav" "boards"}}>{{t "Boards" key="boards"}}</a></li>
        {{#unless this.app_state.currentUser.modeling_only}}
          <li role="presentation" id='nav_updates' class={{if this.index_nav.updates "active"}} style='position: relative;'><a href="#" {{action "set_index_nav" "updates"}}>
            {{t "Updates" key="updates"}}
            {{#if this.pending_updates}}
              <span class="label label-danger unread hidden-xs" style='position: absolute; right: -25px; top: 9px;'>
                {{#if this.pending_updates.count}}
                  {{this.pending_updates.count}}
                {{else}}
                  {{t "!" key="exclaim"}}
                {{/if}}
              </span>
            {{/if}}
          </a></li>
        {{/unless}}
      </ul>
    </div>
    {{#if this.index_nav.supervisees}}
      {{#unless this.app_state.currentUser.modeling_only}}
      <div class='col-xs-12'>
        <h4>{{t "People I Supervise" key="people_i_supervise"}}</h4>
      </div><div style='clear: left;'></div>
      {{#unless this.supervisees_with_badges}}
        <div style='margin: 0 20px; max-width: 600px;'>{{t "You have not been added as a supervisor for any communicators. For privacy reasons, supervisors must be added from the communicators account. Once you have helped your communicators add you to their account as a supervisor, you will see them appear here." key="no_supervisors_explainer"}}</div>
      {{/unless}}
      {{#each this.supervisees_with_badges as |supervisee|}}
        <div class='col-lg-6 col-md-12' style='padding: 0 5px;'>
          <div style='border: 5px solid #ccc; border-radius: 10px; margin-bottom: 10px; padding: 10px 15px;'>
            <div style='float: left; position: relative;'>
              {{#link-to "user" supervisee.user_name}}
                {{#if supervisee.local_avatar_url}}
                  <img src={{supervisee.local_avatar_url}} rel-url={{supervisee.avatar_url}} onerror="button_broken_image(this);" class='fit_image' style="height: 80px; width: 80px; margin: 25px 10px 0 -10px;">
                {{else}}
                  <img src={{supervisee.avatar_url}} onerror="button_broken_image(this);" class='fit_image' style="height: 80px; width: 80px; margin: 25px 10px 0 -10px;">
                {{/if}}
              {{/link-to}}
              {{#if supervisee.online}}
                <div title='currently online' class='online_marker'></div>
              {{/if}}
              {{#if supervisee.earned_badge}}
                {{badge-earned badge=supervisee.earned_badge}}
              {{/if}}
            </div>
            <div style='overflow: hidden; white-space: nowrap; margin-top: -10px;'>
              <span style='font-size: 30px;'>{{supervisee.user_name}}</span>
              <div class='text-muted' style='margin: -10px 0 5px;'>
                {{#if supervisee.goal}}
                  {{supervisee.goal.summary}}
                {{else}}
                  <span style='color: #ccc;'>{{t "no goal set" key="no_goal_set"}}</span>
                  {{#if (persistence-online)}}
                    {{#unless this.app_state.currentUser.modeling_only}}
                      - <a {{action "set_goal" supervisee}} href="#">{{t "set a goal" key="set_a_goal"}}</a>
                    {{/unless}}
                  {{/if}}
                {{/if}}
              </div>
            </div>
            {{#if supervisee.home_board_key}}
              <button class='btn btn-primary' style='overflow: hidden; margin-bottom: 5px; width: 88px; border-width: 2px;' {{action "homeInSpeakMode" supervisee.id true}}>
                <span class='glyphicon glyphicon-hand-up' style='font-size: 30px;'></span><br>
                <div style='line-height: 14px;'>
                  {{t "Model for" key="model_for"}}<br>{{supervisee.user_name}}
                </div>
              </button>
              <button class='btn btn-default modeling_button less_important' style='overflow: hidden; margin-bottom: 5px; width: 88px; border-width: 2px;' {{action "homeInSpeakMode" supervisee.id}}>
                <span class='glyphicon glyphicon-volume-up' style='font-size: 30px;'></span><br>
                <div style='line-height: 14px;'>
                  {{t "Speak as" key="speak_as"}}<br>{{supervisee.user_name}}
                </div>
              </button>
            {{else if supervisee.external_device}}
              <button class='btn btn-default button_row_wrap secondary_button less_important' style='margin-bottom: 5px; width: 88px; border-width: 2px;' {{action "intro" supervisee.id}}>
                <span class='glyphicon glyphicon-user' style='font-size: 30px;'></span><br>
                <div style='line-height: 14px;'>
                  {{t "User" key="user"}}<br>{{t "Profile" key="profile"}}
                </div>
              </button>
            {{else}}
              <button class='btn btn-default button_row_wrap attention_button less_important' style='margin-bottom: 5px; width: 88px; border-width: 2px;' {{action "intro" supervisee.id}}>
                <img src={{path "images/learn.png"}}>
                <div style='line-height: 14px;'>
                  {{t "Setup" key="setup"}}<br>{{t "User" key="user"}}
                </div>
              </button>
            {{/if}}
            {{#if this.app_state.currentUser.modeling_only}}
              <button class='btn btn-default button_row_mini_wrap secondary_button less_important' style='margin-bottom: 5px; width: 88px; border-width: 2px;' {{action "home_board" supervisee.home_board_key}}>
                <span class='glyphicon glyphicon-th' style='font-size: 30px;'></span><br>
                <div style='line-height: 14px;'>
                  {{t "Home" key="home"}}<br>{{t "Board" key="board"}}
                </div>
              </button>
            {{else}}
              <button class='btn btn-default button_row_mini_wrap secondary_button less_important' style='margin-bottom: 5px; width: 88px; border-width: 2px;' {{action "stats" supervisee.user_name}}>
                <span class='glyphicon glyphicon-stats' style='font-size: 30px;'></span><br>
                <div style='line-height: 14px;'>
                  {{t "Usage" key="usage"}}<br>{{t "Reports" key="reports"}}
                </div>
              </button>
              <button class='btn btn-default button_row_wrap alternate_button less_important' style='opacity: 0.8; margin-bottom: 5px; border-width: 2px; color: #444;' {{action "modeling_ideas" supervisee.user_name}}>
                <img src={{path "images/modeling_ideas.svg"}}>
                <div style='line-height: 14px;'>
                  {{t "Modeling" key="modeling"}}<br>{{t "Ideas" key="ideas"}}
                </div>
              </button>
              <div class="btn-group">
                <button class='btn btn-default dropdown-toggle button_row_extras' style='margin-bottom: 5px; border-width: 2px; border-color: #ddd; color: #888;'data-toggle="dropdown" aria-haspopup="true" aria-expanded="false"><span class='text'>{{t "Extras" key="extras"}} </span><span class="caret"></span></button>
                <ul class="dropdown-menu" style='left: auto; right: 0;'>
                  <li>{{#link-to "board" supervisee.home_board_key}}{{t "Home Board" key="home_board"}}{{/link-to}}</li>
                  <li>{{#link-to "user" supervisee.user_name}}{{t "Account" key="account"}}{{/link-to}}</li>
                  <li><a href="#" {{action "record_note" supervisee}}>{{t "New Note" key="new_note"}}</a></li>
                  <li><a href="#" {{action "quick_assessment" supervisee}}>{{t "Quick Assessment" key="quick_assessment"}}</a></li>
                  <li><a href="#" {{action "run_eval" supervisee}}>{{t "Run Evaluation" key="run_evaluation"}}</a></li>
                  {{#if supervisee.remote_modeling}}
                    <li><a href="#" {{action "remote_model" supervisee}}>{{t "Remote Modeling" key="remote_modeling"}}</a></li>
                  {{/if}}
                </ul>
              </div>
            {{/if}}
            <div style='clear: left;'></div>
            {{#if supervisee.current_badge}}
              {{#if supervisee.premium}}
                {{badge-progress badge=supervisee.current_badge}}
              {{else}}
                <div style='height: 35px;'></div>
              {{/if}}
            {{else}}
              <div style='height: 35px;'></div>
            {{/if}}
          </div>
        </div>
      {{/each}}
      {{/unless}}
    {{else if this.index_nav.main}}
      <div class={{if this.show_main_extras "main" "main short_list"}}>
        {{#if this.app_state.currentUser.eval_ended}}
          <div class='alert alert-danger'>
            {{t "Your evaluation has ended" key="eval_ended"}}
            {{#if this.app_state.currentUser.can_reset_eval}}
              <br>
