        {{#if this.recentOfflineBoards}}
          {{#each this.recentOfflineBoards as |board|}}
            {{#if board.key}}
              <div class="col-md-2 col-xs-4 big_button_holder">
                <button class='btn big_button btn-default'>

                  {{board.key}}
                </button>
              </div>
            {{/if}}
          {{/each}}
        {{else}}
          <div class="col-sm-4">
            {{t "None found" key="none_found"}}
          </div>
        {{/if}}
      {{else}}
