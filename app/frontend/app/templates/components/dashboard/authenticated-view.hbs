                <span class="glyphicon glyphicon-share"></span>
                {{#link-to "board" share.board_key}}{{share.board_key}}{{/link-to}}
                {{t "is being shared with you by %{user_name}<br>and needs approval" key="board_share_needs_approval" user_name=share.user_name}}
              </p>
            {{/each}}
          {{/if}}
          {{#if this.app_state.currentUser.unread_messages}}
            <p>
            {{#link-to "user.logs" this.app_state.currentUser.user_name (query-params type="note")}}
              <span class="glyphicon glyphicon-envelope"></span>
              {{t "You have " key="you_have"}}
              {{t "unread message" count=this.app_state.currentUser.unread_messages key="unread_message_count"}}
            {{/link-to}}
            </p>
          {{/if}}
          {{#if this.app_state.currentUser.parsed_notifications}}
            {{#each this.app_state.currentUser.parsed_notifications as |notif|}}
              <UserNotification @notification={{notif}} />
            {{/each}}
          {{/if}}
          {{#unless this.app_state.currentUser.unread_messages}}
            {{#unless this.app_state.currentUser.parsed_notifications}}
              {{#unless this.app_state.currentUser.pending_board_shares}}
