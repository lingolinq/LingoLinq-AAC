<div class="ll-bento-app-shell {{if this.app_state.darkMode "ll-bento-app-shell--dark"}} {{if this.app_state.midDayMode "ll-bento-app-shell--midday"}} {{if this.app_state.defaultMode "ll-bento-app-shell--default"}} {{if this.app_state.lightMode "ll-bento-app-shell--light"}}">
  <div class="ll-bento-bg-orbs" aria-hidden="true">
    <span class="ll-bento-orb ll-bento-orb--a"></span>
    <span class="ll-bento-orb ll-bento-orb--b"></span>
    <span class="ll-bento-orb ll-bento-orb--c"></span>
  </div>
  <div class="ll-bento-device-frame ll-bento-device-frame--wide {{if (is-equal this.sectionBorderMode "off") "ll-bento-device-frame--no-section-border"}} {{if (is-equal this.sectionBorderMode "thick") "ll-bento-device-frame--section-border-thick"}} {{if this.demoMainContentBg "ll-bento-device-frame--demo-bg"}}" style={{this.demoMainContentBgStyle}}>
    <header class="ll-bento-bar {{if this.app_state.midDayMode "ll-bento-bar--midday"}} {{if this.app_state.defaultMode "ll-bento-bar--default"}}">
      <div class="ll-bento-bar__section ll-bento-bar__brand">
        <a href="#" class="ll-bento-brand-link" {{action "index"}}>
          <span class="ll-bento-brand__logo-wrap" aria-hidden="true">
            <img src={{path "images/icon-house-balanced.png"}} alt="" class="ll-bento-logo" aria-hidden="true">
          </span>
          <span class="ll-bento-brand__name">{{t "%app_name%" key="app_name"}}</span>
          <span class="ll-bento-bar__brand-sep" aria-hidden="true">·</span>
          <span class="ll-bento-bar__brand-home">{{t "Home Page" key="home_page"}}</span>
        </a>
      </div>
      <div class="ll-bento-bar__section ll-bento-bar__welcome">
        <span class="ll-bento-bar-welcome" aria-hidden="true">
          <span class="ll-bento-bar-welcome__label">{{t "It's great to see you" key="welcome"}}</span>
          {{#if this.app_state.currentUser.permissions.delete}}
            <LinkTo @route="user" @model={{this.app_state.currentUser.user_name}} class="ll-bento-bar-welcome__link"><span class="ll-bento-bar-welcome__badge">{{this.app_state.currentUser.user_name}}</span></LinkTo>
          {{else}}
            <span class="ll-bento-bar-welcome__badge">{{this.app_state.currentUser.user_name}}</span>
          {{/if}}
          {{#if this.app_state.show_index_celebration}}
            <span class="ll-bento-bar-welcome__celebration-icon" aria-hidden="true" title={{t "Welcome!" key="welcome_exclaim"}}>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true"><path d="M12 3l1.5 4.5L18 9l-4.5 1.5L12 15l-1.5-4.5L6 9l4.5-1.5L12 3z"/><path d="M5 21l2-6 4 2-2 4-4-0z"/><path d="M19 21l2-6-4 2 2 4 4 0z"/></svg>
            </span>
          {{/if}}
        </span>
      </div>
      {{#if this.app_state.defaultMode}}
        <div class="ll-bento-bar__section ll-bento-bar__demo-colors" role="group" aria-label={{t "Demo content background" key="demo_content_background"}}>
          <button type="button" class="ll-bento-demo-color ll-bento-demo-color--navy" title={{t "Navy" key="navy_color"}} aria-label={{t "Navy" key="navy_color"}} {{action "setDemoMainContentBg" "#1B365D"}}></button>
          <button type="button" class="ll-bento-demo-color ll-bento-demo-color--navy-light" title={{t "Medium gray" key="medium_gray"}} aria-label={{t "Medium gray" key="medium_gray"}} {{action "setDemoMainContentBg" "#C6CDD7"}}></button>
          <button type="button" class="ll-bento-demo-color ll-bento-demo-color--tab-light" title={{t "Light teal" key="light_teal"}} aria-label={{t "Light teal" key="light_teal"}} {{action "setDemoMainContentBg" "#E9F9F8"}}></button>
          <button type="button" class="ll-bento-demo-color ll-bento-demo-color--reset" title={{t "Reset to default" key="reset_to_default"}} aria-label={{t "Reset to default" key="reset_to_default"}} {{action "clearDemoMainContentBg"}}>
            <span class="glyphicon glyphicon-repeat" aria-hidden="true"></span>
          </button>
          <button type="button" class="ll-bento-demo-color ll-bento-demo-color--border {{if (is-equal this.sectionBorderMode "off") "ll-bento-demo-color--border-off"}} {{if (is-equal this.sectionBorderMode "thick") "ll-bento-demo-color--border-thick"}}" title={{t "Toggle section border" key="toggle_section_border"}} aria-label={{t "Toggle section border" key="toggle_section_border"}} {{action "toggleSectionBorder"}}>
            <span class="ll-bento-demo-color--border-icon" aria-hidden="true"></span>
          </button>
        </div>
      {{/if}}
      <div class="ll-bento-bar__section ll-bento-bar__actions">
        <a href="#" class="ll-bento-icon-btn ll-bento-icon-btn--refresh" {{action "reload"}} role="button" aria-label={{t "Reload" key="reload"}} title={{t "Reload" key="reload"}}>
          <span class="glyphicon glyphicon-refresh" aria-hidden="true"></span>
        </a>
        {{#if this.app_state.currentUser.permissions.delete}}
          <LinkTo @route="user" @model={{this.app_state.currentUser.user_name}} class="ll-bento-icon-btn" aria-label={{t "Profile" key="profile"}}>
            <img src={{this.app_state.currentUser.avatar_url_with_fallback}} class="fit_image" style="width: 18px; height: 18px; border-radius: 999px; object-fit: cover;" alt="">
          </LinkTo>
        {{else}}
          <span class="ll-bento-icon-btn" aria-hidden="true">
            <img src={{this.app_state.currentUser.avatar_url_with_fallback}} class="fit_image" style="width: 18px; height: 18px; border-radius: 999px; object-fit: cover;" alt="">
          </span>
        {{/if}}
      </div>
    </header>
    <div class="row ll-bento-main-content">
<div class='col col-12' id="bento-main">
  <div class="ll-bento-span">
  <div class="ll-bento-tabs" role="tablist" aria-label={{t "Home filters" key="home_filters"}}>
    <button class="ll-bento-tab {{if this.index_nav.main "ll-bento-tab--active"}}" role="tab" aria-selected={{if this.index_nav.main "true" "false"}} type="button" {{action "set_index_nav" "main"}}>{{t "Actions" key="actions"}}</button>
    {{#unless this.app_state.currentUser.modeling_only}}
      {{#if this.show_communicators_tab}}
        <button class="ll-bento-tab {{if this.index_nav.supervisees "ll-bento-tab--active"}}" role="tab" aria-selected={{if this.index_nav.supervisees "true" "false"}} type="button" {{action "set_index_nav" "supervisees"}}>{{t "Communicators" key="communicators"}}</button>
      {{/if}}
    {{/unless}}
    <button class="ll-bento-tab {{if this.index_nav.boards "ll-bento-tab--active"}}" role="tab" aria-selected={{if this.index_nav.boards "true" "false"}} type="button" {{action "set_index_nav" "boards"}}>{{t "Boards" key="boards"}}</button>
    {{#unless this.app_state.currentUser.supporter_role}}
      {{#unless this.app_state.currentUser.modeling_only}}
        <button class="ll-bento-tab {{if this.index_nav.supervisors "ll-bento-tab--active"}}" role="tab" aria-selected={{if this.index_nav.supervisors "true" "false"}} type="button" {{action "set_index_nav" "supervisors"}}>{{t "Supervisors" key="supervisors"}}</button>
      {{/unless}}
    {{/unless}}
    {{#unless this.app_state.currentUser.modeling_only}}
      <button id='nav_updates' class="ll-bento-tab {{if this.index_nav.updates "ll-bento-tab--active"}}" role="tab" aria-selected={{if this.index_nav.updates "true" "false"}} type="button" {{action "set_index_nav" "updates"}} style='position: relative;'>
        {{t "Updates" key="updates"}}
        {{#if this.pending_updates}}
          <span class="label label-danger unread hidden-xs" style='position: absolute; right: -25px; top: 9px;'>
            {{#if this.pending_updates.count}}
              {{this.pending_updates.count}}
            {{else}}
              {{t "!" key="exclaim"}}
            {{/if}}
          </span>
        {{/if}}
      </button>
      <button id='nav_logging' class="ll-bento-tab {{if this.index_nav.logging "ll-bento-tab--active"}}" role="tab" aria-selected={{if this.index_nav.logging "true" "false"}} type="button" {{action "set_index_nav" "logging"}}>{{t "Logging" key="logging"}}</button>
    {{/unless}}
  </div>
  </div>
  {{#if this.index_nav.main}}
    {{#if this.blank_slate}}
      <a href="#" class="ll-bento-getting-started ll-bento-getting-started--main" {{action "getting_started"}}>
        <img src={{path "images/pastel-getting-started.svg"}} alt="" class="ll-bento-getting-started__image" aria-hidden="true">
        <div class="ll-bento-getting-started__body">
          <div class="ll-bento-getting-started__header">
            <span class="ll-bento-getting-started__title">{{t "Getting Started" key="getting_started"}}</span>
            <span class="ll-bento-getting-started__hint">{{t "Finish setting up your account" key="on_your_way"}}</span>
          </div>
          <div class="ll-bento-progress" role="progressbar" aria-valuenow={{this.blank_slate_percent}} aria-valuemin="0" aria-valuemax="100">
            <div class="ll-bento-progress__fill" style={{this.blank_slate_percent_style}}></div>
            <span class="sr-only">{{t "%{pct}% Complete" key="percent_complete" pct=this.blank_slate_percent}}</span>
          </div>
          <span class="ll-bento-getting-started__stage">{{t "Step %{current} of %{total}" key="step_current_of_total" current=this.getting_started_step total=5}}</span>
          <div class="ll-bento-getting-started__divider" aria-hidden="true"></div>
        </div>
        <span class="ll-bento-getting-started__btn">{{t "Help me Setup my Account" key="help_me_setup_account"}}</span>
      </a>
    {{/if}}
    {{!-- Home board card - commented out, uncomment to restore
    {{#unless this.home_board_or_supporter}}
      {{#unless this.app_state.currentUser.modeling_only}}
        <LinkTo @route="home-boards" class="ll-bento-home-board-card">
          <img src={{path "images/pastel-house.png"}} alt="" class="ll-bento-home-board-card__image" aria-hidden="true">
          <div class="ll-bento-home-board-card__content">
            <h3 class="ll-bento-home-board-card__title">{{t "You haven't set a home board yet" key="choose_home_board"}}</h3>
            <p class="ll-bento-home-board-card__subtitle">{{t "Let us help you choose one." key="let_us_help_choose_home"}}</p>
          </div>
          <span class="ll-bento-home-board-card__btn">{{t "Help Me Choose a Home Board" key="help_me_choose_a_home_board"}}</span>
        </LinkTo>
      {{/unless}}
    {{/unless}}
    --}}
  {{/if}}
  <div class='row big_buttons ll-bento-content'>
    {{#if this.index_nav.supervisees}}
      {{#unless this.app_state.currentUser.modeling_only}}
      <div class='col-xs-12'>
        <h4>{{t "People I Supervise" key="people_i_supervise"}}</h4>
      </div><div style='clear: left;'></div>
      {{#unless this.supervisees_with_badges}}
        <div style='margin: 0 20px; max-width: 600px;'>{{t "You have not been added as a supervisor for any communicators. For privacy reasons, supervisors must be added from the communicators account. Once you have helped your communicators add you to their account as a supervisor, you will see them appear here." key="no_supervisors_explainer"}}</div>
      {{/unless}}
      {{#each this.supervisees_with_badges as |supervisee|}}
        <div class='col-lg-6 col-md-12' style='padding: 0 5px;'>
          <div style='border: 5px solid #ccc; border-radius: 10px; margin-bottom: 10px; padding: 10px 15px;'>
            <div style='float: left; position: relative;'>
              <LinkTo @route="user" @model={{supervisee.user_name}}>
                {{#if supervisee.local_avatar_url}}
                  <img src={{supervisee.local_avatar_url}} rel-url={{supervisee.avatar_url}} onerror="button_broken_image(this);" class='fit_image' style="height: 80px; width: 80px; margin: 25px 10px 0 -10px;">
                {{else}}
                  <img src={{supervisee.avatar_url}} onerror="button_broken_image(this);" class='fit_image' style="height: 80px; width: 80px; margin: 25px 10px 0 -10px;">
                {{/if}}
              </LinkTo>
              {{#if supervisee.online}}
                <div title='currently online' class='online_marker'></div>
              {{/if}}
              {{#if supervisee.earned_badge}}
                {{badge-earned badge=supervisee.earned_badge}}
              {{/if}}
            </div>
            <div style='overflow: hidden; white-space: nowrap; margin-top: -10px;'>
              <span style='font-size: 30px;'>{{supervisee.user_name}}</span>
              <div class='text-muted' style='margin: -10px 0 5px;'>
                {{#if supervisee.goal}}
                  {{supervisee.goal.summary}}
                {{else}}
                  <span style='color: #ccc;'>{{t "no goal set" key="no_goal_set"}}</span>
                  {{#if (persistence-online)}}
                    {{#unless this.app_state.currentUser.modeling_only}}
                      - <a {{action "set_goal" supervisee}} href="#">{{t "set a goal" key="set_a_goal"}}</a>
                    {{/unless}}
                  {{/if}}
                {{/if}}
              </div>
            </div>
            {{#if supervisee.home_board_key}}
              <button class='btn btn-primary' style='overflow: hidden; margin-bottom: 5px; width: 88px; border-width: 2px;' {{action "homeInSpeakMode" supervisee.id true}}>
                <span class='glyphicon glyphicon-hand-up' style='font-size: 30px;'></span><br>
                <div style='line-height: 14px;'>
                  {{t "Model for" key="model_for"}}<br>{{supervisee.user_name}}
                </div>
              </button>
              <button class='btn btn-default modeling_button less_important' style='overflow: hidden; margin-bottom: 5px; width: 88px; border-width: 2px;' {{action "homeInSpeakMode" supervisee.id}}>
                <span class='glyphicon glyphicon-volume-up' style='font-size: 30px;'></span><br>
                <div style='line-height: 14px;'>
                  {{t "Speak as" key="speak_as"}}<br>{{supervisee.user_name}}
                </div>
              </button>
            {{else if supervisee.external_device}}
              <button class='btn btn-default button_row_wrap secondary_button less_important' style='margin-bottom: 5px; width: 88px; border-width: 2px;' {{action "intro" supervisee.id}}>
                <span class='glyphicon glyphicon-user' style='font-size: 30px;'></span><br>
                <div style='line-height: 14px;'>
                  {{t "User" key="user"}}<br>{{t "Profile" key="profile"}}
                </div>
              </button>
            {{else}}
              <button class='btn btn-default button_row_wrap attention_button less_important' style='margin-bottom: 5px; width: 88px; border-width: 2px;' {{action "intro" supervisee.id}}>
                <img src={{path "images/learn.png"}}>
                <div style='line-height: 14px;'>
                  {{t "Setup" key="setup"}}<br>{{t "User" key="user"}}
                </div>
              </button>
            {{/if}}
            {{#if this.app_state.currentUser.modeling_only}}
              <button class='btn btn-default button_row_mini_wrap secondary_button less_important' style='margin-bottom: 5px; width: 88px; border-width: 2px;' {{action "home_board" supervisee.home_board_key}}>
                <span class='glyphicon glyphicon-th' style='font-size: 30px;'></span><br>
                <div style='line-height: 14px;'>
                  {{t "Home" key="home"}}<br>{{t "Board" key="board"}}
                </div>
              </button>
            {{else}}
              <button class='btn btn-default button_row_mini_wrap secondary_button less_important' style='margin-bottom: 5px; width: 88px; border-width: 2px;' {{action "stats" supervisee.user_name}}>
                <span class='glyphicon glyphicon-stats' style='font-size: 30px;'></span><br>
                <div style='line-height: 14px;'>
                  {{t "Usage" key="usage"}}<br>{{t "Reports" key="reports"}}
                </div>
              </button>
              <button class='btn btn-default button_row_wrap alternate_button less_important' style='opacity: 0.8; margin-bottom: 5px; border-width: 2px; color: #444;' {{action "modeling_ideas" supervisee.user_name}}>
                <img src={{path "images/pastel-lightbulb.png"}} class="modeling_ideas_icon">
                <div style='line-height: 14px;'>
                  {{t "Modeling" key="modeling"}}<br>{{t "Ideas" key="ideas"}}
                </div>
              </button>
              <div class="btn-group">
                <button class='btn btn-default dropdown-toggle button_row_extras' style='margin-bottom: 5px; border-width: 2px; border-color: #ddd; color: #888;'data-toggle="dropdown" aria-haspopup="true" aria-expanded="false"><span class='text'>{{t "Extras" key="extras"}} </span><span class="caret"></span></button>
                <ul class="dropdown-menu" style='left: auto; right: 0;'>
                  <li><LinkTo @route="board" @model={{supervisee.home_board_key}}>{{t "Home Board" key="home_board"}}</LinkTo></li>
                  <li><LinkTo @route="user" @model={{supervisee.user_name}}>{{t "Account" key="account"}}</LinkTo></li>
                  <li><a href="#" {{action "record_note" supervisee}}>{{t "New Note" key="new_note"}}</a></li>
                  <li><a href="#" {{action "quick_assessment" supervisee}}>{{t "Quick Assessment" key="quick_assessment"}}</a></li>
                  <li><a href="#" {{action "run_eval" supervisee}}>{{t "Run Evaluation" key="run_evaluation"}}</a></li>
                  {{#if supervisee.remote_modeling}}
                    <li><a href="#" {{action "remote_model" supervisee}}>{{t "Remote Modeling" key="remote_modeling"}}</a></li>
                  {{/if}}
                </ul>
              </div>
            {{/if}}
            <div style='clear: left;'></div>
            {{#if supervisee.current_badge}}
              {{#if supervisee.premium}}
                {{badge-progress badge=supervisee.current_badge}}
              {{else}}
                <div style='height: 35px;'></div>
              {{/if}}
            {{else}}
              <div style='height: 35px;'></div>
            {{/if}}
          </div>
        </div>
      {{/each}}
      {{/unless}}
    {{else if this.index_nav.main}}
      <div class={{if this.show_main_extras "main" "main short_list"}}>
        {{#if this.app_state.currentUser.eval_ended}}
          <div class='alert alert-danger'>
            {{t "Your evaluation has ended" key="eval_ended"}}
            {{#if this.app_state.currentUser.can_reset_eval}}
              <br>
              <button {{action "update_evaluation" "reset"}} class='purchase_link' style='font-size: 20px;'>
                <span style='color: #fff;'>
                  <span class="glyphicon glyphicon-info-sign"></span>
                  {{t "Reset Evaluation" key="reset_evaluation"}}
                </span>
              </button>
            {{else if this.app_state.currentUser.subscription.eval_extendable}}
              <br>
              <button {{action "update_evaluation" "extend"}} class='purchase_link' style='font-size: 20px;'>
                <span style='color: #fff;'>
                  <span class="glyphicon glyphicon-info-sign"></span>
                  {{t "Request an Extension" key="request_extension"}}
                </span>
              </button>
            {{/if}}
          </div>
        {{else if this.app_state.currentUser.eval_ending_soon}}
          <div class='alert alert-danger'>
            {{t "Your evaluation is set to finish soon. This evaluation period will end" key="eval_ending_soon"}}
            {{date this.app_state.currentUser.subscription.eval_expires "day"}}.
            {{#if this.app_state.currentUser.can_reset_eval}}
              <br>
              <button {{action "update_evaluation"}} class='purchase_link' style='font-size: 20px;'>
                <span style='color: #fff;'>
                  <span class="glyphicon glyphicon-info-sign"></span>
                  {{t "Review Evaluation Status" key="review_evaluation"}}
                </span>
              </button>
            {{/if}}
          </div>
        {{else if this.session.modeling_session}}
        {{else if this.app_state.limited_free_space}}
          <div class='alert alert-danger'>
            {{t "Your device is almost out of free space! You only have %{mb}Mb of storage available. You may need to delete some data from other apps for %app_name% to work properly offline." mb=this.app_state.limited_free_space.mb key="need_memory_for_offline"}}
          </div>
        {{else if this.model.earned_badge}}
          <div>
            {{badge-earned badge=this.model.earned_badge big=true}}
          </div>
        {{else if this.model.first_incomplete_lesson}}
          {{#if this.app_state.feature_flags.lessons}}
          <div style='margin-left: 10px; margin-bottom: 10px;'>
            <button class='btn btn-lg btn-default' {{action "next_lesson"}}>
            <span class='glyphicon glyphicon-education'></span>
            {{t "Next Lesson: " key="next_lesson"}}
            {{this.model.first_incomplete_lesson.title}}
            {{#if this.model.first_incomplete_lesson.due_at}}
              <div style='font-size: 14px;'>due {{date this.model.first_incomplete_lesson.due_at}}</div>
            {{/if}}
            </button>
          </div>
          {{/if}}
        {{else if this.rating_allowed}}
          <div>
            <button {{action "launch_rating"}} class='purchase_link' style='font-size: 20px;'>
              <span style='color: #fff;'>
                <span class="glyphicon glyphicon-info-sign"></span>
                {{t "Rate the %app_name% App" key="rate_the_app"}}
              </span>
            </button>
          </div>
        {{else if this.app_state.currentUser.subscription.eval_expires}}
          <div class='alert alert-info'>
            {{t "This is an evaluation account, and will run through " key="eval_ending_date"}}
            {{date this.app_state.currentUser.subscription.eval_expires "day"}}.
          </div>
        {{/if}}
        <div class="ll-bento-actions {{if this.show_main_extras "ll-bento-actions--extras-expanded"}}">
          <div class="ll-bento-section-group">
            <span class="ll-bento-section-label">{{t "Primary Actions" key="primary_actions"}}</span>
            <div class="ll-bento-actions-grid">
            {{#if this.app_state.currentUser.external_device}}
              <a href="#" class="ll-bento-action-card ll-bento-action-card--with-btn" {{action "manual_session"}}>
                <div class="ll-bento-action-card__icon ll-bento-action-card__icon--extras">
                  <img src={{path "images/pastel-logging.png"}} class="ll-bento-action-card__img" alt="" aria-hidden="true">
                </div>
                <div class="ll-bento-action-card__body">
                  <h4 class="ll-bento-action-card__title">{{t "Manual Log Session" key="manual_log_session"}}</h4>
                  <p class="ll-bento-action-card__sub">{{t "Log a session manually for offline use" key="manual_log_subtitle"}}</p>
                </div>
                <span class="ll-bento-action-card__action-btn ll-bento-action-card__action-btn--extras">{{t "Start" key="start"}}</span>
              </a>
            {{else}}
              <a href="#" class="ll-bento-action-card ll-bento-action-card--speak ll-bento-action-card--with-btn" {{action "homeInSpeakMode"}}>
                <div class="ll-bento-action-card__icon ll-bento-action-card__icon--speak">
                  <img src={{path "images/pastel-sound.png"}} class="ll-bento-action-card__img" alt="" aria-hidden="true">
                </div>
                <div class="ll-bento-action-card__body">
                  <h4 class="ll-bento-action-card__title">{{t "Speak Mode" key="speak_mode"}}</h4>
                  <p class="ll-bento-action-card__sub">{{t "Use your boards to speak and communicate" key="speak_mode_subtitle"}}</p>
