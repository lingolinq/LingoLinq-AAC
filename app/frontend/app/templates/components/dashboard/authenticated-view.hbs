                <button class='btn big_button btn-default bottom_row' {{action "lessons"  "pick"}}>
                  <span class='glyphicon glyphicon-education'></span>
                  {{t "Trainings" key="trainings"}}
                </button>
              </div>
            {{/if}}
          {{/if}}
        {{else if (persistence-online)}}
          {{#if this.app_state.currentUser.current_badge}}
            {{badge-progress badge=this.app_state.currentUser.current_badge big=true}}
          {{/if}}
        {{/if}}
      </div>
    {{else if this.index_nav.boards}}
