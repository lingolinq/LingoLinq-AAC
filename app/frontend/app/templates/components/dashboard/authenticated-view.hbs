              {{#link-to "home-boards"}}
                <span>
                <span class="glyphicon glyphicon-search"></span>
                {{t "Help Me Choose a Home Board" key="help_me_choose_a_home_board"}}
                </span>
              {{/link-to}}
            </div>
          {{/unless}}
        {{/if}}
