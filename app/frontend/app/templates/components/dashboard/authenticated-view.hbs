          {{#if this.current_boards.loading}}
            <div class='col-sm-4'>{{t "Loading..." key="loading"}}</div>
          {{else if this.current_boards.error}}
            <div class='col-sm-4'>{{t "Failed to load" key="failed_to_load"}}</div>
          {{else}}
            {{#each this.current_boards as |board|}}
              <div class='col-md-3 col-xs-4 big_button_holder'>
                {{board-icon board=board localized=true allow_style=this.suggested_selected}}
              </div>
