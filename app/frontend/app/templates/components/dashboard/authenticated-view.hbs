                {{/if}}
                <br>
                <span style="color: #888; font-size: 10px; white-space: nowrap; overflow: hidden; display: block;">{{log.summary}}</span>
              </p>
            {{/each}}
          {{else}}
            {{#if this.show_sessions_explanation}}
              <p><em style="font-size: 11px;">{{t "When logging is enabled in your account preferences, your most recent sessions will appear here for quick review. If you are in the supervisor view you will instead see sessions for users you supervise." key="sessions_explanation"}}</em></p>
            {{else}}
              <p>
                {{t "No sessions currently available" key="no_sessions_found"}}
                <a href="#" {{action "show_explanation" "sessions"}}>
                  <span class='glyphicon glyphicon-info-sign'></span>
                </a>
              </p>
            {{/if}}
          {{/if}}
        </div>
      </div>
    {{else if this.index_nav.updates}}
      <div class='col-md-8 col-md-offset-2 col-xs-12'>
        {{#if this.device.needs_install_reminder}}
          <div style="margin-bottom: 20px; text-align: center;">
            <h2>
              <span class="glyphicon glyphicon-phone"></span>
              {{t "Try the App" key="use_cough_drop_app"}}
            </h2>
            <div style='text-align: left;'>
              {{t "%app_name% works in any web browser, but you can also install the free app in the following stores:" key="app_stores"}}
            </div>
            <div>
              {{#if this.app_state.domain_settings.ios_store_url}}
                <a href={{this.app_state.domain_settings.ios_store_url}} target="_blank" rel="noopener">
                  <img src={{path "images/ios_app_store.svg"}} alt="ios app store" style="height: 40px; margin-top: 5px;">
                </a>
              {{/if}}
              {{#if this.app_state.domain_settings.play_store_url}}
                <a href={{this.app_state.domain_settings.play_store_url}} target="_blank" rel="noopener">
                  <img src={{path "images/google_play.png"}} alt="google play" style="height: 40px; margin-top: 5px;">
                </a><br>
              {{/if}}
              {{#if this.app_state.domain_settings.kindle_store_url}}
                <a href={{this.app_state.domain_settings.kindle_store_url}} target="_blank" rel="noopener">
                  <img src={{path "images/amazon.png"}} alt="amazon" style="height: 40px; margin-top: 5px;">
                </a>
              {{/if}}
              <LinkTo @route="download">
                <img src={{path "images/windows.svg"}} alt="windows" style="height: 40px; margin-top: 5px;">
              </LinkTo>
            </div>
          </div>
        {{/if}}
        <h4>{{t "Notifications" key="notifications"}}</h4>
        <div style="margin-left: 20px;">
          {{#if this.app_state.currentUser.pending_org}}
            <p>
              <LinkTo @route="user" @model={{this.app_state.currentUser.user_name}}><span class="glyphicon glyphicon-paperclip"></span> {{t "%{org} wants to support this user as part of their organization." key="remind_pending_org" org=this.app_state.currentUser.pending_org.name}}</LinkTo>
            </p>
          {{/if}}
          {{#if this.app_state.currentUser.pending_supervision_org}}
            <p>
              <LinkTo @route="user" @model={{this.app_state.currentUser.user_name}}><span class="glyphicon glyphicon-paperclip"></span> {{t "%{org} wants to add you as a supervisor to their organization." key="remind_pending_supervision_org" org=this.app_state.currentUser.pending_supervision_org.name}}</LinkTo>
            </p>
          {{/if}}
          {{#if this.app_state.currentUser.pending_board_shares}}
            {{#each this.app_state.currentUser.pending_board_shares as |share|}}
              <p>
                <span class="glyphicon glyphicon-share"></span>
                <LinkTo @route="board" @model={{share.board_key}}>{{share.board_key}}</LinkTo>
                {{t "is being shared with you by %{user_name}<br>and needs approval" key="board_share_needs_approval" user_name=share.user_name}}
              </p>
            {{/each}}
          {{/if}}
          {{#if this.app_state.currentUser.unread_messages}}
            <p>
            <LinkTo @route="user.logs" @model={{this.app_state.currentUser.user_name}} @query={{hash type="note"}}>
              <span class="glyphicon glyphicon-envelope"></span>
              {{t "You have " key="you_have"}}
              {{t "unread message" count=this.app_state.currentUser.unread_messages key="unread_message_count"}}
            </LinkTo>
            </p>
          {{/if}}
          {{#if this.app_state.currentUser.parsed_notifications}}
            {{#each this.app_state.currentUser.parsed_notifications as |notif|}}
              <UserNotification @notification={{notif}} />
            {{/each}}
          {{/if}}
          {{#unless this.app_state.currentUser.unread_messages}}
            {{#unless this.app_state.currentUser.parsed_notifications}}
              {{#unless this.app_state.currentUser.pending_board_shares}}
                {{#if this.show_notifications_explanation}}
                  <em style="font-size: 11px;">{{t "Notifications are alerts sent from other %app_name% users. Users can send messages to everyone on a communicator's team and they'll appear here for quick review." key="notification_explanation"}}</em>
                {{else}}
                  {{t "You have no new messages" key="no_new_messages"}}
                  <a href="#" {{action "show_explanation" "notifications"}}>
                    <span class='glyphicon glyphicon-info-sign'></span>
                  </a>
                {{/if}}
              {{/unless}}
            {{/unless}}
          {{/unless}}
        </div>

        {{#if this.app_state.currentUser.supporter_role}}
          <h4>{{t "Recent Sessions for supervisees" key="recent_sessions_for_supervisees"}}</h4>
        {{else}}
          <h4>{{t "Recent Sessions" key="recent_sessions"}}</h4>
        {{/if}}
        <div style="margin-left: 20px;">
          {{#if this.logs.loading}}
            <p>{{t "Loading..." key="loading"}}</p>
          {{else if this.logs.error}}
            <p>{{t "Failed to load" key="failed_to_load"}}</p>
          {{else if this.logs}}
            {{#each this.logs as |log|}}
              <p>
                <span title={{date log.started_at}}>
                  {{date_ago log.started_at}}
                </span>
                <LinkTo @route="user.log" @models={{array log.user.user_name log.id}}>
                  {{#if log.assessment}}
                    {{t "assessment" key="assessment"}}
                  {{else}}
                    {{t "button" count=log.button_count key="button_count"}}
                  {{/if}}
                </LinkTo>
                {{#if this.app_state.currentUser.supporter_role}}
                  <span> -
                    <LinkTo @route="user" @model={{log.user.user_name}}>
                      {{log.user.user_name}}
                    </LinkTo>
                  </span>
                {{/if}}
                <br>
                <span style="color: #888; font-size: 10px; white-space: nowrap; overflow: hidden; display: block;">{{log.summary}}</span>
              </p>
            {{/each}}
          {{else}}
            {{#if this.show_sessions_explanation}}
              <p><em style="font-size: 11px;">{{t "When logging is enabled in your account preferences, your most recent sessions will appear here for quick review. If you are in the supervisor view you will instead see sessions for users you supervise." key="sessions_explanation"}}</em></p>
            {{else}}
              <p>
                {{t "No sessions currently available" key="no_sessions_found"}}
                <a href="#" {{action "show_explanation" "sessions"}}>
                  <span class='glyphicon glyphicon-info-sign'></span>
                </a>
              </p>
            {{/if}}
          {{/if}}
        </div>
      </div>
    {{/if}}
  </div>
  </div>
</div>
</div>
</div>
