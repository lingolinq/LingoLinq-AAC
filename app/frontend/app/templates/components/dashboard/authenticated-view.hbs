            {{#if this.personal_selected}}
              <div class='col-xs-12'>
                <LinkTo @route="user" @model={{this.app_state.currentUser.user_name}} class="btn btn-default btn-lg thick_border">
                  {{t "See All My Boards" key="see_all_my_boards"}}
                </LinkTo>
              </div>
            {{/if}}
          {{/if}}
        {{else}}
          <div class="col-sm-4">
            {{t "None found" key="none_found"}}
          </div>
        {{/if}}
      {{/if}}
