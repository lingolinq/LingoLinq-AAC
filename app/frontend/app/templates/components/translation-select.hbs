{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="la-translate-board-wrap">
  <div class="modal-header md-modal-header">
    <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h3>{{t "Translate Boards" key="translate_boards"}}</h3>
  </div>
  <div class="modal-body md-modal-body">

    <div class="la-translate-board-section">
      <label class="la-translate-board-label">{{t "Boards" key="boards"}}</label>
      <div class="la-translate-board-boards">
        {{#if this.hierarchy.loading}}
          <span class="la-translate-board-loading">{{t "Loading linked boards..." key="loading_linked_boards"}}</span>
        {{else if this.hierarchy.error}}
          <span class="la-translate-board-error">{{t "There was an error trying to retrieve linked boards" key="error_getting_linked_boards"}}</span>
        {{else}}
          {{board-hierarchy hierarchy=this.hierarchy selectable=true}}
        {{/if}}
      </div>
    </div>

    <div class="la-translate-board-section">
      <label class="la-translate-board-label" for="translate_locale">{{t "Language" key="language"}}</label>
      {{bound-select select_class="la-translate-board-select" select_id="translate_locale" content=this.locales selection=this.translate_locale action=(action "updateTranslateLocale") }}
    </div>

    <div class="la-translate-board-section">
      <label class="la-translate-board-checkbox">
        <Input @type="checkbox" @checked={{this.default_language}} class="la-translate-board-check" />
        <span>{{t "Switch to this as the Default Language" key="set_as_default_language"}}</span>
      </label>
    </div>

    {{#if this.existing_default_language}}
      <div class="la-translate-board-section">
        <p class="la-translate-board-info">
          {{t "This board already has some translations for this language. Would you like to switch to the existing translations as the new default language?" key="switch_default_languages_prompt"}}
        </p>
      </div>
    {{/if}}

  </div>
  <div class="modal-footer md-modal-footer">
    {{#if this.existing_default_language}}
      <button disabled={{this.switch_status.pending}} class='la-translate-board-submit' {{action "switch_language"}}>
        {{#if this.switch_status.pending}}
          {{t "Applying Translations..." key="applying_translations"}}
        {{else if this.switch_status.error}}
          {{t "Error Applying Translations" key="error_applying_translations"}}
        {{else}}
          {{t "Switch to Existing Translation" key="switch_translation"}}
        {{/if}}
      </button>
      <button class='la-translate-board-alt-btn' {{action "translate"}}>{{t "Re-Translate" key="re_translate"}}</button>
    {{else}}
      <button class='la-translate-board-submit' {{action "translate"}} disabled={{this.not_ready}}>{{t "Start Translation" key="start_translation"}}</button>
    {{/if}}
    <a href="#" class="la-translate-board-cancel" {{action "close"}}>{{t "Cancel" key="cancel"}}</a>
  </div>
  </div>
{{/modal-dialog}}
