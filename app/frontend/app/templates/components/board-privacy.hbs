{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="la-board-privacy-wrap">
  <div class="modal-header md-modal-header">
    <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h3>{{t "Adjust Board Privacy" key="adjust_board_privacy"}}</h3>
  </div>
  <div class="modal-body md-modal-body">
    {{#if this.model.confirmation}}
      <p class="la-board-privacy-desc">{{t "Would you like to update your home board to use the symbol library you've selected? You can update all the linked boards or pick and choose which to change." key="confirm_swap_images"}}</p>
    {{else}}
      <p class="la-board-privacy-desc">{{t "Select the boards you would like modified and the new level of privacy you would like set for those boards." key="privacy_instructions"}}</p>
    {{/if}}

    <div class="la-board-privacy-section">
      <label class="la-board-privacy-label">{{t "Boards" key="boards"}}</label>
      <div class="la-board-privacy-boards">
        {{#if this.hierarchy.loading}}
          <span class="la-board-privacy-loading">{{t "Loading linked boards..." key="loading_linked_boards"}}</span>
        {{else if this.hierarchy.error}}
          <span class="la-board-privacy-error">{{t "There was an error trying to retrieve linked boards" key="error_getting_linked_boards"}}</span>
        {{else if this.hierarchy}}
          {{board-hierarchy hierarchy=this.hierarchy selectable=true}}
        {{else}}
          <span class="la-board-privacy-loading">{{t "No linked boards" key="no_linked_boards"}}</span>
        {{/if}}
      </div>
    </div>

    <div class="la-board-privacy-section">
      <label class="la-board-privacy-label" for="privacy_level">{{t "Privacy" key="privacy"}}</label>
      {{bound-select select_class="la-board-privacy-select" select_id="privacy_level" content=this.privacy_levels selection=this.privacy action=(action (mut this.privacy)) }}
    </div>
  </div>
  <div class="modal-footer md-modal-footer">
    <button class='la-board-privacy-submit' {{action "update"}} disabled={{this.status.loading}}>
      {{#if this.status.loading}}
        {{t "Updating Boards..." key="updating_boards"}}
      {{else if this.status.error}}
        {{t "Updating Boards Failed" key="updating_boards_failed"}}
      {{else}}
        {{t "Update Board(s)" key="update_boards"}}
      {{/if}}
    </button>
    <a href="#" class="la-board-privacy-cancel" {{action "close"}}>{{t "Cancel" key="cancel"}}</a>
  </div>
  </div>
{{/modal-dialog}}
