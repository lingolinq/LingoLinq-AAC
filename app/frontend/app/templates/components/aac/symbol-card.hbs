{{!-- =============================================================================
  VoiceReach AAC — Symbol Card Template
  app/templates/components/aac/symbol-card.hbs
============================================================================= --}}

<div
  class={{this.cardClass}}
  role="gridcell"
  tabindex="0"
  aria-label={{this.symbol.label}}
  {{on "click" this.handleSelect}}
  {{on "keydown" this.handleKeyDown}}
>
  <div class={{this.iconWrapClass}}>
    {{#if this.symbol.imageUrl}}
      <img
        class="symbol-card__icon-img"
        src={{this.symbol.imageUrl}}
        alt={{this.symbol.label}}
        loading="lazy"
      />
    {{else}}
      <span aria-hidden="true">{{this.symbol.emoji}}</span>
    {{/if}}
  </div>

  <span class="symbol-card__label">{{this.symbol.label}}</span>
</div>
