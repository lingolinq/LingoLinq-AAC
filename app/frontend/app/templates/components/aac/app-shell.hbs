{{!-- =============================================================================
  VoiceReach AAC — App Shell Template
  app/templates/components/aac/app-shell.hbs
============================================================================= --}}

<div class="app-shell" ...attributes>

  {{!-- ======== TOP BAR ======== --}}
  <header class="app-topbar" role="banner">
    <div class="topbar__logo" aria-label="VoiceReach">
      Voice<span>Reach</span>
    </div>

    <label class="sr-only" for="topbar-search">Search symbols and phrases</label>
    <input
      id="topbar-search"
      class="topbar__search"
      type="search"
      placeholder="Search symbols, phrases…"
      value={{this.searchQuery}}
      {{on "input" this.updateSearch}}
    />

    <div class="topbar__right">
      <span
        class="topbar__badge {{if this.isClinicalMode '' 'topbar__badge--non-clinical'}}"
        aria-label="Current mode: {{this.modeLabel}}"
      >
        {{this.modeLabel}}
      </span>

      <button
        type="button"
        class="topbar__avatar"
        aria-label="Open user menu for {{this.currentUser.firstName}}"
        {{on "click" this.openUserMenu}}
      >
        {{this.userInitials}}
      </button>
    </div>
  </header>

  {{!-- ======== SIDEBAR ======== --}}
  <aside
    class="app-sidebar"
    role="navigation"
    aria-label="Main navigation"
  >
    {{#each this.navGroups as |group|}}
      <div class="sidebar__section-label">{{group.section}}</div>

      {{#each group.items as |item|}}
        <LinkTo
          class="nav-item {{if (is-active item.route) 'active'}}"
          @route={{item.route}}
          role="menuitem"
          aria-current={{if (is-active item.route) "page"}}
        >
          <span class="nav-item__icon" aria-hidden="true">{{item.icon}}</span>
          {{item.label}}
        </LinkTo>
      {{/each}}
    {{/each}}
  </aside>

  {{!-- ======== MAIN CONTENT ======== --}}
  <main class="app-main" id="main-content" role="main">
    {{yield}}
  </main>

  {{!-- ======== RIGHT PANEL ======== --}}
  <aside class="app-panel" role="complementary" aria-label="Activity panel">

    {{!-- Recent Phrases --}}
    <div class="panel-card">
      <div class="panel-card__title">Recent Phrases</div>
      <Aac::RecentPhrases />
    </div>

    {{!-- Goal Progress --}}
    <div class="panel-card">
      <div class="panel-card__title">Weekly Goals</div>
      <Aac::GoalProgress />
    </div>

    {{!-- Schedule --}}
    <div class="panel-card">
      <div class="panel-card__title">Today's Schedule</div>
      <Aac::DaySchedule />
    </div>

  </aside>

</div>
