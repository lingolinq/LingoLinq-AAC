{{!-- Single baseline for authenticated nav inner: used on authenticated view (index) and modern-dashboard. Reuses landing collapse: la-topbar-hamburger + la-mobile-drawer on small screens. --}}
<div class="app-navbar-authenticated-inner">
  <span class="app-navbar__nav-header">
    <h1 class="app-navbar__brand">
      <span class="nav-header__brand">
        <LinkTo @route="index" class="nav-header__logo-link">
          <span class="nav-header__logo">
            <img src={{path "images/logo-new.png"}} alt={{t "%app_name%" key="app_name"}}>
          </span>
        </LinkTo>
        <LinkTo @route="index" class="nav-header__app-name-link">
          <span class="nav-header__app-name"><span class="nav-header__app-name-primary">{{t "Lingo" key="app_name_lingo"}}</span><span class="nav-header__app-name-accent">{{t "Linq" key="app_name_linq"}}</span></span>
        </LinkTo>
      </span>
    </h1>
    {{#if this.appState.empty_header}}
      {{#if (persistence-online)}}
        {{#unless this.appState.super_no_linky}}
          {{#if this.application.allow_search}}
            <form id="header_search" {{action "searchBoards" on="submit"}}>
              <div class="header-search-wrap">
                <Input @type="text" @value={{this.application.searchString}} {{on "input" (action "handleSearchInput")}} @enter={{action "searchBoards"}} class="form-control header-search-input" placeholder={{t "Search Boards" key="search_boards"}} />
                <button type="submit" class="header-search-btn" aria-label={{t "Search Boards" key="search_boards"}} title={{t "Search Boards" key="search_boards"}}>
                  <svg class="header-search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                </button>
              </div>
            </form>
          {{/if}}
        {{/unless}}
      {{/if}}
    {{/if}}
  </span>
  <span id="identity" class="app-navbar-auth-nav--desktop advanced_selection identity-with-dark-toggle">
    {{#if @showModernDashboardLink}}
      <LinkTo @route="modern-dashboard" class="ll-bento-help-btn ll-bento-help-btn--nav ll-bento-help-btn--nav-icon-only" aria-label={{t "Modern Dashboard" key="modern_dashboard"}} title={{t "Modern Dashboard" key="modern_dashboard"}}>
        <span class="ll-bento-help-btn__icon" aria-hidden="true">
          <svg class="ll-bento-help-btn__nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        </span>
      </LinkTo>
    {{/if}}
    <button type="button" class="md-pillnav__upgrade-nav" aria-label={{t "Upgrade" key="upgrade"}} title={{t "Upgrade" key="upgrade"}} {{action "goUpgrade"}}>
      {{t "Upgrade" key="upgrade"}}
    </button>
    <span style="display: inline-block;" class="dropdown">
      <a class={{if (persistence-online) "btn btn-default online" "btn btn-default offline"}} id="identity_button" href="#" data-toggle="dropdown">
        <span class="user_holder">
          <img src={{this.appState.currentUser.avatar_url_with_fallback}} class="user" onerror="button_broken_image(this);">
        </span>
        {{#if this.application.session.invalid_token}}
          <span class="label label-danger unread">{{t "!" key="exclaim"}}</span>
        {{else if (persistence-value "syncing")}}
          <span class="spinning unread">
            <span class="glyphicon glyphicon-refresh" style="z-index: 2;"></span>
            <span class="glyphicon glyphicon-refresh" style="color: #fff; position: absolute; left: 2px; top: 2px;"></span>
          </span>
        {{else if (persistence-value "app_needs_update")}}
          <span class="label label-danger unread">{{t "!" key="exclaim"}}</span>
        {{else if this.appState.currentUser.unread_messages}}
          <span class="label label-danger unread">{{this.appState.currentUser.unread_messages}}</span>
        {{else}}
          <span class="status unread"></span>
        {{/if}}
        <span class="caret"></span>
      </a>
      <ul class="dropdown-menu" role="menu" aria-labelledby="dLabel" style="right: 0; left: auto; text-align: left;">
        <li class="dropdown-header">{{this.appState.currentUser.name}}</li>
        <li role="presentation">
          <LinkTo @route="user" @model={{this.appState.currentUser.user_name}}>{{t "My Account" key="my_account"}}</LinkTo>
        </li>
        <li><LinkTo @route="user.index" @model={{this.appState.currentUser.user_name}}>{{t "My Boards" key="my_boards"}}</LinkTo></li>
        <li><LinkTo @route="user.preferences" @model={{this.appState.currentUser.user_name}}>{{t "Preferences" key="preferences"}}</LinkTo></li>
        <li><LinkTo @route="user.logs" @model={{this.appState.currentUser.user_name}} @query={{hash type="note"}}>
          {{#if this.appState.currentUser.unread_messages}}
            <span class="label label-danger" style="border-radius: 5px;">{{this.appState.currentUser.unread_messages}}</span>
          {{/if}}
          {{t "Messages" key="messages"}}
        </LinkTo></li>
        <li><a href="#" {{action "support"}}>{{t "Help" key="help"}}</a></li>
        <li class="dropdown-header ll-theme-picker-dropdown-label">{{t "Color Tone" key="color_tone"}}</li>
        <li class="ll-bento-theme-picker-dropdown">
          <div class="ll-bento-theme-picker ll-bento-theme-picker--in-dropdown" role="group" aria-label={{t "Choose theme" key="choose_theme"}}>
            <div class="ll-bento-theme-picker__row">
              <div class="ll-bento-theme-picker__options">
                <button type="button" class="ll-bento-theme-picker__option {{if (is-equal this.appState.themeMode "light") "ll-bento-theme-picker__option--active"}}" {{action "selectThemeMode" "light"}} title={{t "Light" key="light"}} aria-pressed={{is-equal this.appState.themeMode "light"}}>
                  <span class="ll-bento-theme-picker__icon" aria-hidden="true"><svg class="ll-bento-theme-picker__light-teal-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="36" height="36"><defs><linearGradient id="ll-light-teal-grad-picker-dropdown" x1="0%" y1="100%" x2="100%" y2="0%"><stop offset="0%" stop-color="#64b9bc"/><stop offset="100%" stop-color="#82afdc"/></linearGradient></defs><path fill="url(#ll-light-teal-grad-picker-dropdown)" fill-rule="evenodd" d="M12 4.5L19.5 12 12 19.5 4.5 12 12 4.5z" clip-rule="evenodd"/></svg></span>
                </button>
                <button type="button" class="ll-bento-theme-picker__option {{if (is-equal this.appState.themeMode "midDay") "ll-bento-theme-picker__option--active"}}" {{action "selectThemeMode" "midDay"}} title={{t "Midday" key="midday"}} aria-pressed={{is-equal this.appState.themeMode "midDay"}}>
                  <span class="ll-bento-theme-picker__icon" aria-hidden="true"><svg class="ll-bento-theme-picker__midday-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="36" height="36"><defs><radialGradient id="ll-eclipse-sun-picker-dropdown" cx="35%" cy="35%" r="65%"><stop offset="0%" stop-color="#ffe082"/><stop offset="25%" stop-color="#ffc107"/><stop offset="50%" stop-color="#ff8f00"/><stop offset="75%" stop-color="#e65100"/><stop offset="100%" stop-color="#bf360c"/></radialGradient><radialGradient id="ll-eclipse-moon-picker-dropdown" cx="35%" cy="35%" r="65%"><stop offset="0%" stop-color="#d4dce8"/><stop offset="50%" stop-color="#a8b4c8"/><stop offset="100%" stop-color="#64748b"/></radialGradient></defs><path fill="url(#ll-eclipse-sun-picker-dropdown)" fill-rule="evenodd" d="M20 12L15.7 10.5 17.66 6.34 13.5 8.3 12 4 10.5 8.3 6.34 6.34 8.3 10.5 4 12 8.3 13.5 6.34 17.66 10.5 15.7 12 20 13.5 15.7 17.66 17.66 15.7 13.5 20 12z" clip-rule="evenodd"/><circle cx="15" cy="12" r="5.5" fill="url(#ll-eclipse-moon-picker-dropdown)"/></svg></span>
                </button>
                <button type="button" class="ll-bento-theme-picker__option {{if (is-equal this.appState.themeMode "dark") "ll-bento-theme-picker__option--active"}}" {{action "selectThemeMode" "dark"}} title={{t "Dark" key="dark"}} aria-pressed={{is-equal this.appState.themeMode "dark"}}>
                  <span class="ll-bento-theme-picker__icon" aria-hidden="true"><svg class="ll-bento-dark-toggle__moon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24"><defs><radialGradient id="ll-moon-grad-picker-dropdown" cx="35%" cy="35%" r="65%"><stop offset="0%" stop-color="#d4dce8"/><stop offset="50%" stop-color="#a8b4c8"/><stop offset="100%" stop-color="#64748b"/></radialGradient></defs><path fill="url(#ll-moon-grad-picker-dropdown)" fill-rule="evenodd" d="M9.528 1.718a.75.75 0 01.162.819A8.97 8.97 0 009 6a9 9 0 009 9 8.97 8.97 0 003.463-.69.75.75 0 01.981.98 10.503 10.503 0 01-9.694 6.46c-5.799 0-10.5-4.701-10.5-10.5 0-4.368 2.667-8.112 6.46-9.694a.75.75 0 01.818.162z" clip-rule="evenodd"/></svg></span>
                </button>
                <button type="button" class="ll-bento-theme-picker__option {{if (is-equal this.appState.themeMode "default") "ll-bento-theme-picker__option--active"}}" {{action "selectThemeMode" "default"}} title={{t "Default" key="default_theme"}} aria-pressed={{is-equal this.appState.themeMode "default"}}>
                  <span class="ll-bento-theme-picker__icon" aria-hidden="true"><svg class="ll-bento-theme-picker__gold-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="36" height="36"><defs><linearGradient id="ll-gold-grad-picker-dropdown" x1="0%" y1="100%" x2="100%" y2="0%"><stop offset="0%" stop-color="#4ECDC4"/><stop offset="50%" stop-color="#F0F0F0"/><stop offset="100%" stop-color="#FF6B47"/></linearGradient></defs><path fill="url(#ll-gold-grad-picker-dropdown)" fill-rule="evenodd" d="M12 4.5L19.5 12 12 19.5 4.5 12 12 4.5z" clip-rule="evenodd"/></svg></span>
                </button>
              </div>
            </div>
          </div>
        </li>
        <li><a href="#" {{action "invalidateSession"}}>{{t "Sign Out" key="logout"}}</a></li>
      </ul>
    </span>
  </span>
  <span class="app-navbar-auth-nav--mobile">
    <button class="la-topbar-hamburger" type="button" aria-label={{t "Open menu" key="fsa_open_menu"}} aria-expanded={{this.isDrawerOpen}} {{action "toggleDrawer"}}>
      <span class="la-topbar-hamburger__bar"></span>
      <span class="la-topbar-hamburger__bar"></span>
      <span class="la-topbar-hamburger__bar"></span>
    </button>
  </span>
  <LaMobileDrawer @isOpen={{this.isDrawerOpen}} @onClose={{action "closeDrawer"}}>
    <div class="la-mobile-drawer__header">{{this.appState.currentUser.name}}</div>
    <div class="la-mobile-drawer__divider"></div>
    {{#if @showModernDashboardLink}}
      <LinkTo @route="modern-dashboard" class="la-mobile-drawer__link" {{action "closeDrawer"}}>{{t "Modern Dashboard" key="modern_dashboard"}}</LinkTo>
    {{/if}}
    <button type="button" class="la-mobile-drawer__link la-mobile-drawer__link--button" {{action "closeDrawerAndSend" "goUpgrade"}}>{{t "Upgrade" key="upgrade"}}</button>
    <button type="button" class="la-mobile-drawer__link la-mobile-drawer__link--button" {{action "closeDrawerAndSend" "support"}}>{{t "Help" key="help"}}</button>
    <button type="button" class="la-mobile-drawer__link la-mobile-drawer__link--button" {{action "toggleThemePicker"}}>{{t "Theme" key="theme"}}</button>
    {{#if this.application.showThemePicker}}
      <div class="ll-bento-theme-picker ll-bento-theme-picker--in-drawer" role="dialog" aria-label={{t "Choose theme" key="choose_theme"}}>
        <div class="ll-bento-theme-picker__row">
          <div class="ll-bento-theme-picker__options">
            <button type="button" class="ll-bento-theme-picker__option {{if (is-equal this.appState.themeMode "light") "ll-bento-theme-picker__option--active"}}" {{action "selectThemeMode" "light"}} title={{t "Light" key="light"}} aria-pressed={{is-equal this.appState.themeMode "light"}}>
              <span class="ll-bento-theme-picker__icon" aria-hidden="true"><svg class="ll-bento-theme-picker__light-teal-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="36" height="36"><defs><linearGradient id="ll-light-teal-grad-picker-drawer" x1="0%" y1="100%" x2="100%" y2="0%"><stop offset="0%" stop-color="#64b9bc"/><stop offset="100%" stop-color="#82afdc"/></linearGradient></defs><path fill="url(#ll-light-teal-grad-picker-drawer)" fill-rule="evenodd" d="M12 4.5L19.5 12 12 19.5 4.5 12 12 4.5z" clip-rule="evenodd"/></svg></span>
            </button>
            <button type="button" class="ll-bento-theme-picker__option {{if (is-equal this.appState.themeMode "midDay") "ll-bento-theme-picker__option--active"}}" {{action "selectThemeMode" "midDay"}} title={{t "Midday" key="midday"}} aria-pressed={{is-equal this.appState.themeMode "midDay"}}>
              <span class="ll-bento-theme-picker__icon" aria-hidden="true"><svg class="ll-bento-theme-picker__midday-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="36" height="36"><defs><radialGradient id="ll-eclipse-sun-picker-drawer" cx="35%" cy="35%" r="65%"><stop offset="0%" stop-color="#ffe082"/><stop offset="25%" stop-color="#ffc107"/><stop offset="50%" stop-color="#ff8f00"/><stop offset="75%" stop-color="#e65100"/><stop offset="100%" stop-color="#bf360c"/></radialGradient><radialGradient id="ll-eclipse-moon-picker-drawer" cx="35%" cy="35%" r="65%"><stop offset="0%" stop-color="#d4dce8"/><stop offset="50%" stop-color="#a8b4c8"/><stop offset="100%" stop-color="#64748b"/></radialGradient></defs><path fill="url(#ll-eclipse-sun-picker-drawer)" fill-rule="evenodd" d="M20 12L15.7 10.5 17.66 6.34 13.5 8.3 12 4 10.5 8.3 6.34 6.34 8.3 10.5 4 12 8.3 13.5 6.34 17.66 10.5 15.7 12 20 13.5 15.7 17.66 17.66 15.7 13.5 20 12z" clip-rule="evenodd"/><circle cx="15" cy="12" r="5.5" fill="url(#ll-eclipse-moon-picker-drawer)"/></svg></span>
            </button>
            <button type="button" class="ll-bento-theme-picker__option {{if (is-equal this.appState.themeMode "dark") "ll-bento-theme-picker__option--active"}}" {{action "selectThemeMode" "dark"}} title={{t "Dark" key="dark"}} aria-pressed={{is-equal this.appState.themeMode "dark"}}>
              <span class="ll-bento-theme-picker__icon" aria-hidden="true"><svg class="ll-bento-dark-toggle__moon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24"><defs><radialGradient id="ll-moon-grad-picker-drawer" cx="35%" cy="35%" r="65%"><stop offset="0%" stop-color="#d4dce8"/><stop offset="50%" stop-color="#a8b4c8"/><stop offset="100%" stop-color="#64748b"/></radialGradient></defs><path fill="url(#ll-moon-grad-picker-drawer)" fill-rule="evenodd" d="M9.528 1.718a.75.75 0 01.162.819A8.97 8.97 0 009 6a9 9 0 009 9 8.97 8.97 0 003.463-.69.75.75 0 01.981.98 10.503 10.503 0 01-9.694 6.46c-5.799 0-10.5-4.701-10.5-10.5 0-4.368 2.667-8.112 6.46-9.694a.75.75 0 01.818.162z" clip-rule="evenodd"/></svg></span>
            </button>
            <button type="button" class="ll-bento-theme-picker__option {{if (is-equal this.appState.themeMode "default") "ll-bento-theme-picker__option--active"}}" {{action "selectThemeMode" "default"}} title={{t "Default" key="default_theme"}} aria-pressed={{is-equal this.appState.themeMode "default"}}>
              <span class="ll-bento-theme-picker__icon" aria-hidden="true"><svg class="ll-bento-theme-picker__gold-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="36" height="36"><defs><linearGradient id="ll-gold-grad-picker-drawer" x1="0%" y1="100%" x2="100%" y2="0%"><stop offset="0%" stop-color="#4ECDC4"/><stop offset="50%" stop-color="#F0F0F0"/><stop offset="100%" stop-color="#FF6B47"/></linearGradient></defs><path fill="url(#ll-gold-grad-picker-drawer)" fill-rule="evenodd" d="M12 4.5L19.5 12 12 19.5 4.5 12 12 4.5z" clip-rule="evenodd"/></svg></span>
            </button>
          </div>
        </div>
      </div>
    {{/if}}
    <div class="la-mobile-drawer__divider"></div>
    <LinkTo @route="user" @model={{this.appState.currentUser.user_name}} class="la-mobile-drawer__link" {{action "closeDrawer"}}>{{t "My Account" key="my_account"}}</LinkTo>
    <LinkTo @route="user.index" @model={{this.appState.currentUser.user_name}} class="la-mobile-drawer__link" {{action "closeDrawer"}}>{{t "My Boards" key="my_boards"}}</LinkTo>
    <LinkTo @route="search" @models={{array "any" "_"}} class="la-mobile-drawer__link" {{action "closeDrawer"}}>{{t "Find Board" key="find_board"}}</LinkTo>
    {{#if this.appState.currentUser.permissions.delete}}
      <a href="#" class="la-mobile-drawer__link" {{action "closeDrawerAndSend" "newBoard"}}>{{t "Create a New Board" key="create_a_new_board"}}</a>
    {{/if}}
    <LinkTo @route="user.preferences" @model={{this.appState.currentUser.user_name}} class="la-mobile-drawer__link" {{action "closeDrawer"}}>{{t "Preferences" key="preferences"}}</LinkTo>
    <LinkTo @route="user.logs" @model={{this.appState.currentUser.user_name}} @query={{hash type="note"}} class="la-mobile-drawer__link" {{action "closeDrawer"}}>{{t "Messages" key="messages"}}</LinkTo>
    <a href="#" class="la-mobile-drawer__link" {{action "closeDrawerAndSend" "invalidateSession"}}>{{t "Sign Out" key="logout"}}</a>
  </LaMobileDrawer>
</div>
