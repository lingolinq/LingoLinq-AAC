{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="modal-header md-modal-header">
    <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h3>{{t "Push Local Data to the Cloud" key="push_local_to_cloud"}}</h3>
  </div>
  <div class="modal-body md-modal-body">
    <p>
      <span class='glyphicon glyphicon-cloud-upload' style='float: left; font-size: 50px; margin: 0 10px 5px 0;'></span>
      {{t "Are you sure you want to push your %{cnt} local boards to the cloud? If you have made changes to your boards from a different device then your changed may be overwritten." cnt=this.local_boards key="confirm_push_to_cloud"}}
    </p>
  </div>
  <div class="modal-header md-modal-header">
    <button class='btn btn-default btn-lg' {{action "push"}} disabled={{this.status.pushing}}>
      {{#if this.status.pushing}}
        {{t "Pushing to Cloud..." key="pushing_to_cloud"}}
      {{else if this.status.error}}
        {{t "Error Pushing to Cloud" key="error_pushing_to_cloud"}}
      {{else}}
        {{t "Push to Cloud" key="push_to_cloud"}}
      {{/if}}
    </button>
    <button class='btn btn-primary btn-lg' {{action "close"}}>{{t "Cancel" key="cancel"}}</button>
    {{#if this.status.save_failed}}
      <p class='text-danger'>{{t "One or more boards were not successfully pushed to the cloud" key="one_or_more_boards_failed_to_push"}}</p>
    {{/if}}
  </div>
{{/modal-dialog}}
