{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="la-batch-recording-wrap">
  <div class="modal-header md-modal-header">
    <button type="button" class="la-modal-close" {{action "close"}} aria-label={{t "Close" key="close"}}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h3>
      {{#if this.model.single}}
        {{t "Record Audio" key="record_audio"}}
      {{else}}
        {{t "Batch Recording" key="batch_recording"}}
      {{/if}}
    </h3>
  </div>
  <div class="modal-body md-modal-body">
    {{#if this.appState.currentUser.supervisees}}
      <div class="la-batch-recording-section">
        <label class="la-batch-recording-label">{{t "Recording For" key="recording_for"}}</label>
        {{user-select select_id="for_user_id" selection=this.for_user_id action=(action "updateForUserId") }}
      </div>
    {{/if}}
    {{#if this.model.user}}
      {{#if this.model.single}}
        {{audio-recorder id=this.phrase.id pending_sound=this.phrase.pending_sound text=this.phrase.text next_phrase=this.next_phrase sound=this.phrase.sound decide_on_recording=(action "decide_on_recording") select_phrase=(action "select_phrase") audio_ready=(action "audio_ready") audio_not_ready=(action "audio_not_ready")}}
      {{else if this.phrase}}
        <div class="la-batch-recording-nav">
          <button class='la-batch-recording-back-btn' {{action "select_phrase"}}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <div>
            <h4 class="la-batch-recording-phrase-title">"{{this.phrase.text}}"</h4>
            <span class="la-batch-recording-breadcrumb">{{this.category.name}} <span class="la-batch-recording-breadcrumb--dim">{{this.repository.name}}</span></span>
          </div>
        </div>
        {{audio-recorder id=this.phrase.id user_id=this.model.user.id pending_sound=this.phrase.pending_sound text=this.phrase.text next_phrase=this.next_phrase sound=this.phrase.sound decide_on_recording="decide_on_recording" select_phrase="select_phrase" audio_ready="audio_ready" audio_not_ready="audio_not_ready"}}
      {{else if this.category}}
        <div class="la-batch-recording-nav">
          <button class='la-batch-recording-back-btn' {{action "select_category"}}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <div>
            <h4 class="la-batch-recording-phrase-title">{{this.category.name}}</h4>
            <span class="la-batch-recording-breadcrumb">{{this.repository.name}}</span>
          </div>
        </div>
        <div class='la-batch-recording-list'>
          {{#each this.category.phrases as |p|}}
            <button class='la-batch-recording-list-item' {{action "select_phrase" p.id}}>
              {{#if p.pending_sound}}
                <span class="la-batch-recording-icon la-batch-recording-icon--warning">!</span>
              {{else if p.sound}}
                <span class="la-batch-recording-icon la-batch-recording-icon--ok">&#x2713;</span>
              {{/if}}
              <span>{{p.text}}</span>
            </button>
          {{/each}}
          {{#if this.custom_phrase}}
            <div class='la-batch-recording-list-item la-batch-recording-list-item--input'>
              <Input @insert-newline={{action "confirm_add_phrase"}} @escape-press={{action "cancel_add_phrase"}} id="custom_phrase_text" @type="text" class="la-batch-recording-input" @value={{this.custom_phrase.text}} placeholder={{t "Type a phrase" key="type_a_phrase"}} />
              <button class='la-batch-recording-add-btn' {{action "confirm_add_phrase"}}>{{t "Add" key="add"}}</button>
            </div>
          {{else}}
            <button class='la-batch-recording-list-item la-batch-recording-list-item--add' {{action "add_phrase"}}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              {{t "Add another phrase" key="add_another_phrase"}}
            </button>
          {{/if}}
        </div>
        {{#if this.next_category}}
          <div class="la-batch-recording-next">
            <button class='la-batch-recording-next-btn' {{action "select_category" this.next_category.id}}>{{t "Next Category" key="next_category"}}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
        {{/if}}
      {{else if this.repository}}
        {{#if this.repository.loading}}
          <p class="la-batch-recording-loading">{{t "Loading repository..." key="loading_repository"}}</p>
        {{else if this.repository.error}}
          <p class="la-batch-recording-error">{{t "Error loading repository" key="error_loading_repository"}}</p>
        {{else}}
          <h4 class="la-batch-recording-repo-title">{{this.repository.name}}</h4>
          <p class="la-batch-recording-repo-desc">
            {{this.repository.description}}
            {{#if this.repository.url}}
              <a href={{this.repository.url}} target="_blank" rel="noopener">{{t "learn more" key="learn_more_lower"}}</a>
            {{/if}}
          </p>
          {{#if this.repository.total}}
            <div class="la-batch-recording-progress">{{delimit this.repository.recorded}} / {{delimit this.repository.total}} {{t "recorded" key="recorded"}}</div>
          {{/if}}
          <div class="la-batch-recording-list">
            {{#each this.repository.categories as |cat|}}
              <button class='la-batch-recording-list-item' {{action "select_category" cat.id}}>
                {{#if cat.pending_sound}}
                  <span class="la-batch-recording-icon la-batch-recording-icon--warning">!</span>
                {{/if}}
                <span>{{cat.name}}</span>
                <span class="la-batch-recording-count">{{cat.recordings}} / {{cat.phrases.length}}</span>
              </button>
            {{/each}}
          </div>
        {{/if}}
      {{else}}
        <p class="la-batch-recording-loading">{{t "Loading..." key="loading"}}</p>
      {{/if}}
    {{else}}
      <div class="la-batch-recording-section">
        <p>{{t "Select the user to record audio for" key="select_recording_user"}}</p>
        {{user-select select_id="for_user_id" buttons=true selection=this.for_user_id action=(action "updateForUserId") }}
      </div>
    {{/if}}
  </div>
  <div class="modal-footer md-modal-footer">
    <a href="#" class="la-batch-recording-close" {{action "close"}}>{{t "Close" key="close"}}</a>
  </div>
  </div>
{{/modal-dialog}}
