{{#opening-observer opening=(action "opening")}}
<div class="flash" style={{this.extra_styles}}>
  <div class={{this.display_class}}>
    <div class='shadow'></div>
    {{#if this.sticky}}
      {{#if this.redirect.contact}}
        <div style='float: right; width: 100px; margin: -10px -30px -10px 10px;'>
        <button type='button' class='btn btn-default' data-dismiss='alert' style='width: 100px;' {{action "confirm"}} aria-hidden='true'>{{t "Got It" key="got_it"}}</button>
        <button type='button' class='btn btn-default' data-dismiss='alert' style='width: 100px; margin-top: 2px;' {{action "contact"}} aria-hidden='true'>{{t "Contact Us" key="contact_us"}}</button>
        </div>
      {{else}}
        <button type='button' class='btn btn-default' data-dismiss='alert' {{action "confirm"}} aria-hidden='true' style='float: right; margin: -8px -20px -10px 10px;'>{{t "Got It" key="got_it"}}</button>
      {{/if}}
    {{else if this.action}}
      <button type='button' class='btn btn-default' data-dismiss='alert' {{action "confirm"}} aria-hidden='true' style='float: right; margin: -8px -20px -10px 10px;'>{{this.action.text}}</button>
    {{else}}
      <button type="button" class="close" data-dismiss="alert" aria-hidden="true">&times;</button>
    {{/if}}
    {{this.message}}
    <div style='clear: right;'></div>
  </div>
</div>
{{/opening-observer}}