<LinkTo @route="board" @model={{board}} class="well well-sm board_icon">
  <span style='display: block;' title={{board.long_preview}}>
    <span class="icon" style='display: block;'>
      <img src={{board.icon_url_with_fallback}} onerror="button_broken_image(this);">
    </span>
    <span style="display: block; height: 50px">
      <span style="color: #666; padding-left: 8px; display: block;">
        {{board.grid.rows}} x {{board.grid.columns}}
      </span>
      {{#if board.unlinked_buttons}}
        <span style="color: #888; padding-left: 8px; display: block;">
          <span class="glyphicon glyphicon-th"></span>
          {{board.unlinked_buttons}}
        </span>
      {{/if}}
      {{#if board.stars}}
        <span style="color: #e74c6f; padding-left: 8px; display: block;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle;"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          {{board.stars}}
        </span>
      {{/if}}
      {{#if board.different_locale}}
        <span style='color: #888; padding-left: 8px; display: block;'>
          {{board.shortened_locale}}
        </span>
      {{/if}}
    </span>
    <span style="display: block; clear: both;"></span>
  </span>
  <span class="names" title={{board.long_preview}}>
    <span class="name">
      {{#unless board.public}}<span class="glyphicon glyphicon-lock"></span>{{/unless}}
      {{board.name}}{{#if board.copy_version}} <span style='color: #666; font-size: 10px;'>({{board.copy_version}})</span>{{/if}}
    </span><br>
    <span class="labels">{{board.labels}}</span>
  </span><br>
  <span class="user_name">{{board.user_name}}</span><br>
</LinkTo>
