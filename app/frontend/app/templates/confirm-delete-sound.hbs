{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
  <div class="modal-header">
    <button type="button" class="close" {{action "close"}}>&times;</button>
    <h3>{{t "Remove this Sound" key="delete_this_sound"}}</h3>
  </div>
  <div class="modal-body">
    <p>
      {{t "Are you sure you want to delete this recording? Any buttons using it will no longe work." key="confirm_delete_recording"}}
    </p>

    {{this.model.sound.name}} {{t "created" key="created_lower"}} {{date this.model.sound.created "short_day"}}
    <div class='text-muted' style='margin-left: 30px;'>
      {{#if this.model.sound.transcription}}
        {{this.model.sound.transcription}}
      {{else}}
        {{t "no transcription" key="no_transcription"}}
      {{/if}}
    </div>

    {{#if this.status.error}}
      <p class='text-danger'>{{t "There was an error trying to delete the recording" key="error_deleting_sound"}}</p>
    {{/if}}
  </div>
  <div class="modal-footer">
    <button class='btn btn-default' {{action "delete_sound"}} disabled={{this.status.deleting}}>
      {{#if this.status.deleting}}
        {{t "Deleting Recording" key="deleting_sound"}}
      {{else}}
        {{t "Delete Recording" key="delete_sound"}}
      {{/if}}
    </button>
    <button class='btn btn-default' {{action "close"}}>{{t "Cancel" key="cancel"}}</button>
  </div>
{{/modal-dialog}}

