<div style='max-width: 600px; margin: 20px auto 0;'>
  {{#if this.result.loading}}
    <h2>{{t "Loading..." key="loading"}} {{this.code}}</h2>
  {{else if this.result.error}}
    <h2>{{t "Error Loading" key="error_loading"}} {{this.code}}</h2>
  {{else}}
    {{#if this.result.image_url}}
      <img src={{this.result.image_url}} style='width: 50px; height: 50px; margin-right: 15px; margin-top: -10px;' class='fit_image' >
    {{else}}
      <span class='glyphicon glyphicon-paperclip' style='float: left; font-size: 50px; margin-right: 15px; margin-top: -10px;'></span>
    {{/if}}
    <h2>{{t "Start Code - " key="start_code_dash"}} {{this.result.code}}</h2>
    <div style='clear: both;'></div>
    <dl class='dl-horizontal'>
      <dt>{{t "Name:" key="name_colon"}}</dt>
        <dd>
          {{#if this.result.organization}}
            {{#link-to "organization" this.result.target_id}}{{this.result.name}}{{/link-to}}
          {{else if this.result.supervisor}}
            {{#link-to "user" this.result.target_id}}{{this.result.name}}{{/link-to}}
          {{else}}
            {{this.result.name}}
          {{/if}}
          {{#if this.result.disabled}}
            {{t "(disabled)" key="paren_disabled"}}
          {{/if}}
        </dd>
      <dt>{{t "Type:" key="type_colon"}}</dt>
        <dd>{{this.result.type}}</dd>
      {{#if this.result.overrides.home_board_key}}
        <dt>{{t "Home Board:" key="home_board_colon"}}</dt>
          <dd>
            {{#link-to "board" this.result.overrides.home_board_key}}
              {{this.result.overrides.home_board_key}}
            {{/link-to}}
          </dd>
      {{/if}}
      {{#if this.result.overrides.locale}}
        <dt>{{t "Language:" key="language_colon"}}</dt> 
          <dd>{{this.result.overrides.locale}}</dd>
      {{/if}}
      {{#if this.result.overrides.symbol_library}}
        <dt>{{t "Symbols:" key="symbols_colon"}}</dt> 
          <dd>{{this.result.overrides.symbol_library}}</dd>
      {{/if}}
      {{#if this.result.overrides.premium}}
        <dt>{{t "Sponsored" key="sponsored"}}</dt>
          <dd>{{t "yes" key="yes"}}</dd>
      {{/if}}
      {{#if this.result.overrides.premium_symbols}}
        <dt>{{t "Premium Symbols" key="premium_symbols"}}</dt>
          <dd>{{t "yes" key="yes"}}</dd>
      {{/if}}
      {{#if this.result.overrides.supervisors}}
        <dt>
          {{t "Supervisors:" key="supervisors_colon"}}
        </dt>
          <dd>
            {{#each this.result.overrides.supervisors as |sup|}}
              <span style='padding-right: 10px;'>{{sup}}</span>
            {{/each}}
          </dd>
      {{/if}}
    </dl>
    <h4>{{t "Activated Users" key="activated_users"}}</h4>
    {{#if this.result.users.length}}
      <ul class='list-group'>
      {{#each this.result.users as |user|}}
        <li class='list-group-item'>
          {{#link-to "user" user.id}}
            <img src={{user.avatar_url}} style='height: 30px; width: 30px; margin-right: 10px;' class='fit_image' >
            {{user.user_name}}
          {{/link-to}}
        </li>
      {{/each}}
      </ul>
    {{else}}
      <p>{{t "None" key="none"}}</p>
    {{/if}}
  {{/if}}
</div>