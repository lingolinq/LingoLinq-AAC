<div style="display: flex; align-items: flex-start; justify-content: center; padding: 20px 24px; min-height: 60vh;">
  <div style="background: rgba(255,255,255,0.76); border: 1px solid rgba(17,26,46,0.10); border-radius: 28px; box-shadow: 0 18px 50px rgba(17,26,46,0.12); padding: 48px; max-width: 600px; width: 100%; text-align: center;">
    <div style="display: flex; align-items: center; justify-content: center; gap: 20px; margin-bottom: 24px;">
      <img src={{path "images/not-found.png"}} alt="" style="width: 180px; height: auto; flex-shrink: 0;">
      <div style="display: inline-block; background: rgba(240,106,91,0.16); color: #f06a5b; font-size: 18px; font-weight: 700; padding: 4px 14px; border-radius: 20px;">
        {{#if (persistence-online)}}
          {{t "Error" key="error"}}
        {{else}}
          {{t "Offline" key="offline"}}
        {{/if}}
      </div>
    </div>
    <h1 style="font-size: 32px; font-weight: 800; color: #1B365D; margin-bottom: 12px; letter-spacing: -0.5px;">
      {{#if (persistence-online)}}
        {{t "Failed to load" key="failed_to_load"}}
      {{else}}
        {{t "Unavailable offline" key="unavailable_offline"}}
      {{/if}}
    </h1>
    <p style="font-size: 17px; line-height: 1.6; color: #46505F; margin-bottom: 16px;">
      {{#if (persistence-online)}}
        {{t "The requested resource failed to load. If you got here through a web link then it's possible the resource was renamed, and you might find it by searching. If you got here from a link within %app_name% you may want to report the error through our support tool." key="failed_to_load_online"}}
      {{else}}
        {{t "The requested resource failed to load. This probably happened because you tried to access something that isn't available when offline. You can try connecting to the Internet and attempting the action again." key="failed_to_load_offline"}}
      {{/if}}
    </p>
    <p style="font-size: 15px; line-height: 1.6; color: #7389A3; margin-bottom: 28px;">
      {{t "If you reached this page unexpectedly, we'd appreciate it if you let us know so we can look into it." key="error_report_prompt"}}
    </p>
    <a href="/beta-feedback" style="display: inline-block; background: #316f70; color: #fff; font-size: 16px; font-weight: 700; padding: 12px 32px; border-radius: 50px; text-decoration: none; box-shadow: 0 4px 12px rgba(49,111,112,0.3);">{{t "Send Beta Feedback" key="send_beta_feedback"}}</a>
  </div>
</div>
