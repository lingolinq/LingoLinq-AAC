<div class="md-shell md-shell--org">
  <div class="md-workspace">
    <nav class="md-pillnav md-pillnav--dashboard" aria-label={{t "Organization Navigation" key="org_navigation"}}>
      <LinkTo @route="organization.index" @model={{this.model.id}} class="md-pillnav__pill">{{t "Admin" key="admin"}}</LinkTo>
      <LinkTo @route="organization.people" @model={{this.model.id}} class="md-pillnav__pill">{{t "People" key="people"}}</LinkTo>
      <LinkTo @route="organization.reports" @model={{this.model.id}} class="md-pillnav__pill">{{t "Reports" key="reports"}}</LinkTo>
      <LinkTo @route="organization.rooms" @model={{this.model.id}} class="md-pillnav__pill">{{t "Rooms" key="rooms"}}</LinkTo>
      <LinkTo @route="organization.settings" @model={{this.model.id}} class="md-pillnav__pill">{{t "Settings" key="settings"}}</LinkTo>
    </nav>

    <header class="md-hero md-hero--dashboard md-hero--org">
      <h1 class="md-hero__title"><span class="md-hero__title--from-left">
        {{#if this.model.permissions.view}}
          {{this.model.name}}
        {{else}}
          {{t "Organization" key="organization"}}
        {{/if}}
      </span></h1>
      <div class="md-org-meta">
        <span class="md-org-meta__chip">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          {{t "user" key="user_count" count=this.model.total_users}}
        </span>
        {{#if this.model.total_supervisors}}
          <span class="md-org-meta__chip">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            {{t "supervisor" key="supervisor_count" count=this.model.total_supervisors}}
          </span>
        {{/if}}
        <span class="md-org-meta__chip">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          {{t "manager" key="manager_count" count=this.model.total_managers}}
        </span>
        {{#if this.model.created}}
          <span class="md-org-meta__chip md-org-meta__chip--muted" title={{date this.model.created}}>
            {{t "created" key="created_lower"}} {{date_ago this.model.created}}
          </span>
        {{/if}}
      </div>
    </header>

    <main class="md-main md-main--org">
      {{outlet}}
    </main>
  </div>
</div>
