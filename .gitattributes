# Ensure Unix line endings in Docker containers
*.sh text eol=lf
*.rb text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.js text eol=lf
*.json text eol=lf
Gemfile text eol=lf
Gemfile.lock text eol=lf
Rakefile text eol=lf
config.ru text eol=lf

# Windows-specific files keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary