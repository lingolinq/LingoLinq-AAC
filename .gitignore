bin/nrdebug
bin/pry
bin/puma
bin/pumactl
bin/racc
bin/rackup
bin/rbs
bin/rdoc
bin/resque
bin/resque-web
bin/reverse_markdown
bin/ri
bin/rotp
bin/rspec
bin/rubocop
bin/ruby-parse
bin/ruby-rewrite
bin/sdoc
bin/sdoc-merge
bin/solargraph
bin/sprockets
bin/stripe-console
bin/thor
