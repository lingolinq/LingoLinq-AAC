# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore file:
#   git config --global core.excludesfile '~/.gitignore_global'

# Ignore bundler config.
/.bundle

# Ignore all logfiles and tempfiles.
/log/*
/logs/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore database files
/db/*.sqlite3

# Ignore large generated JavaScript assets (these cause Windows path issues)
/app/assets/javascripts/frontend.js
/app/assets/javascripts/vendor.js

# Ignore backups and caches
/.cleanup-backup/
/.ruby-lsp/

/coverage/

/public/uploads/*
!/public/uploads/.keep

/vendor/bundle

.env
.env.test

# IMPORTANT: We now commit pre-built Ember assets to ensure consistent deployments
# /app/frontend/dist  # REMOVED - dist/ is now committed to git
/app/frontend/tmp

/app/assets/javascripts/app.js
/app/assets/javascripts/templates.js
/app/assets/javascripts/vendor.js
/app/assets/stylesheets/app.css
/app/assets/stylesheets/vendor.css
/app/assets/fonts/*
!/app/assets/fonts/.keep

/public/assets

.DS_Store

/node_modules
npm-debug.log

config/database.yml.backup

# AI Development Tools
# Personal Claude settings (team configs should be committed)
.claude/settings.personal.json
.claude/session-*
.claude/temp-*

# AI session and temporary files
.ai/context/session-*.json
.ai/context/agent-changes-*.log
.ai/context/temp-*.json
.ai/temp/
.ai/sessions/
ai-session-*.json
ai-debug-*.log

# MCP and AI tool temporary files
.ai/tools/*/node_modules
.ai/tools/*/temp/
.ai/tools/*/.npm-cache
mcp-debug-*.log

# Personal environment overrides
.env.personal
.env.local.*

# Docker development
docker-compose.override.yml
.docker-build-cache/

# Backups and temporary files
bin/devin.backup
launcher.ps1
*.backup
*.tmp
*~
/config/master.key

# Temporary debug logs
*.log
docker-build*.log
fly-deploy*.log

# Session handoff files (document elsewhere if needed)
DEBUGGING_LOG.md
HELP_REQUEST.md
NEXT_SESSION_PROMPT.md
SESSION_HANDOFF.md

# IDE settings (local only)
.vscode/
.claude/settings.local.json

# Gem binstubs (auto-generated)
bin/_guard-core
bin/aws_sqs_active_job
bin/brakeman
bin/bundle-audit
bin/bundler-audit
bin/coderay
bin/dotenv
bin/erb
bin/guard
bin/htmldiff
bin/irb
bin/jmespath.rb
bin/kramdown
bin/ldiff
bin/listen
bin/newrelic
