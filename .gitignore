# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

# Ignore bundler config.
/.bundle

# Ignore the default SQLite database.
/db/*.sqlite3
/db/*.sqlite3-journal

# Ignore all logfiles and tempfiles.
/log
/tmp
/test
/vendor

/.env
/.env.*
!.env.example

/app/frontend/dist/
/app/frontend/tmp/
/app/assets/javascripts/frontend/bower_components/

/coverage

.DS_Store
*.code-workspace
/lib/domains.json
# Ignore master key for decrypting credentials and more.
/config/master.key
.env


# Development tools (keep context files for contributors)
.ai/tools/deepwiki-mcp/node_modules/
.ai/tools/deepwiki-mcp/dist/
.vscode/

# AI Development Environment - Session Data (ignore)
/.ai/context/session-context.json
/.ai/context/agent-changes.log
/.ai/context/shared-state.json
/.ai/agents/coordinator/node_modules/
/logs/

# AI Development Environment - Config Files (keep for team)
# These files should be committed so other developers can use AI coordination:
# /ai-agents/project-constraints.json  
# /ai-agents/claude-config.json
# /ai-agents/gemini-config.json
# /docker-compose.dev.yml

# Docker volumes (always ignore)
postgres_data/
redis_data/
backend_gems/
frontend_node_modules/
ai_context_data/
