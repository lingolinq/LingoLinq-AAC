# =============================================================================
# LingoLinq-AAC Local Development Environment Template
# =============================================================================
#
# This file uses 1Password secret references (op:// URIs) instead of plaintext
# secrets. It is SAFE to commit to git.
#
# HOW TO USE:
#
# 1. Install the 1Password CLI:
#    curl -sS https://downloads.1password.com/linux/keys/1password.asc | \
#      sudo gpg --batch --dearmor -o /usr/share/keyrings/1password-archive-keyring.gpg
#    echo "deb [arch=amd64 signed-by=/usr/share/keyrings/1password-archive-keyring.gpg] \
#      https://downloads.1password.com/linux/debian/amd64 stable main" | \
#      sudo tee /etc/apt/sources.list.d/1password.list
#    sudo apt update && sudo apt install 1password-cli
#
# 2. Sign in with your personal 1Password account:
#    eval $(op signin)
#
# 3. Run your app with secrets injected:
#    op run --env-file=.env.op.template -- bundle exec rails server
#    op run --env-file=.env.op.template -- bundle exec rake db:migrate
#    op run --env-file=.env.op.template -- bundle exec rspec
#
# Secrets are decrypted in memory and cleared when the process exits.
# They never touch disk. When values change in 1Password, restart your
# app and you get the new values automatically.
#
# For convenience, alias it in your shell:
#   alias rails-dev='op run --env-file=$HOME/projects/LingoLinq-AAC/.env.op.template --'
#   Then: rails-dev bundle exec rails server
#
# =============================================================================
# Shared keys (everyone gets these via Shared Dev vault)
# =============================================================================

# AI APIs
GEMINI_API_KEY=op://LingoLinq Shared Dev/AI Keys/GEMINI_API_KEY
ANTHROPIC_API_KEY=op://LingoLinq Shared Dev/AI Keys/ANTHROPIC_API_KEY

# Stripe (test mode keys for local dev)
STRIPE_SECRET_KEY=op://LingoLinq Shared Dev/Stripe/STRIPE_SECRET_KEY
STRIPE_PUBLIC_KEY=op://LingoLinq Shared Dev/Stripe/STRIPE_PUBLIC_KEY

# OpenSymbols (symbol library)
OPENSYMBOLS_SECRET=op://LingoLinq Shared Dev/OpenSymbols/OPENSYMBOLS_SECRET

# Google APIs (TTS, Translate, Places, YouTube)
GOOGLE_TTS_TOKEN=op://LingoLinq Shared Dev/Google APIs/GOOGLE_TTS_TOKEN
GOOGLE_TRANSLATE_TOKEN=op://LingoLinq Shared Dev/Google APIs/GOOGLE_TRANSLATE_TOKEN
GOOGLE_PLACES_TOKEN=op://LingoLinq Shared Dev/Google APIs/GOOGLE_PLACES_TOKEN
YOUTUBE_API_KEY=op://LingoLinq Shared Dev/Google APIs/YOUTUBE_API_KEY

# External services
IPLOCATE_API_KEY=op://LingoLinq Shared Dev/External Services/IPLOCATE_API_KEY

# Email config
DEFAULT_EMAIL_FROM=op://LingoLinq Shared Dev/Email Config/DEFAULT_EMAIL_FROM
SYSTEM_ERROR_EMAIL=op://LingoLinq Shared Dev/Email Config/SYSTEM_ERROR_EMAIL
NEW_REGISTRATION_EMAIL=op://LingoLinq Shared Dev/Email Config/NEW_REGISTRATION_EMAIL

# Rails secrets (dev-level -- safe for local dev)
SECRET_KEY_BASE=op://LingoLinq Shared Dev/Rails Secrets/SECRET_KEY_BASE
SECURE_NONCE_KEY=op://LingoLinq Shared Dev/Rails Secrets/SECURE_NONCE_KEY

# =============================================================================
# Admin-only keys (senior devs + co-founders only via Admin vault)
# =============================================================================
#
# AWS credentials -- contractors don't need this. Comment out if you are a
# contractor who doesn't need S3 upload testing locally.
AWS_KEY=op://LingoLinq Admin/AWS Credentials/AWS_KEY
AWS_SECRET=op://LingoLinq Admin/AWS Credentials/AWS_SECRET

# =============================================================================
# Personal tokens (each dev uses their own -- stored in their Private vault)
# =============================================================================
#
# Change these paths to match YOUR 1Password Private vault structure.
# Example: if you named your item "GitHub PAT" in your Private vault:
#   GITHUB_PERSONAL_ACCESS_TOKEN=op://Private/GitHub PAT/credential
#
# GitHub PAT -- used for fetching private dependencies, if applicable
# GITHUB_PERSONAL_ACCESS_TOKEN=op://Private/GitHub PAT/token

# =============================================================================
# Local dev overrides (no secret -- can be plain values)
# =============================================================================

# Rails env
RACK_ENV=development
RAILS_ENV=development

# Database (local postgres)
DB_USER=postgres
# DATABASE_URL=postgres://localhost/lingolinq_development

# Redis (local)
REDIS_URL=redis://localhost:6379

# Local host
DEFAULT_HOST=localhost:3000

# S3 buckets -- local dev usually uses the dev bucket or mocks S3
UPLOADS_S3_BUCKET=lingolinq-dev-uploads
STATIC_S3_BUCKET=lingolinq-dev-static
AWS_REGION=us-west-2

# User key for console auditing
USER_KEY=local-dev
