commit 25c9306ad4be9c543ce9e18c6f5542dd0fd06957
Author: swahlquist <scotwahlquist@gmail.com>
Date:   Tue Feb 10 13:29:55 2026 -0700

    Modal refactor: convert to component-based modals with modal-container
    
    Complete modal system overhaul converting outlet-based modals to
    component-based pattern. This is the net result of Melissa's modal
    refactor branch merged with integration fixes, squashed into a
    single clean commit.
    
    Changes include:
    - Add modal-container component for centralized modal rendering
    - Convert 40+ modals from outlet to component pattern
    - Update modal.js utility for component-based opening/closing
    - Add new components: button-settings, add-tool, assessment-settings
    - Fix sendAction deprecations in modal components
    - Update application.hbs and application.js for new modal flow
    - Update adapter and app.js for compatibility
    - Add/update component tests
    
    Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>

diff --git a/app/frontend/app/templates/components/assessment-settings.hbs b/app/frontend/app/templates/components/assessment-settings.hbs
new file mode 100644
index 000000000..023d039b2
--- /dev/null
+++ b/app/frontend/app/templates/components/assessment-settings.hbs
@@ -0,0 +1,127 @@
+{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
+  <div class="modal-header">
+    <button type="button" class="close" {{action "close"}}>&times;</button>
+    <h3>
+      {{t "Eval Settings" key="assessment_settings"}}
+    </h3>
+  </div>
+  <div class="modal-body">
+    <form class="form-horizontal">
+      <div class='form-group'>
+        <label class='control-label col-sm-3'>{{t "For" key="for"}}</label>
+        <div class='col-sm-6'>
+          {{#if this.settings.saved}}
+            <b>{{this.settings.user_name}}</b>
+          {{else if this.settings}}
+            {{user-select select_id="for_user_id" selection=this.settings.for_user.user_id action=(action (mut this.settings.for_user.user_id)) }}
+          {{/if}}
+        </div>
+      </div>
+      <div class='form-group'>
+        <label class='control-label col-sm-3'>{{t "Title" key="title"}}</label>
+        <div class='col-sm-6'>
+          <Input type="text" @value={{this.settings.name}} class="form-control" placeholder={{this.name_placeholder}} />
+        </div>
+      </div>
+      {{#unless this.save_option}}
+        <div class='form-group'>
+          <label class='control-label col-sm-3'>{{t "Prompt Symbol(s)" key="prompt_symbols"}}</label>
+          <div class='col-sm-6'>
+            {{bound-select select_class="form-control" select_id="default_symbols" content=this.symbol_libraries selection=this.settings.default_library action=(action (mut this.settings.default_library)) }}
+          </div>
+        </div>
+        <div class='form-group'>
+          <label class='control-label col-sm-3'>{{t "Search Target" key="search_target"}}</label>
+          <div class='col-sm-6'>
+            <span class="dropdown" style="display: inline-block; width: 100%;">
+              <button class='btn btn-default symbol_target small' data-toggle="dropdown" style='width: 100%; text-align: left; white-space: nowrap; overflow: hidden;'>
+                <span class='text'>
+                  {{#each this.current_option.images as |url|}}
+                    <img src={{url}} >
+                  {{/each}}
+                  {{this.current_option.label}}
+                </span>
+                <span class='caret' style='position: absolute; right: 5px; top: 15px;'></span>
+              </button>
+              <ul class="dropdown-menu" role="menu" aria-labelledby="dLabel" style='max-height: 225px; overflow: auto;'>
+                {{#each this.symbol_options as |option|}}
+                  <li role="presentation">
+                    <a role="menuitem" class='symbol_target' href="#" tabindex="-1" {{action "choose" option.id}}>
+                      {{#each option.images as |url|}}
+                        <img src={{url}} >
+                      {{/each}}
+                      {{option.label}}
+                    </a>
+                  </li>
+                {{/each}}
+              </ul>
+            </span>
+          </div>
+        </div>
+        <div class='form-group'>
+          <label for="prompts" class="col-sm-3 control-label">{{t "Audible Prompt" key="audible_prompt"}}</label>
+          <div class="col-sm-9">
+            <div class="checkbox big_checkbox">
+              <label id='prompts'>
+                <Input @type="checkbox" @checked={{this.settings.prompts}} />
+                {{t "Speak prompts out loud" key="speak_prompts_out_loud"}}
+              </label>
+            </div>
+          </div>
+        </div>
+        {{#if this.settings.prompts}}
+          <div class='form-group'>
+            <label class='control-label col-sm-3'>{{t "Prompt Delay" key="prompt_delay"}}</label>
+            <div class='col-sm-3'>
+              <Input type="text" @value={{this.settings.prompts_delay}} class="form-control" placeholder="no delay" />
+            </div>
+            <div class='col-sm-3'>
+              <p class='form-control-static'>
+                {{t "milliseconds" key="milliseconds"}}
+              </p>
+            </div>
+          </div>
+        {{/if}}
+        <div class='form-group'>
+          <label for="chimes" class="col-sm-3 control-label">{{t "Chime" key="chime"}}</label>
+          <div class="col-sm-9">
+            <div class="checkbox big_checkbox">
+              <label id='chimes'>
+                <Input @type="checkbox" @checked={{this.settings.chimes}} />
+                {{t "Play a sound on correct actions" key="play_sound_on_success"}}
+              </label>
+            </div>
+          </div>
+        </div>
+      {{/unless}}
+      <div class='form-group'>
+        <label class='control-label col-sm-3'>{{t "Notes" key="notes"}}</label>
+        <div class='col-sm-9'>
+          <Textarea @value={{this.settings.accommodations}} class="form-control" placeholder="any accommodations or supports provided that wouldn't be otherwise noted" rows={{2}} />
+        </div>
+        <div class='col-sm-9 col-sm-offset-3' style='margin-top: 10px;'>
+          <Textarea @value={{this.settings.notes}} class="form-control" placeholder="additional notes" rows={{4}} />
+        </div>
+      </div>
+    </form>
+  </div>
+  <div class='modal-footer'>
+    {{#if this.aborting}}
+      <p class='text-danger'>{{t "Are you sure you want to abort? All changed will be lost." key="confirm_abort"}}</p>
+      <button class='btn btn-default btn-lg' {{action "abort" true}}>{{t "Abort" key="abort"}}</button>
+      <button class='btn btn-default btn-lg' {{action "close"}}>{{t "Cancel" key="cancel"}}</button>
+    {{else}}
+      <button class='btn btn-primary btn-lg' {{action "confirm"}}>
+        {{#if this.save_option}}
+          {{t "Save" key="save"}}
+        {{else}}
+          {{t "Update" key="update"}}
+        {{/if}}
+      </button>
+      {{#if this.save_option}}
+        <button class='btn btn-default btn-lg' {{action "abort"}}>{{t "Abort" key="abort"}}</button>
+      {{/if}}
+      <button class='btn btn-default btn-lg' {{action "close"}}>{{t "Cancel" key="cancel"}}</button>
+    {{/if}}
+  </div>
+{{/modal-dialog}}
diff --git a/app/frontend/app/templates/components/button-stash.hbs b/app/frontend/app/templates/components/button-stash.hbs
new file mode 100644
index 000000000..200f0c9fc
--- /dev/null
+++ b/app/frontend/app/templates/components/button-stash.hbs
@@ -0,0 +1,59 @@
+{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
+  <div class="modal-body">
+    {{#if this.button_stashes}}
+      <p>
+      {{t "Select a stashed button from the list, then select the location on the board where you'd like it applied." key="select_stashed_button"}}
+      </p>
+      {{#each this.button_stashes as |button|}}
+          <span class="stash_button_container" {{action "pickButton" button}}>
+            <a href='#' style={{button.computed_style}} class={{button.computed_class}} data-id={{button.id}} tabindex="0">
+              {{#if button.pending}}
+                <div class="pending">
+                  <img src={{path "images/spinner.gif"}} draggable='false' >
+                </div>
+              {{/if}}
+              <div class={{button.action_class}}>
+                <span class="action">
+                  <img src={{button.action_image}} alt={{button.action_alt}} draggable='false' >
+                </span>
+              </div>
+              <span class='img_holder' style={{button.image_holder_style}}>
+                {{#unless this.appState.currentUser.hide_symbols}}
+                  {{#unless button.board.text_only}}
+                    {{#unless button.text_only}}
+                      <img src={{button.local_image_url}} rel={{button.original_image_url}} draggable='false' onerror="button_broken_image(this);" style={{button.image_style}} class={{if button.hc_image "symbol hc" "symbol"}}>
+                    {{/unless}}
+                  {{/unless}}
+                {{/unless}}
+              </span>
+              <div class={{if button.text_only this.text_only_button_symbol_class this.button_symbol_class}}>
+                {{#if this.editModeNormalText}}
+                  {{#if button.sound}}
+                    <div class="sound_container">
+                      <span class="glyphicon glyphicon-volume-up"></span>
+                    </div>
+                  {{/if}}
+                  {{label-field value=button.label class="button-label" placeholder="enter label"}}
+                  {{#if button.levels_list}}
+                    <span class='levels' style='opacity: 0.7;'>{{button.levels_list}}</span>
+                  {{/if}}
+                {{else}}
+                  {{#unless button.hide_label}}
+                    <span class="button-label">{{button.label}}</span>
+                  {{/unless}}
+                {{/if}}
+              </div>
+            </a>
+          </span>
+        {{/each}}
+      <div style="clear: left;"></div>
+    {{else}}
+      <p>
+      {{t "The button stash makes it easier to reuse or move buttons across multiple boards. Buttons that you copy to your stash will appear here once there are any. To copy a button to the stash either drag it to the stash button or click the copy button in the General settings area for the button." key="stash_explanation"}}
+      </p>
+    {{/if}}
+  </div>
+  <div class="modal-footer">
+    <a href="#" class="btn" {{action "close"}}>{{t "Close" key="close"}}</a>
+  </div>
+{{/modal-dialog}}
diff --git a/app/frontend/app/templates/components/user-status.hbs b/app/frontend/app/templates/components/user-status.hbs
new file mode 100644
index 000000000..03c814d4c
--- /dev/null
+++ b/app/frontend/app/templates/components/user-status.hbs
@@ -0,0 +1,88 @@
+{{#modal-dialog action=(action "close") opening=(action "opening") closing=(action "closing")}}
+  <div class="modal-header">
+    <button type="button" class="close" {{action "close"}}>&times;</button>
+    <h3>
+      <img src={{this.model.user.avatar_url}} style='height: 50px;'>
+      {{t "Progress for %{un}" un=this.model.user.user_name key="progress_for_user"}}
+    </h3>
+  </div>
+  <div class="modal-body">
+    <div style='margin: 0 20px;'>
+      <div style='margin: 30px 0px; font-size: 24px;'>
+        <span class={{this.state_class}}></span>
+        {{this.state}}
+        {{#if this.model.user.org_status.note}}
+          <div style='margin-top: 10px; font-size: 16px;'>
+            <p><em>{{this.model.user.org_status.note}}</em></p>
+          </div>
+        {{/if}}
+        {{#if this.model.user.org_status.date}}
+          <div style='margin-top: 10px; font-size: 14px; color: #888;'>
+            <p>{{t "Last updated" key="last_updated"}} {{date_ago this.model.user.org_status.date "day"}}</p>
+          </div>
+        {{/if}}
+      </div>
+      {{#if this.editing}}
+        <form class="form-horizontal" {{action "nothing" on="submit"}}>
+          <div class="form-group">
+            <label for="status" class="col-sm-3 control-label">{{t "Status" key="status"}}</label>
+            <div class="col-sm-9">
+              <span class="dropdown" style="display: inline-block; width: 100%;">
+                <button class='btn btn-default' id='status' data-toggle="dropdown" style='width: 100%; text-align: left; white-space: nowrap; overflow: hidden;'>
+                  <span class='text'>
+                    <span class={{this.current_status.glyph}}></span>
+                    {{this.current_status.label}}
+                  </span>
+                  <span class='caret' style='position: absolute; right: 5px; top: 15px;'></span>
+                </button>
+                <ul class="dropdown-menu" role="menu" aria-labelledby="dLabel" style='max-height: 180px; overflow: auto; max-width: 100%;'>
+                  {{#each this.statuses as |option|}}
+                    <li role="presentation">
+                      <a role="menuitem" class='symbol_target' href="#" tabindex="-1" {{action "choose" option.id}}>
+                        <span class={{option.glyph}}></span>
+                        {{option.label}}
+                      </a>
+                    </li>
+                  {{/each}}
+                </ul>
+              </span>
+            </div>
+          </div>
+          <div class="form-group">
+            <label class="col-sm-3 control-label" for="notes">
+              {{t "Notes" key="notes"}}
+            </label>
+            <div class="col-sm-9">
+              <Textarea @value={{this.status_note}} id="notes" class="form-control" placeholder="brief note related to this status" rows={{3}} />
+            </div>
+          </div>
+        </form>
+
+      {{else}}
+        <div>
+          <button class='btn btn-default' {{action "edit"}}>{{t "Update Progress" key="update_state"}}</button>
+        </div>
+      {{/if}}
+    </div>
+  </div>
+  <div class="modal-footer">
+    {{#if this.editing}}
+      <button class='btn btn-lg btn-primary' {{action "update"}} disabled={{this.save_status.loading}}>
+        {{#if this.save_status.loading}}
+          {{t "Updating" key="updating"}}
+        {{else if this.save_status.error}}
+          {{t "Update Failed" key="update_failed"}}
+        {{else}}
+          {{t "Update" key="update"}}
+        {{/if}}
+      </button>
+    {{/if}}
+    <a href="#" class="btn btn-lg btn-default" {{action "close"}}>
+      {{#if this.editing}}
+        {{t "Cancel" key="cancel"}}
+      {{else}}
+        {{t "Close" key="close"}}
+      {{/if}}
+    </a>
+  </div>
+{{/modal-dialog}}

